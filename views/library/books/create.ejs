<div class="page-header">
    <div>
        <h1>➕ Add New Book</h1>
        <p>Add a book to the library catalogue</p>
    </div>
    <a href="/library/books" class="btn btn-secondary">← Back to Books</a>
</div>

<form action="/library/books/create" method="POST">
    <div class="form-section">
        <div class="form-section-header">
            <span>📚</span>
            <h3>Book Information</h3>
        </div>
        <div class="form-section-body">
            <div class="form-grid">
                <div class="form-group col-span-2">
                    <label class="form-label">Title *</label>
                    <input type="text" name="title" class="form-control" required placeholder="Full book title" />
                </div>
                <div class="form-group">
                    <label class="form-label">Authors</label>
                    <input type="text" name="authors" class="form-control" placeholder="Comma-separated e.g. John Doe, Jane Smith" />
                </div>
                <div class="form-group">
                    <label class="form-label">ISBN</label>
                    <input type="text" name="isbn" class="form-control" placeholder="978-0-000-00000-0" />
                </div>
                <div class="form-group">
                    <label class="form-label">Publisher</label>
                    <input type="text" name="publisher" class="form-control" />
                </div>
                <div class="form-group">
                    <label class="form-label">Category</label>
                    <input type="text" name="category" class="form-control" placeholder="e.g. Science, Fiction, History" list="cat-list" />
                    <datalist id="cat-list">
                        <option value="Fiction"><option value="Non-Fiction"><option value="Science">
                        <option value="Mathematics"><option value="History"><option value="Biography">
                        <option value="Reference"><option value="Literature"><option value="Technology"><option value="Arts">
                    </datalist>
                </div>
                <div class="form-group">
                    <label class="form-label">Edition</label>
                    <input type="text" name="edition" class="form-control" placeholder="e.g. 3rd Edition" />
                </div>
                <div class="form-group">
                    <label class="form-label">Language</label>
                    <select name="language" class="form-control">
                        <option value="English">English</option>
                        <option value="Hindi">Hindi</option>
                        <option value="Sanskrit">Sanskrit</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <div class="form-group col-span-2">
                    <label class="form-label">Description</label>
                    <textarea name="description" class="form-control" rows="3" placeholder="Brief description (optional)"></textarea>
                </div>
            </div>
            <div style="display:flex; gap:10px; margin-top:8px;">
                <button type="submit" class="btn btn-primary">Add Book</button>
                <a href="/library/books" class="btn btn-secondary">Cancel</a>
            </div>
        </div>
    </div>
</form>
