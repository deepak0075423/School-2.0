<div class="page-header">
    <div>
        <h1>📋 Issuances</h1>
        <p>Track all book issuances and returns</p>
    </div>
    <div style="display:flex; gap:8px;">
        <a href="/library/issue" class="btn btn-primary">📖 Issue New</a>
        <a href="/library/return" class="btn btn-secondary">↩️ Return</a>
    </div>
</div>

<!-- Filter -->
<div class="card" style="margin-bottom:20px;">
    <div class="card-body" style="padding:16px 20px;">
        <form action="/library/issuances" method="GET" style="display:flex; gap:12px; align-items:flex-end; flex-wrap:wrap;">
            <div class="form-group" style="margin:0; flex:2; min-width:180px;">
                <label class="form-label">Search</label>
                <input type="text" name="q" value="<%= query %>" class="form-control" placeholder="User name, book title, copy code…" />
            </div>
            <div class="form-group" style="margin:0; flex:1; min-width:160px;">
                <label class="form-label">Status</label>
                <select name="status" class="form-control">
                    <option value="" <%= !filterStatus ? 'selected' : '' %>>Active (Issued + Overdue)</option>
                    <option value="issued"   <%= filterStatus === 'issued'   ? 'selected' : '' %>>Issued</option>
                    <option value="overdue"  <%= filterStatus === 'overdue'  ? 'selected' : '' %>>Overdue</option>
                    <option value="returned" <%= filterStatus === 'returned' ? 'selected' : '' %>>Returned (History)</option>
                    <option value="lost"     <%= filterStatus === 'lost'     ? 'selected' : '' %>>Lost</option>
                </select>
            </div>
            <div style="display:flex; gap:8px;">
                <button type="submit" class="btn btn-primary">Filter</button>
                <a href="/library/issuances" class="btn btn-secondary">Reset</a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="table-wrapper">
        <% if (issuances.length === 0) { %>
        <div class="empty-state">
            <div class="empty-icon">📭</div>
            <h3>No Issuances Found</h3>
            <p>Try adjusting your filters.</p>
        </div>
        <% } else { %>
        <table>
            <thead>
                <tr>
                    <th>User</th>
                    <th>Book</th>
                    <th>Copy Code</th>
                    <th>Issued On</th>
                    <th>Due Date</th>
                    <th>Renewals</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% issuances.forEach(iss => {
                    const isOverdue = iss.status === 'overdue';
                    const daysOverdue = isOverdue ? Math.floor((new Date() - new Date(iss.dueDate)) / (1000*60*60*24)) : 0;
                %>
                <tr style="<%= isOverdue ? 'background:#fff5f5;' : '' %>">
                    <td>
                        <div class="fw-semibold"><%= iss.issuedTo?.name || '—' %></div>
                        <small class="text-muted"><%= iss.issuedToRole %></small>
                    </td>
                    <td>
                        <a href="/library/books/<%= iss.book?._id %>" class="text-primary"><%= iss.book?.title || '—' %></a>
                    </td>
                    <td><code style="background:#f0f4ff;padding:2px 7px;border-radius:5px;font-size:12px;color:#4f46e5;"><%= iss.bookCopy?.uniqueCode || '—' %></code></td>
                    <td class="text-muted"><%= new Date(iss.issueDate).toDateString() %></td>
                    <td>
                        <div><%= new Date(iss.dueDate).toDateString() %></div>
                        <% if (isOverdue) { %><small style="color:var(--danger); font-weight:600;"><%= daysOverdue %> day(s) overdue</small><% } %>
                    </td>
                    <td class="text-muted"><%= iss.renewalCount %></td>
                    <td>
                        <span class="badge <%= iss.status === 'overdue' ? 'badge-red' : iss.status === 'returned' ? 'badge-green' : iss.status === 'lost' ? 'badge-red' : 'badge-orange' %>">
                            <%= iss.status %>
                        </span>
                    </td>
                    <td>
                        <% if (['issued','overdue'].includes(iss.status)) { %>
                        <a href="/library/return?id=<%= iss._id %>" class="btn btn-sm btn-primary">Return</a>
                        <form action="/library/issuances/<%= iss._id %>/renew" method="POST" style="display:inline">
                            <button type="submit" class="btn btn-sm btn-secondary">Renew</button>
                        </form>
                        <% } %>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <% } %>
    </div>
</div>
