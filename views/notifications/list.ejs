<%
const createUrl = role === 'super_admin' ? '/super-admin/notifications/create'
                : role === 'school_admin' ? '/admin/notifications/create'
                : '/teacher/notifications/create';

const targetLabel = {
    all_schools:      '🌐 All Schools (School Admins)',
    specific_school:  '🏫 Specific School (School Admins)',
    all:              '👥 Everyone in School',
    all_teachers:     '👨‍🏫 All Teachers',
    all_students:     '🎒 All Students',
    all_parents:      '👪 All Parents',
    class_students:   '🏫 Class — Students',
    class_parents:    '🏫 Class — Parents',
    section_students: '📚 Section — Students',
    section_parents:  '📚 Section — Parents',
    section_all:      '👥 Section — Everyone',
};
%>

<div class="page-header">
    <div>
        <h1>🔔 <%= title %></h1>
        <p>
            <% if (role === 'super_admin') { %>All notifications sent by Super Admin<% } %>
            <% if (role === 'school_admin') { %>Notifications sent by school admin and teachers<% } %>
            <% if (role === 'teacher') { %>Notifications you have sent<% } %>
        </p>
    </div>
    <a href="<%= createUrl %>" class="btn btn-primary">+ Send Notification</a>
</div>

<% if (notifications.length === 0) { %>
<div class="card">
    <div class="empty-state" style="padding:60px 20px; text-align:center;">
        <div style="font-size:48px; margin-bottom:12px;">🔕</div>
        <h3 style="color:var(--text);">No notifications sent yet</h3>
        <p style="color:var(--text-muted,#94a3b8); margin-bottom:20px;">Start communicating with your audience.</p>
        <a href="<%= createUrl %>" class="btn btn-primary">Send First Notification</a>
    </div>
</div>
<% } else { %>

<!-- Summary strip -->
<div style="display:grid; grid-template-columns:repeat(3,1fr); gap:14px; margin-bottom:20px;">
    <div class="card" style="padding:16px; text-align:center;">
        <div style="font-size:26px; font-weight:700; color:#3b82f6;"><%= notifications.length %></div>
        <div style="font-size:12px; color:var(--text-muted,#94a3b8);">Total Sent</div>
    </div>
    <div class="card" style="padding:16px; text-align:center;">
        <div style="font-size:26px; font-weight:700; color:#10b981;"><%= notifications.filter(n=>n.channels.inApp).length %></div>
        <div style="font-size:12px; color:var(--text-muted,#94a3b8);">In-App</div>
    </div>
    <div class="card" style="padding:16px; text-align:center;">
        <div style="font-size:26px; font-weight:700; color:#6366f1;"><%= notifications.filter(n=>n.channels.email).length %></div>
        <div style="font-size:12px; color:var(--text-muted,#94a3b8);">Email</div>
    </div>
</div>

<div class="card">
    <div class="card-header" style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px; padding:14px 18px; border-bottom:1px solid var(--border,rgba(255,255,255,0.08));">
        <span style="font-size:13px; color:var(--text-muted,#94a3b8);"><%= notifications.length %> notification<%= notifications.length !== 1 ? 's' : '' %></span>
        <div style="position:relative;">
            <span style="position:absolute; left:10px; top:50%; transform:translateY(-50%); font-size:14px; pointer-events:none;">🔍</span>
            <input type="text" id="notifSearch" placeholder="Search title or message…"
                oninput="filterNotifs(this.value)"
                style="padding:7px 12px 7px 32px; font-size:13px; background:var(--input-bg,rgba(255,255,255,0.05));
                       border:1px solid var(--border,rgba(255,255,255,0.1)); border-radius:10px;
                       color:var(--text,#e2e8f0); outline:none; width:240px;"
                onfocus="this.style.borderColor='#4f46e5'" onblur="this.style.borderColor='var(--border,rgba(255,255,255,0.1))'">
        </div>
    </div>
    <div class="table-wrapper">
        <table id="notifTable">
            <thead>
                <tr>
                    <th>Title &amp; Message</th>
                    <th>Target</th>
                    <th>Channels</th>
                    <th>Recipients</th>
                    <% if (role !== 'teacher') { %><th>Sent By</th><% } %>
                    <th>Date</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                <% notifications.forEach(n => { %>
                <tr style="cursor:pointer;" onclick="viewNotif('<%= n._id %>')">
                    <td>
                        <div class="fw-semibold" style="max-width:220px;">
                            <%= n.title %>
                        </div>
                        <div class="text-muted" style="font-size:11px; margin-top:2px; max-width:220px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                            <%= n.body %>
                        </div>
                    </td>
                    <td>
                        <div style="font-size:12px; color:var(--text-muted,#94a3b8);">
                            <%= targetLabel[n.target.type] || n.target.type %>
                        </div>
                        <% if (n.target.class) { %>
                            <div style="font-size:11px; color:var(--text-muted,#94a3b8); margin-top:2px;">
                                Class <%= n.target.class.classNumber %> — <%= n.target.class.className %>
                            </div>
                        <% } %>
                        <% if (n.target.section) { %>
                            <div style="font-size:11px; color:var(--text-muted,#94a3b8); margin-top:2px;">
                                Sec <%= n.target.section.sectionName %>
                            </div>
                        <% } %>
                    </td>
                    <td>
                        <div style="display:flex; gap:6px; flex-wrap:wrap;">
                            <% if (n.channels.inApp) { %>
                                <span class="badge badge-cyan" style="font-size:10px;">🔔 In-App</span>
                            <% } %>
                            <% if (n.channels.email) { %>
                                <span class="badge badge-purple" style="font-size:10px;">📧 Email</span>
                            <% } %>
                        </div>
                    </td>
                    <td>
                        <span style="font-weight:600; color:#3b82f6;"><%= n.recipientCount %></span>
                        <span style="font-size:11px; color:var(--text-muted,#94a3b8);"> users</span>
                    </td>
                    <% if (role !== 'teacher') { %>
                    <td>
                        <div style="font-size:13px;">
                            <%= n.sender?.name || '—' %>
                        </div>
                        <div class="text-muted" style="font-size:11px;">
                            <%= n.senderRole?.replace('_', ' ') %>
                        </div>
                    </td>
                    <% } %>
                    <td class="text-muted" style="font-size:12px; white-space:nowrap;">
                        <%= new Date(n.createdAt).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }) %>
                        <div style="font-size:10px; margin-top:2px;">
                            <%= new Date(n.createdAt).toLocaleTimeString('en-IN', { hour:'2-digit', minute:'2-digit' }) %>
                        </div>
                    </td>
                    <td onclick="event.stopPropagation()">
                        <button onclick="viewNotif('<%= n._id %>')"
                            style="background:rgba(59,130,246,.12);border:1px solid rgba(59,130,246,.3);color:#3b82f6;
                                   border-radius:8px;padding:4px 10px;font-size:11px;cursor:pointer;white-space:nowrap;">
                            👁 View
                        </button>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>
<% } %>

<!-- no-results row injected by JS -->
<div id="notifNoResults" style="display:none; padding:40px 20px; text-align:center; color:var(--text-muted,#94a3b8); font-size:13px;">
    🔕 No notifications match your search
</div>

<!-- Notification Detail Modal -->
<div id="notifListModal" onclick="if(event.target===this)this.style.display='none'"
     style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:9999;
            align-items:center;justify-content:center;">
    <div style="background:var(--card-bg,#1a1d2e);border:1px solid var(--border,#2a2d3e);
                border-radius:16px;width:min(560px,92vw);max-height:85vh;overflow-y:auto;
                padding:32px;position:relative;box-shadow:0 24px 64px rgba(0,0,0,.6);">
        <button onclick="document.getElementById('notifListModal').style.display='none'"
            style="position:absolute;top:14px;right:14px;background:none;border:none;
                   cursor:pointer;color:var(--text-muted,#94a3b8);font-size:22px;line-height:1;
                   opacity:.7;" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity=.7">×</button>

        <div style="font-size:11px;color:#3b82f6;font-weight:600;text-transform:uppercase;
                    letter-spacing:.06em;margin-bottom:10px;">🔔 Notification Detail</div>

        <div id="nlTitle" style="font-weight:700;font-size:20px;color:var(--text,#e2e8f0);
                                  margin-bottom:10px;padding-right:28px;line-height:1.4;"></div>

        <div style="display:flex;gap:16px;flex-wrap:wrap;margin-bottom:14px;">
            <div style="font-size:12px;color:var(--text-muted,#94a3b8);">
                <span style="color:var(--text,#e2e8f0);font-weight:600;">Sent by:</span>
                <span id="nlSender"></span>
            </div>
            <div style="font-size:12px;color:var(--text-muted,#94a3b8);">
                <span style="color:var(--text,#e2e8f0);font-weight:600;">Recipients:</span>
                <span id="nlCount"></span>
            </div>
            <div style="font-size:12px;color:var(--text-muted,#94a3b8);">
                <span style="color:var(--text,#e2e8f0);font-weight:600;">Date:</span>
                <span id="nlDate"></span>
            </div>
        </div>

        <div style="font-size:12px;color:var(--text-muted,#94a3b8);margin-bottom:6px;">
            <span style="color:var(--text,#e2e8f0);font-weight:600;">Target:</span>
            <span id="nlTarget"></span>
        </div>

        <div style="font-size:12px;color:var(--text-muted,#94a3b8);margin-bottom:20px;">
            <span style="color:var(--text,#e2e8f0);font-weight:600;">Channels:</span>
            <span id="nlChannels"></span>
        </div>

        <div style="border-top:1px solid var(--border,#2a2d3e);padding-top:20px;">
            <div style="font-size:11px;color:var(--text-muted,#94a3b8);font-weight:600;
                        text-transform:uppercase;letter-spacing:.05em;margin-bottom:10px;">Message</div>
            <div id="nlBody" style="font-size:14px;color:var(--text,#e2e8f0);line-height:1.8;
                                     white-space:pre-wrap;word-break:break-word;"></div>
        </div>
    </div>
</div>

<script>
const _nlData = <%- JSON.stringify(notifications.map(function(n){ return {
    id:   String(n._id),
    title: n.title,
    body:  n.body,
    senderName:     (n.sender && n.sender.name) ? n.sender.name : '—',
    senderRole:     n.senderRole || '',
    targetType:     (n.target && n.target.type) || '',
    targetClass:    (n.target && n.target.class) ? ('Class ' + (n.target.class.classNumber||'') + ' — ' + (n.target.class.className||'')) : '',
    targetSection:  (n.target && n.target.section) ? ('Sec ' + (n.target.section.sectionName||'')) : '',
    recipientCount: n.recipientCount || 0,
    inApp:  !!(n.channels && n.channels.inApp),
    email:  !!(n.channels && n.channels.email),
    createdAt: n.createdAt,
}; })) %>;

const _nlIndex = {};
_nlData.forEach(function(n){ _nlIndex[n.id] = n; });

const _nlTargetLabel = {
    all_schools:'🌐 All Schools (School Admins)', specific_school:'🏫 Specific School (School Admins)',
    all:'👥 Everyone in School', all_teachers:'👨‍🏫 All Teachers', all_students:'🎒 All Students',
    all_parents:'👪 All Parents', class_students:'🏫 Class — Students', class_parents:'🏫 Class — Parents',
    section_students:'📚 Section — Students', section_parents:'📚 Section — Parents', section_all:'👥 Section — Everyone',
};

function viewNotif(id) {
    var n = _nlIndex[id];
    if (!n) return;
    document.getElementById('nlTitle').textContent   = n.title || '—';
    document.getElementById('nlSender').textContent  = ' ' + n.senderName + ' (' + n.senderRole.replace(/_/g,' ') + ')';
    document.getElementById('nlTarget').textContent  =
        ' ' + (_nlTargetLabel[n.targetType] || n.targetType) +
        (n.targetClass   ? ' · ' + n.targetClass   : '') +
        (n.targetSection ? ' · ' + n.targetSection : '');
    document.getElementById('nlCount').textContent   = ' ' + n.recipientCount + ' users';
    document.getElementById('nlDate').textContent    = ' ' + new Date(n.createdAt).toLocaleString('en-IN',{
        day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit'
    });
    var ch = [];
    if (n.inApp) ch.push('🔔 In-App');
    if (n.email) ch.push('📧 Email');
    document.getElementById('nlChannels').textContent = ' ' + (ch.join('  ·  ') || '—');
    document.getElementById('nlBody').textContent    = n.body || '';
    document.getElementById('notifListModal').style.display = 'flex';
}

document.addEventListener('keydown', function(e){
    if (e.key === 'Escape') document.getElementById('notifListModal').style.display = 'none';
});

function filterNotifs(q) {
    q = q.trim().toLowerCase();
    var rows = document.querySelectorAll('#notifTable tbody tr');
    var visible = 0;
    rows.forEach(function(row) {
        var text = row.textContent.toLowerCase();
        var show = !q || text.includes(q);
        row.style.display = show ? '' : 'none';
        if (show) visible++;
    });
    document.getElementById('notifNoResults').style.display = (visible === 0 && q) ? 'block' : 'none';
}
</script>
