<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-logo">
            <div class="logo-icon">🛡️</div>
            <h1>Set New Password</h1>
            <p>OTP verified! Create your new password below.</p>
        </div>

        <% if (error && error.length> 0) { %>
            <% error.forEach(msg=> { %>
                <div class="alert alert-error">❌ <%= msg %><button class="alert-close">×</button></div>
                <% }) %>
                    <% } %>

                        <form action="/auth/new-password" method="POST">
                            <div class="form-group">
                                <label class="form-label">New Password</label>
                                <div class="input-icon-wrapper">
                                    <span class="icon">🔑</span>
                                    <input type="password" id="newPassword" name="password" class="form-control"
                                        placeholder="Minimum 8 characters" required minlength="8" />
                                </div>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Confirm New Password</label>
                                <div class="input-icon-wrapper">
                                    <span class="icon">✅</span>
                                    <input type="password" id="confirmPassword" name="confirmPassword"
                                        class="form-control" placeholder="Repeat your new password" required
                                        minlength="8" />
                                </div>
                            </div>

                            <ul style="color:var(--text-muted); font-size:12px; margin:0 0 20px 16px; line-height:2;">
                                <li>At least 8 characters long</li>
                                <li>Mix of letters, numbers and symbols recommended</li>
                            </ul>

                            <button type="submit" class="btn btn-primary btn-block btn-lg">
                                🔒 Reset Password
                            </button>
                        </form>

                        <div style="margin-top:20px; text-align:center;">
                            <a href="/auth/login" style="color:var(--primary); font-size:13px; font-weight:500;">← Back
                                to Login</a>
                        </div>
    </div>
</div>