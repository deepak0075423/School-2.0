<div class="page-header">
    <div>
        <h1>📋 Mark Attendance</h1>
        <% if (section) { %>
            <p>
                <%= section.class?.className %> – Section <%= section.sectionName %>
            </p>
            <% } %>
    </div>
    <a href="/teacher/my-section" class="btn btn-secondary">← My Section</a>
</div>

<% if (!section) { %>
    <div class="card">
        <div class="empty-state" style="padding:40px;">
            <div class="empty-icon">📋</div>
            <h3>No Section Assigned</h3>
            <p style="max-width:420px; margin:8px auto 0;">
                You have not been assigned as a Class Teacher or Vice Class Teacher for any section yet.
                Contact your School Admin to assign you to a section before you can mark attendance.
            </p>
            <div style="margin-top:20px; padding:16px; background:rgba(79,70,229,0.08); border-radius:10px; font-size:13px; color:var(--text-muted); max-width:380px; margin-left:auto; margin-right:auto; text-align:left;">
                <strong style="color:var(--text);">Admin steps:</strong>
                <ol style="margin:8px 0 0 16px; padding:0; line-height:2;">
                    <li>Go to <strong>Classes</strong> → select a class → open a section</li>
                    <li>Under <strong>Teacher Assignment</strong>, choose you as Class Teacher</li>
                    <li>Click <strong>Update Teachers</strong></li>
                </ol>
            </div>
        </div>
    </div>
<% } else { %>
        <div class="card" style="margin-bottom:16px;">
            <div class="card-body">
                <form method="GET" style="display:flex; align-items:center; gap:12px;">
                    <label class="form-label" style="margin:0;">Date:</label>
                    <input type="date" name="date" class="form-control" style="width:200px;" value="<%= date %>"
                        max="<%= new Date().toISOString().split('T')[0] %>">
                    <button type="submit" class="btn btn-secondary">Load</button>
                </form>
            </div>
        </div>

        <% if (students.length===0) { %>
            <div class="card">
                <div class="empty-state" style="padding:30px;">
                    <p>No students in this section.</p>
                </div>
            </div>
            <% } else { %>
                <div class="card">
                    <div class="card-header">
                        <div class="card-title">
                            📋 Attendance — <%= new Date(date + 'T00:00:00Z').toLocaleDateString('en-IN', { weekday:'long', day:'numeric', month:'long', year:'numeric', timeZone:'UTC' }) %>
                                <% if (attendance) { %><span class="badge badge-green" style="margin-left:8px;">Already
                                        Marked</span>
                                    <% } %>
                        </div>
                    </div>
                    <form action="/teacher/attendance/mark" method="POST">
                        <input type="hidden" name="sectionId" value="<%= section._id %>">
                        <input type="hidden" name="date" value="<%= date %>">
                        <div class="table-wrapper">
                            <table>
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Student</th>
                                        <th>Present</th>
                                        <th>Absent</th>
                                        <th>Late</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% students.forEach((p, i)=> {
                                        const sid = p.user?._id?.toString();
                                        const existing = recordMap[sid];
                                        %>
                                        <tr>
                                            <td class="text-muted">
                                                <%= i + 1 %>
                                            </td>
                                            <td class="text-primary fw-semibold">🎒 <%= p.user?.name %>
                                            </td>
                                            <td style="text-align:center;">
                                                <input type="radio" name="statuses[<%= sid %>]" value="Present"
                                                    <%=!existing || existing.status==='Present' ? 'checked' : '' %>>
                                            </td>
                                            <td style="text-align:center;">
                                                <input type="radio" name="statuses[<%= sid %>]" value="Absent"
                                                    <%=existing && existing.status==='Absent' ? 'checked' : '' %>>
                                            </td>
                                            <td style="text-align:center;">
                                                <input type="radio" name="statuses[<%= sid %>]" value="Late" <%=existing
                                                    && existing.status==='Late' ? 'checked' : '' %>>
                                            </td>
                                        </tr>
                                        <% }) %>
                                </tbody>
                            </table>
                        </div>
                        <div style="padding:16px; border-top:1px solid var(--border);">
                            <button type="submit" class="btn btn-primary">💾 Save Attendance</button>
                        </div>
                    </form>
                </div>
                <% } %>
                    <% } %>