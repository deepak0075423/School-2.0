<div class="page-header">
    <div>
        <h1>✅ Marks Validation</h1>
        <p>Review and validate marks submitted by subject teachers for your section.</p>
    </div>
</div>

<% if (!exams || exams.length === 0) { %>
<div class="card">
    <div class="empty-state">
        <div class="empty-icon">✅</div>
        <h3>Nothing to Validate</h3>
        <p>No exams are currently pending your validation.</p>
    </div>
</div>
<% } else { %>
<% const statusBadge = { MARKS_PENDING:'badge-orange', SUBMITTED:'badge-blue', REJECTED:'badge-red', REOPENED:'badge-orange', CLASS_APPROVED:'badge-purple', FINAL_APPROVED:'badge-green' }; %>
<% const typeLabel = { MID_TERM: 'Mid Term', FINAL: 'Final', UNIT_TEST: 'Unit Test' }; %>
<div class="card">
    <div class="card-header">
        <div class="card-title">Formal Exams (<%= exams.length %>)</div>
    </div>
    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>Exam</th>
                    <th>Type</th>
                    <th>Section</th>
                    <th style="text-align:center;">Subjects</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                <% exams.forEach(exam => { %>
                <tr>
                    <td class="fw-semibold"><%= exam.title %></td>
                    <td><span class="badge badge-blue"><%= typeLabel[exam.examType] %></span></td>
                    <td><%= exam.section?.class?.className %> – <%= exam.section?.sectionName %></td>
                    <td style="text-align:center;"><%= exam.subjects.length %></td>
                    <td><span class="badge <%= statusBadge[exam.status] || 'badge-orange' %>"><%= exam.status.replace(/_/g,' ') %></span></td>
                    <td>
                        <a href="/teacher/results/validation/<%= exam._id %>" class="btn btn-sm <%= ['CLASS_APPROVED','FINAL_APPROVED'].includes(exam.status) ? 'btn-secondary' : 'btn-primary' %>">
                            <%= ['CLASS_APPROVED','FINAL_APPROVED'].includes(exam.status) ? 'View Results' : 'Review' %>
                        </a>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>
<% } %>
