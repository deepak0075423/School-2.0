<div class="page-header">
    <div>
        <h1>✏️ Enter Marks: <%= test.title %></h1>
        <p><%= test.subject?.subjectName %> — <%= test.section?.class?.className %> Section <%= test.section?.sectionName %></p>
        <p style="color:var(--text-muted); font-size:13px;">Max Marks: <%= test.maxMarks %> | Passing: <%= test.passingMarks %></p>
    </div>
    <a href="/teacher/results/class-tests" class="btn btn-secondary">← Back</a>
</div>

<% if (isReadOnly) { %>
<div class="card" style="margin-bottom:16px;">
    <div style="padding:14px 18px; background:#f0fdf4; border-radius:10px; display:flex; align-items:center; gap:10px;">
        <span style="font-size:20px;">✅</span>
        <div>
            <strong>Test Approved — View Only</strong>
            <div style="color:var(--text-muted); font-size:13px;">This test has been approved by the class teacher. Marks are locked.</div>
        </div>
    </div>
</div>
<% } %>

<div class="card">
    <form method="POST" action="/teacher/results/class-tests/<%= test._id %>/marks/save" id="marksForm">
        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Student Name</th>
                        <th>Marks (max <%= test.maxMarks %>)</th>
                        <th style="text-align:center;">Absent</th>
                        <th>Remarks</th>
                    </tr>
                </thead>
                <tbody>
                    <% entries.forEach((entry, i) => { %>
                    <tr>
                        <td style="color:var(--text-muted);"><%= i + 1 %></td>
                        <td class="fw-semibold">
                            <%= entry.studentName %>
                            <input type="hidden" name="entries[<%= i %>][studentId]" value="<%= entry.studentId %>" />
                        </td>
                        <td>
                            <input
                                type="number"
                                name="entries[<%= i %>][marks]"
                                class="form-control marks-input"
                                style="max-width:110px;"
                                value="<%= entry.marksObtained ?? '' %>"
                                min="0" max="<%= test.maxMarks %>"
                                step="0.5"
                                data-max="<%= test.maxMarks %>"
                                data-row="<%= i %>"
                                <%= (entry.isAbsent || isReadOnly) ? 'disabled' : '' %>
                            />
                        </td>
                        <td style="text-align:center;">
                            <input
                                type="checkbox"
                                name="entries[<%= i %>][isAbsent]"
                                class="absent-cb"
                                data-row="<%= i %>"
                                <%= entry.isAbsent ? 'checked' : '' %>
                                <%= isReadOnly ? 'disabled' : '' %>
                            />
                        </td>
                        <td>
                            <input type="text" name="entries[<%= i %>][remarks]" class="form-control" style="max-width:180px;" value="<%= entry.remarks || '' %>" placeholder="Optional" />
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <div style="display:flex; gap:10px; margin-top:20px; padding:0 16px 16px;">
            <% if (!isReadOnly) { %>
            <input type="hidden" name="submitFlag" id="submitFlag" value="0" />
            <button type="button" class="btn btn-secondary" onclick="saveMarks(0)">Save Draft</button>
            <button type="button" class="btn btn-primary" onclick="saveMarks(1)">Submit for Class Teacher Approval</button>
            <% } %>
            <a href="/teacher/results/class-tests" class="btn btn-secondary"><%= isReadOnly ? '← Back' : 'Cancel' %></a>
        </div>
    </form>
</div>

<script>
document.querySelectorAll('.absent-cb').forEach(cb => {
    cb.addEventListener('change', function() {
        const inp = document.querySelector(`[data-row="${this.dataset.row}"].marks-input`);
        inp.disabled = this.checked;
        if (this.checked) inp.value = '';
    });
});

document.querySelectorAll('.marks-input').forEach(inp => {
    inp.addEventListener('input', function() {
        const max = parseFloat(this.dataset.max);
        if (parseFloat(this.value) > max) this.value = max;
    });
});

function saveMarks(submit) {
    document.getElementById('submitFlag').value = submit;
    document.getElementById('marksForm').submit();
}
</script>
