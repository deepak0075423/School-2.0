<div class="page-header">
    <div>
        <h1>🔍 Validate: <%= exam.title %></h1>
        <p><%= exam.section?.class?.className %> – Section <%= exam.section?.sectionName %></p>
    </div>
    <a href="/teacher/results/validation" class="btn btn-secondary">← Back</a>
</div>

<% sheets.forEach(sheet => {
    const sc = exam.subjects.find(s => String(s.subject?._id || s.subject) === String(sheet.subject?._id));
%>
<div class="card" style="margin-bottom:20px;">
    <div class="card-header">
        <div>
            <div class="card-title" style="margin-bottom:4px;"><%= sheet.subject?.subjectName %></div>
            <% if (sc) { %><div style="color:var(--text-muted); font-size:13px;">Max: <%= sc.maxMarks %> | Passing: <%= sc.passingMarks %></div><% } %>
        </div>
        <span class="badge <%= sheet.status === 'SUBMITTED' ? 'badge-green' : 'badge-orange' %>"><%= sheet.status %></span>
    </div>

    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>Student</th>
                    <th style="text-align:center;">Marks</th>
                    <th style="text-align:center;">Absent</th>
                    <th style="text-align:center;">Grade</th>
                    <th>Remarks</th>
                </tr>
            </thead>
            <tbody>
                <% sheet.entries.forEach(entry => {
                    const stud = students.find(s => String(s._id) === String(entry.student?._id || entry.student));
                    const maxM = sc ? sc.maxMarks : 100;
                    const pct  = entry.isAbsent ? 0 : ((entry.marksObtained || 0) / maxM * 100);
                    let grade = 'AB';
                    if (!entry.isAbsent) {
                        if (pct>=90) grade='A+'; else if(pct>=80) grade='A';
                        else if(pct>=70) grade='B+'; else if(pct>=60) grade='B';
                        else if(pct>=50) grade='C'; else if(pct>=40) grade='D'; else grade='F';
                    }
                %>
                <tr>
                    <td class="fw-semibold"><%= stud?.name || entry.student?.name || '—' %></td>
                    <td style="text-align:center;">
                        <% if (entry.isAbsent) { %><span class="text-muted">AB</span>
                        <% } else if (entry.marksObtained === null || entry.marksObtained === undefined) { %>
                            <span class="badge badge-red">MISSING</span>
                        <% } else { %><strong><%= entry.marksObtained %></strong>/<%= maxM %><% } %>
                    </td>
                    <td style="text-align:center;"><%= entry.isAbsent ? '✅' : '—' %></td>
                    <td style="text-align:center;">
                        <span class="badge <%= grade==='F'||grade==='AB' ? 'badge-red' : grade.startsWith('A') ? 'badge-green' : 'badge-blue' %>"><%= grade %></span>
                    </td>
                    <td style="color:var(--text-muted); font-size:13px;"><%= entry.remarks || '—' %></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>
<% }) %>

<% if (['CLASS_APPROVED', 'FINAL_APPROVED'].includes(exam.status) && results && results.length > 0) { %>
<div class="card" style="margin-bottom:20px;">
    <div class="card-header">
        <div class="card-title">
            <%= exam.status === 'FINAL_APPROVED' ? '📊 Final Results' : '📋 Approved Marks (Pending Admin Approval)' %>
        </div>
    </div>
    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th style="text-align:center;">Rank</th>
                    <th>Student</th>
                    <% exam.subjects.forEach(sc => { %>
                        <th style="text-align:center;"><%= sc.subject?.subjectName %> (<%= sc.maxMarks %>)</th>
                    <% }) %>
                    <th style="text-align:center;">Total</th>
                    <th style="text-align:center;">%</th>
                    <th style="text-align:center;">Grade</th>
                    <th style="text-align:center;">Result</th>
                </tr>
            </thead>
            <tbody>
                <% results.forEach(r => { %>
                <tr style="<%= r.isPassed ? '' : 'background:#fff5f5;' %>">
                    <td style="text-align:center; font-weight:700; color:var(--primary);">#<%= r.rank %></td>
                    <td class="fw-semibold"><%= r.student?.name %></td>
                    <% exam.subjects.forEach(sc => {
                        const sr = r.subjects.find(s => String(s.subject?._id || s.subject) === String(sc.subject?._id));
                    %>
                        <td style="text-align:center;">
                            <% if (!sr) { %>—
                            <% } else if (sr.isAbsent) { %><span class="badge badge-orange">AB</span>
                            <% } else { %><%= sr.marksObtained %> <span style="color:var(--text-muted);font-size:11px;">(<%= sr.grade %>)</span>
                            <% } %>
                        </td>
                    <% }) %>
                    <td style="text-align:center; font-weight:600;"><%= r.totalMarks %>/<%= r.totalMaxMarks %></td>
                    <td style="text-align:center;"><%= r.percentage %>%</td>
                    <td style="text-align:center;">
                        <span class="badge <%= r.grade === 'F' ? 'badge-red' : r.grade.startsWith('A') ? 'badge-green' : 'badge-blue' %>"><%= r.grade %></span>
                    </td>
                    <td style="text-align:center;">
                        <span class="badge <%= r.isPassed ? 'badge-green' : 'badge-red' %>"><%= r.isPassed ? 'PASS' : 'FAIL' %></span>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>
<% } %>

<% if (exam.status === 'SUBMITTED') { %>
<div class="card">
    <div class="card-header">
        <div class="card-title">Validation Actions</div>
    </div>
    <div class="card-body">
        <div style="display:flex; gap:10px; margin-bottom:16px;">
            <form method="POST" action="/teacher/results/validation/<%= exam._id %>/approve" style="display:inline;">
                <input type="text" name="notes" class="form-control" style="display:inline-block; width:260px; margin-right:8px;" placeholder="Approval notes (optional)" />
                <button type="submit" class="btn btn-primary"
                    data-confirm="Approve all marks and send for Admin final approval?"
                    data-confirm-title="Approve Marks"
                    data-confirm-type="warning"
                    data-confirm-ok="Approve">
                    Approve Marks
                </button>
            </form>
            <button class="btn btn-danger" onclick="document.getElementById('rejectPanel').style.display='block'">Reject & Return</button>
        </div>

        <div id="rejectPanel" style="display:none; background:#fff5f5; border:1px solid #fca5a5; border-radius:10px; padding:16px;">
            <form method="POST" action="/teacher/results/validation/<%= exam._id %>/reject">
                <div class="form-group">
                    <label class="form-label">Rejection Reason *</label>
                    <textarea name="reason" class="form-control" rows="3" required placeholder="Specify what needs to be corrected…"></textarea>
                </div>
                <div style="display:flex; gap:8px;">
                    <button type="submit" class="btn btn-danger">Confirm Reject</button>
                    <button type="button" class="btn btn-secondary" onclick="document.getElementById('rejectPanel').style.display='none'">Cancel</button>
                </div>
            </form>
        </div>
    </div>
</div>
<% } %>
