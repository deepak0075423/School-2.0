<div class="page-header">
    <div>
        <h1>✏️ Enter Marks</h1>
        <p><strong><%= subConf.subject?.subjectName %></strong> — <%= exam.title %></p>
        <p style="color:var(--text-muted); font-size:13px;">Max Marks: <%= subConf.maxMarks %> &nbsp;|&nbsp; Passing Marks: <%= subConf.passingMarks %></p>
    </div>
    <a href="/teacher/results/marks-entry" class="btn btn-secondary">← Back</a>
</div>

<% if (isReadOnly) { %>
<div class="card" style="margin-bottom:16px;">
    <div style="padding:14px 18px; background:#f0fdf4; border-radius:10px; display:flex; align-items:center; gap:10px;">
        <span style="font-size:20px;">✅</span>
        <div>
            <strong>Marks Submitted</strong>
            <div style="color:var(--text-muted); font-size:13px;">These marks have been submitted for class teacher validation. No further edits are allowed.</div>
        </div>
    </div>
</div>
<% } %>

<div class="card">
    <form method="POST" action="/teacher/results/marks-entry/<%= exam._id %>/<%= subConf.subject?._id || subConf.subject %>/save" id="marksForm">
        <div class="table-wrapper">
            <table id="marksTable">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Student Name</th>
                        <th>Marks Obtained (max <%= subConf.maxMarks %>)</th>
                        <th style="text-align:center;">Absent</th>
                        <th>Remarks</th>
                    </tr>
                </thead>
                <tbody>
                    <% entries.forEach((entry, i) => { %>
                    <tr id="row-<%= i %>">
                        <td style="color:var(--text-muted);"><%= i + 1 %></td>
                        <td class="fw-semibold">
                            <%= entry.studentName %>
                            <input type="hidden" name="entries[<%= i %>][studentId]" value="<%= entry.studentId %>" />
                        </td>
                        <td>
                            <input
                                type="number"
                                name="entries[<%= i %>][marks]"
                                class="form-control marks-input"
                                style="max-width:110px;"
                                value="<%= entry.marksObtained ?? '' %>"
                                min="0" max="<%= subConf.maxMarks %>"
                                step="0.5"
                                data-max="<%= subConf.maxMarks %>"
                                data-row="<%= i %>"
                                <%= (entry.isAbsent || isReadOnly) ? 'disabled' : '' %>
                            />
                        </td>
                        <td style="text-align:center;">
                            <input
                                type="checkbox"
                                name="entries[<%= i %>][isAbsent]"
                                class="absent-cb"
                                data-row="<%= i %>"
                                <%= entry.isAbsent ? 'checked' : '' %>
                                <%= isReadOnly ? 'disabled' : '' %>
                            />
                        </td>
                        <td>
                            <input type="text" name="entries[<%= i %>][remarks]" class="form-control" style="max-width:180px;" value="<%= entry.remarks || '' %>" placeholder="Optional" />
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <div style="display:flex; gap:10px; margin-top:20px; padding:0 16px 16px;">
            <% if (!isReadOnly) { %>
            <input type="hidden" name="submitFlag" id="submitFlag" value="0" />
            <button type="button" class="btn btn-secondary" onclick="saveMarks(0)">Save Draft</button>
            <button type="button" class="btn btn-primary" onclick="saveMarks(1)">Submit for Validation</button>
            <% } %>
            <a href="/teacher/results/marks-entry" class="btn btn-secondary"><%= isReadOnly ? '← Back' : 'Cancel' %></a>
        </div>
    </form>
</div>

<script>
document.querySelectorAll('.absent-cb').forEach(cb => {
    cb.addEventListener('change', function() {
        const row  = this.dataset.row;
        const marksInput = document.querySelector(`[data-row="${row}"].marks-input`);
        if (this.checked) {
            marksInput.disabled = true;
            marksInput.value = '';
        } else {
            marksInput.disabled = false;
        }
    });
});

document.querySelectorAll('.marks-input').forEach(inp => {
    inp.addEventListener('input', function() {
        const max = parseFloat(this.dataset.max);
        if (parseFloat(this.value) > max) {
            this.value = max;
            this.setCustomValidity(`Cannot exceed ${max}`);
        } else {
            this.setCustomValidity('');
        }
    });
});

function saveMarks(submit) {
    let valid = true;
    document.querySelectorAll('.marks-input:not([disabled])').forEach(inp => {
        const val = parseFloat(inp.value);
        const max = parseFloat(inp.dataset.max);
        if (inp.value !== '' && (val < 0 || val > max)) {
            inp.style.borderColor = 'var(--danger)';
            valid = false;
        } else {
            inp.style.borderColor = '';
        }
    });
    if (!valid) {
        showGlobalAlert('Some marks exceed the maximum allowed. Please correct them before saving.', 'Validation Error', 'warning');
        return;
    }
    document.getElementById('submitFlag').value = submit;
    document.getElementById('marksForm').submit();
}
</script>
