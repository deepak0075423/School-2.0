
<div class="page-header">
    <div>
        <h1>✏️ Enter Marks</h1>
        <p><strong><%= subConf.subject?.subjectName %></strong> — <%= exam.title %></p>
        <p class="text-muted text-sm">Max Marks: <%= subConf.maxMarks %> &nbsp;|&nbsp; Passing Marks: <%= subConf.passingMarks %></p>
    </div>
    <a href="/teacher/results/marks-entry" class="btn btn-ghost">← Back</a>
</div>

<div class="card">
    <form method="POST" action="/teacher/results/marks-entry/<%= exam._id %>/<%= subConf.subject?._id || subConf.subject %>/save" id="marksForm">
        <div class="table-wrapper">
            <table id="marksTable">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Student Name</th>
                        <th>Marks Obtained (max <%= subConf.maxMarks %>)</th>
                        <th>Absent</th>
                        <th>Remarks</th>
                    </tr>
                </thead>
                <tbody>
                    <% entries.forEach((entry, i) => { %>
                    <tr id="row-<%= i %>">
                        <td class="text-muted"><%= i + 1 %></td>
                        <td class="fw-semibold">
                            <%= entry.studentName %>
                            <input type="hidden" name="entries[<%= i %>][studentId]" value="<%= entry.studentId %>" />
                        </td>
                        <td>
                            <input
                                type="number"
                                name="entries[<%= i %>][marks]"
                                class="form-control form-control-sm marks-input"
                                value="<%= entry.marksObtained ?? '' %>"
                                min="0" max="<%= subConf.maxMarks %>"
                                step="0.5"
                                data-max="<%= subConf.maxMarks %>"
                                data-row="<%= i %>"
                                <%= entry.isAbsent ? 'disabled' : '' %>
                            />
                        </td>
                        <td class="text-center">
                            <input
                                type="checkbox"
                                name="entries[<%= i %>][isAbsent]"
                                class="absent-cb"
                                data-row="<%= i %>"
                                <%= entry.isAbsent ? 'checked' : '' %>
                            />
                        </td>
                        <td>
                            <input type="text" name="entries[<%= i %>][remarks]" class="form-control form-control-sm" value="<%= entry.remarks || '' %>" placeholder="Optional" />
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <div class="form-actions mt-4">
            <input type="hidden" name="submit" id="submitFlag" value="0" />
            <button type="button" class="btn btn-secondary" onclick="saveMarks(0)">Save Draft</button>
            <button type="button" class="btn btn-primary" onclick="saveMarks(1)">Submit for Validation</button>
            <a href="/teacher/results/marks-entry" class="btn btn-ghost">Cancel</a>
        </div>
    </form>
</div>

<script>
// Toggle absent checkbox
document.querySelectorAll('.absent-cb').forEach(cb => {
    cb.addEventListener('change', function() {
        const row  = this.dataset.row;
        const marksInput = document.querySelector(`[data-row="${row}"].marks-input`);
        if (this.checked) {
            marksInput.disabled = true;
            marksInput.value = '';
        } else {
            marksInput.disabled = false;
        }
    });
});

// Validate marks don't exceed max
document.querySelectorAll('.marks-input').forEach(inp => {
    inp.addEventListener('input', function() {
        const max = parseFloat(this.dataset.max);
        if (parseFloat(this.value) > max) {
            this.value = max;
            this.setCustomValidity(`Cannot exceed ${max}`);
        } else {
            this.setCustomValidity('');
        }
    });
});

function saveMarks(submit) {
    document.getElementById('submitFlag').value = submit;
    document.getElementById('marksForm').submit();
}
</script>
