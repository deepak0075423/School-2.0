<div class="page-header">
    <div>
        <h1>✏️ Marks Entry</h1>
        <p>Enter marks for exams assigned to your subjects.</p>
    </div>
</div>

<% if (!enrichedExams || enrichedExams.length === 0) { %>
<div class="card">
    <div class="empty-state">
        <div class="empty-icon">✏️</div>
        <h3>No Exams Pending</h3>
        <p>There are no exams awaiting your marks entry at this time.</p>
    </div>
</div>
<% } else { %>
<% const statusBadge = { MARKS_PENDING:'badge-orange', SUBMITTED:'badge-blue', REJECTED:'badge-red', REOPENED:'badge-orange', CLASS_APPROVED:'badge-purple', FINAL_APPROVED:'badge-green' }; %>
<% const typeLabel = { MID_TERM:'Mid Term', FINAL:'Final Exam', UNIT_TEST:'Unit Test' }; %>

<% enrichedExams.forEach(({ exam, mySubjects }) => { %>
<div class="card" style="margin-bottom:20px;">
    <div class="card-header">
        <div>
            <div class="card-title" style="margin-bottom:4px;"><%= exam.title %></div>
            <div style="color:var(--text-muted); font-size:13px;">
                <%= exam.section?.class?.className %> – Section <%= exam.section?.sectionName %> &nbsp;|&nbsp; <%= exam.academicYear?.yearName %>
                &nbsp;|&nbsp; <%= new Date(exam.startDate).toLocaleDateString('en-IN') %> – <%= new Date(exam.endDate).toLocaleDateString('en-IN') %>
            </div>
        </div>
        <span class="badge <%= statusBadge[exam.status] || 'badge-orange' %>"><%= exam.status.replace(/_/g,' ') %></span>
    </div>

    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>Subject</th>
                    <th style="text-align:center;">Max Marks</th>
                    <th style="text-align:center;">Passing Marks</th>
                    <th>Marks Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                <% mySubjects.forEach(sc => { %>
                <tr>
                    <td class="fw-semibold"><%= sc.subject?.subjectName %></td>
                    <td style="text-align:center;"><%= sc.maxMarks %></td>
                    <td style="text-align:center;"><%= sc.passingMarks %></td>
                    <td>
                        <% if (sc.sheetStatus === 'SUBMITTED') { %>
                            <span class="badge badge-green">SUBMITTED</span>
                        <% } else { %>
                            <span class="badge badge-orange">PENDING</span>
                        <% } %>
                    </td>
                    <td>
                        <% if (['CLASS_APPROVED', 'FINAL_APPROVED'].includes(exam.status) || sc.sheetStatus === 'SUBMITTED') { %>
                            <a href="/teacher/results/marks-entry/<%= exam._id %>/<%= sc.subject?._id || sc.subject %>" class="btn btn-sm btn-secondary">View Marks</a>
                        <% } else if (['MARKS_PENDING', 'REJECTED', 'REOPENED'].includes(exam.status)) { %>
                            <a href="/teacher/results/marks-entry/<%= exam._id %>/<%= sc.subject?._id || sc.subject %>" class="btn btn-sm btn-primary">Enter Marks</a>
                        <% } else { %>
                            <a href="/teacher/results/marks-entry/<%= exam._id %>/<%= sc.subject?._id || sc.subject %>" class="btn btn-sm btn-secondary">View Marks</a>
                        <% } %>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>
<% }) %>
<% } %>
