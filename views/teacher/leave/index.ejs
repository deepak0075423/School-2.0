<style>
.status-badge { display:inline-block; padding:3px 10px; border-radius:12px; font-size:11px; font-weight:700; }
.status-pending     { background:#fefce8; color:#a16207; border:1px solid #fde68a; }
.status-approved    { background:#ecfdf5; color:#065f46; border:1px solid #a7f3d0; }
.status-rejected    { background:#fef2f2; color:#991b1b; border:1px solid #fecaca; }
.status-modification_requested { background:#f5f3ff; color:#6d28d9; border:1px solid #ddd6fe; }
.status-cancelled   { background:#f3f4f6; color:#6b7280; border:1px solid #e5e7eb; }
</style>

<div class="page-header">
    <div>
        <h1 class="page-title">My Leaves</h1>
        <p class="text-muted">Your leave applications and history</p>
    </div>
    <a href="/teacher/leave/apply" class="btn btn-primary" style="background:linear-gradient(135deg,#b45309,#d97706); border:none;">+ Apply Leave</a>
</div>

<!-- Balance summary -->
<% if (balances.length) { %>
<div style="display:flex; gap:12px; flex-wrap:wrap; margin-bottom:20px;">
    <% balances.forEach(b => { %>
    <div class="card" style="min-width:180px; flex:1;">
        <div class="card-body" style="padding:14px;">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
                <span class="badge badge-blue" style="font-size:11px;"><%= b.leaveType ? b.leaveType.code : '?' %></span>
                <span style="font-size:11px; color:var(--text-muted);"><%= b.leaveType ? b.leaveType.name : '' %></span>
            </div>
            <div style="font-size:28px; font-weight:800; color:var(--text);"><%= b.remaining %></div>
            <div style="font-size:11px; color:var(--text-muted);">
                of <%= b.totalAllocated + b.carriedForward %> days available
                <% if (b.pending > 0) { %> · <span style="color:#a16207;"><%= b.pending %> pending</span><% } %>
            </div>
        </div>
    </div>
    <% }) %>
    <div class="card" style="min-width:140px; display:flex; align-items:center; justify-content:center;">
        <a href="/teacher/leave/balance" style="text-align:center; text-decoration:none; color:var(--primary); font-size:13px; font-weight:600; padding:14px;">
            📊<br/>Full Balance
        </a>
    </div>
</div>
<% } %>

<!-- Filter -->
<form method="GET" action="/teacher/leave" style="margin-bottom:14px; display:flex; gap:10px; align-items:center;">
    <select name="status" class="form-control" style="width:180px;">
        <option value="">All Statuses</option>
        <% ['pending','approved','rejected','modification_requested','cancelled'].forEach(s => { %>
        <option value="<%= s %>" <%= filters.status === s ? 'selected' : '' %>><%= s.replace(/_/g,' ') %></option>
        <% }) %>
    </select>
    <button type="submit" class="btn btn-secondary btn-sm">Filter</button>
    <a href="/teacher/leave" class="btn btn-secondary btn-sm">Clear</a>
</form>

<% if (!applications.length) { %>
<div class="card">
    <div class="card-body">
        <div class="empty-state">
            <div class="empty-icon">🏖️</div>
            <h3>No leave applications yet</h3>
            <p class="text-muted">Apply for leave when needed.</p>
            <a href="/teacher/leave/apply" class="btn btn-primary" style="margin-top:12px; background:linear-gradient(135deg,#b45309,#d97706); border:none;">Apply for Leave</a>
        </div>
    </div>
</div>
<% } else { %>
<div class="card">
    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>Leave Type</th>
                    <th>From</th>
                    <th>To</th>
                    <th>Days</th>
                    <th>Mode</th>
                    <th>Status</th>
                    <th>Applied</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% applications.forEach(app => { %>
                <tr>
                    <td>
                        <% if (app.leaveType) { %>
                        <span class="badge badge-blue"><%= app.leaveType.code %></span>
                        <span style="font-size:12px; margin-left:4px;"><%= app.leaveType.name %></span>
                        <% } else { %>—<% } %>
                    </td>
                    <td><%= fmtDate(app.fromDate) %></td>
                    <td><%= fmtDate(app.toDate) %></td>
                    <td><strong><%= app.totalDays %></strong></td>
                    <td><span class="badge badge-gray"><%= app.leaveMode === 'half_day' ? 'Half Day' : 'Full Day' %></span></td>
                    <td><span class="status-badge status-<%= app.status %>"><%= app.status.replace(/_/g,' ') %></span></td>
                    <td style="font-size:12px;"><%= fmtDate(app.appliedAt) %></td>
                    <td>
                        <div style="display:flex; gap:4px;">
                            <button onclick="toggleReason('<%= app._id %>')" class="btn btn-sm btn-secondary">Details</button>
                            <% if (app.status === 'pending' || app.status === 'modification_requested') { %>
                            <form method="POST" action="/teacher/leave/<%= app._id %>/cancel"
                                  data-confirm-submit="Cancel this leave application?"
                                  data-confirm-title="Cancel Leave">
                                <button type="submit" class="btn btn-sm btn-danger">Cancel</button>
                            </form>
                            <% } %>
                        </div>
                    </td>
                </tr>
                <!-- Detail row -->
                <tr id="reason-<%= app._id %>" style="display:none;">
                    <td colspan="8" style="background:var(--card-bg); padding:14px 24px;">
                        <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
                            <div>
                                <div class="form-label">Reason</div>
                                <p style="margin:4px 0; font-size:13px;"><%= app.reason %></p>
                            </div>
                            <div>
                                <% if (app.adminComment) { %>
                                <div class="form-label">Admin Comment</div>
                                <p style="margin:4px 0; font-size:13px; color:var(--text-muted);"><%= app.adminComment %></p>
                                <% } %>
                                <% if (app.document) { %>
                                <div class="form-label" style="margin-top:8px;">Document</div>
                                <a href="<%= app.document %>" target="_blank" class="btn btn-sm btn-secondary">View</a>
                                <% } %>
                                <% if (app.approvedBy) { %>
                                <div class="form-label" style="margin-top:8px;">Processed by</div>
                                <span style="font-size:12px;"><%= app.approvedBy.name %></span>
                                <% } %>
                            </div>
                        </div>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>
<% } %>

<script>
function toggleReason(id) {
    const row = document.getElementById('reason-' + id);
    if (row) row.style.display = row.style.display === 'none' ? '' : 'none';
}
</script>
