<div class="page-header">
    <div>
        <h1>🎒 Student Profile</h1>
        <p><%= profile.user.name %> — <%= teacherSection.class?.className %>, Section <%= teacherSection.sectionName %></p>
    </div>
    <a href="/teacher/attendance-dashboard" class="btn btn-secondary">← Dashboard</a>
</div>

<!-- Profile Card + Stats -->
<div style="display:grid; grid-template-columns:280px 1fr; gap:20px; margin-bottom:20px; align-items:start;">

    <!-- Profile Info -->
    <div class="card">
        <div class="card-body" style="text-align:center; padding:28px 20px;">
            <% if (profile.user.profileImage) { %>
                <img src="<%= profile.user.profileImage %>" style="width:80px;height:80px;border-radius:50%;object-fit:cover;border:3px solid #4f46e5;margin-bottom:12px;">
            <% } else { %>
                <div style="width:80px;height:80px;border-radius:50%;background:linear-gradient(135deg,#4f46e5,#7c3aed);display:flex;align-items:center;justify-content:center;font-size:28px;margin:0 auto 12px;">🎒</div>
            <% } %>
            <div class="fw-semibold text-primary" style="font-size:16px;"><%= profile.user.name %></div>
            <div class="text-muted" style="font-size:12px; margin-top:4px;"><%= profile.user.email %></div>
            <% if (profile.rollNumber) { %><div style="margin-top:8px;"><span class="badge badge-cyan">Roll #<%= profile.rollNumber %></span></div><% } %>
            <% if (profile.admissionNumber) { %><div style="margin-top:4px;"><span class="badge badge-purple">Adm: <%= profile.admissionNumber %></span></div><% } %>
        </div>
        <div style="border-top:1px solid var(--border,rgba(255,255,255,0.08)); padding:16px;">
            <div style="display:flex; flex-direction:column; gap:10px; font-size:13px;">
                <% if (profile.gender) { %><div><span class="text-muted">Gender:</span> <span class="text-primary"><%= profile.gender %></span></div><% } %>
                <% if (profile.dob) { %><div><span class="text-muted">DOB:</span> <span class="text-primary"><%= new Date(profile.dob).toLocaleDateString('en-IN') %></span></div><% } %>
                <% if (profile.bloodGroup) { %><div><span class="text-muted">Blood Group:</span> <span class="text-primary"><%= profile.bloodGroup %></span></div><% } %>
                <% if (profile.parent) { %><div><span class="text-muted">Parent:</span> <span class="text-primary"><%= profile.parent.name || 'Linked' %></span></div><% } %>
            </div>
        </div>
    </div>

    <!-- Stats + Calendar -->
    <div style="display:flex; flex-direction:column; gap:20px;">

        <!-- Attendance Stats -->
        <div class="stats-grid" style="grid-template-columns: repeat(5, 1fr);">
            <div class="stat-card">
                <div class="stat-icon cyan">📅</div>
                <div class="stat-info"><div class="stat-value"><%= stats.total %></div><div class="stat-label">Total Days</div></div>
            </div>
            <div class="stat-card">
                <div class="stat-icon green">✅</div>
                <div class="stat-info"><div class="stat-value"><%= stats.present %></div><div class="stat-label">Present</div></div>
            </div>
            <div class="stat-card">
                <div class="stat-icon red">❌</div>
                <div class="stat-info"><div class="stat-value"><%= stats.absent %></div><div class="stat-label">Absent</div></div>
            </div>
            <div class="stat-card">
                <div class="stat-icon yellow">⏰</div>
                <div class="stat-info"><div class="stat-value"><%= stats.late %></div><div class="stat-label">Late</div></div>
            </div>
            <div class="stat-card">
                <div class="stat-icon <%= stats.percentage >= 75 ? 'green' : stats.percentage >= 50 ? 'yellow' : 'red' %>">📊</div>
                <div class="stat-info">
                    <div class="stat-value" style="color:<%= stats.percentage >= 75 ? '#10b981' : stats.percentage >= 50 ? '#f59e0b' : '#ef4444' %>">
                        <%= stats.percentage %>%
                    </div>
                    <div class="stat-label">Attendance</div>
                </div>
            </div>
        </div>

        <!-- Calendar -->
        <div class="card">
            <div class="card-header"><div class="card-title">📅 Attendance Calendar</div></div>
            <div class="card-body">
                <div id="studentCalendar"></div>
                <div style="display:flex; gap:12px; flex-wrap:wrap; margin-top:12px; font-size:12px;">
                    <span><span style="display:inline-block;width:12px;height:12px;border-radius:3px;background:#10b981;margin-right:4px;"></span>Present</span>
                    <span><span style="display:inline-block;width:12px;height:12px;border-radius:3px;background:#ef4444;margin-right:4px;"></span>Absent</span>
                    <span><span style="display:inline-block;width:12px;height:12px;border-radius:3px;background:#f59e0b;margin-right:4px;"></span>Late</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Attendance History Table -->
<div class="card">
    <div class="card-header">
        <div class="card-title">📋 Attendance History (Last 30 records)</div>
    </div>
    <% if (history.length === 0) { %>
        <div class="empty-state" style="padding:24px;"><p>No attendance records found.</p></div>
    <% } else { %>
    <div class="table-wrapper">
        <table>
            <thead>
                <tr><th>Date</th><th>Day</th><th>Status</th><th>Remarks</th></tr>
            </thead>
            <tbody>
                <% history.forEach(h => { %>
                <tr>
                    <td class="fw-semibold"><%= new Date(h.date).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }) %></td>
                    <td class="text-muted"><%= new Date(h.date).toLocaleDateString('en-IN', { weekday:'long' }) %></td>
                    <td>
                        <% if(h.status==='Present') { %><span class="badge badge-green">✅ Present</span>
                        <% } else if(h.status==='Absent') { %><span class="badge" style="background:rgba(239,68,68,0.15);color:#ef4444;">❌ Absent</span>
                        <% } else { %><span class="badge" style="background:rgba(245,158,11,0.15);color:#f59e0b;">⏰ Late</span><% } %>
                    </td>
                    <td class="text-muted" style="font-size:12px;"><%= h.remarks || '—' %></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
    <% } %>
</div>

<script>
(function() {
    const calMap = <%- calendarMap %>;
    const statusColors = { Present: '#10b981', Absent: '#ef4444', Late: '#f59e0b' };
    const statusBg    = { Present: 'rgba(16,185,129,0.15)', Absent: 'rgba(239,68,68,0.15)', Late: 'rgba(245,158,11,0.15)' };

    const now = new Date();
    const year = now.getFullYear();
    const month = now.getMonth();
    const firstDay = new Date(year, month, 1).getDay();
    const daysInMonth = new Date(year, month + 1, 0).getDate();
    const dayNames = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
    const todayStr = now.toISOString().split('T')[0];

    let html = '<table style="width:100%; border-collapse:collapse; font-size:13px;">';
    html += '<thead><tr>';
    dayNames.forEach(d => { html += `<th style="padding:6px 2px; text-align:center; color:var(--text-muted,#94a3b8); font-weight:600; font-size:11px;">${d}</th>`; });
    html += '</tr></thead><tbody><tr>';

    for (let i = 0; i < firstDay; i++) html += '<td></td>';
    let col = firstDay;
    for (let day = 1; day <= daysInMonth; day++) {
        const dateStr = `${year}-${String(month+1).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
        const status = calMap[dateStr];
        const isToday = dateStr === todayStr;
        const color = status ? statusColors[status] : 'transparent';
        const bg = status ? statusBg[status] : 'transparent';
        const border = isToday ? '2px solid #4f46e5' : `1px solid ${status ? color : 'var(--border,rgba(255,255,255,0.08))'}`;
        html += `<td style="padding:3px;text-align:center;">
            <div title="${status ? dateStr+': '+status : dateStr}" style="width:32px;height:32px;border-radius:6px;margin:auto;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:${isToday?'700':'400'};color:${status?color:'var(--text,#e2e8f0)'};background:${bg};border:${border}">
                ${day}
            </div></td>`;
        col++;
        if (col === 7 && day < daysInMonth) { html += '</tr><tr>'; col = 0; }
    }
    html += '</tr></tbody></table>';
    document.getElementById('studentCalendar').innerHTML = html;
})();
</script>
