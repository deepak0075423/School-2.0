<div class="page-header">
    <div>
        <h1>📊 Submissions — <%= exam.title %></h1>
        <p>
            <%= exam.section?.class?.className %> – <%= exam.section?.sectionName %>
            · <%= new Date(exam.examDate).toLocaleDateString('en-IN') %>
        </p>
    </div>
    <div style="display:flex; gap:8px;">
        <a href="/teacher/exams" class="btn btn-secondary">← Back</a>
        <a href="/teacher/exams/<%= exam._id %>/analytics" class="btn btn-secondary">📈 Analytics</a>
        <a href="/teacher/exams/<%= exam._id %>/result-approval" class="btn btn-primary">✅ Result Approval</a>
    </div>
</div>

<!-- Summary cards -->
<div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(160px, 1fr)); gap:16px; margin-bottom:20px;">
    <div class="card">
        <div class="card-body" style="text-align:center; padding:16px;">
            <div style="font-size:28px; font-weight:800; color:#3b82f6;"><%= results.length %></div>
            <div style="font-size:12px; color:var(--text-muted);">Submitted</div>
        </div>
    </div>
    <div class="card">
        <div class="card-body" style="text-align:center; padding:16px;">
            <div style="font-size:28px; font-weight:800; color:#22c55e;">
                <% const avg = results.length ? Math.round(results.reduce((s,r) => s+r.obtainedMarks, 0) / results.length * 10) / 10 : 0; %>
                <%= avg %>
            </div>
            <div style="font-size:12px; color:var(--text-muted);">Avg Score / <%= exam.totalMarks %></div>
        </div>
    </div>
    <div class="card">
        <div class="card-body" style="text-align:center; padding:16px;">
            <div style="font-size:28px; font-weight:800; color:#a78bfa;">
                <%= results.length ? Math.max(...results.map(r => r.obtainedMarks)) : '—' %>
            </div>
            <div style="font-size:12px; color:var(--text-muted);">Highest</div>
        </div>
    </div>
    <div class="card">
        <div class="card-body" style="text-align:center; padding:16px;">
            <div style="font-size:28px; font-weight:800; color:#f59e0b;">
                <%= results.length ? Math.min(...results.map(r => r.obtainedMarks)) : '—' %>
            </div>
            <div style="font-size:12px; color:var(--text-muted);">Lowest</div>
        </div>
    </div>
    <div class="card">
        <div class="card-body" style="text-align:center; padding:16px;">
            <% if (exam.resultApprovalStatus === 'approved') { %>
            <span class="badge badge-green" style="font-size:13px; padding:6px 14px;">Published</span>
            <% } else if (exam.subjectTeacherApprovalStatus === 'approved') { %>
            <span class="badge badge-yellow" style="font-size:13px; padding:6px 14px;">Awaiting Class Teacher</span>
            <% } else if (exam.subjectTeacherApprovalStatus === 'rejected') { %>
            <span class="badge badge-red" style="font-size:13px; padding:6px 14px;">Rejected</span>
            <% } else { %>
            <span class="badge badge-yellow" style="font-size:13px; padding:6px 14px;">Awaiting Subject Teacher</span>
            <% } %>
            <div style="font-size:12px; color:var(--text-muted); margin-top:4px;">Result Status</div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <div class="card-title">Student Submissions</div>
    </div>
    <% if (results.length === 0) { %>
    <div class="empty-state" style="padding:30px;">
        <p>No submissions yet.</p>
    </div>
    <% } else { %>
    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Student</th>
                    <th>Score</th>
                    <th>Percentage</th>
                    <th>Submitted At</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% results.forEach((r, i) => { %>
                <tr>
                    <td class="text-muted"><%= i+1 %></td>
                    <td class="fw-semibold">🎒 <%= r.student?.name %></td>
                    <td>
                        <span style="font-weight:700; color:<%= r.percentage >= 60 ? '#22c55e' : r.percentage >= 40 ? '#f59e0b' : '#ef4444' %>">
                            <%= r.obtainedMarks %> / <%= r.totalMarks %>
                        </span>
                    </td>
                    <td>
                        <div style="display:flex; align-items:center; gap:8px;">
                            <div style="width:80px; height:8px; background:var(--bg); border-radius:99px; overflow:hidden;">
                                <div style="width:<%= r.percentage %>%; height:100%; background:<%= r.percentage >= 60 ? '#22c55e' : r.percentage >= 40 ? '#f59e0b' : '#ef4444' %>; border-radius:99px;"></div>
                            </div>
                            <span style="font-size:13px;"><%= r.percentage %>%</span>
                        </div>
                    </td>
                    <td class="text-muted" style="font-size:12px;">
                        <%= r.createdAt ? new Date(r.createdAt).toLocaleString('en-IN', {day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'}) : '—' %>
                    </td>
                    <td>
                        <a href="/teacher/exams/<%= exam._id %>/submissions/<%= r.student?._id %>" class="btn btn-secondary" style="padding:4px 10px; font-size:12px;">View Response</a>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
    <% } %>
</div>
