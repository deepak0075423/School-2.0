<div class="page-header">
    <div>
        <h1>📈 Analytics — <%= exam.title %></h1>
        <p><%= exam.section?.class?.className %> – <%= exam.section?.sectionName %> · <%= new Date(exam.examDate).toLocaleDateString('en-IN') %></p>
    </div>
    <div style="display:flex; gap:8px;">
        <a href="/teacher/exams" class="btn btn-secondary">← Back</a>
        <a href="/teacher/exams/<%= exam._id %>/submissions" class="btn btn-secondary">📊 Submissions</a>
    </div>
</div>

<% if (!analytics) { %>
<div class="card">
    <div class="empty-state" style="padding:40px;">
        <div class="empty-icon">📊</div>
        <h3>No Submissions Yet</h3>
        <p>Analytics will appear once students submit the exam.</p>
    </div>
</div>
<% } else { %>

<!-- Summary metrics -->
<div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(150px, 1fr)); gap:16px; margin-bottom:20px;">
    <div class="card"><div class="card-body" style="text-align:center; padding:16px;">
        <div style="font-size:28px; font-weight:800; color:#3b82f6;"><%= analytics.totalSubmissions %></div>
        <div style="font-size:12px; color:var(--text-muted);">Total Submissions</div>
    </div></div>
    <div class="card"><div class="card-body" style="text-align:center; padding:16px;">
        <div style="font-size:28px; font-weight:800; color:#22c55e;"><%= analytics.avgScore %></div>
        <div style="font-size:12px; color:var(--text-muted);">Avg Score (<%= analytics.avgPct %>%)</div>
    </div></div>
    <div class="card"><div class="card-body" style="text-align:center; padding:16px;">
        <div style="font-size:28px; font-weight:800; color:#a78bfa;"><%= analytics.highScore %></div>
        <div style="font-size:12px; color:var(--text-muted);">Highest Score</div>
    </div></div>
    <div class="card"><div class="card-body" style="text-align:center; padding:16px;">
        <div style="font-size:28px; font-weight:800; color:#f59e0b;"><%= analytics.lowScore %></div>
        <div style="font-size:12px; color:var(--text-muted);">Lowest Score</div>
    </div></div>
</div>

<div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:20px;">

    <!-- Score distribution -->
    <div class="card">
        <div class="card-header"><div class="card-title">Score Distribution</div></div>
        <div class="card-body">
            <% const bucketLabels = ['0-20%', '21-40%', '41-60%', '61-80%', '81-100%'];
               const bucketColors = ['#ef4444','#f59e0b','#eab308','#22c55e','#3b82f6'];
               const maxBucket = Math.max(...analytics.buckets, 1);
               analytics.buckets.forEach((count, i) => { %>
            <div style="margin-bottom:14px;">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:4px;">
                    <span style="font-size:13px; color:var(--text-muted);"><%= bucketLabels[i] %></span>
                    <span style="font-size:13px; font-weight:600;"><%= count %> student<%= count !== 1 ? 's' : '' %></span>
                </div>
                <div style="height:12px; background:var(--bg); border-radius:99px; overflow:hidden;">
                    <div style="height:100%; width:<%= Math.round(count/maxBucket*100) %>%; background:<%= bucketColors[i] %>; border-radius:99px; transition:width .6s;"></div>
                </div>
            </div>
            <% }) %>
        </div>
    </div>

    <!-- Per-question difficulty -->
    <div class="card">
        <div class="card-header"><div class="card-title">Question-wise Accuracy</div></div>
        <div class="card-body" style="max-height:320px; overflow-y:auto;">
            <% analytics.questionStats.forEach((qs, i) => { %>
            <div style="margin-bottom:12px;">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:3px;">
                    <span style="font-size:12px; color:var(--text-muted); max-width:200px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;" title="<%= qs.question.questionText %>">
                        Q<%= i+1 %>: <%= qs.question.questionText %>
                    </span>
                    <span style="font-size:13px; font-weight:700; color:<%= qs.correctPct >= 60 ? '#22c55e' : qs.correctPct >= 40 ? '#f59e0b' : '#ef4444' %>; white-space:nowrap; margin-left:8px;">
                        <%= qs.correctPct %>%
                    </span>
                </div>
                <div style="height:8px; background:var(--bg); border-radius:99px; overflow:hidden;">
                    <div style="height:100%; width:<%= qs.correctPct %>%; background:<%= qs.correctPct >= 60 ? '#22c55e' : qs.correctPct >= 40 ? '#f59e0b' : '#ef4444' %>; border-radius:99px;"></div>
                </div>
            </div>
            <% }) %>
        </div>
    </div>
</div>

<!-- Difficult questions -->
<div class="card">
    <div class="card-header"><div class="card-title">🔴 Difficult Questions (accuracy &lt; 40%)</div></div>
    <% const difficult = analytics.questionStats.filter(qs => qs.correctPct < 40); %>
    <% if (difficult.length === 0) { %>
    <div class="card-body"><p style="color:var(--text-muted); font-size:14px;">No particularly difficult questions detected.</p></div>
    <% } else { %>
    <div class="table-wrapper">
        <table>
            <thead><tr><th>#</th><th>Question</th><th>Type</th><th>% Correct</th><th>Correct / Total</th></tr></thead>
            <tbody>
                <% difficult.forEach(qs => { %>
                <tr>
                    <td class="text-muted"><%= analytics.questionStats.indexOf(qs) + 1 %></td>
                    <td style="max-width:300px;"><%= qs.question.questionText %></td>
                    <td><span style="font-size:11px; color:#a78bfa;"><%= qs.question.questionType.replace('_',' ') %></span></td>
                    <td><span style="color:#ef4444; font-weight:700;"><%= qs.correctPct %>%</span></td>
                    <td><%= qs.correctCount %> / <%= qs.totalCount %></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
    <% } %>
</div>

<% } %>
