<div class="page-header">
    <div>
        <h1>✅ Result Approval — <%= exam.title %></h1>
        <p>
            <%= exam.section?.class?.className %> – Section <%= exam.section?.sectionName %>
            · <%= new Date(exam.examDate).toLocaleDateString('en-IN') %>
        </p>
    </div>
    <a href="/teacher/exams/<%= exam._id %>/submissions" class="btn btn-secondary">← Submissions</a>
</div>

<!-- Two-step workflow status banner -->
<div class="card" style="margin-bottom:20px;">
    <div class="card-header"><div class="card-title">Approval Workflow</div></div>
    <div class="card-body" style="display:flex; gap:0; align-items:stretch;">

        <!-- Step 1: Subject Teacher -->
        <div style="flex:1; padding:16px; border-right:1px solid var(--border);">
            <div style="font-size:12px; font-weight:600; color:var(--text-muted); text-transform:uppercase; letter-spacing:.05em; margin-bottom:8px;">Step 1 — Subject Teacher Review</div>
            <% if (exam.subjectTeacherApprovalStatus === 'approved') { %>
            <span class="badge badge-green" style="font-size:13px; padding:4px 12px;">Approved</span>
            <div style="font-size:12px; color:var(--text-muted); margin-top:6px;">
                By <%= exam.subjectTeacherApprovedBy?.name || 'Subject Teacher' %>
                · <%= exam.subjectTeacherApprovedAt ? new Date(exam.subjectTeacherApprovedAt).toLocaleDateString('en-IN') : '' %>
            </div>
            <% } else if (exam.subjectTeacherApprovalStatus === 'rejected') { %>
            <span class="badge badge-red" style="font-size:13px; padding:4px 12px;">Rejected</span>
            <div style="font-size:12px; color:#ef4444; margin-top:6px;"><%= exam.subjectTeacherRejectionReason || 'No reason given' %></div>
            <% } else { %>
            <span class="badge badge-yellow" style="font-size:13px; padding:4px 12px;">Pending</span>
            <div style="font-size:12px; color:var(--text-muted); margin-top:6px;">Waiting for subject teacher to review.</div>
            <% } %>
        </div>

        <!-- Arrow -->
        <div style="display:flex; align-items:center; padding:0 16px; color:var(--text-muted); font-size:20px;">→</div>

        <!-- Step 2: Class Teacher -->
        <div style="flex:1; padding:16px;">
            <div style="font-size:12px; font-weight:600; color:var(--text-muted); text-transform:uppercase; letter-spacing:.05em; margin-bottom:8px;">Step 2 — Class Teacher Final Approval</div>
            <% if (exam.resultApprovalStatus === 'approved') { %>
            <span class="badge badge-green" style="font-size:13px; padding:4px 12px;">Approved</span>
            <div style="font-size:12px; color:var(--text-muted); margin-top:6px;">
                Publish date: <strong><%= exam.resultPublishDate ? new Date(exam.resultPublishDate).toDateString() : '—' %></strong>
            </div>
            <% } else if (exam.resultApprovalStatus === 'rejected') { %>
            <span class="badge badge-red" style="font-size:13px; padding:4px 12px;">Rejected</span>
            <div style="font-size:12px; color:#ef4444; margin-top:6px;"><%= exam.resultRejectionReason || 'No reason given' %></div>
            <% } else if (exam.subjectTeacherApprovalStatus !== 'approved') { %>
            <span class="badge" style="font-size:13px; padding:4px 12px; background:var(--bg-secondary); color:var(--text-muted);">Locked</span>
            <div style="font-size:12px; color:var(--text-muted); margin-top:6px;">Available after Step 1 is approved.</div>
            <% } else { %>
            <span class="badge badge-yellow" style="font-size:13px; padding:4px 12px;">Pending</span>
            <div style="font-size:12px; color:var(--text-muted); margin-top:6px;">Waiting for class teacher final approval.</div>
            <% } %>
        </div>
    </div>
</div>

<div style="display:grid; grid-template-columns:1fr 380px; gap:20px; align-items:start;">

    <!-- Results table -->
    <div class="card">
        <div class="card-header"><div class="card-title">Results Summary (<%= results.length %> students)</div></div>
        <% if (results.length === 0) { %>
        <div class="empty-state" style="padding:30px;"><p>No submissions yet.</p></div>
        <% } else { %>
        <div class="table-wrapper">
            <table>
                <thead>
                    <tr><th>#</th><th>Student</th><th>Score</th><th>%</th></tr>
                </thead>
                <tbody>
                    <% results.forEach((r, i) => { %>
                    <tr>
                        <td class="text-muted"><%= i+1 %></td>
                        <td class="fw-semibold">🎒 <%= r.student?.name %></td>
                        <td style="color:<%= r.percentage >= 60 ? '#22c55e' : r.percentage >= 40 ? '#f59e0b' : '#ef4444' %>; font-weight:700;">
                            <%= r.obtainedMarks %> / <%= r.totalMarks %>
                        </td>
                        <td><%= r.percentage %>%</td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
        <% } %>
    </div>

    <!-- Action panel -->
    <div style="display:flex; flex-direction:column; gap:16px;">

        <% if (results.length === 0) { %>
        <div class="card"><div class="card-body"><p style="color:var(--text-muted); font-size:14px;">No submissions to review yet.</p></div></div>

        <% } else if (isSubjectTeacher && exam.subjectTeacherApprovalStatus === 'pending') { %>
        <!-- Subject teacher: approve step -->
        <div class="card" style="border:1px solid rgba(34,197,94,.3);">
            <div class="card-header"><div class="card-title" style="color:#22c55e;">✅ Step 1 — Approve for Class Teacher Review</div></div>
            <div class="card-body">
                <p style="font-size:13px; color:var(--text-muted); margin-bottom:16px;">
                    Review the results above. Once you approve, the class teacher will be notified to do final approval and set a publish date.
                </p>
                <form action="/teacher/exams/<%= exam._id %>/subject-approve" method="POST">
                    <input type="hidden" name="action" value="approve">
                    <button type="submit" class="btn btn-primary" style="width:100%;"
                        data-confirm="Approve results and forward to class teacher?"
                        data-confirm-title="Approve Results"
                        data-confirm-type="warning"
                        data-confirm-ok="Approve">
                        ✅ Approve Results
                    </button>
                </form>
            </div>
        </div>

        <div class="card" style="border:1px solid rgba(239,68,68,.2);">
            <div class="card-header"><div class="card-title" style="color:#ef4444;">❌ Reject / Needs Revision</div></div>
            <div class="card-body">
                <form action="/teacher/exams/<%= exam._id %>/subject-approve" method="POST">
                    <input type="hidden" name="action" value="reject">
                    <div class="form-group">
                        <label class="form-label">Reason</label>
                        <textarea name="rejectionReason" class="form-control" rows="3" placeholder="Optional reason…"></textarea>
                    </div>
                    <button type="submit" class="btn btn-secondary" style="width:100%; color:#ef4444;"
                        data-confirm="Reject these results?"
                        data-confirm-title="Reject Results"
                        data-confirm-ok="Reject">
                        ❌ Reject
                    </button>
                </form>
            </div>
        </div>

        <% } else if (isSubjectTeacher && exam.subjectTeacherApprovalStatus === 'approved') { %>
        <div class="card" style="border:1px solid rgba(34,197,94,.3);">
            <div class="card-body">
                <p style="color:#22c55e; font-size:14px; font-weight:600;">✅ You have approved these results.</p>
                <p style="font-size:13px; color:var(--text-muted);">The class teacher can now give final approval and set the publish date.</p>
            </div>
        </div>
        <!-- Allow subject teacher to rescind approval if class teacher hasn't acted yet -->
        <% if (exam.resultApprovalStatus === 'pending') { %>
        <div class="card" style="border:1px solid rgba(239,68,68,.2);">
            <div class="card-header"><div class="card-title" style="color:#ef4444;">↩ Rescind Approval</div></div>
            <div class="card-body">
                <form action="/teacher/exams/<%= exam._id %>/subject-approve" method="POST">
                    <input type="hidden" name="action" value="reject">
                    <div class="form-group">
                        <label class="form-label">Reason</label>
                        <textarea name="rejectionReason" class="form-control" rows="2" placeholder="Why are you rescinding…"></textarea>
                    </div>
                    <button type="submit" class="btn btn-secondary" style="width:100%; color:#ef4444;"
                        data-confirm="Rescind your approval?"
                        data-confirm-title="Rescind Approval"
                        data-confirm-ok="Rescind">
                        ↩ Rescind Approval
                    </button>
                </form>
            </div>
        </div>
        <% } %>

        <% } else if (isSubjectTeacher && exam.subjectTeacherApprovalStatus === 'rejected') { %>
        <div class="card" style="border:1px solid rgba(239,68,68,.2);">
            <div class="card-body">
                <p style="color:#ef4444; font-size:14px; font-weight:600;">❌ You rejected these results.</p>
                <p style="font-size:13px; color:var(--text-muted);"><%= exam.subjectTeacherRejectionReason || '' %></p>
            </div>
        </div>
        <div class="card" style="border:1px solid rgba(34,197,94,.3);">
            <div class="card-header"><div class="card-title" style="color:#22c55e;">↩ Re-approve</div></div>
            <div class="card-body">
                <form action="/teacher/exams/<%= exam._id %>/subject-approve" method="POST">
                    <input type="hidden" name="action" value="approve">
                    <button type="submit" class="btn btn-primary" style="width:100%;"
                        data-confirm="Re-approve results?"
                        data-confirm-title="Re-approve Results"
                        data-confirm-type="warning"
                        data-confirm-ok="Re-approve">
                        ✅ Re-approve Results
                    </button>
                </form>
            </div>
        </div>

        <% } else if (isClassTeacher && exam.subjectTeacherApprovalStatus === 'approved' && exam.resultApprovalStatus === 'pending') { %>
        <!-- Class teacher: final approval -->
        <div class="card" style="border:1px solid rgba(34,197,94,.3);">
            <div class="card-header"><div class="card-title" style="color:#22c55e;">✅ Step 2 — Final Approval & Publish Date</div></div>
            <div class="card-body">
                <form action="/teacher/exams/<%= exam._id %>/result-approval" method="POST">
                    <input type="hidden" name="action" value="approve">
                    <div class="form-group">
                        <label class="form-label">Result Publication Date *</label>
                        <input type="date" name="publishDate" class="form-control" required
                            min="<%= new Date().toISOString().split('T')[0] %>">
                        <small style="color:var(--text-muted); font-size:11px;">Students and parents can view results on or after this date.</small>
                    </div>
                    <button type="submit" class="btn btn-primary" style="width:100%;"
                        data-confirm="Approve and publish results on the selected date?"
                        data-confirm-title="Approve & Publish"
                        data-confirm-type="warning"
                        data-confirm-ok="Approve">
                        ✅ Approve & Set Publish Date
                    </button>
                </form>
            </div>
        </div>

        <div class="card" style="border:1px solid rgba(239,68,68,.2);">
            <div class="card-header"><div class="card-title" style="color:#ef4444;">❌ Reject</div></div>
            <div class="card-body">
                <form action="/teacher/exams/<%= exam._id %>/result-approval" method="POST">
                    <input type="hidden" name="action" value="reject">
                    <div class="form-group">
                        <label class="form-label">Reason for Rejection</label>
                        <textarea name="rejectionReason" class="form-control" rows="3" placeholder="Optional reason…"></textarea>
                    </div>
                    <button type="submit" class="btn btn-secondary" style="width:100%; color:#ef4444;"
                        data-confirm="Reject these results?"
                        data-confirm-title="Reject Results"
                        data-confirm-ok="Reject">
                        ❌ Reject Results
                    </button>
                </form>
            </div>
        </div>

        <% } else if (isClassTeacher && exam.resultApprovalStatus === 'approved') { %>
        <div class="card" style="border:1px solid rgba(34,197,94,.3);">
            <div class="card-body">
                <p style="color:#22c55e; font-size:14px; font-weight:600;">✅ Final approval done.</p>
                <p style="font-size:13px; color:var(--text-muted);">Students can view results from <strong><%= exam.resultPublishDate ? new Date(exam.resultPublishDate).toDateString() : '—' %></strong>.</p>
            </div>
        </div>

        <% } else if (isClassTeacher && exam.subjectTeacherApprovalStatus !== 'approved') { %>
        <div class="card">
            <div class="card-body">
                <p style="font-size:14px; color:var(--text-muted);">⏳ Waiting for the subject teacher to complete Step 1 approval before you can take action.</p>
            </div>
        </div>

        <% } %>
    </div>
</div>
