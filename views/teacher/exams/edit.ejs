<div class="page-header">
    <div>
        <h1>✏️ Edit Exam Configuration</h1>
        <p>Changes apply immediately. Students will see the updated schedule.</p>
    </div>
    <a href="/teacher/exams/<%= exam._id %>/questions" class="btn btn-secondary">← Back to Questions</a>
</div>

<% if (errors && errors.length > 0) { %>
<div class="card" style="border-color:#ef4444; margin-bottom:16px;">
    <div class="card-body">
        <% errors.forEach(e => { %><p style="color:#ef4444; margin:4px 0;">❌ <%= e %></p><% }) %>
    </div>
</div>
<% } %>

<div class="card">
    <div class="card-header">
        <div class="card-title">Exam Details</div>
    </div>
    <div class="card-body">
        <form action="/teacher/exams/<%= exam._id %>/edit" method="POST">

            <div class="form-group">
                <label class="form-label">Exam Title *</label>
                <input type="text" name="title" class="form-control"
                    value="<%= exam.title || '' %>" required>
            </div>

            <div class="form-group">
                <label class="form-label">Section</label>
                <input type="text" class="form-control"
                    value="<%= exam.section?.class?.className %> – Section <%= exam.section?.sectionName %>"
                    disabled style="opacity:.6;">
                <small style="color:var(--text-muted); font-size:11px;">Section cannot be changed after creation.</small>
            </div>

            <div class="form-group">
                <label class="form-label">Subject (optional)</label>
                <select name="subjectId" class="form-control">
                    <option value="">— None —</option>
                    <% (subjects || []).forEach(s => { %>
                    <option value="<%= s._id %>" <%= (exam.subject?._id?.toString() || exam.subject?.toString()) === s._id.toString() ? 'selected' : '' %>>
                        <%= s.subjectName %> (<%= s.subjectCode %>)
                    </option>
                    <% }) %>
                </select>
            </div>

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
                <div class="form-group">
                    <label class="form-label">Exam Date *</label>
                    <input type="date" name="examDate" class="form-control"
                        value="<%= exam.examDate ? new Date(exam.examDate).toISOString().split('T')[0] : '' %>" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Start Time *</label>
                    <input type="time" name="startTime" class="form-control"
                        value="<%= exam.startTime || '09:00' %>" required>
                </div>
            </div>

            <div style="display:grid; grid-template-columns:1fr 1fr 1fr 1fr; gap:16px;">
                <div class="form-group">
                    <label class="form-label">Duration (minutes) *</label>
                    <input type="number" name="duration" class="form-control" min="1"
                        value="<%= exam.duration || '' %>" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Total Questions *</label>
                    <input type="number" name="totalQuestions" class="form-control" min="1"
                        value="<%= exam.totalQuestions || '' %>" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Total Marks *</label>
                    <input type="number" name="totalMarks" class="form-control" min="1" step="0.5"
                        value="<%= exam.totalMarks || '' %>" required>
                    <small style="color:var(--text-muted); font-size:11px;">Must equal the sum of all question marks.</small>
                </div>
                <div class="form-group">
                    <label class="form-label">Max Violations (auto-submit)</label>
                    <input type="number" name="maxViolations" class="form-control" min="1" max="20"
                        value="<%= exam.maxViolations || 3 %>">
                </div>
            </div>

            <div style="margin-top:8px; display:flex; gap:10px; align-items:center;">
                <button type="submit" class="btn btn-primary">💾 Save Changes</button>
                <a href="/teacher/exams/<%= exam._id %>/questions" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
