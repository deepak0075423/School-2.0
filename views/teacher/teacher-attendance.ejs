<div class="page-header">
    <div>
        <h1>🗓️ My Attendance</h1>
        <p>Track and manage your own attendance record</p>
    </div>
    <div style="display:flex; gap:10px;">
        <a href="/teacher/regularization" class="btn btn-secondary">📋 Regularization Requests <% if(pendingCount > 0) { %><span class="badge badge-red" style="margin-left:4px;"><%= pendingCount %></span><% } %></a>
        <a href="/teacher/dashboard" class="btn btn-secondary">← Dashboard</a>
    </div>
</div>

<!-- Monthly Stats -->
<div class="stats-grid" style="grid-template-columns: repeat(4, 1fr); margin-bottom:20px;">
    <div class="stat-card">
        <div class="stat-icon green">✅</div>
        <div class="stat-info">
            <div class="stat-value"><%= stats.present %></div>
            <div class="stat-label">Present</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon red">❌</div>
        <div class="stat-info">
            <div class="stat-value"><%= stats.absent %></div>
            <div class="stat-label">Absent</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon yellow">🌗</div>
        <div class="stat-info">
            <div class="stat-value"><%= stats.halfDay %></div>
            <div class="stat-label">Half-Day</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon purple">📅</div>
        <div class="stat-info">
            <div class="stat-value"><%= stats.leave %></div>
            <div class="stat-label">Leave</div>
        </div>
    </div>
</div>

<div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; align-items:start;">

    <!-- Mark Today's Attendance -->
    <div class="card">
        <div class="card-header">
            <div class="card-title">📌 Mark Today's Attendance</div>
        </div>
        <div class="card-body">
            <% if (todayRecord) { %>
                <div style="background: var(--bg-secondary, #1a1d2e); border-radius:10px; padding:16px; margin-bottom:16px; display:flex; align-items:center; gap:12px;">
                    <span style="font-size:28px;">
                        <% if(todayRecord.status === 'Present') { %>✅<% } else if(todayRecord.status === 'Absent') { %>❌<% } else if(todayRecord.status === 'Half-Day') { %>🌗<% } else { %>📅<% } %>
                    </span>
                    <div>
                        <div class="fw-semibold text-primary">Today: <strong><%= todayRecord.status %></strong></div>
                        <% if(todayRecord.remarks) { %><div class="text-muted" style="font-size:12px;"><%= todayRecord.remarks %></div><% } %>
                    </div>
                </div>
                <p class="text-muted" style="font-size:13px; margin-bottom:12px;">You can update today's attendance below.</p>
            <% } %>
            <form action="/teacher/my-attendance/mark" method="POST">
                <input type="hidden" name="date" value="<%= today %>">
                <div style="margin-bottom:16px;">
                    <label class="form-label">Status *</label>
                    <select name="status" class="form-control" required>
                        <option value="Present" <%=todayRecord && todayRecord.status==='Present' ? 'selected' : '' %>>✅ Present</option>
                        <option value="Absent" <%=todayRecord && todayRecord.status==='Absent' ? 'selected' : '' %>>❌ Absent</option>
                        <option value="Half-Day" <%=todayRecord && todayRecord.status==='Half-Day' ? 'selected' : '' %>>🌗 Half-Day</option>
                        <option value="Leave" <%=todayRecord && todayRecord.status==='Leave' ? 'selected' : '' %>>📅 Leave</option>
                    </select>
                </div>
                <div style="margin-bottom:16px;">
                    <label class="form-label">Remarks (optional)</label>
                    <input type="text" name="remarks" class="form-control" placeholder="e.g. Medical appointment"
                        value="<%= todayRecord ? todayRecord.remarks : '' %>">
                </div>
                <button type="submit" class="btn btn-primary" style="width:100%;">
                    <%= todayRecord ? '💾 Update' : '✅ Mark Attendance' %>
                </button>
            </form>
        </div>
    </div>

    <!-- Monthly Calendar -->
    <div class="card">
        <div class="card-header">
            <div class="card-title">📅 <%= monthYear %></div>
        </div>
        <div class="card-body">
            <div id="attendanceCalendar"></div>
            <div style="display:flex; gap:12px; flex-wrap:wrap; margin-top:16px; font-size:12px;">
                <span><span style="display:inline-block;width:12px;height:12px;border-radius:3px;background:#10b981;margin-right:4px;"></span>Present</span>
                <span><span style="display:inline-block;width:12px;height:12px;border-radius:3px;background:#ef4444;margin-right:4px;"></span>Absent</span>
                <span><span style="display:inline-block;width:12px;height:12px;border-radius:3px;background:#f59e0b;margin-right:4px;"></span>Half-Day</span>
                <span><span style="display:inline-block;width:12px;height:12px;border-radius:3px;background:#8b5cf6;margin-right:4px;"></span>Leave</span>
            </div>
        </div>
    </div>
</div>

<script>
(function() {
    const calMap = <%- calendarMap %>;
    const statusColors = { Present: '#10b981', Absent: '#ef4444', 'Half-Day': '#f59e0b', Leave: '#8b5cf6' };
    const statusBg    = { Present: 'rgba(16,185,129,0.15)', Absent: 'rgba(239,68,68,0.15)', 'Half-Day': 'rgba(245,158,11,0.15)', Leave: 'rgba(139,92,246,0.15)' };

    const now = new Date();
    const year = now.getFullYear();
    const month = now.getMonth();
    const firstDay = new Date(year, month, 1).getDay(); // 0=Sun
    const daysInMonth = new Date(year, month + 1, 0).getDate();
    const dayNames = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];

    let html = '<table style="width:100%; border-collapse:collapse; font-size:13px;">';
    html += '<thead><tr>';
    dayNames.forEach(d => { html += `<th style="padding:6px 2px; text-align:center; color:var(--text-muted,#94a3b8); font-weight:600; font-size:11px;">${d}</th>`; });
    html += '</tr></thead><tbody><tr>';

    for (let i = 0; i < firstDay; i++) html += '<td></td>';

    let col = firstDay;
    for (let day = 1; day <= daysInMonth; day++) {
        const dateStr = `${year}-${String(month+1).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
        const status = calMap[dateStr];
        const isToday = dateStr === '<%= today %>';
        const color = status ? statusColors[status] : 'transparent';
        const bg = status ? statusBg[status] : 'transparent';
        const border = isToday ? '2px solid #4f46e5' : `1px solid ${status ? color : 'var(--border,rgba(255,255,255,0.08))'}`;
        const title = status ? `${dateStr}: ${status}` : dateStr;

        html += `<td style="padding:3px; text-align:center;">
            <div title="${title}" style="
                width:32px; height:32px; border-radius:6px; margin:auto;
                display:flex; align-items:center; justify-content:center;
                font-size:12px; font-weight: ${isToday ? '700' : '400'};
                color:${status ? color : 'var(--text,#e2e8f0)'};
                background:${bg}; border:${border}; cursor:default;">
                ${day}
            </div>
        </td>`;

        col++;
        if (col === 7 && day < daysInMonth) { html += '</tr><tr>'; col = 0; }
    }
    html += '</tr></tbody></table>';
    document.getElementById('attendanceCalendar').innerHTML = html;
})();
</script>
