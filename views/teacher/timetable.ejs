<style>
.timetable-grid {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 20px;
}
.timetable-grid th, .timetable-grid td {
    border: 1px solid var(--border);
    padding: 12px;
    vertical-align: top;
    text-align: center;
}
.timetable-grid th {
    background-color: var(--sidebar-bg);
}
.subject-name {
    font-weight: 600;
    color: var(--primary);
    margin-bottom: 4px;
}
.class-info {
    font-size: 12px;
    color: var(--text-muted);
}
</style>

<div class="page-header" style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 20px;">
    <div>
        <h1>📅 Teacher Timetable</h1>
        <p>Viewing schedule for: <strong><%= targetTeacher.name %></strong></p>
    </div>
    
    <div style="display: flex; gap: 10px; align-items: center;">
        <form action="/teacher/timetable" method="GET" style="display: flex; gap: 8px;">
            <select name="searchTeacherId" class="form-control" required style="min-width: 200px;">
                <option value="">— Search Teacher —</option>
                <% allTeachers.forEach(t => { %>
                    <option value="<%= t._id %>" <%= searchTeacherId && searchTeacherId.toString() === t._id.toString() ? 'selected' : '' %>><%= t.name %></option>
                <% }) %>
            </select>
            <button type="submit" class="btn btn-secondary">Search</button>
        </form>
        <% if (searchTeacherId) { %>
            <a href="/teacher/timetable" class="btn btn-primary">My Timetable</a>
        <% } %>
    </div>
</div>

<div class="card" style="overflow-x: auto;">
    <div class="card-body">
        <% if (!entries || entries.length === 0) { %>
            <div class="empty-state">
                No periods assigned to this teacher yet.
            </div>
        <% } else { %>
            <!-- Since a teacher can have classes from multiple timetables with DIFFERENT structures (though rarely), 
                 we must build a generic grid from Day vs Period, up to max PeriodNumber. -->
            <% 
                let maxPeriod = 1;
                entries.forEach(e => {
                    if (e.periodNumber > maxPeriod) maxPeriod = e.periodNumber;
                });
            %>
            <table class="timetable-grid">
                <thead>
                    <tr>
                        <th>Day</th>
                        <% for(let i=1; i<=maxPeriod; i++) { %>
                            <th>Period <%= i %></th>
                        <% } %>
                    </tr>
                </thead>
                <tbody>
                    <% days.forEach(day => { %>
                        <tr>
                            <td style="font-weight: 600; vertical-align: middle;"><%= day %></td>
                            <% for(let i=1; i<=maxPeriod; i++) { %>
                                <% 
                                    const entry = entries.find(e => e.dayOfWeek === day && e.periodNumber === i); 
                                %>
                                <td>
                                    <% if (entry) { %>
                                        <div class="subject-name"><%= entry.subject?.subjectName %></div>
                                        <div class="class-info">
                                            <%= entry.timetable?.section?.class?.classNumber %> - <%= entry.timetable?.section?.sectionName %>
                                        </div>
                                    <% } else { %>
                                        <div style="color: var(--text-muted); font-size: 12px;">—</div>
                                    <% } %>
                                </td>
                            <% } %>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } %>
    </div>
</div>