<style>
.status-submitted { background:#ecfdf5; color:#065f46; border:1px solid #a7f3d0; }
.status-late      { background:#fef2f2; color:#991b1b; border:1px solid #fecaca; }
.status-pending   { background:#fefce8; color:#a16207; border:1px solid #fde68a; }
.status-badge { display:inline-block; padding:2px 10px; border-radius:10px; font-size:11px; font-weight:700; }
.review-modal { display:none; position:fixed; inset:0; background:rgba(0,0,0,.5); z-index:9999; align-items:center; justify-content:center; }
.review-modal.open { display:flex; }
.modal-box { background:var(--card-bg); border:1px solid var(--border); border-radius:14px; width:min(480px,92vw); padding:28px; }
</style>

<div class="page-header">
    <div>
        <h1 class="page-title">Submissions</h1>
        <p class="text-muted"><%= doc.title %></p>
    </div>
    <a href="/teacher/documents/<%= doc._id %>" class="btn btn-secondary">← Back to Document</a>
</div>

<!-- Stats -->
<div style="display:grid; grid-template-columns:repeat(4,1fr); gap:12px; margin-bottom:20px;">
    <div class="card"><div class="card-body" style="text-align:center; padding:16px;">
        <div style="font-size:28px; font-weight:700;"><%= stats.total %></div>
        <div class="text-muted" style="font-size:12px;">Total</div>
    </div></div>
    <div class="card"><div class="card-body" style="text-align:center; padding:16px;">
        <div style="font-size:28px; font-weight:700; color:#059669;"><%= stats.submitted %></div>
        <div class="text-muted" style="font-size:12px;">Submitted</div>
    </div></div>
    <div class="card"><div class="card-body" style="text-align:center; padding:16px;">
        <div style="font-size:28px; font-weight:700; color:#ef4444;"><%= stats.late %></div>
        <div class="text-muted" style="font-size:12px;">Late</div>
    </div></div>
    <div class="card"><div class="card-body" style="text-align:center; padding:16px;">
        <div style="font-size:28px; font-weight:700; color:#d97706;"><%= stats.pending %></div>
        <div class="text-muted" style="font-size:12px;">Pending</div>
    </div></div>
</div>

<% if (!submissions.length) { %>
<div class="card"><div class="card-body"><div class="empty-state"><p>No submissions yet.</p></div></div></div>
<% } else { %>
<div class="card">
    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>Student</th>
                    <th>Status</th>
                    <th>Submitted At</th>
                    <th>Files</th>
                    <th>Marks</th>
                    <th>Feedback</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% submissions.forEach(sub => { %>
                <tr>
                    <td><div class="fw-semibold"><%= sub.student ? sub.student.name : '—' %></div></td>
                    <td><span class="status-badge status-<%= sub.status %>"><%= sub.status %></span></td>
                    <td style="font-size:12px;">
                        <%= sub.submittedAt ? new Date(sub.submittedAt).toLocaleString('en-IN',{day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) : '—' %>
                    </td>
                    <td>
                        <% sub.files.forEach(f => { %>
                        <a href="<%= f.filePath %>" target="_blank" class="btn btn-sm btn-secondary" style="margin:1px; font-size:11px;">
                            📄 <%= f.originalName.length > 14 ? f.originalName.slice(0,14)+'…' : f.originalName %>
                        </a>
                        <% }) %>
                    </td>
                    <td style="font-size:13px;">
                        <% if (sub.marks !== null && sub.marks !== undefined) { %>
                        <strong><%= sub.marks %><%= doc.totalMarks ? '/' + doc.totalMarks : '' %></strong>
                        <% } else { %><span class="text-muted">—</span><% } %>
                    </td>
                    <td style="font-size:12px; max-width:160px;">
                        <span title="<%= sub.feedback %>"><%= sub.feedback ? sub.feedback.slice(0,40) + (sub.feedback.length > 40 ? '…' : '') : '—' %></span>
                    </td>
                    <td>
                        <button onclick="openReview('<%= sub._id %>', '<%= sub.marks !== null ? sub.marks : '' %>', `<%= sub.feedback.replace(/`/g, '') %>`)"
                                class="btn btn-sm btn-primary">Review</button>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>
<% } %>

<!-- Review Modal -->
<div class="review-modal" id="reviewModal">
    <div class="modal-box">
        <h3 style="margin:0 0 16px;">Review Submission</h3>
        <form method="POST" id="reviewForm">
            <div class="form-group">
                <label class="form-label">Marks <% if (doc.totalMarks) { %>(out of <%= doc.totalMarks %>)<% } %></label>
                <input type="number" name="marks" id="reviewMarks" class="form-control" min="0"
                       max="<%= doc.totalMarks || '' %>" placeholder="Optional" />
            </div>
            <div class="form-group">
                <label class="form-label">Feedback</label>
                <textarea name="feedback" id="reviewFeedback" class="form-control" rows="3"
                          placeholder="Optional feedback for the student…"></textarea>
            </div>
            <div style="display:flex; gap:10px; justify-content:flex-end; margin-top:16px;">
                <button type="button" onclick="closeReview()" class="btn btn-secondary">Cancel</button>
                <button type="submit" class="btn btn-primary">Save Review</button>
            </div>
        </form>
    </div>
</div>

<script>
function openReview(subId, marks, feedback) {
    document.getElementById('reviewForm').action = `/teacher/documents/submissions/${subId}/review`;
    document.getElementById('reviewMarks').value    = marks;
    document.getElementById('reviewFeedback').value = feedback;
    document.getElementById('reviewModal').classList.add('open');
}
function closeReview() {
    document.getElementById('reviewModal').classList.remove('open');
}
document.getElementById('reviewModal').addEventListener('click', e => {
    if (e.target === document.getElementById('reviewModal')) closeReview();
});
</script>
