<style>
.drop-zone { border:2px dashed var(--border); border-radius:10px; padding:32px; text-align:center; cursor:pointer; transition:border-color .15s; }
.drop-zone:hover, .drop-zone.drag-over { border-color:var(--primary); }
.file-preview-list { list-style:none; padding:0; margin:10px 0 0; }
.file-preview-list li { display:flex; align-items:center; gap:8px; padding:6px 10px; background:var(--input-bg); border-radius:6px; margin-bottom:6px; font-size:13px; }
.file-preview-list .remove-file { cursor:pointer; color:#ef4444; margin-left:auto; font-size:16px; }
.section-check-group { max-height:260px; overflow-y:auto; border:1px solid var(--border); border-radius:8px; padding:10px; }
</style>

<div class="page-header">
    <div>
        <h1 class="page-title"><%= editDoc ? 'Edit Document' : 'Upload Document' %></h1>
        <p class="text-muted">Share files with your assigned classes</p>
    </div>
    <a href="/teacher/documents" class="btn btn-secondary">← Back</a>
</div>

<% if (!allowedSections.length) { %>
<div class="card">
    <div class="card-body">
        <div class="empty-state">
            <p>You are not assigned to any class sections. Please contact your school admin.</p>
        </div>
    </div>
</div>
<% } else { %>

<form method="POST" action="<%= editDoc ? '/teacher/documents/' + editDoc._id + '/edit' : '/teacher/documents/upload' %>"
      enctype="multipart/form-data">

<div style="display:grid; grid-template-columns:1fr 340px; gap:20px;">

<!-- Left -->
<div style="display:flex; flex-direction:column; gap:16px;">
    <div class="card">
        <div class="card-header"><h2 class="card-title">Document Details</h2></div>
        <div class="card-body">
            <div class="form-group">
                <label class="form-label">Title <span style="color:#ef4444;">*</span></label>
                <input type="text" name="title" class="form-control" required
                       value="<%= editDoc ? editDoc.title : '' %>" placeholder="e.g. Chapter 3 Assignment" />
            </div>
            <div class="form-group">
                <label class="form-label">Description</label>
                <textarea name="description" class="form-control" rows="2"><%= editDoc ? editDoc.description : '' %></textarea>
            </div>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
                <div class="form-group">
                    <label class="form-label">Category <span style="color:#ef4444;">*</span></label>
                    <select name="category" class="form-control" required>
                        <% ['Assignment','Notes','Circular','Report','Other'].forEach(c => { %>
                        <option value="<%= c %>" <%= editDoc && editDoc.category === c ? 'selected' : '' %>><%= c %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Subject</label>
                    <input type="text" name="subject" class="form-control"
                           value="<%= editDoc ? editDoc.subject : '' %>" />
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Tags (comma-separated)</label>
                <input type="text" name="tags" class="form-control"
                       value="<%= editDoc ? editDoc.tags.join(', ') : '' %>" placeholder="e.g. homework, ch3" />
            </div>
        </div>
    </div>

    <!-- Files -->
    <div class="card">
        <div class="card-header"><h2 class="card-title">Files <span style="color:#ef4444;">*</span></h2></div>
        <div class="card-body">
            <p class="text-muted" style="font-size:13px; margin-bottom:10px;">Supported: PDF, Word (.docx), Excel (.xlsx), Images. Max 20 MB each.</p>
            <div class="drop-zone" id="dropZone" onclick="document.getElementById('fileInput').click()">
                <div style="font-size:32px; margin-bottom:8px;">📎</div>
                <p style="margin:0; color:var(--text-secondary);">Drag & drop or click to browse</p>
            </div>
            <input type="file" id="fileInput" name="files" multiple
                   accept=".pdf,.doc,.docx,.xls,.xlsx,.jpg,.jpeg,.png,.gif,.webp" style="display:none;" />
            <ul class="file-preview-list" id="fileList"></ul>
            <% if (editDoc) { %>
            <div class="form-group" style="margin-top:12px;">
                <label class="form-label">Change Note</label>
                <input type="text" name="changeNote" class="form-control" placeholder="What changed?" />
            </div>
            <% } %>
        </div>
    </div>

    <!-- Assignment settings -->
    <div class="card">
        <div class="card-header" style="display:flex; justify-content:space-between; align-items:center;">
            <h2 class="card-title">Assignment Settings</h2>
            <label style="display:flex; align-items:center; gap:8px; cursor:pointer;">
                <input type="checkbox" name="isAssignment" id="isAssignmentCheck"
                       <%= editDoc && editDoc.isAssignment ? 'checked' : '' %> />
                <span style="font-size:13px;">This is an assignment</span>
            </label>
        </div>
        <div class="card-body" id="assignmentFields" style="<%= editDoc && editDoc.isAssignment ? '' : 'display:none' %>">
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
                <div class="form-group">
                    <label class="form-label">Due Date</label>
                    <input type="datetime-local" name="dueDate" class="form-control"
                           value="<%= editDoc && editDoc.dueDate ? new Date(editDoc.dueDate).toISOString().slice(0,16) : '' %>" />
                </div>
                <div class="form-group">
                    <label class="form-label">Total Marks (optional)</label>
                    <input type="number" name="totalMarks" class="form-control" min="0"
                           value="<%= editDoc && editDoc.totalMarks ? editDoc.totalMarks : '' %>" />
                </div>
            </div>
            <div style="display:flex; gap:20px;">
                <label style="display:flex; align-items:center; gap:8px; cursor:pointer; font-size:13px;">
                    <input type="checkbox" name="allowSubmission"
                           <%= !editDoc || editDoc.allowSubmission ? 'checked' : '' %> />
                    Allow file submissions
                </label>
                <label style="display:flex; align-items:center; gap:8px; cursor:pointer; font-size:13px;">
                    <input type="checkbox" name="marksEnabled"
                           <%= editDoc && editDoc.marksEnabled ? 'checked' : '' %> />
                    Enable marks
                </label>
            </div>
        </div>
    </div>
</div>

<!-- Right: Section targeting -->
<div>
    <div class="card">
        <div class="card-header"><h2 class="card-title">Share With</h2></div>
        <div class="card-body">
            <input type="hidden" name="targetType" value="class_sections" />
            <p class="text-muted" style="font-size:12px; margin-bottom:10px;">Select sections from your assigned classes:</p>
            <div class="section-check-group">
                <% allowedSections.forEach(({ section, isClassTeacher, subjects }) => { %>
                <label style="display:flex; align-items:flex-start; gap:8px; padding:6px 0; cursor:pointer; border-bottom:1px solid var(--border);">
                    <input type="checkbox" name="targetSections" value="<%= section._id %>"
                           style="margin-top:2px;"
                           <%= editDoc && editDoc.targetSections && editDoc.targetSections.some(s => s.toString() === section._id.toString()) ? 'checked' : '' %> />
                    <div>
                        <div style="font-size:13px; font-weight:600;">
                            <%= section.class ? `Class ${section.class.classNumber} — ${section.class.className}` : '' %>
                            Section <%= section.sectionName %>
                        </div>
                        <div class="text-muted" style="font-size:11px;">
                            <%= isClassTeacher ? 'Class Teacher' : 'Subject Teacher' %>
                            <% if (!isClassTeacher && subjects.length) { %>
                            · <%= subjects.map(s => s.name || s).join(', ') %>
                            <% } %>
                        </div>
                    </div>
                </label>
                <% }) %>
            </div>
        </div>
    </div>

    <button type="submit" class="btn btn-primary" style="width:100%; margin-top:16px;">
        <%= editDoc ? 'Update Document' : 'Upload & Share' %>
    </button>
</div>

</div>
</form>
<% } %>

<script>
document.getElementById('isAssignmentCheck') && document.getElementById('isAssignmentCheck').addEventListener('change', function () {
    document.getElementById('assignmentFields').style.display = this.checked ? '' : 'none';
});

const dropZone  = document.getElementById('dropZone');
const fileInput = document.getElementById('fileInput');
const fileList  = document.getElementById('fileList');
let selectedFiles = [];

function renderFileList() {
    fileList.innerHTML = '';
    selectedFiles.forEach((f, i) => {
        const li = document.createElement('li');
        li.innerHTML = `<span>📄</span><span>${f.name}</span><span class="text-muted">(${(f.size/1024).toFixed(1)} KB)</span><span class="remove-file" data-idx="${i}">✕</span>`;
        fileList.appendChild(li);
    });
}

function mergeFiles(newFiles) {
    const names = new Set(selectedFiles.map(f => f.name));
    for (const f of newFiles) { if (!names.has(f.name)) selectedFiles.push(f); }
    const dt = new DataTransfer(); selectedFiles.forEach(f => dt.items.add(f)); fileInput.files = dt.files;
    renderFileList();
}

dropZone && dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
dropZone && dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
dropZone && dropZone.addEventListener('drop', e => { e.preventDefault(); dropZone.classList.remove('drag-over'); mergeFiles([...e.dataTransfer.files]); });
fileInput && fileInput.addEventListener('change', () => mergeFiles([...fileInput.files]));
fileList && fileList.addEventListener('click', e => {
    if (e.target.classList.contains('remove-file')) {
        selectedFiles.splice(Number(e.target.dataset.idx), 1);
        const dt = new DataTransfer(); selectedFiles.forEach(f => dt.items.add(f)); fileInput.files = dt.files;
        renderFileList();
    }
});
</script>
