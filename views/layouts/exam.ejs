<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | <%= appName %></title>
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>📝</text></svg>" />
    <style>
        * { box-sizing: border-box; }
        body { margin: 0; background: var(--bg, #0f1117); color: var(--text, #e2e8f0); font-family: system-ui, sans-serif; }

        .exam-shell { display: flex; flex-direction: column; min-height: 100vh; }

        /* ── Top bar ── */
        .exam-topbar {
            position: sticky; top: 0; z-index: 100;
            display: flex; align-items: center; justify-content: space-between;
            padding: 10px 20px;
            background: var(--card-bg, #1a1d2e);
            border-bottom: 1px solid var(--border, #2a2d3e);
            gap: 16px;
        }
        .exam-topbar-title { font-weight: 700; font-size: 15px; flex: 1; min-width: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .exam-timer {
            font-size: 22px; font-weight: 800; font-variant-numeric: tabular-nums;
            background: rgba(59,130,246,.12); border: 1px solid rgba(59,130,246,.3);
            border-radius: 10px; padding: 6px 18px; color: #3b82f6;
            letter-spacing: 2px; white-space: nowrap;
        }
        .exam-timer.warning { color: #f59e0b; border-color: rgba(245,158,11,.4); background: rgba(245,158,11,.08); }
        .exam-timer.danger  { color: #ef4444; border-color: rgba(239,68,68,.4);   background: rgba(239,68,68,.08); animation: timerPulse 1s ease infinite; }

        @keyframes timerPulse { 0%,100% { opacity:1; } 50% { opacity:.6; } }

        /* ── Body layout ── */
        .exam-body { display: flex; flex: 1; overflow: hidden; }

        /* ── Question panel ── */
        .exam-question-panel {
            flex: 1; overflow-y: auto; padding: 24px;
            display: flex; flex-direction: column; gap: 24px;
        }

        /* ── Sidebar palette ── */
        .exam-palette {
            width: 220px; flex-shrink: 0;
            background: var(--card-bg, #1a1d2e);
            border-left: 1px solid var(--border, #2a2d3e);
            padding: 16px; overflow-y: auto;
            display: flex; flex-direction: column; gap: 12px;
        }
        .palette-title { font-size: 12px; font-weight: 700; color: var(--text-muted, #94a3b8); text-transform: uppercase; letter-spacing: .06em; }
        .palette-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 6px; }
        .palette-btn {
            aspect-ratio: 1; border-radius: 8px; border: 1px solid var(--border, #2a2d3e);
            background: var(--bg, #0f1117); color: var(--text, #e2e8f0);
            font-size: 12px; font-weight: 600; cursor: pointer; transition: all .15s;
            display: flex; align-items: center; justify-content: center;
        }
        .palette-btn.answered  { background: #22c55e20; border-color: #22c55e; color: #22c55e; }
        .palette-btn.current   { background: rgba(59,130,246,.25); border-color: #3b82f6; color: #3b82f6; }
        .palette-btn.skipped   { background: rgba(245,158,11,.1); border-color: #f59e0b60; color: #f59e0b; }
        .palette-legend { display: flex; flex-direction: column; gap: 6px; }
        .legend-row { display: flex; align-items: center; gap: 8px; font-size: 11px; color: var(--text-muted, #94a3b8); }
        .legend-dot { width: 10px; height: 10px; border-radius: 3px; flex-shrink: 0; }

        /* ── Question card ── */
        .question-card {
            background: var(--card-bg, #1a1d2e);
            border: 1px solid var(--border, #2a2d3e);
            border-radius: 16px; padding: 24px;
        }
        .question-meta { font-size: 12px; color: var(--text-muted, #94a3b8); margin-bottom: 12px; display: flex; gap: 12px; align-items: center; }
        .question-type-badge {
            padding: 2px 10px; border-radius: 99px; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .04em;
            background: rgba(139,92,246,.15); color: #a78bfa; border: 1px solid rgba(139,92,246,.3);
        }
        .question-text { font-size: 17px; font-weight: 600; line-height: 1.6; margin-bottom: 20px; }
        .options-list { display: flex; flex-direction: column; gap: 10px; }
        .option-label {
            display: flex; align-items: center; gap: 14px;
            background: var(--bg, #0f1117); border: 1.5px solid var(--border, #2a2d3e);
            border-radius: 12px; padding: 12px 16px; cursor: pointer; transition: all .15s;
        }
        .option-label:hover { border-color: #3b82f6; background: rgba(59,130,246,.05); }
        .option-label.selected { border-color: #3b82f6; background: rgba(59,130,246,.12); }
        .option-label input { display: none; }
        .option-indicator {
            width: 22px; height: 22px; border-radius: 50%; border: 2px solid var(--border, #2a2d3e);
            flex-shrink: 0; display: flex; align-items: center; justify-content: center;
            font-size: 11px; font-weight: 700; transition: all .15s;
        }
        .option-label.selected .option-indicator { background: #3b82f6; border-color: #3b82f6; color: #fff; }
        .option-text { font-size: 15px; line-height: 1.4; }

        /* Multiple correct hint */
        .multiple-hint { font-size: 12px; color: #f59e0b; background: rgba(245,158,11,.08); border: 1px solid rgba(245,158,11,.2); border-radius: 8px; padding: 8px 12px; margin-bottom: 12px; }

        /* ── Navigation ── */
        .exam-nav { display: flex; align-items: center; justify-content: space-between; padding: 16px 24px; background: var(--card-bg, #1a1d2e); border-top: 1px solid var(--border, #2a2d3e); }
        .exam-nav-info { font-size: 13px; color: var(--text-muted, #94a3b8); }

        /* ── Submit modal ── */
        .modal-overlay {
            display: none; position: fixed; inset: 0; background: rgba(0,0,0,.6); z-index: 9999;
            align-items: center; justify-content: center;
        }
        .modal-overlay.open { display: flex; }
        .modal-box {
            background: var(--card-bg, #1a1d2e); border: 1px solid var(--border, #2a2d3e);
            border-radius: 18px; padding: 32px; width: min(460px, 92vw);
            box-shadow: 0 24px 64px rgba(0,0,0,.6);
        }
        .modal-title { font-size: 20px; font-weight: 700; margin-bottom: 12px; }
        .modal-body  { font-size: 14px; color: var(--text-muted, #94a3b8); line-height: 1.6; margin-bottom: 24px; }
        .modal-actions { display: flex; gap: 12px; justify-content: flex-end; }

        /* ── Violation modal ── */
        .violation-overlay {
            display: none; position: fixed; inset: 0; background: rgba(239,68,68,.18); z-index: 10000;
            align-items: center; justify-content: center;
        }
        .violation-overlay.open { display: flex; }
        .violation-box {
            background: var(--card-bg, #1a1d2e); border: 2px solid #ef4444;
            border-radius: 18px; padding: 32px; width: min(420px, 92vw); text-align: center;
        }
        .violation-icon { font-size: 48px; margin-bottom: 12px; }
        .violation-title { font-size: 20px; font-weight: 700; color: #ef4444; margin-bottom: 8px; }
        .violation-msg   { font-size: 14px; color: var(--text-muted, #94a3b8); margin-bottom: 20px; }

        @media (max-width: 640px) {
            .exam-palette { display: none; }
            .exam-timer { font-size: 16px; padding: 6px 12px; }
        }
    </style>
</head>
<body>
<div class="exam-shell">
    <%- body %>
</div>
</body>
</html>
