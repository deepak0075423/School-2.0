        </div>
    </div>
    <script src="/js/main.js"></script>

    <% if (session && session.userId) { %>

    <!-- Notification Detail Modal -->
    <div id="notifDetailModal" onclick="if(event.target===this)this.style.display='none'"
         style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:100000;
                align-items:center;justify-content:center;">
        <div style="background:var(--card-bg,#1a1d2e);border:1px solid var(--border,#2a2d3e);
                    border-radius:16px;width:min(520px,92vw);max-height:82vh;overflow-y:auto;
                    padding:28px;position:relative;box-shadow:0 24px 64px rgba(0,0,0,.6);">
            <button onclick="document.getElementById('notifDetailModal').style.display='none'"
                style="position:absolute;top:14px;right:14px;background:none;border:none;
                       cursor:pointer;color:var(--text-muted,#94a3b8);font-size:22px;line-height:1;
                       opacity:.7;" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity=.7">×</button>
            <div style="font-size:11px;color:#3b82f6;font-weight:600;text-transform:uppercase;
                        letter-spacing:.06em;margin-bottom:10px;">🔔 Notification</div>
            <div id="ndTitle" style="font-weight:700;font-size:18px;color:var(--text,#e2e8f0);
                                     margin-bottom:8px;padding-right:28px;line-height:1.4;"></div>
            <div id="ndMeta"  style="font-size:12px;color:var(--text-muted,#94a3b8);margin-bottom:20px;"></div>
            <div id="ndBody"  style="font-size:14px;color:var(--text,#e2e8f0);line-height:1.8;
                                     border-top:1px solid var(--border,#2a2d3e);padding-top:18px;
                                     white-space:pre-wrap;word-break:break-word;"></div>
        </div>
    </div>

    <!-- Toast container -->
    <div id="toastContainer" style="position:fixed;bottom:24px;right:24px;z-index:99999;display:flex;flex-direction:column;gap:10px;pointer-events:none;"></div>

    <script>
    /* ════════════════════════════════════════════════════════════
       NOTIFICATION SYSTEM  — SSE + BroadcastChannel + Browser API
    ════════════════════════════════════════════════════════════ */

    /* ── Helpers ─────────────────────────────────────────────── */
    function escHtml(s){ return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
    function roleIcon(r){ return {super_admin:'👑',school_admin:'🛡️',teacher:'👨‍🏫'}[r]||'🔔'; }
    function timeAgo(d){
        const m=Math.floor((Date.now()-new Date(d))/60000);
        if(m<1)return'Just now'; if(m<60)return m+'m ago';
        const h=Math.floor(m/60); if(h<24)return h+'h ago';
        return Math.floor(h/24)+'d ago';
    }

    /* ── Bell state ──────────────────────────────────────────── */
    let bellOpen=false, bellLoaded=false, _unreadLocal=<%= _unreadCount %>;
    const _notifMap = {};  // receiptId → notification object for detail modal

    function setBadge(n){
        const b=document.getElementById('bellBadge');
        _unreadLocal=n;
        if(n>0){ b.style.display='flex'; b.textContent=n>9?'9+':n; }
        else    { b.style.display='none'; }
        // Also update the "(X unread)" text inside the open dropdown
        const countEl=document.getElementById('dropUnreadCount');
        if(countEl) countEl.textContent=n>0?'('+n+' unread)':'';
    }
    function incrementBadge(){ setBadge(_unreadLocal+1); }

    function toggleBell(e){
        e.stopPropagation();
        bellOpen=!bellOpen;
        document.getElementById('bellDropdown').style.display=bellOpen?'block':'none';
        if(bellOpen && !bellLoaded) loadBell();
        if(bellOpen) _checkNotifPermission();
    }

    function _checkNotifPermission(){
        const banner=document.getElementById('notifPermBanner');
        if(!banner || !('Notification' in window)) return;
        const perm=Notification.permission;
        if(perm==='granted'){
            banner.style.display='none';
        } else if(perm==='denied'){
            banner.style.display='block';
            banner.innerHTML='<span style="font-size:11px;color:#f59e0b;">⚠️ Browser alerts blocked — enable in browser site settings</span>';
        } else {
            // 'default' — not asked yet, show a button
            banner.style.display='block';
            banner.innerHTML='<button onclick="_requestNotifPerm()" '+
                'style="font-size:11px;background:rgba(59,130,246,.15);border:1px solid rgba(59,130,246,.4);'+
                'color:#3b82f6;border-radius:6px;padding:4px 10px;cursor:pointer;">'+
                '🔔 Enable browser alerts</button>';
        }
    }

    function _requestNotifPerm(){
        Notification.requestPermission().then(function(result){
            _checkNotifPermission();
        });
    }
    document.addEventListener('click',function(e){
        const w=document.getElementById('bellWrapper');
        if(w && !w.contains(e.target)){ bellOpen=false; document.getElementById('bellDropdown').style.display='none'; }
    });

    /* ── Render bell list ────────────────────────────────────── */
    function renderBell(data){
        const list=document.getElementById('bellList');
        const countEl=document.getElementById('dropUnreadCount');
        setBadge(data.unreadCount||0);
        countEl.textContent=data.unreadCount>0?'('+data.unreadCount+' unread)':'';
        if(!data.notifications||!data.notifications.length){
            list.innerHTML='<div style="padding:40px 20px;text-align:center;color:var(--text-muted,#94a3b8);font-size:13px;">🔕 No notifications</div>';
            return;
        }
        // Store for detail modal
        (data.notifications||[]).forEach(n=>{ _notifMap[n.receiptId]=n; });
        list.innerHTML=data.notifications.map(n=>`
            <div id="receipt-${n.receiptId}"
                 style="padding:14px 18px;border-bottom:1px solid var(--border,#2a2d3e);
                        background:${n.isRead?'transparent':'rgba(59,130,246,.06)'};transition:background .2s;">
              <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px;">
                <div onclick="showNotifDetail('${n.receiptId}')"
                     style="flex:1;min-width:0;cursor:pointer;">
                  <div style="display:flex;align-items:center;gap:6px;margin-bottom:4px;">
                    ${!n.isRead?'<span style="width:7px;height:7px;border-radius:50%;background:#3b82f6;flex-shrink:0;display:inline-block;"></span>':''}
                    <span style="font-weight:${n.isRead?'500':'700'};font-size:13px;color:var(--text,#e2e8f0);">${escHtml(n.title||'—')}</span>
                  </div>
                  <div style="font-size:12px;color:var(--text-muted,#94a3b8);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:220px;">${escHtml(n.body||'')}</div>
                  <div style="font-size:10px;color:var(--text-muted,#94a3b8);margin-top:4px;">${roleIcon(n.senderRole)} ${(n.senderRole||'').replace('_',' ')} &bull; ${timeAgo(n.createdAt)}</div>
                </div>
                <button onclick="clearOne('${n.receiptId}')" title="Dismiss"
                    style="background:none;border:none;cursor:pointer;color:var(--text-muted,#94a3b8);font-size:16px;padding:0 0 0 8px;flex-shrink:0;opacity:.6;"
                    onmouseover="this.style.opacity=1" onmouseout="this.style.opacity=.6">×</button>
              </div>
            </div>`).join('');
    }

    /* ── Notification Detail Modal ───────────────────────────── */
    function showNotifDetail(receiptId){
        const n=_notifMap[receiptId];
        if(!n) return;
        document.getElementById('ndTitle').textContent = n.title||'—';
        document.getElementById('ndMeta').textContent  =
            roleIcon(n.senderRole)+' '+(n.senderRole||'').replace(/_/g,' ')+'  ·  '+
            new Date(n.createdAt).toLocaleString('en-IN',{day:'numeric',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'});
        document.getElementById('ndBody').textContent  = n.body||'';
        document.getElementById('notifDetailModal').style.display='flex';
        // Mark as read on open
        if(!n.isRead){
            n.isRead=true;
            setBadge(Math.max(0,_unreadLocal-1));
            const el=document.getElementById('receipt-'+receiptId);
            if(el){
                el.style.background='transparent';
                // Remove blue unread dot
                const dot=el.querySelector('span[style*="border-radius:50%"]');
                if(dot) dot.remove();
                // Change title to normal weight
                const titleSpan=el.querySelector('span[style*="font-weight"]');
                if(titleSpan) titleSpan.style.fontWeight='500';
            }
            fetch('/notifications/api/'+receiptId+'/mark-read',{method:'POST'}).catch(()=>{});
        }
    }

    // Close modal on Escape key
    document.addEventListener('keydown',function(e){ if(e.key==='Escape') document.getElementById('notifDetailModal').style.display='none'; });

    function loadBell(){ bellLoaded=true; fetch('/notifications/api/inbox').then(r=>r.json()).then(renderBell).catch(()=>{}); }
    function markAllRead(){ fetch('/notifications/api/mark-all-read',{method:'POST'}).then(()=>loadBell()); }
    function clearAll(){
        fetch('/notifications/api/clear-all',{method:'POST'}).then(()=>{
            renderBell({unreadCount:0,notifications:[]}); bellLoaded=false;
        });
    }
    function clearOne(id){
        fetch('/notifications/api/'+id+'/clear',{method:'POST'}).then(()=>{
            const el=document.getElementById('receipt-'+id);
            if(el){ el.style.opacity='0'; el.style.transition='opacity .3s'; setTimeout(()=>el.remove(),300); }
            loadBell();
        });
    }

    /* ── Toast ───────────────────────────────────────────────── */
    function showToast(title, body, senderRole){
        const tc=document.getElementById('toastContainer');
        const t=document.createElement('div');
        t.style.cssText='pointer-events:auto;background:var(--card-bg,#1a1d2e);border:1px solid var(--border,#2a2d3e);'+
            'border-left:4px solid #3b82f6;border-radius:12px;padding:14px 16px;width:300px;'+
            'box-shadow:0 8px 32px rgba(0,0,0,.5);animation:slideInToast .3s ease;position:relative;';
        t.innerHTML=`
            <div style="font-weight:700;font-size:13px;color:var(--text,#e2e8f0);margin-bottom:4px;padding-right:20px;">🔔 ${escHtml(title)}</div>
            <div style="font-size:12px;color:var(--text-muted,#94a3b8);line-height:1.4;max-height:40px;overflow:hidden;">${escHtml(body)}</div>
            <div style="font-size:10px;color:#3b82f6;margin-top:6px;">${roleIcon(senderRole)} ${(senderRole||'').replace('_',' ')}</div>
            <button onclick="this.closest('div[style]').remove()"
                style="position:absolute;top:10px;right:10px;background:none;border:none;cursor:pointer;
                       color:var(--text-muted,#94a3b8);font-size:16px;line-height:1;">×</button>`;
        tc.appendChild(t);
        setTimeout(()=>{ t.style.animation='fadeOutToast .4s ease forwards'; setTimeout(()=>t.remove(),400); }, 5000);
    }

    /* ── Browser Notification (background tabs/windows) ─────── */
    function showBrowserNotification(title, body){
        if(!('Notification' in window) || Notification.permission !== 'granted') return;
        try {
            var n = new Notification(title, { body, icon: '/favicon.ico' });
            n.onerror = function(e){ console.error('[Notif] show error:', e); };
            n.onclick = function(){ window.focus(); n.close(); };
        } catch(e) { console.error('[Notif] create error:', e); }
    }


    /* ── Notification chime (Web Audio API — no audio file needed) ── */
    let _audioCtx=null;
    function _getAudioCtx(){
        if(!_audioCtx){
            try{ _audioCtx=new(window.AudioContext||window.webkitAudioContext)(); }catch{ return null; }
        }
        if(_audioCtx.state==='suspended') _audioCtx.resume().catch(()=>{});
        return _audioCtx;
    }
    // Warm up AudioContext on first user interaction (browser autoplay policy)
    document.addEventListener('click',function(){ _getAudioCtx(); },{once:true});

    function playNotifSound(){
        const ctx=_getAudioCtx();
        if(!ctx) return;
        try{
            // Two-tone chime: A5 then C#6
            [[880,0,0.28],[1108,0.16,0.32]].forEach(([freq,delay,dur])=>{
                const osc=ctx.createOscillator();
                const gain=ctx.createGain();
                osc.connect(gain);
                gain.connect(ctx.destination);
                osc.type='sine';
                osc.frequency.value=freq;
                const t=ctx.currentTime+delay;
                gain.gain.setValueAtTime(0,t);
                gain.gain.linearRampToValueAtTime(0.22,t+0.015);
                gain.gain.exponentialRampToValueAtTime(0.001,t+dur);
                osc.start(t);
                osc.stop(t+dur+0.05);
            });
        }catch{ /* ignore */ }
    }

    /* ── BroadcastChannel (cross-tab sync) ──────────────────── */
    let bc;
    try { bc=new BroadcastChannel('school_notif'); } catch{ bc=null; }

    function onNewNotification(data){
        incrementBadge();
        showToast(data.title, data.body, data.senderRole);
        if(bellOpen){ bellLoaded=false; loadBell(); }   // refresh open dropdown
        if(document.hidden){
            showBrowserNotification(data.title, data.body);
            playNotifSound();
        }
    }

    if(bc){
        bc.onmessage=function(e){
            if(e.data && e.data.type==='notification') onNewNotification(e.data.payload);
        };
    }

    /* ── SSE connection ──────────────────────────────────────── */
    let _sseOk = false;

    (function connectSSE(){
        if(!window.EventSource) return;  // very old browser — fall back to poll

        const es = new EventSource('/notifications/sse');

        es.addEventListener('connected', function(){
            _sseOk = true;
        });

        es.addEventListener('notification', function(e){
            try {
                const data = JSON.parse(e.data);
                onNewNotification(data);
                if(bc) bc.postMessage({type:'notification', payload:data});
            } catch { /* malformed JSON */ }
        });

        es.onerror = function(){
            _sseOk = false;
            // EventSource auto-reconnects natively — no manual retry needed
        };

        es.onopen = function(){
            _sseOk = true;
        };
    })();

    /* ── Polling fallback ────────────────────────────────────────
       Runs every 30 s. When SSE is live it just refreshes the badge.
       When SSE is blocked (nginx buffer issue, etc.) this is the
       sole delivery mechanism — 30 s lag is acceptable as backup.
    ─────────────────────────────────────────────────────────── */
    setInterval(function(){
        fetch('/notifications/api/inbox').then(r=>r.json()).then(function(data){
            setBadge(data.unreadCount||0);
            if(bellOpen) renderBell(data);
        }).catch(()=>{});
    }, 30000);

    </script>

    <style>
    @keyframes slideInToast {
        from { opacity:0; transform:translateX(40px); }
        to   { opacity:1; transform:translateX(0); }
    }
    @keyframes fadeOutToast {
        to { opacity:0; transform:translateX(40px); }
    }
    </style>
    <% } %>
</body>

</html>