<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        <%= title %> | <%= appName %>
    </title>
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="icon"
        href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🎓</text></svg>" />
</head>

<body>
    <div class="app-layout">
        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-logo">
                <div class="logo-icon">🎓</div>
                <div>
                    <div class="logo-text">
                        <%= appName %>
                    </div>
                    <% if (session && session.schoolName) { %>
                        <div class="logo-sub">
                            <%= session.schoolName %>
                        </div>
                        <% } %>
                </div>
            </div>

            <nav class="sidebar-nav">
                <%
                    // Resolve which modules this school has enabled.
                    // currentUser is set by loadUser middleware on every authenticated request.
                    const _schoolModules = (currentUser && currentUser.school && currentUser.school.modules) || {};
                    const _hasAttendance = !!_schoolModules.attendance;
                    const _path = (typeof locals !== 'undefined' && locals.title) ? title : '';
                %>

                <% if (session && session.userRole === 'super_admin') { %>
                    <div class="nav-section-label">Overview</div>
                    <a href="/super-admin/dashboard"
                        class="nav-item <%= _path.includes('Dashboard') ? 'active' : '' %>">
                        <span class="nav-icon">📊</span> Dashboard
                    </a>

                    <div class="nav-section-label">Management</div>
                    <a href="/super-admin/schools"
                        class="nav-item <%= _path.includes('School') ? 'active' : '' %>">
                        <span class="nav-icon">🏫</span> Schools
                    </a>
                    <a href="/super-admin/schools/create" class="nav-item">
                        <span class="nav-icon">🏗️</span> Add School
                    </a>
                    <a href="/super-admin/users"
                        class="nav-item <%= _path.includes('User') ? 'active' : '' %>">
                        <span class="nav-icon">👥</span> All Users
                    </a>
                    <a href="/super-admin/users/create" class="nav-item">
                        <span class="nav-icon">➕</span> Add User
                    </a>

                    <div class="nav-section-label">Settings</div>
                    <a href="/super-admin/permissions"
                        class="nav-item <%= _path.includes('Permission') ? 'active' : '' %>">
                        <span class="nav-icon">🔐</span> Module Permissions
                    </a>

                    <div class="nav-section-label">Communications</div>
                    <a href="/super-admin/notifications"
                        class="nav-item <%= _path.includes('Notification') ? 'active' : '' %>">
                        <span class="nav-icon">🔔</span> Notifications
                    </a>
                    <a href="/super-admin/notifications/create" class="nav-item">
                        <span class="nav-icon">📢</span> Send Notification
                    </a>

                <% } else if (session && session.userRole === 'school_admin') { %>
                    <div class="nav-section-label">Overview</div>
                    <a href="/admin/dashboard"
                        class="nav-item <%= _path === 'Admin Dashboard' ? 'active' : '' %>">
                        <span class="nav-icon">📊</span> Dashboard
                    </a>

                    <div class="nav-section-label">Staff & Students</div>
                    <a href="/admin/teachers"
                        class="nav-item <%= _path.includes('Teacher') ? 'active' : '' %>">
                        <span class="nav-icon">👨‍🏫</span> Teachers
                    </a>
                    <a href="/admin/teachers/create" class="nav-item">
                        <span class="nav-icon">➕</span> Add Teacher
                    </a>
                    <a href="/admin/students"
                        class="nav-item <%= _path.includes('Student') ? 'active' : '' %>">
                        <span class="nav-icon">🎒</span> Students
                    </a>
                    <a href="/admin/students/create" class="nav-item">
                        <span class="nav-icon">➕</span> Add Student
                    </a>

                    <div class="nav-section-label">Administration</div>
                    <a href="/admin/admins"
                        class="nav-item <%= _path.includes('Co-Admin') ? 'active' : '' %>">
                        <span class="nav-icon">🛡️</span> Co-Admins
                    </a>
                    <a href="/admin/admins/create" class="nav-item">
                        <span class="nav-icon">➕</span> Add Co-Admin
                    </a>

                    <% if (_hasAttendance) { %>
                    <div class="nav-section-label">Attendance</div>
                    <a href="/admin/regularization-requests"
                        class="nav-item <%= _path.includes('Regularization') ? 'active' : '' %>">
                        <span class="nav-icon">📋</span> Regularization
                    </a>
                    <% } %>

                    <div class="nav-section-label">Communications</div>
                    <a href="/admin/notifications"
                        class="nav-item <%= _path.includes('Notification') ? 'active' : '' %>">
                        <span class="nav-icon">🔔</span> Notifications
                    </a>
                    <a href="/admin/notifications/create" class="nav-item">
                        <span class="nav-icon">📢</span> Send Notification
                    </a>

                <% } else if (session && session.userRole === 'teacher') { %>
                    <div class="nav-section-label">Classroom</div>
                    <a href="/teacher/dashboard"
                        class="nav-item <%= _path.includes('Dashboard') ? 'active' : '' %>">
                        <span class="nav-icon">📊</span> Dashboard
                    </a>
                    <a href="/teacher/my-section"
                        class="nav-item <%= _path.includes('Section') ? 'active' : '' %>">
                        <span class="nav-icon">👥</span> My Section
                    </a>
                    <a href="/teacher/timetable"
                        class="nav-item <%= _path.includes('Timetable') ? 'active' : '' %>">
                        <span class="nav-icon">📅</span> Timetable
                    </a>

                    <div class="nav-section-label">Communications</div>
                    <a href="/teacher/notifications"
                        class="nav-item <%= _path.includes('Notification') ? 'active' : '' %>">
                        <span class="nav-icon">🔔</span> Notifications
                    </a>
                    <a href="/teacher/notifications/create" class="nav-item">
                        <span class="nav-icon">📢</span> Send Notification
                    </a>

                    <% if (_hasAttendance) { %>
                    <div class="nav-section-label">Attendance</div>
                    <a href="/teacher/attendance"
                        class="nav-item <%= _path === 'Attendance' ? 'active' : '' %>">
                        <span class="nav-icon">📋</span> Mark Attendance
                    </a>
                    <a href="/teacher/attendance-dashboard"
                        class="nav-item <%= _path.includes('Dashboard') && _path.includes('Attendance') ? 'active' : '' %>">
                        <span class="nav-icon">📊</span> Class Analytics
                    </a>
                    <a href="/teacher/my-attendance"
                        class="nav-item <%= _path.includes('My Attendance') ? 'active' : '' %>">
                        <span class="nav-icon">🗓️</span> My Attendance
                    </a>
                    <a href="/teacher/regularization"
                        class="nav-item <%= _path.includes('Regularization') ? 'active' : '' %>">
                        <span class="nav-icon">📝</span> Regularization
                    </a>
                    <a href="/teacher/correction-requests"
                        class="nav-item <%= _path.includes('Correction') ? 'active' : '' %>">
                        <span class="nav-icon">🔔</span> Correction Requests
                    </a>
                    <% } %>

                <% } else if (session && session.userRole === 'student') { %>
                    <div class="nav-section-label">My School</div>
                    <a href="/student/dashboard"
                        class="nav-item <%= _path.includes('Dashboard') ? 'active' : '' %>">
                        <span class="nav-icon">📊</span> Dashboard
                    </a>
                    <a href="/student/my-class"
                        class="nav-item <%= _path.includes('Class') ? 'active' : '' %>">
                        <span class="nav-icon">🏫</span> My Class
                    </a>

                    <% if (_hasAttendance) { %>
                    <div class="nav-section-label">Attendance</div>
                    <a href="/student/my-attendance"
                        class="nav-item <%= _path.includes('Attendance') ? 'active' : '' %>">
                        <span class="nav-icon">📅</span> My Attendance
                    </a>
                    <a href="/student/correction"
                        class="nav-item <%= _path.includes('Correction') ? 'active' : '' %>">
                        <span class="nav-icon">📝</span> Request Correction
                    </a>
                    <% } %>

                <% } else if (session && session.userRole === 'parent') { %>
                    <div class="nav-section-label">My Child</div>
                    <a href="/parent/dashboard"
                        class="nav-item <%= _path.includes('Dashboard') ? 'active' : '' %>">
                        <span class="nav-icon">📊</span> Dashboard
                    </a>
                    <a href="/parent/child-class"
                        class="nav-item <%= _path.includes('Child') && !_path.includes('Attendance') ? 'active' : '' %>">
                        <span class="nav-icon">🏫</span> Child's Class
                    </a>

                    <% if (_hasAttendance) { %>
                    <div class="nav-section-label">Attendance</div>
                    <a href="/parent/child-attendance"
                        class="nav-item <%= _path.includes('Attendance') ? 'active' : '' %>">
                        <span class="nav-icon">✅</span> Child's Attendance
                    </a>
                    <% } %>

                <% } %>
            </nav>

            <div class="sidebar-bottom">
                <div class="user-card">
                    <div class="user-avatar" style="overflow: hidden; display: flex; align-items: center; justify-content: center; background-color: #3b82f6; color: white;">
                        <% if (session && session.profileImage) { %>
                            <img src="<%= session.profileImage %>" alt="Profile" style="width: 100%; height: 100%; object-fit: cover; border-radius: 50%;" />
                        <% } else { %>
                            <%= session && session.userName ? session.userName.charAt(0).toUpperCase() : '?' %>
                        <% } %>
                    </div>
                    <div class="user-info">
                        <div class="user-name">
                            <%= session && session.userName %>
                        </div>
                        <div class="user-role">
                            <%= session && session.userRole ? session.userRole.replace('_', ' ' ) : '' %>
                        </div>
                    </div>
                </div>
                <a href="/profile" class="nav-item" style="margin-top:16px;">
                    <span class="nav-icon">👤</span> My Profile
                </a>
                <a href="/auth/logout" class="nav-item" style="margin-top:8px; color: #ef4444;">
                    <span class="nav-icon">🚪</span> Logout
                </a>
            </div>
        </aside>

        <!-- Main content -->
        <div class="main-content">
            <header class="topbar">
                <div class="d-flex align-center gap-3">
                    <button class="sidebar-toggle" id="sidebarToggle">☰</button>
                    <div class="topbar-title">
                        <h2>
                            <%= title %>
                        </h2>
                    </div>
                </div>
                <div class="topbar-actions">
                    <% if (session && session.schoolName) { %>
                        <div class="topbar-btn">🏫 <%= session.schoolName %></div>
                    <% } %>

                    <!-- ── Bell Icon ──────────────────────────────── -->
                    <% if (session && session.userId) { %>
                    <div style="position:relative;" id="bellWrapper">
                        <button id="bellBtn" onclick="toggleBell(event)"
                            style="position:relative; background:var(--card-bg,#1a1d2e); border:1px solid var(--border,#2a2d3e);
                                   border-radius:10px; padding:8px 12px; cursor:pointer; color:var(--text,#e2e8f0);
                                   font-size:18px; display:flex; align-items:center; gap:6px; transition:background .2s;">
                            🔔
                            <span id="bellBadge"
                                  style="display:<%= unreadNotificationCount > 0 ? 'flex' : 'none' %>;
                                         position:absolute; top:-6px; right:-6px; background:#ef4444; color:#fff;
                                         border-radius:50%; width:18px; height:18px; font-size:10px; font-weight:700;
                                         align-items:center; justify-content:center; line-height:1;">
                                <%= unreadNotificationCount > 9 ? '9+' : unreadNotificationCount %>
                            </span>
                        </button>

                        <!-- Dropdown panel -->
                        <div id="bellDropdown"
                             style="display:none; position:absolute; right:0; top:calc(100% + 8px); width:340px;
                                    background:var(--card-bg,#1a1d2e); border:1px solid var(--border,#2a2d3e);
                                    border-radius:14px; box-shadow:0 20px 60px rgba(0,0,0,.5); z-index:9999; overflow:hidden;">

                            <!-- Header -->
                            <div style="display:flex; align-items:center; justify-content:space-between;
                                        padding:14px 18px; border-bottom:1px solid var(--border,#2a2d3e);">
                                <span style="font-weight:700; font-size:14px; color:var(--text,#e2e8f0);">
                                    🔔 Notifications
                                    <span id="dropUnreadCount" style="font-size:11px; color:#3b82f6; margin-left:4px;"></span>
                                </span>
                                <div style="display:flex; gap:8px;">
                                    <button onclick="markAllRead()"
                                        style="font-size:11px; color:#3b82f6; background:none; border:none; cursor:pointer; padding:2px 6px;">
                                        ✓ Mark all read
                                    </button>
                                    <button onclick="clearAll()"
                                        style="font-size:11px; color:#94a3b8; background:none; border:none; cursor:pointer; padding:2px 6px;">
                                        🗑 Clear all
                                    </button>
                                </div>
                            </div>

                            <!-- Notification list -->
                            <div id="bellList" style="max-height:360px; overflow-y:auto;"></div>

                            <!-- Footer -->
                            <div style="padding:10px 18px; border-top:1px solid var(--border,#2a2d3e); text-align:center;">
                                <span style="font-size:11px; color:var(--text-muted,#94a3b8);">Only you can see and clear your notifications</span>
                            </div>
                        </div>
                    </div>
                    <% } %>

                    <a href="/auth/logout" class="topbar-btn">🚪 Logout</a>
                </div>
            </header>

            <main class="page-content">
                <% if (success && success.length> 0) { %>
                    <% success.forEach(msg=> { %>
                        <div class="alert alert-success">
                            ✅ <%- msg %>
                                <button class="alert-close">×</button>
                        </div>
                        <% }) %>
                            <% } %>
                                <% if (error && error.length> 0) { %>
                                    <% error.forEach(msg=> { %>
                                        <div class="alert alert-error">
                                            ❌ <%- msg %>
                                                <button class="alert-close">×</button>
                                        </div>
                                        <% }) %>
                                            <% } %>

                                                <%- body %>
            </main>
        </div>
    </div>
    <script src="/js/main.js"></script>

    <% if (session && session.userId) { %>
    <script>
    /* ── Bell Icon Logic ──────────────────────────────────────── */
    let bellOpen = false;
    let bellLoaded = false;

    function toggleBell(e) {
        e.stopPropagation();
        bellOpen = !bellOpen;
        document.getElementById('bellDropdown').style.display = bellOpen ? 'block' : 'none';
        if (bellOpen && !bellLoaded) loadBell();
    }

    document.addEventListener('click', function (e) {
        if (!document.getElementById('bellWrapper').contains(e.target)) {
            bellOpen = false;
            document.getElementById('bellDropdown').style.display = 'none';
        }
    });

    function roleIcon(role) {
        return { super_admin:'👑', school_admin:'🛡️', teacher:'👨‍🏫' }[role] || '🔔';
    }

    function timeAgo(dateStr) {
        const diff = Date.now() - new Date(dateStr);
        const mins  = Math.floor(diff / 60000);
        const hours = Math.floor(diff / 3600000);
        const days  = Math.floor(diff / 86400000);
        if (mins  < 1)   return 'Just now';
        if (mins  < 60)  return mins  + 'm ago';
        if (hours < 24)  return hours + 'h ago';
        return days + 'd ago';
    }

    function renderBell(data) {
        const list = document.getElementById('bellList');
        const badge = document.getElementById('bellBadge');
        const countEl = document.getElementById('dropUnreadCount');

        // Update badge
        if (data.unreadCount > 0) {
            badge.style.display = 'flex';
            badge.textContent = data.unreadCount > 9 ? '9+' : data.unreadCount;
        } else {
            badge.style.display = 'none';
        }
        countEl.textContent = data.unreadCount > 0 ? '(' + data.unreadCount + ' unread)' : '';

        if (!data.notifications || data.notifications.length === 0) {
            list.innerHTML = '<div style="padding:40px 20px; text-align:center; color:var(--text-muted,#94a3b8); font-size:13px;">🔕 No notifications</div>';
            return;
        }

        list.innerHTML = data.notifications.map(n => `
            <div id="receipt-${n.receiptId}"
                 style="padding:14px 18px; border-bottom:1px solid var(--border,#2a2d3e);
                        background:${n.isRead ? 'transparent' : 'rgba(59,130,246,.06)'};
                        transition:background .2s;">
                <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:8px;">
                    <div style="flex:1; min-width:0;">
                        <div style="display:flex; align-items:center; gap:6px; margin-bottom:4px;">
                            ${!n.isRead ? '<span style="width:7px;height:7px;border-radius:50%;background:#3b82f6;flex-shrink:0;display:inline-block;"></span>' : ''}
                            <span style="font-weight:${n.isRead ? '500' : '700'}; font-size:13px; color:var(--text,#e2e8f0);">
                                ${escHtml(n.title || '—')}
                            </span>
                        </div>
                        <div style="font-size:12px; color:var(--text-muted,#94a3b8); overflow:hidden; text-overflow:ellipsis; white-space:nowrap; max-width:220px;">
                            ${escHtml(n.body || '')}
                        </div>
                        <div style="font-size:10px; color:var(--text-muted,#94a3b8); margin-top:4px;">
                            ${roleIcon(n.senderRole)} ${(n.senderRole||'').replace('_',' ')} &bull; ${timeAgo(n.createdAt)}
                        </div>
                    </div>
                    <button onclick="clearOne('${n.receiptId}')" title="Dismiss"
                        style="background:none; border:none; cursor:pointer; color:var(--text-muted,#94a3b8);
                               font-size:16px; padding:0 0 0 8px; flex-shrink:0; opacity:.6;"
                        onmouseover="this.style.opacity=1" onmouseout="this.style.opacity=.6">×</button>
                </div>
            </div>`
        ).join('');
    }

    function escHtml(str) {
        return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    function loadBell() {
        bellLoaded = true;
        fetch('/notifications/api/inbox')
            .then(r => r.json())
            .then(renderBell)
            .catch(() => {});
    }

    function markAllRead() {
        fetch('/notifications/api/mark-all-read', { method:'POST' })
            .then(() => loadBell());
    }

    function clearAll() {
        fetch('/notifications/api/clear-all', { method:'POST' })
            .then(() => {
                renderBell({ unreadCount: 0, notifications: [] });
                bellLoaded = false;
            });
    }

    function clearOne(receiptId) {
        fetch('/notifications/api/' + receiptId + '/clear', { method:'POST' })
            .then(() => {
                const el = document.getElementById('receipt-' + receiptId);
                if (el) { el.style.opacity = '0'; el.style.transition = 'opacity .3s'; setTimeout(() => el.remove(), 300); }
                loadBell();
            });
    }

    // Silently refresh badge count every 60 s
    setInterval(() => {
        fetch('/notifications/api/inbox')
            .then(r => r.json())
            .then(data => {
                const badge = document.getElementById('bellBadge');
                if (data.unreadCount > 0) {
                    badge.style.display = 'flex';
                    badge.textContent = data.unreadCount > 9 ? '9+' : data.unreadCount;
                } else {
                    badge.style.display = 'none';
                }
                if (bellOpen) renderBell(data);
            }).catch(() => {});
    }, 60000);
    </script>
    <% } %>
</body>

</html>