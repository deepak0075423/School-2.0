<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        <%= title %> | <%= appName %>
    </title>
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="icon"
        href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🎓</text></svg>" />
</head>

<body>
    <div class="app-layout">
        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-logo">
                <div class="logo-icon">🎓</div>
                <div>
                    <div class="logo-text">
                        <%= appName %>
                    </div>
                    <% if (session && session.schoolName) { %>
                        <div class="logo-sub">
                            <%= session.schoolName %>
                        </div>
                        <% } %>
                </div>
            </div>

            <nav class="sidebar-nav">
                <%
                    // Resolve which modules this school has enabled.
                    // currentUser is set by loadUser middleware on every authenticated request.
                    const _schoolModules   = (currentUser && currentUser.school && currentUser.school.modules) || {};
                    const _hasAttendance   = !!_schoolModules.attendance;
                    const _hasNotification = !!_schoolModules.notification;
                    const _hasAptitudeExam = !!_schoolModules.aptitudeExam;
                    const _hasResult       = !!_schoolModules.result;
                    const _hasTimetable    = !!_schoolModules.timetable || (currentUser && currentUser.role === 'super_admin');
                    const _hasHoliday      = !!_schoolModules.holiday;
                    const _hasLeave        = !!_schoolModules.leave;
                    const _hasDocument     = !!_schoolModules.document;
                    const _hasLibrary      = !!_schoolModules.library;
                    const _hasPayroll      = !!_schoolModules.payroll;
                    const _hasFees         = !!_schoolModules.fees;
                    const _hasChat         = !!_schoolModules.chat;
                    const _path = (typeof locals !== 'undefined' && locals.title) ? title : '';
                    const _unreadCount     = (typeof unreadNotificationCount !== 'undefined') ? unreadNotificationCount : 0;
                    const _unreadChatCount = (typeof unreadChatCount !== 'undefined') ? unreadChatCount : 0;
                %>

                <% if (session && session.userRole === 'super_admin') { %>
                    <div class="nav-section-label">Overview</div>
                    <a href="/super-admin/dashboard"
                        class="nav-item <%= _path.includes('Dashboard') ? 'active' : '' %>">
                        <span class="nav-icon">📊</span> Dashboard
                    </a>

                    <div class="nav-section-label">Management</div>
                    <a href="/super-admin/schools"
                        class="nav-item <%= _path.includes('School') ? 'active' : '' %>">
                        <span class="nav-icon">🏫</span> Schools
                    </a>
                    <a href="/super-admin/schools/create" class="nav-item">
                        <span class="nav-icon">🏗️</span> Add School
                    </a>
                    <a href="/super-admin/users"
                        class="nav-item <%= _path.includes('User') ? 'active' : '' %>">
                        <span class="nav-icon">👥</span> All Users
                    </a>
                    <a href="/super-admin/users/create" class="nav-item">
                        <span class="nav-icon">➕</span> Add User
                    </a>

                    <div class="nav-section-label">Settings</div>
                    <a href="/super-admin/permissions"
                        class="nav-item <%= _path.includes('Permission') ? 'active' : '' %>">
                        <span class="nav-icon">🔐</span> Module Permissions
                    </a>

                    <div class="nav-section-label">Communications</div>
                    <a href="/super-admin/notifications"
                        class="nav-item <%= _path.includes('Notification') ? 'active' : '' %>">
                        <span class="nav-icon">🔔</span> Notifications
                    </a>
                    <a href="/super-admin/notifications/create" class="nav-item">
                        <span class="nav-icon">📢</span> Send Notification
                    </a>
                    <a href="/chat" class="nav-item <%= _path === 'Chat' ? 'active' : '' %>">
                        <span class="nav-icon">💬</span> Chat
                    </a>

                    <div class="nav-section-label">Logs</div>
                    <a href="/super-admin/logs"
                        class="nav-item <%= _path === 'Logs' ? 'active' : '' %>">
                        <span class="nav-icon">🗂</span> Logs
                    </a>

                <% } else if (session && session.userRole === 'school_admin') { %>
                    <div class="nav-section-label">Overview</div>
                    <a href="/admin/dashboard"
                        class="nav-item <%= _path === 'Admin Dashboard' ? 'active' : '' %>">
                        <span class="nav-icon">📊</span> Dashboard
                    </a>

                    <div class="nav-section-label">Staff & Students</div>
                    <a href="/admin/teachers"
                        class="nav-item <%= _path.includes('Teacher') ? 'active' : '' %>">
                        <span class="nav-icon">👨‍🏫</span> Teachers
                    </a>
                    <a href="/admin/teachers/create" class="nav-item">
                        <span class="nav-icon">➕</span> Add Teacher
                    </a>
                    <a href="/admin/students"
                        class="nav-item <%= _path.includes('Student') ? 'active' : '' %>">
                        <span class="nav-icon">🎒</span> Students
                    </a>
                    <a href="/admin/students/create" class="nav-item">
                        <span class="nav-icon">➕</span> Add Student
                    </a>

                    <div class="nav-section-label">Administration</div>
                    <a href="/admin/admins"
                        class="nav-item <%= _path.includes('Co-Admin') ? 'active' : '' %>">
                        <span class="nav-icon">🛡️</span> Co-Admins
                    </a>
                    <a href="/admin/admins/create" class="nav-item">
                        <span class="nav-icon">➕</span> Add Co-Admin
                    </a>

                    <% if (_hasAptitudeExam) { %>
                    <div class="nav-section-label">Exams</div>
                    <a href="/admin/exams" class="nav-item <%= _path.includes('Exam') && !_path.includes('Formal') ? 'active' : '' %>">
                        <span class="nav-icon">📝</span> Aptitude Exams
                    </a>
                    <% } %>

                    <% if (_hasResult) { %>
                    <div class="nav-section-label">Results</div>
                    <a href="/admin/results/exams" class="nav-item <%= _path.includes('Formal Exam') || _path.includes('Result') ? 'active' : '' %>">
                        <span class="nav-icon">📋</span> Formal Exams
                    </a>
                    <% } %>

                    <% if (_hasAttendance) { %>
                    <div class="nav-section-label">Attendance</div>
                    <a href="/admin/regularization-requests"
                        class="nav-item <%= _path.includes('Regularization') ? 'active' : '' %>">
                        <span class="nav-icon">📋</span> Regularization
                    </a>
                    <% } %>

                    <% if (_hasNotification) { %>
                    <div class="nav-section-label">Communications</div>
                    <a href="/admin/notifications"
                        class="nav-item <%= _path.includes('Notification') ? 'active' : '' %>">
                        <span class="nav-icon">🔔</span> Notifications
                    </a>
                    <a href="/admin/notifications/create" class="nav-item">
                        <span class="nav-icon">📢</span> Send Notification
                    </a>
                    <% } %>
                    <% if (_hasChat) { %>
                    <% if (!_hasNotification) { %><div class="nav-section-label">Communications</div><% } %>
                    <a href="/chat" class="nav-item <%= _path === 'Chat' ? 'active' : '' %>" style="position:relative;">
                        <span class="nav-icon">💬</span> Chat
                        <% if (_unreadChatCount > 0) { %>
                        <span style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:#3b82f6;color:#fff;border-radius:10px;min-width:18px;height:18px;font-size:10px;font-weight:700;display:inline-flex;align-items:center;justify-content:center;padding:0 4px;">
                            <%= _unreadChatCount > 99 ? '99+' : _unreadChatCount %>
                        </span>
                        <% } %>
                    </a>
                    <% } %>

                    <% if (_hasHoliday) { %>
                    <div class="nav-section-label">Calendar</div>
                    <a href="/admin/holidays"
                        class="nav-item <%= _path.includes('Holiday') ? 'active' : '' %>">
                        <span class="nav-icon">🎉</span> Holidays
                    </a>
                    <a href="/admin/holidays/create" class="nav-item">
                        <span class="nav-icon">➕</span> Add Holiday
                    </a>
                    <% } %>

                    <% if (_hasLeave) { %>
                    <div class="nav-section-label">Leave</div>
                    <a href="/admin/leave/requests"
                        class="nav-item <%= _path.includes('Leave Request') ? 'active' : '' %>">
                        <span class="nav-icon">📋</span> Leave Requests
                    </a>
                    <a href="/admin/leave/types"
                        class="nav-item <%= _path.includes('Leave Type') ? 'active' : '' %>">
                        <span class="nav-icon">⚙️</span> Leave Types
                    </a>
                    <a href="/admin/leave/allocations"
                        class="nav-item <%= _path.includes('Leave Allocation') ? 'active' : '' %>">
                        <span class="nav-icon">📊</span> Allocations
                    </a>
                    <a href="/admin/leave/reports"
                        class="nav-item <%= _path.includes('Leave Report') ? 'active' : '' %>">
                        <span class="nav-icon">📈</span> Leave Reports
                    </a>
                    <% } %>

                    <% if (_hasDocument) { %>
                    <div class="nav-section-label">Documents</div>
                    <a href="/admin/documents"
                        class="nav-item <%= _path === 'Documents' ? 'active' : '' %>">
                        <span class="nav-icon">📄</span> Documents
                    </a>
                    <a href="/admin/documents/upload" class="nav-item">
                        <span class="nav-icon">➕</span> Upload Document
                    </a>
                    <a href="/admin/documents/audit"
                        class="nav-item <%= _path.includes('Audit Log') ? 'active' : '' %>">
                        <span class="nav-icon">📋</span> Audit Log
                    </a>
                    <% } %>

                    <% if (_hasLibrary) { %>
                    <div class="nav-section-label">Library</div>
                    <a href="/library/dashboard" class="nav-item <%= _path === 'Library Dashboard' ? 'active' : '' %>">
                        <span class="nav-icon">📚</span> Library
                    </a>
                    <a href="/library/books" class="nav-item <%= _path.includes('Library — Books') || _path === 'Add Book' ? 'active' : '' %>">
                        <span class="nav-icon">📖</span> Book Catalogue
                    </a>
                    <a href="/library/issuances" class="nav-item <%= _path.includes('Issuances') ? 'active' : '' %>">
                        <span class="nav-icon">🔄</span> Issuances
                    </a>
                    <a href="/library/reservations" class="nav-item <%= _path === 'Reservations' ? 'active' : '' %>">
                        <span class="nav-icon">🔖</span> Reservations
                    </a>
                    <a href="/library/fines" class="nav-item <%= _path === 'Library Fines' ? 'active' : '' %>">
                        <span class="nav-icon">💰</span> Fines
                    </a>
                    <a href="/library/policy" class="nav-item <%= _path === 'Library Policy' ? 'active' : '' %>">
                        <span class="nav-icon">⚙️</span> Policy
                    </a>
                    <a href="/library/audit-log" class="nav-item <%= _path === 'Library Audit Log' ? 'active' : '' %>">
                        <span class="nav-icon">📋</span> Audit Log
                    </a>
                    <% } %>

                    <% if (_hasPayroll) { %>
                    <div class="nav-section-label">Payroll</div>
                    <a href="/payroll/admin/dashboard" class="nav-item <%= _path === 'Payroll Dashboard' ? 'active' : '' %>">
                        <span class="nav-icon">💰</span> Dashboard
                    </a>
                    <a href="/payroll/admin/structures" class="nav-item <%= _path.includes('Salary Structure') ? 'active' : '' %>">
                        <span class="nav-icon">🏗️</span> Structures
                    </a>
                    <a href="/payroll/admin/assignments" class="nav-item <%= _path.includes('Salary Assignment') ? 'active' : '' %>">
                        <span class="nav-icon">👤</span> Assignments
                    </a>
                    <a href="/payroll/admin/runs" class="nav-item <%= _path.includes('Payroll Run') || _path.includes('Payroll —') ? 'active' : '' %>">
                        <span class="nav-icon">▶️</span> Payroll Runs
                    </a>
                    <a href="/payroll/admin/reports" class="nav-item <%= _path === 'Payroll Reports' ? 'active' : '' %>">
                        <span class="nav-icon">📊</span> Reports
                    </a>
                    <a href="/payroll/admin/audit" class="nav-item <%= _path === 'Payroll Audit Log' ? 'active' : '' %>">
                        <span class="nav-icon">📋</span> Audit Log
                    </a>
                    <% } %>

                    <% if (_hasFees) { %>
                    <div class="nav-section-label">Fees</div>
                    <a href="/fees/admin/dashboard" class="nav-item <%= _path === 'Fees Dashboard' ? 'active' : '' %>">
                        <span class="nav-icon">💰</span> Dashboard
                    </a>
                    <a href="/fees/admin/fee-heads" class="nav-item <%= _path === 'Fee Heads' ? 'active' : '' %>">
                        <span class="nav-icon">🏷️</span> Fee Heads
                    </a>
                    <a href="/fees/admin/fee-structures" class="nav-item <%= _path.includes('Fee Structure') ? 'active' : '' %>">
                        <span class="nav-icon">🏗️</span> Fee Structures
                    </a>
                    <a href="/fees/admin/student-fees" class="nav-item <%= _path.includes('Student Fee') ? 'active' : '' %>">
                        <span class="nav-icon">🎒</span> Student Fees
                    </a>
                    <a href="/fees/admin/payments" class="nav-item <%= _path === 'Fee Payments' ? 'active' : '' %>">
                        <span class="nav-icon">💳</span> Payments
                    </a>
                    <a href="/fees/admin/fine-rules" class="nav-item <%= _path === 'Fine Rules' ? 'active' : '' %>">
                        <span class="nav-icon">⏰</span> Fine Rules
                    </a>
                    <a href="/fees/admin/concessions" class="nav-item <%= _path === 'Concession Templates' ? 'active' : '' %>">
                        <span class="nav-icon">🎁</span> Concessions
                    </a>
                    <a href="/fees/admin/ledger" class="nav-item <%= _path === 'Fee Ledger' ? 'active' : '' %>">
                        <span class="nav-icon">📒</span> Ledger
                    </a>
                    <a href="/fees/admin/reports/collection" class="nav-item <%= _path === 'Collection Report' ? 'active' : '' %>">
                        <span class="nav-icon">📈</span> Reports
                    </a>
                    <a href="/fees/admin/settings" class="nav-item <%= _path === 'Fee Settings' ? 'active' : '' %>">
                        <span class="nav-icon">⚙️</span> Fee Settings
                    </a>
                    <% } %>

                <% } else if (session && session.userRole === 'teacher') { %>
                    <div class="nav-section-label">Classroom</div>
                    <a href="/teacher/dashboard"
                        class="nav-item <%= _path.includes('Dashboard') ? 'active' : '' %>">
                        <span class="nav-icon">📊</span> Dashboard
                    </a>
                    <a href="/teacher/my-section"
                        class="nav-item <%= _path.includes('Section') ? 'active' : '' %>">
                        <span class="nav-icon">👥</span> My Section
                    </a>
                    <% if (_hasTimetable) { %>
                    <a href="/teacher/timetable"
                        class="nav-item <%= _path.includes('Timetable') ? 'active' : '' %>">
                        <span class="nav-icon">📅</span> Timetable
                    </a>
                    <% } %>

                    <% if (_hasHoliday) { %>
                    <a href="/teacher/holidays"
                        class="nav-item <%= _path.includes('Holiday') ? 'active' : '' %>">
                        <span class="nav-icon">🎉</span> Holidays
                    </a>
                    <% } %>

                    <% if (_hasLeave) { %>
                    <div class="nav-section-label">Leave</div>
                    <a href="/teacher/leave"
                        class="nav-item <%= _path === 'My Leaves' ? 'active' : '' %>">
                        <span class="nav-icon">🏖️</span> My Leaves
                    </a>
                    <a href="/teacher/leave/apply" class="nav-item">
                        <span class="nav-icon">➕</span> Apply Leave
                    </a>
                    <a href="/teacher/leave/balance"
                        class="nav-item <%= _path.includes('Leave Balance') ? 'active' : '' %>">
                        <span class="nav-icon">📊</span> Leave Balance
                    </a>
                    <% } %>

                    <% if (_hasNotification || _hasChat) { %>
                    <div class="nav-section-label">Communications</div>
                    <% if (_hasNotification) { %>
                    <a href="/teacher/notifications"
                        class="nav-item <%= _path.includes('Notification') ? 'active' : '' %>">
                        <span class="nav-icon">🔔</span> Notifications
                    </a>
                    <a href="/teacher/notifications/create" class="nav-item">
                        <span class="nav-icon">📢</span> Send Notification
                    </a>
                    <% } %>
                    <% if (_hasChat) { %>
                    <a href="/chat" class="nav-item <%= _path === 'Chat' ? 'active' : '' %>" style="position:relative;">
                        <span class="nav-icon">💬</span> Chat
                        <% if (_unreadChatCount > 0) { %>
                        <span style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:#3b82f6;color:#fff;border-radius:10px;min-width:18px;height:18px;font-size:10px;font-weight:700;display:inline-flex;align-items:center;justify-content:center;padding:0 4px;">
                            <%= _unreadChatCount > 99 ? '99+' : _unreadChatCount %>
                        </span>
                        <% } %>
                    </a>
                    <% } %>
                    <% } %>

                    <% if (_hasAptitudeExam) { %>
                    <div class="nav-section-label">Exams</div>
                    <a href="/teacher/exams" class="nav-item <%= _path.includes('Exam') && !_path.includes('Formal') ? 'active' : '' %>">
                        <span class="nav-icon">📝</span> My Exams
                    </a>
                    <% } %>

                    <% if (_hasResult) { %>
                    <div class="nav-section-label">Results</div>
                    <a href="/teacher/results/marks-entry" class="nav-item <%= _path.includes('Marks Entry') ? 'active' : '' %>">
                        <span class="nav-icon">✏️</span> Marks Entry
                    </a>
                    <a href="/teacher/results/validation" class="nav-item <%= _path.includes('Marks Validation') ? 'active' : '' %>">
                        <span class="nav-icon">✅</span> Validate Marks
                    </a>
                    <a href="/teacher/results/class-tests" class="nav-item <%= _path.includes('Class Test') ? 'active' : '' %>">
                        <span class="nav-icon">📝</span> Class Tests
                    </a>
                    <a href="/teacher/results/class-test-validation" class="nav-item <%= _path.includes('Class Test Validation') ? 'active' : '' %>">
                        <span class="nav-icon">🔍</span> Validate Class Tests
                    </a>
                    <% } %>

                    <% if (_hasAttendance) { %>
                    <div class="nav-section-label">Attendance</div>
                    <a href="/teacher/attendance"
                        class="nav-item <%= _path === 'Attendance' ? 'active' : '' %>">
                        <span class="nav-icon">📋</span> Mark Attendance
                    </a>
                    <a href="/teacher/attendance-dashboard"
                        class="nav-item <%= _path.includes('Dashboard') && _path.includes('Attendance') ? 'active' : '' %>">
                        <span class="nav-icon">📊</span> Class Analytics
                    </a>
                    <a href="/teacher/my-attendance"
                        class="nav-item <%= _path.includes('My Attendance') ? 'active' : '' %>">
                        <span class="nav-icon">🗓️</span> My Attendance
                    </a>
                    <a href="/teacher/regularization"
                        class="nav-item <%= _path.includes('Regularization') ? 'active' : '' %>">
                        <span class="nav-icon">📝</span> Regularization
                    </a>
                    <a href="/teacher/correction-requests"
                        class="nav-item <%= _path.includes('Correction') ? 'active' : '' %>">
                        <span class="nav-icon">🔔</span> Correction Requests
                    </a>
                    <% } %>

                    <% if (_hasDocument) { %>
                    <div class="nav-section-label">Documents</div>
                    <a href="/teacher/documents"
                        class="nav-item <%= _path === 'Documents' ? 'active' : '' %>">
                        <span class="nav-icon">📄</span> Documents
                    </a>
                    <a href="/teacher/documents/upload" class="nav-item">
                        <span class="nav-icon">➕</span> Upload Document
                    </a>
                    <% } %>

                    <% if (_hasLibrary && !isLibrarian) { %>
                    <div class="nav-section-label">Library</div>
                    <a href="/library/teacher" class="nav-item <%= _path === 'My Library' ? 'active' : '' %>">
                        <span class="nav-icon">📚</span> My Library
                    </a>
                    <a href="/library/teacher/search" class="nav-item <%= _path === 'Library Search' ? 'active' : '' %>">
                        <span class="nav-icon">🔍</span> Search Books
                    </a>
                    <a href="/library/teacher/my-books" class="nav-item <%= _path === 'My Books' ? 'active' : '' %>">
                        <span class="nav-icon">📖</span> My Books
                    </a>
                    <% if (teacherFinesEnabled) { %>
                    <a href="/library/teacher/my-fines" class="nav-item <%= _path === 'My Library Fines' ? 'active' : '' %>">
                        <span class="nav-icon">💰</span> My Fines
                    </a>
                    <% } %>
                    <% } %>
                    <% if (_hasLibrary && isLibrarian) { %>
                    <div class="nav-section-label">Library</div>
                    <a href="/library/dashboard" class="nav-item <%= _path === 'Library Dashboard' ? 'active' : '' %>">
                        <span class="nav-icon">📚</span> Library
                    </a>
                    <a href="/library/books" class="nav-item">
                        <span class="nav-icon">📖</span> Book Catalogue
                    </a>
                    <a href="/library/issue" class="nav-item">
                        <span class="nav-icon">➕</span> Issue Book
                    </a>
                    <a href="/library/reservations" class="nav-item <%= _path === 'Reservations' ? 'active' : '' %>">
                        <span class="nav-icon">🔖</span> Reservations
                    </a>
                    <a href="/library/return" class="nav-item">
                        <span class="nav-icon">↩️</span> Return Book
                    </a>
                    <% } %>

                    <% if (_hasPayroll) { %>
                    <div class="nav-section-label">Payroll</div>
                    <a href="/payroll/teacher/payslips" class="nav-item <%= _path === 'My Salary Slips' || _path.includes('Salary Slip —') ? 'active' : '' %>">
                        <span class="nav-icon">💰</span> My Salary Slips
                    </a>
                    <a href="/payroll/teacher/ctc" class="nav-item <%= _path === 'My CTC Details' ? 'active' : '' %>">
                        <span class="nav-icon">📊</span> My CTC
                    </a>
                    <% } %>

                <% } else if (session && session.userRole === 'student') { %>
                    <div class="nav-section-label">My School</div>
                    <a href="/student/dashboard"
                        class="nav-item <%= _path.includes('Dashboard') ? 'active' : '' %>">
                        <span class="nav-icon">📊</span> Dashboard
                    </a>
                    <a href="/student/my-class"
                        class="nav-item <%= _path.includes('Class') ? 'active' : '' %>">
                        <span class="nav-icon">🏫</span> My Class
                    </a>
                    <% if (_hasTimetable) { %>
                    <a href="/student/timetable"
                        class="nav-item <%= _path.includes('Timetable') ? 'active' : '' %>">
                        <span class="nav-icon">📅</span> My Timetable
                    </a>
                    <% } %>

                    <% if (_hasHoliday) { %>
                    <a href="/student/holidays"
                        class="nav-item <%= _path.includes('Holiday') ? 'active' : '' %>">
                        <span class="nav-icon">🎉</span> Holidays
                    </a>
                    <% } %>

                    <% if (_hasAptitudeExam) { %>
                    <div class="nav-section-label">Exams</div>
                    <a href="/student/exams" class="nav-item <%= _path.includes('Exam') && !_path.includes('Formal') ? 'active' : '' %>">
                        <span class="nav-icon">📝</span> My Exams
                    </a>
                    <% } %>

                    <% if (_hasResult) { %>
                    <div class="nav-section-label">Results</div>
                    <a href="/student/results" class="nav-item <%= _path.includes('My Results') || _path.includes('Result:') ? 'active' : '' %>">
                        <span class="nav-icon">📊</span> My Results
                    </a>
                    <a href="/student/results/class-tests" class="nav-item <%= _path.includes('Class Test Results') ? 'active' : '' %>">
                        <span class="nav-icon">📝</span> Class Tests
                    </a>
                    <% } %>

                    <% if (_hasAttendance) { %>
                    <div class="nav-section-label">Attendance</div>
                    <a href="/student/my-attendance"
                        class="nav-item <%= _path.includes('Attendance') ? 'active' : '' %>">
                        <span class="nav-icon">📅</span> My Attendance
                    </a>
                    <a href="/student/correction"
                        class="nav-item <%= _path.includes('Correction') ? 'active' : '' %>">
