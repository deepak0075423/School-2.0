<div class="welcome-banner">
    <div class="welcome-icon">💰</div>
    <div>
        <h2>Payroll Dashboard</h2>
        <p>Manage salaries, run payroll, and generate payslips for <%= session.schoolName %>.</p>
    </div>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon green">🏗️</div>
        <div class="stat-info">
            <div class="stat-value"><%= stats.totalStructures %></div>
            <div class="stat-label">Salary Structures</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon blue">👨‍💼</div>
        <div class="stat-info">
            <div class="stat-value"><%= stats.totalAssignments %></div>
            <div class="stat-label">Active Assignments</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon purple" style="background:rgba(147,51,234,0.15);color:#9333ea;">📋</div>
        <div class="stat-info">
            <div class="stat-value"><%= stats.totalRuns %></div>
            <div class="stat-label">Payroll Runs</div>
        </div>
    </div>
    <% if (lastRun) { %>
    <div class="stat-card">
        <div class="stat-icon orange">💵</div>
        <div class="stat-info">
            <div class="stat-value">₹<%= (lastRun.totalNet || 0).toLocaleString('en-IN') %></div>
            <div class="stat-label">Last Net Payroll</div>
        </div>
    </div>
    <% } %>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:20px;">

    <!-- Quick Actions -->
    <div class="card">
        <div class="card-header"><div class="card-title">⚡ Quick Actions</div></div>
        <div class="card-body" style="display:flex;flex-direction:column;gap:10px;">
            <% if (!thisMonthRun) { %>
            <a href="/payroll/admin/runs/create" class="btn btn-primary">▶️ Run Payroll — <%= MONTH_NAMES[thisMonth] %> <%= thisYear %></a>
            <% } else { %>
            <a href="/payroll/admin/runs/<%= thisMonthRun._id %>" class="btn btn-secondary">📋 View <%= MONTH_NAMES[thisMonth] %> Run
                <span class="badge badge-<%= thisMonthRun.status === 'published' ? 'success' : (thisMonthRun.status === 'approved' ? 'info' : 'warning') %>" style="margin-left:6px;">
                    <%= thisMonthRun.status %>
                </span>
            </a>
            <% } %>
            <a href="/payroll/admin/structures/create" class="btn btn-secondary">🏗️ Create Salary Structure</a>
            <a href="/payroll/admin/assignments/assign" class="btn btn-secondary">👤 Assign Salary to Employee</a>
            <a href="/payroll/admin/reports" class="btn btn-secondary">📊 Payroll Reports</a>
        </div>
    </div>

    <!-- Recent Payroll Runs -->
    <div class="card">
        <div class="card-header">
            <div class="card-title">📋 Recent Payroll Runs</div>
            <a href="/payroll/admin/runs" class="btn btn-secondary btn-sm">View All</a>
        </div>
        <div class="table-wrapper">
            <% if (!recentRuns.length) { %>
            <div class="empty-state" style="padding:30px;">
                <p>No payroll runs yet. <a href="/payroll/admin/runs/create">Run your first payroll</a>.</p>
            </div>
            <% } else { %>
            <table>
                <thead><tr><th>Period</th><th>Employees</th><th>Net Payroll</th><th>Status</th></tr></thead>
                <tbody>
                    <% recentRuns.forEach(run => { %>
                    <tr>
                        <td><a href="/payroll/admin/runs/<%= run._id %>"><%= MONTH_NAMES[run.month] %> <%= run.year %></a></td>
                        <td><%= run.totalEmployees %></td>
                        <td>₹<%= (run.totalNet || 0).toLocaleString('en-IN') %></td>
                        <td>
                            <span class="badge badge-<%= run.status === 'published' ? 'success' : (run.status === 'approved' ? 'info' : 'warning') %>">
                                <%= run.status %>
                            </span>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
            <% } %>
        </div>
    </div>
</div>
