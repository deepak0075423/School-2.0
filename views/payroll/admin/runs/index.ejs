<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
    <h2 style="margin:0;">📋 Payroll Runs</h2>
    <a href="/payroll/admin/runs/create" class="btn btn-primary">▶️ Run Payroll</a>
</div>

<% if (success && success.length) { %><div class="alert alert-success"><%= success %></div><% } %>
<% if (error && error.length) { %><div class="alert alert-error"><%= error %></div><% } %>

<div class="card">
    <div class="table-wrapper">
        <% if (!runs.length) { %>
        <div class="empty-state" style="padding:40px;">
            <div style="font-size:2.5rem;">📋</div>
            <p>No payroll runs yet.</p>
            <a href="/payroll/admin/runs/create" class="btn btn-primary">Run First Payroll</a>
        </div>
        <% } else { %>
        <table>
            <thead>
                <tr>
                    <th>Period</th>
                    <th>Employees</th>
                    <th>Gross</th>
                    <th>Deductions</th>
                    <th>Net Payroll</th>
                    <th>Status</th>
                    <th>Processed By</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% runs.forEach(run => { %>
                <tr>
                    <td><strong><%= MONTH_NAMES[run.month] %> <%= run.year %></strong></td>
                    <td><%= run.totalEmployees %></td>
                    <td>₹<%= (run.totalGross || 0).toLocaleString('en-IN') %></td>
                    <td style="color:#dc2626;">₹<%= (run.totalDeductions || 0).toLocaleString('en-IN') %></td>
                    <td style="color:#16a34a;font-weight:600;">₹<%= (run.totalNet || 0).toLocaleString('en-IN') %></td>
                    <td>
                        <span class="badge badge-<%=
                            run.status === 'published' ? 'success' :
                            run.status === 'approved'  ? 'info'    :
                            run.status === 'reviewed'  ? 'warning' : 'secondary'
                        %>"><%= run.status.charAt(0).toUpperCase() + run.status.slice(1) %></span>
                    </td>
                    <td style="font-size:0.82rem;color:var(--text-muted);">
                        <%= run.processedBy ? run.processedBy.name : '—' %>
                    </td>
                    <td>
                        <a href="/payroll/admin/runs/<%= run._id %>" class="btn btn-secondary btn-sm">View</a>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <% } %>
    </div>
</div>
