<div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;">
    <a href="/fees/student/my-fees" class="btn btn-secondary btn-sm">← My Fees</a>
    <h2 style="margin:0;">💳 My Payments</h2>
    <% if (activeYear) { %><span class="badge badge-info"><%= activeYear.yearName %></span><% } %>
</div>

<div class="stats-grid" style="margin-bottom:20px;">
    <div class="stat-card">
        <div class="stat-icon green">💰</div>
        <div class="stat-info">
            <div class="stat-value">₹<%= total.toLocaleString('en-IN') %></div>
            <div class="stat-label">Total Paid</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon blue">📋</div>
        <div class="stat-info">
            <div class="stat-value"><%= payments.length %></div>
            <div class="stat-label">Transactions</div>
        </div>
    </div>
</div>

<div class="card">
    <div class="table-wrapper">
        <% if (!payments.length) { %>
        <div class="empty-state" style="padding:40px;">
            <div style="font-size:2.5rem;">💳</div>
            <p>No payments recorded yet.</p>
        </div>
        <% } else { %>
        <table>
            <thead>
                <tr><th>Receipt No.</th><th>Amount</th><th>Mode</th><th>Date</th><th>Status</th><th>Actions</th></tr>
            </thead>
            <tbody>
                <% payments.forEach(p => { %>
                <tr>
                    <td style="font-family:monospace;font-size:0.82rem;"><%= p.receiptNumber || '—' %></td>
                    <td style="font-weight:700;color:#16a34a;">₹<%= (p.amount || 0).toLocaleString('en-IN') %></td>
                    <td><span class="badge badge-secondary"><%= (p.paymentMode || '').replace(/_/g,' ').toUpperCase() %></span></td>
                    <td style="font-size:0.82rem;color:var(--text-muted);">
                        <%= new Date(p.paymentDate).toLocaleDateString('en-IN', {day:'2-digit',month:'short',year:'numeric'}) %>
                    </td>
                    <td>
                        <span class="badge badge-<%= p.paymentStatus === 'completed' ? 'success' : 'warning' %>">
                            <%= p.paymentStatus %>
                        </span>
                    </td>
                    <td>
                        <div style="display:flex;gap:6px;">
                            <a href="/fees/student/payments/<%= p._id %>/receipt" class="btn btn-secondary btn-sm">View</a>
                            <a href="/fees/student/payments/<%= p._id %>/download" class="btn btn-secondary btn-sm">PDF</a>
                        </div>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <% } %>
    </div>
</div>
