<%
const flash_success = typeof success !== 'undefined' ? success : (locals.success || '');
const flash_error   = typeof error   !== 'undefined' ? error   : (locals.error   || '');
const sym = currencySymbol || '₹';
%>

<div style="display:flex;align-items:center;gap:10px;margin-bottom:20px;">
    <a href="/fees/student/my-fees" class="btn btn-secondary btn-sm">← Back</a>
    <h2 style="margin:0;">Pay Fees</h2>
    <% if (activeYear) { %><span class="badge badge-info"><%= activeYear.yearName %></span><% } %>
</div>

<% if (flash_success && flash_success.length) { %><div class="alert alert-success"><%= flash_success %></div><% } %>
<% if (flash_error   && flash_error.length)   { %><div class="alert alert-error"><%= flash_error   %></div><% } %>

<%
const dueMonths      = (monthlySchedule || []).filter(m => m.payStatus === 'due' || m.payStatus === 'partial');
const upcomingMonths = (monthlySchedule || []).filter(m => m.payStatus === 'upcoming');
const paidMonths     = (monthlySchedule || []).filter(m => m.payStatus === 'paid');
const hasDues        = dueMonths.length > 0;
const hasSchedule    = monthlySchedule && monthlySchedule.length > 0;
const dueTotal       = dueMonths.reduce((s, m) => s + m.amountDue, 0);
%>

<div style="display:grid;grid-template-columns:1fr 360px;gap:20px;align-items:start;">

    <!-- Left: Fee Book Month Selection -->
    <div>
        <% if (hasSchedule) { %>
        <div class="card" style="margin-bottom:16px;">
            <div class="card-header" style="border-bottom:2px solid var(--border);">
                <div>
                    <div class="card-title">📒 Select Months to Pay</div>
                    <div style="font-size:0.78rem;color:var(--text-muted);margin-top:2px;">
                        <% if (hasDues) { %>Overdue months are pre-selected. Pay them first before selecting future months.
                        <% } else { %>All dues cleared. Select upcoming months to pay in advance.
                        <% } %>
                    </div>
                </div>
                <div style="font-size:0.88rem;font-weight:600;color:#1d4ed8;">
                    <span id="selectedCount"><%= dueMonths.length %></span> month(s) selected
                </div>
            </div>
            <div id="feeBookList" style="padding:0 16px 16px;">

                <!-- Due / Partial months — required -->
                <% if (dueMonths.length) { %>
                <div style="padding:12px 0 6px;font-size:0.72rem;text-transform:uppercase;font-weight:700;color:#dc2626;letter-spacing:0.05em;">⚠ Overdue Months — Required</div>
                <% dueMonths.forEach((month, idx) => { %>
                <div style="border:1.5px solid #fca5a5;border-radius:8px;margin-bottom:8px;background:#fef2f2;padding:12px 14px;">
                    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;">
                        <div style="display:flex;align-items:center;gap:10px;">
                            <input type="checkbox" checked disabled style="width:16px;height:16px;accent-color:#dc2626;">
                            <span style="font-weight:700;font-size:0.95rem;"><%= month.monthLabel %></span>
                            <% if (month.isCurrentMonth) { %><span style="font-size:0.7rem;color:#3b82f6;">(Current)</span><% } %>
                            <span class="badge" style="background:#fee2e2;color:#dc2626;font-size:0.68rem;"><%= month.payStatus === 'partial' ? 'PARTIAL' : 'OVERDUE' %></span>
                        </div>
                        <div style="text-align:right;">
                            <% if (month.payStatus === 'partial') { %><div style="font-size:0.72rem;color:#16a34a;">Paid: <%= sym %><%= month.amountPaid.toLocaleString('en-IN') %></div><% } %>
                            <div style="font-weight:700;color:#dc2626;"><%= sym %><%= month.amountDue.toLocaleString('en-IN') %></div>
                        </div>
                    </div>
                    <div style="margin-top:8px;border-top:1px dashed #fca5a5;padding-top:8px;">
                        <% month.items.forEach(item => { %>
                        <div style="display:flex;justify-content:space-between;font-size:0.79rem;color:#7f1d1d;padding:2px 0;">
                            <span><%= item.name %></span><span><%= sym %><%= item.amount.toLocaleString('en-IN') %></span>
                        </div>
                        <% }) %>
                    </div>
                </div>
                <% }) %>
                <% } %>

                <!-- Upcoming months — optional -->
                <% if (upcomingMonths.length) { %>
                <div style="padding:12px 0 6px;font-size:0.72rem;text-transform:uppercase;font-weight:700;color:#6b7280;letter-spacing:0.05em;">
                    Upcoming Months — <% if (hasDues) { %>Available after clearing overdue<% } else { %>Advance Payment (Optional)<% } %>
                </div>
                <% upcomingMonths.forEach((month, idx) => { %>
                <div class="upcoming-card" id="uc-<%= idx %>"
                    data-amount="<%= month.totalAmount %>" data-idx="<%= idx %>"
                    style="border:1.5px solid #d1d5db;border-radius:8px;margin-bottom:8px;background:var(--bg-secondary);padding:12px 14px;cursor:pointer;transition:border-color 0.15s,background 0.15s;"
                    onclick="toggleUpcoming(<%= idx %>)">
                    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;">
                        <div style="display:flex;align-items:center;gap:10px;">
                            <input type="checkbox" id="uc-cb-<%= idx %>" data-idx="<%= idx %>"
                                style="width:16px;height:16px;accent-color:#3b82f6;"
                                onclick="event.stopPropagation();toggleUpcoming(<%= idx %>)">
                            <span style="font-weight:600;font-size:0.92rem;"><%= month.monthLabel %></span>
                            <% if (month.isCurrentMonth) { %><span style="font-size:0.7rem;color:#3b82f6;">(Current)</span><% } %>
                            <span class="badge badge-secondary" style="font-size:0.68rem;">UPCOMING</span>
                        </div>
                        <div style="font-weight:700;color:#6b7280;"><%= sym %><%= month.totalAmount.toLocaleString('en-IN') %></div>
                    </div>
                    <div style="margin-top:8px;border-top:1px dashed #d1d5db;padding-top:8px;">
                        <% month.items.forEach(item => { %>
                        <div style="display:flex;justify-content:space-between;font-size:0.79rem;color:var(--text-muted);padding:2px 0;">
                            <span><%= item.name %></span><span><%= sym %><%= item.amount.toLocaleString('en-IN') %></span>
                        </div>
                        <% }) %>
                    </div>
                </div>
                <% }) %>
                <% } %>

                <!-- Paid months reference -->
                <% if (paidMonths.length) { %>
                <div style="padding:12px 0 6px;font-size:0.72rem;text-transform:uppercase;font-weight:700;color:#16a34a;letter-spacing:0.05em;">✓ Already Paid</div>
                <% paidMonths.slice(0,2).forEach(month => { %>
                <div style="border:1px solid #bbf7d0;border-radius:8px;margin-bottom:6px;background:#f0fdf4;padding:10px 14px;opacity:0.8;">
                    <div style="display:flex;justify-content:space-between;align-items:center;">
                        <div style="display:flex;align-items:center;gap:8px;">
                            <span>✅</span>
                            <span style="font-weight:600;font-size:0.88rem;color:#166534;"><%= month.monthLabel %></span>
                            <span class="badge badge-success" style="font-size:0.65rem;">PAID</span>
                        </div>
                        <span style="font-size:0.88rem;font-weight:600;color:#16a34a;"><%= sym %><%= month.amountPaid.toLocaleString('en-IN') %></span>
                    </div>
                </div>
                <% }) %>
                <% if (paidMonths.length > 2) { %><div style="text-align:center;font-size:0.78rem;color:var(--text-muted);padding-top:4px;">+ <%= paidMonths.length-2 %> more · <a href="/fees/student/my-fees" style="color:#3b82f6;">View all</a></div><% } %>
                <% } %>

                <% if (!dueMonths.length && !upcomingMonths.length) { %>
                <div style="padding:32px;text-align:center;">
                    <div style="font-size:2rem;">✅</div>
                    <p style="color:var(--text-muted);font-size:0.88rem;margin:8px 0 0;">All fees paid and up to date. Enter an amount to pay in advance.</p>
                </div>
                <% } %>
            </div>
        </div>
        <% } %>
    </div>

    <!-- Right: Payment Form -->
    <div style="position:sticky;top:20px;">

        <!-- Balance Card -->
        <div style="background:linear-gradient(135deg,#1d4ed8,#3b82f6);border-radius:12px;padding:16px 20px;margin-bottom:16px;color:#fff;">
            <% if (balance > 0) { %>
            <div style="font-size:0.72rem;opacity:0.8;text-transform:uppercase;letter-spacing:0.05em;">Outstanding Balance</div>
            <div style="font-size:1.8rem;font-weight:800;color:#fde68a;"><%= sym %><%= balance.toLocaleString('en-IN') %></div>
            <div style="font-size:0.78rem;opacity:0.8;margin-top:2px;">Due for payment</div>
            <% } else if (balance < 0) { %>
            <div style="font-size:0.72rem;opacity:0.8;text-transform:uppercase;letter-spacing:0.05em;">Credit Balance</div>
            <div style="font-size:1.8rem;font-weight:800;color:#a7f3d0;"><%= sym %><%= Math.abs(balance).toLocaleString('en-IN') %></div>
            <div style="font-size:0.78rem;opacity:0.8;margin-top:2px;">Advance paid</div>
            <% } else { %>
            <div style="font-size:1rem;font-weight:700;color:#a7f3d0;">✅ All Dues Cleared</div>
            <div style="font-size:0.78rem;opacity:0.8;margin-top:2px;">No outstanding balance</div>
            <% } %>
        </div>

        <% if (balance <= 0 && !hasDues) { %>
        <div style="background:#EFF6FF;border:1px solid #BFDBFE;border-radius:8px;padding:12px 14px;margin-bottom:14px;display:flex;gap:10px;">
            <span style="font-size:1.2rem;">➕</span>
            <div>
                <div style="font-weight:700;color:#1e40af;font-size:0.88rem;">Advance Payment</div>
                <div style="font-size:0.78rem;color:#3b82f6;margin-top:2px;">Select upcoming months above, or enter a custom amount below.</div>
            </div>
        </div>
        <% } %>

        <% if (hasDues) { %>
        <div style="background:#FFF7ED;border:1px solid #FED7AA;border-radius:8px;padding:10px 14px;margin-bottom:14px;font-size:0.8rem;color:#92400E;">
            ⚠️ <strong>Pay overdue months first</strong> before selecting upcoming months.
        </div>
        <% } %>

        <div class="card">
            <div class="card-header"><div class="card-title">Payment Details</div></div>
            <div class="card-body">

                <div class="form-group">
                    <label class="form-label">Amount (<%= sym %>)</label>
                    <input type="number" id="payAmount" class="form-control"
                        value="<%= suggestedAmount > 0 ? suggestedAmount : '' %>"
                        placeholder="<%= suggestedAmount > 0 ? '' : 'Enter amount' %>"
                        min="1" step="0.01"
                        style="font-size:1.2rem;font-weight:700;color:#1d4ed8;"
                        oninput="onAmountInput()">
                    <div id="amtBreakdown" style="font-size:0.76rem;color:var(--text-muted);margin-top:4px;"></div>
                </div>

                <% if (!gateway || gateway === 'none') { %>
                <form method="POST" action="/fees/student/pay" onsubmit="return validateOffline()">
                    <div class="form-group">
                        <label class="form-label">Payment Mode</label>
                        <select name="paymentMode" class="form-control" required>
                            <option value="cash">Cash</option>
                            <option value="upi">UPI</option>
                            <option value="bank_transfer">Bank Transfer</option>
                            <option value="cheque">Cheque</option>
                            <option value="other">Other</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Transaction Ref <span style="color:var(--text-muted);font-size:0.75rem;">(optional)</span></label>
                        <input type="text" name="transactionRef" class="form-control" placeholder="UTR / Ref No">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Payment Date</label>
                        <input type="date" name="paymentDate" class="form-control" value="<%= new Date().toISOString().split('T')[0] %>">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Remarks <span style="color:var(--text-muted);font-size:0.75rem;">(optional)</span></label>
                        <input type="text" name="remarks" class="form-control" placeholder="Optional">
                    </div>
                    <input type="hidden" name="amount" id="hiddenAmt" value="<%= suggestedAmount || '' %>">
                    <button type="submit" class="btn btn-primary btn-block" style="font-size:1rem;padding:13px;">
                        Submit Payment Request
                    </button>
                    <p style="text-align:center;font-size:0.73rem;color:var(--text-muted);margin:8px 0 0;">Admin will verify and confirm your payment.</p>
                </form>

                <% } else if (gateway === 'razorpay') { %>
                <div class="form-group">
                    <label class="form-label">Remarks <span style="color:var(--text-muted);font-size:0.75rem;">(optional)</span></label>
                    <input type="text" id="rzpRemarks" class="form-control" placeholder="Optional">
                </div>
                <button onclick="doRazorpay()" class="btn btn-primary btn-block" style="font-size:1rem;padding:13px;">
                    💳 Pay via Razorpay
                </button>

                <% } else if (gateway === 'stripe') { %>
                <div class="form-group">
                    <label class="form-label">Card Details</label>
                    <div id="card-element" style="padding:12px;border:1px solid var(--border);border-radius:6px;"></div>
                    <div id="card-errors" style="color:#dc2626;font-size:0.8rem;margin-top:6px;"></div>
                </div>
                <button onclick="doStripe()" class="btn btn-primary btn-block" style="font-size:1rem;padding:13px;">
                    💳 Pay via Stripe
                </button>
                <% } %>
            </div>
        </div>
    </div>
</div>

<script>
const DUE_TOTAL = <%= dueTotal %>;
const UP_AMOUNTS = [<% upcomingMonths.forEach((m,i) => { %><%= m.totalAmount %><%= i < upcomingMonths.length-1 ? ',' : '' %><% }) %>];
const N_DUE = <%= dueMonths.length %>;
let selUp = new Array(<%= upcomingMonths.length %>).fill(false);

function getTotal() {
    return Math.round((DUE_TOTAL + selUp.reduce((s,v,i) => s + (v ? UP_AMOUNTS[i] : 0), 0)) * 100) / 100;
}

function toggleUpcoming(idx) {
    if (!selUp[idx]) {
        // Selecting: enforce sequential — all prior must be selected
        for (let i = 0; i < idx; i++) {
            if (!selUp[i]) {
                const card = document.getElementById('uc-' + i);
                const name = card?.querySelector('span[style*="font-weight:600"]')?.textContent?.trim() || ('Month ' + (i+1));
                alert('Please select months in order. Select "' + name + '" first.');
                return;
            }
        }
        selUp[idx] = true;
    } else {
        // Deselecting: also deselect all subsequent
        for (let i = idx; i < selUp.length; i++) selUp[i] = false;
    }
    renderUpcoming();
    updateAmount();
}

function renderUpcoming() {
    selUp.forEach((v, i) => {
        const cb   = document.getElementById('uc-cb-' + i);
        const card = document.getElementById('uc-' + i);
        if (cb)   cb.checked = v;
        if (card) {
            card.style.borderColor = v ? '#3b82f6' : '#d1d5db';
            card.style.background  = v ? '#eff6ff' : 'var(--bg-secondary)';
        }
    });
    const el = document.getElementById('selectedCount');
    if (el) el.textContent = N_DUE + selUp.filter(Boolean).length;
}

function updateAmount() {
    const total = getTotal();
    const inp   = document.getElementById('payAmount');
    if (inp) inp.value = total > 0 ? total : '';
    syncHidden(total);
    showBreakdown(total);
}

function onAmountInput() {
    const v = parseFloat(document.getElementById('payAmount').value) || 0;
    syncHidden(v);
}

function syncHidden(val) {
    const h = document.getElementById('hiddenAmt');
    if (h) h.value = val || '';
}

function showBreakdown(total) {
    const el = document.getElementById('amtBreakdown');
    if (!el) return;
    const parts = [];
    if (DUE_TOTAL > 0) parts.push('Overdue: ₹' + DUE_TOTAL.toLocaleString('en-IN'));
    const adv = selUp.reduce((s,v,i) => s + (v ? UP_AMOUNTS[i] : 0), 0);
    if (adv > 0) parts.push('Advance: ₹' + adv.toLocaleString('en-IN'));
    el.textContent = parts.join(' + ');
}

function validateOffline() {
    const amount = parseFloat(document.getElementById('payAmount').value) || 0;
    if (amount <= 0) { alert('Please enter a valid amount greater than 0.'); return false; }
    if (DUE_TOTAL > 0 && amount < DUE_TOTAL) {
        return confirm('Amount (₹' + amount.toLocaleString('en-IN') + ') is less than total overdue (₹' + DUE_TOTAL.toLocaleString('en-IN') + '). Submit anyway?');
    }
    document.getElementById('hiddenAmt').value = amount;
    return true;
}

<% if (gateway === 'razorpay') { %>
function doRazorpay() {
    const amount = parseFloat(document.getElementById('payAmount').value) || 0;
    if (!amount || amount <= 0) { alert('Enter a valid amount.'); return; }
    if (DUE_TOTAL > 0 && amount < DUE_TOTAL && !confirm('Amount less than total overdue. Proceed?')) return;
    fetch('/fees/student/pay/razorpay/create-order', {
        method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({amount}),
    }).then(r=>r.json()).then(data => {
        if (data.error) { alert(data.error); return; }
        new Razorpay({
            key: '<%= razorpayKeyId %>',
            order_id: data.orderId, amount: data.amount, currency: data.currency,
            name: '<%= schoolName %>', description: 'Fee Payment',
            prefill: { name: '<%= studentName %>' },
            handler(resp) {
                fetch('/fees/student/pay/razorpay/verify', {
                    method:'POST', headers:{'Content-Type':'application/json'},
                    body: JSON.stringify({ razorpay_order_id: resp.razorpay_order_id, razorpay_payment_id: resp.razorpay_payment_id, razorpay_signature: resp.razorpay_signature, amount }),
                }).then(r=>r.json()).then(v => { if(v.success) location.href = v.receiptUrl; else alert('Verification failed: ' + (v.error||'')); });
            },
        }).open();
    }).catch(() => alert('Failed to initiate payment.'));
}
<% } %>

<% if (gateway === 'stripe') { %>
const _stripe = Stripe('<%= stripePublishableKey %>');
const _elems  = _stripe.elements();
const _card   = _elems.create('card');
_card.mount('#card-element');
_card.on('change', e => { document.getElementById('card-errors').textContent = e.error ? e.error.message : ''; });
async function doStripe() {
    const amount = parseFloat(document.getElementById('payAmount').value)||0;
    if (!amount || amount <= 0) { alert('Enter a valid amount.'); return; }
    const { clientSecret, error:ie } = await fetch('/fees/student/pay/stripe/create-intent', {
        method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({amount}),
    }).then(r=>r.json());
    if (ie) { alert(ie); return; }
    const { paymentIntent, error } = await _stripe.confirmCardPayment(clientSecret, {
        payment_method: { card: _card, billing_details: { name: '<%= studentName %>' } },
    });
    if (error) { document.getElementById('card-errors').textContent = error.message; return; }
    if (paymentIntent.status === 'succeeded') {
        const v = await fetch('/fees/student/pay/stripe/verify', {
            method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({paymentIntentId: paymentIntent.id, amount}),
        }).then(r=>r.json());
        if (v.success) location.href = v.receiptUrl; else alert('Verification failed: '+(v.error||''));
    }
}
<% } %>

// Init
document.addEventListener('DOMContentLoaded', () => {
    renderUpcoming();
    const initAmt = getTotal() || <%= suggestedAmount || 0 %>;
    if (initAmt > 0) document.getElementById('payAmount').value = initAmt;
    syncHidden(initAmt);
    showBreakdown(initAmt);
    const el = document.getElementById('selectedCount');
    if (el) el.textContent = N_DUE;
});
</script>

<% if (gateway === 'razorpay') { %><script src="https://checkout.razorpay.com/v1/checkout.js"></script><% } %>
<% if (gateway === 'stripe') { %><script src="https://js.stripe.com/v3/"></script><% } %>
