<%
const flash_success = typeof success !== 'undefined' ? success : (locals.success || '');
const flash_error   = typeof error   !== 'undefined' ? error   : (locals.error   || '');
const base = `/fees/parent/child/${childId}`;
%>

<% if (flash_success && flash_success.length) { %><div class="alert alert-success"><%= flash_success %></div><% } %>
<% if (flash_error   && flash_error.length)   { %><div class="alert alert-error"><%=   flash_error   %></div><% } %>

<!-- Header -->
<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:22px;flex-wrap:wrap;gap:12px;">
    <div style="display:flex;align-items:center;gap:14px;">
        <a href="/parent/dashboard" class="btn btn-secondary btn-sm">← Dashboard</a>
        <div>
            <h2 style="margin:0;font-size:1.3rem;">💰 Fees — <%= child.name %></h2>
            <% if (activeYear) { %>
            <span style="font-size:0.8rem;color:var(--text-muted);">Academic Year: <strong><%= activeYear.yearName %></strong></span>
            <% } %>
        </div>
    </div>
    <% if (balance > 0) { %>
    <a href="<%= base %>/pay" class="btn btn-primary" style="padding:10px 22px;font-weight:700;">
        💳 Pay Now — ₹<%= balance.toLocaleString('en-IN') %>
    </a>
    <% } %>
</div>

<!-- Stats Row -->
<div class="stats-grid" style="margin-bottom:22px;">
    <div class="stat-card" style="border-left:4px solid <%= balance > 0 ? '#dc2626' : '#16a34a' %>;">
        <div class="stat-icon <%= balance > 0 ? 'orange' : 'green' %>"><%= balance > 0 ? '⏳' : '✅' %></div>
        <div class="stat-info">
            <div class="stat-value" style="color:<%= balance > 0 ? '#dc2626' : '#16a34a' %>;">
                ₹<%= Math.abs(balance).toLocaleString('en-IN') %>
            </div>
            <div class="stat-label"><%= balance > 0 ? 'Outstanding Due' : balance < 0 ? 'Credit Balance' : 'Fully Cleared' %></div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green">💳</div>
        <div class="stat-info">
            <div class="stat-value">₹<%= totalPaid.toLocaleString('en-IN') %></div>
            <div class="stat-label">Total Paid</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon blue">📋</div>
        <div class="stat-info">
            <div class="stat-value">₹<%= totalCharged.toLocaleString('en-IN') %></div>
            <div class="stat-label">Total Charged</div>
        </div>
    </div>
    <% if (totalConcession > 0) { %>
    <div class="stat-card">
        <div class="stat-icon" style="background:rgba(147,51,234,0.12);color:#9333ea;">🎁</div>
        <div class="stat-info">
            <div class="stat-value">₹<%= totalConcession.toLocaleString('en-IN') %></div>
            <div class="stat-label">Concession</div>
        </div>
    </div>
    <% } %>
</div>

<% if (fineAmt > 0) { %>
<div style="background:#FEF3C7;border:1px solid #F59E0B;border-radius:10px;padding:12px 18px;margin-bottom:20px;display:flex;align-items:center;gap:10px;">
    <span style="font-size:1.3rem;">⚠️</span>
    <div>
        <div style="font-weight:700;color:#92400E;">Late Fine Applicable</div>
        <div style="font-size:0.83rem;color:#78350F;">A late fine of <strong>₹<%= fineAmt.toLocaleString('en-IN') %></strong> may be added for overdue fee components.</div>
    </div>
</div>
<% } %>

<div style="display:grid;grid-template-columns:2fr 1fr;gap:20px;">

    <!-- Fee Structure -->
    <div>
        <div class="card" style="margin-bottom:20px;">
            <div class="card-header">
                <div class="card-title">📋 Fee Structure</div>
                <% if (resolved && resolved.structureName) { %>
                <span class="badge badge-info" style="font-size:0.72rem;"><%= resolved.structureName %></span>
                <% } %>
            </div>
            <div class="card-body" style="padding:0;">
                <% if (!resolved || !resolved.items.length) { %>
                <div style="padding:36px;text-align:center;color:var(--text-muted);">
                    <div style="font-size:2rem;margin-bottom:10px;">📋</div>
                    No fee structure assigned. Contact school admin.
                </div>
                <% } else { %>
                <table style="width:100%;border-collapse:collapse;font-size:0.9rem;">
                    <thead>
                        <tr style="background:var(--bg-secondary);">
                            <th style="padding:10px 16px;text-align:left;font-size:0.78rem;text-transform:uppercase;letter-spacing:0.04em;">Component</th>
                            <th style="padding:10px 16px;text-align:right;font-size:0.78rem;text-transform:uppercase;letter-spacing:0.04em;">Amount</th>
                            <th style="padding:10px 16px;text-align:center;font-size:0.78rem;text-transform:uppercase;letter-spacing:0.04em;">Due Date</th>
                            <th style="padding:10px 16px;text-align:center;font-size:0.78rem;text-transform:uppercase;letter-spacing:0.04em;">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% resolved.items.forEach(item => {
                            const isOverdue = item.dueDate && new Date(item.dueDate) < new Date();
                        %>
                        <tr style="border-bottom:1px solid var(--border);">
                            <td style="padding:12px 16px;">
                                <div style="font-weight:500;"><%= item.feeName %></div>
                                <div style="font-size:0.73rem;color:var(--text-muted);text-transform:capitalize;"><%= (item.category||'').replace(/_/g,' ') %></div>
                            </td>
                            <td style="padding:12px 16px;text-align:right;font-weight:700;color:#1d4ed8;">
                                ₹<%= (item.amount||0).toLocaleString('en-IN') %>
                            </td>
                            <td style="padding:12px 16px;text-align:center;font-size:0.82rem;">
                                <% if (item.dueDate) { %>
                                <span style="color:<%= isOverdue?'#dc2626':'var(--text-muted)' %>;font-weight:<%= isOverdue?'600':'400' %>;">
                                    <%= new Date(item.dueDate).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) %>
                                    <%= isOverdue ? ' ⚠️' : '' %>
                                </span>
                                <% } else { %><span style="color:var(--text-muted);">—</span><% } %>
                            </td>
                            <td style="padding:12px 16px;text-align:center;">
                                <% if (isOverdue) { %>
                                <span class="badge" style="background:#FEE2E2;color:#dc2626;font-size:0.7rem;">Overdue</span>
                                <% } else if (item.dueDate) { %>
                                <span class="badge badge-info" style="font-size:0.7rem;">Upcoming</span>
                                <% } else { %>
                                <span class="badge badge-secondary" style="font-size:0.7rem;">—</span>
                                <% } %>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                    <tfoot>
                        <tr style="background:#EBF5FB;border-top:2px solid #BFDBFE;">
                            <td style="padding:13px 16px;font-weight:700;">Total</td>
                            <td style="padding:13px 16px;text-align:right;font-weight:800;color:#1d4ed8;font-size:1rem;">
                                ₹<%= resolved.items.reduce((s,i)=>s+i.amount,0).toLocaleString('en-IN') %>
                            </td>
                            <td colspan="2"></td>
                        </tr>
                    </tfoot>
                </table>
                <% if (balance > 0) { %>
                <div style="padding:14px 16px;border-top:1px solid var(--border);">
                    <a href="<%= base %>/pay" class="btn btn-primary" style="width:100%;text-align:center;padding:11px;font-size:0.95rem;font-weight:700;">
                        💳 Pay ₹<%= balance.toLocaleString('en-IN') %> Now
                    </a>
                </div>
                <% } %>
                <% } %>
            </div>
        </div>

        <!-- Payment History -->
        <div class="card">
            <div class="card-header">
                <div class="card-title">💳 Payment History</div>
                <span style="font-size:0.82rem;color:var(--text-muted);"><%= payments.length %> transaction(s)</span>
            </div>
            <div class="card-body" style="padding:0;">
                <% if (!payments.length) { %>
                <div style="padding:30px;text-align:center;color:var(--text-muted);font-size:0.88rem;">No payments recorded yet.</div>
                <% } else { %>
                <table style="width:100%;border-collapse:collapse;font-size:0.88rem;">
                    <thead>
                        <tr style="background:var(--bg-secondary);">
                            <th style="padding:10px 14px;text-align:left;">Receipt No.</th>
                            <th style="padding:10px 14px;text-align:right;">Amount</th>
                            <th style="padding:10px 14px;text-align:center;">Mode</th>
                            <th style="padding:10px 14px;text-align:center;">Date</th>
                            <th style="padding:10px 14px;text-align:center;">Status</th>
                            <th style="padding:10px 14px;text-align:center;">Receipt</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% payments.forEach(p => { %>
                        <tr style="border-bottom:1px solid var(--border);<%= p.paymentStatus==='pending'?'background:#FFFBEB;':'' %>">
                            <td style="padding:10px 14px;font-family:monospace;font-size:0.8rem;">
                                <%= p.receiptNumber || '<span style="color:var(--text-muted);">Pending</span>' %>
                            </td>
                            <td style="padding:10px 14px;text-align:right;font-weight:700;color:#16a34a;">
                                ₹<%= (p.amount||0).toLocaleString('en-IN') %>
                            </td>
                            <td style="padding:10px 14px;text-align:center;">
                                <span class="badge badge-secondary" style="font-size:0.7rem;">
                                    <%= (p.paymentMode||'').replace(/_/g,' ').toUpperCase() %>
                                </span>
                            </td>
                            <td style="padding:10px 14px;text-align:center;color:var(--text-muted);">
                                <%= new Date(p.paymentDate).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) %>
                            </td>
                            <td style="padding:10px 14px;text-align:center;">
                                <span class="badge badge-<%=
                                    p.paymentStatus==='completed'?'success':
                                    p.paymentStatus==='pending'?'warning':'danger'
                                %>" style="font-size:0.7rem;"><%= p.paymentStatus %></span>
                            </td>
                            <td style="padding:10px 14px;text-align:center;">
                                <% if (p.paymentStatus === 'completed') { %>
                                <div style="display:flex;gap:5px;justify-content:center;">
                                    <a href="<%= base %>/payments/<%= p._id %>/receipt" class="btn btn-secondary btn-sm" style="font-size:0.72rem;padding:3px 9px;">View</a>
                                    <a href="<%= base %>/payments/<%= p._id %>/download" class="btn btn-secondary btn-sm" style="font-size:0.72rem;padding:3px 9px;">PDF</a>
                                </div>
                                <% } else { %>
                                <span style="font-size:0.75rem;color:var(--text-muted);">—</span>
                                <% } %>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Right Sidebar -->
    <div style="display:flex;flex-direction:column;gap:16px;">

        <!-- Quick Actions -->
        <div class="card">
            <div class="card-header"><div class="card-title">Quick Actions</div></div>
            <div class="card-body" style="display:flex;flex-direction:column;gap:10px;">
                <% if (balance > 0) { %>
                <a href="<%= base %>/pay" class="btn btn-primary" style="text-align:center;">💳 Pay Fees</a>
                <% } %>
                <a href="/parent/dashboard" class="btn btn-secondary" style="text-align:center;">← Parent Dashboard</a>
            </div>
        </div>

        <!-- Concessions -->
        <% if (concessions && concessions.length) { %>
        <div class="card">
            <div class="card-header"><div class="card-title">🎁 Concessions</div></div>
            <div class="card-body" style="padding:0;">
                <% concessions.forEach((sc, idx) => { %>
                <div style="padding:12px 16px;border-bottom:<%= idx<concessions.length-1?'1px solid var(--border)':'none' %>;">
                    <div style="font-weight:600;font-size:0.87rem;"><%= sc.concession?.name || '—' %></div>
                    <div style="font-size:0.76rem;color:#16a34a;margin-top:2px;">
                        <%= sc.concession?.concessionType==='percentage'
                            ? sc.concession.value+'% off'
                            : '₹'+(sc.concession?.value||0).toLocaleString('en-IN')+' waiver' %>
                    </div>
                </div>
                <% }) %>
            </div>
        </div>
        <% } %>

        <!-- Balance Summary -->
        <div class="card" style="background:<%= balance>0?'#FFF5F5':'#F0FDF4' %>;border:1px solid <%= balance>0?'#FED7D7':'#BBF7D0' %>;">
            <div class="card-body" style="font-size:0.83rem;color:<%= balance>0?'#92400E':'#166534' %>;">
                <div style="font-weight:700;margin-bottom:10px;font-size:0.9rem;">
                    <%= balance > 0 ? '⚠️ Payment Due' : '✅ Account Clear' %>
                </div>
                <div style="display:flex;justify-content:space-between;margin-bottom:6px;">
                    <span>Total Charged</span><span style="font-weight:600;">₹<%= totalCharged.toLocaleString('en-IN') %></span>
                </div>
                <div style="display:flex;justify-content:space-between;margin-bottom:6px;">
                    <span>Total Paid</span><span style="font-weight:600;color:#16a34a;">₹<%= totalPaid.toLocaleString('en-IN') %></span>
                </div>
                <% if (totalConcession > 0) { %>
                <div style="display:flex;justify-content:space-between;margin-bottom:6px;">
                    <span>Concession</span><span style="font-weight:600;color:#9333ea;">₹<%= totalConcession.toLocaleString('en-IN') %></span>
                </div>
                <% } %>
                <div style="display:flex;justify-content:space-between;border-top:1px solid currentColor;padding-top:8px;margin-top:4px;font-weight:700;font-size:0.95rem;">
                    <span>Balance Due</span>
                    <span style="color:<%= balance>0?'#dc2626':'#16a34a' %>;">₹<%= Math.abs(balance).toLocaleString('en-IN') %></span>
                </div>
            </div>
        </div>
    </div>
</div>
