<div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;">
    <a href="/fees/admin/dashboard" class="btn btn-secondary btn-sm">← Dashboard</a>
    <h2 style="margin:0;">📈 Collection Report</h2>
    <% if (activeYear) { %><span class="badge badge-info"><%= activeYear.yearName %></span><% } %>
</div>

<div class="card" style="margin-bottom:16px;">
    <div class="card-body">
        <form method="GET" style="display:flex;gap:12px;flex-wrap:wrap;align-items:flex-end;">
            <div class="form-group" style="margin:0;">
                <label class="form-label">From Date</label>
                <input type="date" name="from" class="form-control" value="<%= from || '' %>">
            </div>
            <div class="form-group" style="margin:0;">
                <label class="form-label">To Date</label>
                <input type="date" name="to" class="form-control" value="<%= to || '' %>">
            </div>
            <div class="form-group" style="margin:0;">
                <label class="form-label">Mode</label>
                <select name="mode" class="form-control">
                    <option value="">All Modes</option>
                    <% ['cash','cheque','bank_transfer','online','dd','upi'].forEach(m => { %>
                    <option value="<%= m %>" <%= mode === m ? 'selected' : '' %>><%= m.replace(/_/g,' ').replace(/\b\w/g,c=>c.toUpperCase()) %></option>
                    <% }) %>
                </select>
            </div>
            <button type="submit" class="btn btn-primary" style="height:40px;">Filter</button>
            <a href="/fees/admin/reports/collection" class="btn btn-secondary" style="height:40px;line-height:24px;">Reset</a>
        </form>
    </div>
</div>

<div class="stats-grid" style="margin-bottom:20px;">
    <div class="stat-card">
        <div class="stat-icon green">💰</div>
        <div class="stat-info">
            <div class="stat-value">₹<%= (total.total || 0).toLocaleString('en-IN') %></div>
            <div class="stat-label">Total Collected</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon blue">📋</div>
        <div class="stat-info">
            <div class="stat-value"><%= total.count || 0 %></div>
            <div class="stat-label">Total Transactions</div>
        </div>
    </div>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
    <div class="card">
        <div class="card-header"><div class="card-title">By Payment Mode</div></div>
        <div class="table-wrapper">
            <% if (!byMode.length) { %>
            <div class="empty-state" style="padding:20px;"><p>No data.</p></div>
            <% } else { %>
            <table>
                <thead><tr><th>Mode</th><th>Transactions</th><th>Amount</th></tr></thead>
                <tbody>
                    <% byMode.forEach(row => { %>
                    <tr>
                        <td><span class="badge badge-secondary"><%= (row._id || '').replace(/_/g,' ').toUpperCase() %></span></td>
                        <td><%= row.count %></td>
                        <td style="font-weight:600;color:#16a34a;">₹<%= (row.total || 0).toLocaleString('en-IN') %></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
            <% } %>
        </div>
    </div>

    <div class="card">
        <div class="card-header"><div class="card-title">Daily Collection (Last 30 Days)</div></div>
        <div class="table-wrapper">
            <% if (!daily.length) { %>
            <div class="empty-state" style="padding:20px;"><p>No data.</p></div>
            <% } else { %>
            <table>
                <thead><tr><th>Date</th><th>Transactions</th><th>Amount</th></tr></thead>
                <tbody>
                    <% daily.forEach(row => { %>
                    <tr>
                        <td style="font-size:0.85rem;"><%= row._id %></td>
                        <td><%= row.count %></td>
                        <td style="font-weight:600;color:#16a34a;">₹<%= (row.total || 0).toLocaleString('en-IN') %></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
            <% } %>
        </div>
    </div>
</div>
