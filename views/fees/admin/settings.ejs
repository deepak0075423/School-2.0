<div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;">
    <a href="/fees/admin/dashboard" class="btn btn-secondary btn-sm">← Dashboard</a>
    <h2 style="margin:0;">⚙️ Fee Settings</h2>
</div>

<% if (success && success.length) { %><div class="alert alert-success"><%= success %></div><% } %>
<% if (error && error.length) { %><div class="alert alert-error"><%= error %></div><% } %>

<form method="POST" action="/fees/admin/settings">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">

        <!-- Payment Settings -->
        <div class="card">
            <div class="card-header"><div class="card-title">💳 Payment Settings</div></div>
            <div class="card-body">
                <div class="form-group">
                    <label style="display:flex;align-items:center;gap:10px;cursor:pointer;">
                        <input type="checkbox" name="onlinePaymentEnabled" value="1"
                            <%= settings.onlinePaymentEnabled ? 'checked' : '' %>>
                        <span class="form-label" style="margin:0;">Enable Online Payments</span>
                    </label>
                </div>

                <div class="form-group">
                    <label class="form-label">Payment Gateway</label>
                    <select name="paymentGateway" class="form-control" id="gatewaySelect" onchange="toggleGateway()">
                        <option value="none"      <%= (settings.paymentGateway || 'none') === 'none'      ? 'selected' : '' %>>None (Manual Only)</option>
                        <option value="razorpay"  <%= settings.paymentGateway === 'razorpay'  ? 'selected' : '' %>>Razorpay</option>
                        <option value="stripe"    <%= settings.paymentGateway === 'stripe'    ? 'selected' : '' %>>Stripe</option>
                    </select>
                </div>

                <div id="razorpayConfig" style="display:none;">
                    <div class="form-group">
                        <label class="form-label">Razorpay Key ID</label>
                        <input type="text" name="razorpayKeyId" class="form-control"
                            value="<%= settings.razorpayKeyId || '' %>" placeholder="rzp_live_…">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Razorpay Key Secret</label>
                        <input type="password" name="razorpayKeySecret" class="form-control"
                            value="<%= settings.razorpayKeySecret || '' %>" placeholder="••••••••">
                    </div>
                </div>

                <div id="stripeConfig" style="display:none;">
                    <div class="form-group">
                        <label class="form-label">Stripe Publishable Key</label>
                        <input type="text" name="stripePublishableKey" class="form-control"
                            value="<%= settings.stripePublishableKey || '' %>" placeholder="pk_live_…">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Stripe Secret Key</label>
                        <input type="password" name="stripeSecretKey" class="form-control"
                            value="<%= settings.stripeSecretKey || '' %>" placeholder="sk_live_…">
                    </div>
                </div>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                    <div class="form-group">
                        <label class="form-label">Currency</label>
                        <input type="text" name="currency" class="form-control"
                            value="<%= settings.currency || 'INR' %>" placeholder="INR">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Currency Symbol</label>
                        <input type="text" name="currencySymbol" class="form-control"
                            value="<%= settings.currencySymbol || '₹' %>" placeholder="₹">
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Rounding Rule</label>
                    <select name="roundingRule" class="form-control">
                        <option value="none"  <%= (settings.roundingRule || 'none') === 'none'  ? 'selected' : '' %>>None (2 decimals)</option>
                        <option value="round" <%= settings.roundingRule === 'round' ? 'selected' : '' %>>Round to nearest</option>
                        <option value="ceil"  <%= settings.roundingRule === 'ceil'  ? 'selected' : '' %>>Round up (ceil)</option>
                        <option value="floor" <%= settings.roundingRule === 'floor' ? 'selected' : '' %>>Round down (floor)</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Receipt Settings -->
        <div class="card">
            <div class="card-header"><div class="card-title">🧾 Receipt Configuration</div></div>
            <div class="card-body">
                <div class="form-group">
                    <label class="form-label">Receipt Number Prefix</label>
                    <input type="text" name="receiptPrefix" class="form-control"
                        value="<%= settings.receiptPrefix || 'REC' %>" placeholder="REC" maxlength="10">
                    <small style="color:var(--text-muted);font-size:0.78rem;">
                        Next receipt: <strong><%= settings.receiptPrefix || 'REC' %>-<%= new Date().getFullYear() %>-<%= String((settings.lastReceiptNumber || 0) + 1).padStart(6,'0') %></strong>
                    </small>
                </div>
                <div class="form-group">
                    <label class="form-label">Header Text</label>
                    <input type="text" name="receiptHeader" class="form-control"
                        value="<%= settings.receipt?.header || '' %>" placeholder="School address / slogan">
                </div>
                <div class="form-group">
                    <label class="form-label">Footer Text</label>
                    <textarea name="receiptFooter" class="form-control" rows="2"
                        placeholder="Thank you for your payment…"><%= settings.receipt?.footer || '' %></textarea>
                </div>
                <div class="form-group">
                    <label class="form-label">Custom Notes</label>
                    <textarea name="receiptCustomNotes" class="form-control" rows="2"
                        placeholder="Any additional notes printed on receipt"><%= settings.receipt?.customNotes || '' %></textarea>
                </div>
            </div>
        </div>
    </div>

    <div style="margin-top:20px;display:flex;gap:10px;">
        <button type="submit" class="btn btn-primary">💾 Save Settings</button>
        <a href="/fees/admin/dashboard" class="btn btn-secondary">Cancel</a>
    </div>
</form>

<script>
function toggleGateway() {
    const g = document.getElementById('gatewaySelect').value;
    document.getElementById('razorpayConfig').style.display = g === 'razorpay' ? '' : 'none';
    document.getElementById('stripeConfig').style.display   = g === 'stripe'   ? '' : 'none';
}
toggleGateway();
</script>
