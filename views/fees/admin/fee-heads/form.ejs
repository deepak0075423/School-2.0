<div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;">
    <a href="/fees/admin/fee-heads" class="btn btn-secondary btn-sm">← Back</a>
    <h2 style="margin:0;"><%= isEdit ? 'Edit' : 'Create' %> Fee Head</h2>
</div>

<% if (error && error.length) { %><div class="alert alert-error"><%= error %></div><% } %>

<div class="card" style="max-width:620px;">
    <div class="card-body">
        <form method="POST" action="/fees/admin/fee-heads/<%= isEdit ? feeHead._id + '/edit' : 'create' %>">

            <div class="form-group">
                <label class="form-label">Name <span style="color:#dc2626;">*</span></label>
                <input type="text" name="name" class="form-control" required
                    value="<%= feeHead?.name || '' %>" placeholder="e.g. Tuition Fee, Transport Fee, Sports Fee">
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                <div class="form-group">
                    <label class="form-label">Category</label>
                    <% if (categories && categories.length) { %>
                    <select name="category" class="form-control">
                        <option value="">— No Category —</option>
                        <% categories.forEach(cat => { %>
                        <option value="<%= cat._id %>"
                            <%= feeHead?.category?._id?.toString() === cat._id.toString() || feeHead?.category?.toString() === cat._id.toString() ? 'selected' : '' %>>
                            <%= cat.name %>
                        </option>
                        <% }) %>
                    </select>
                    <% } else { %>
                    <div style="padding:8px 12px;background:var(--bg-secondary);border-radius:6px;border:1px solid var(--border);font-size:0.82rem;color:var(--text-muted);">
                        No categories yet.
                        <a href="/fees/admin/fee-categories/create" target="_blank" style="color:#2563eb;">Create categories</a>
                        first, then come back.
                    </div>
                    <input type="hidden" name="category" value="">
                    <% } %>
                </div>
                <div class="form-group">
                    <label class="form-label">Type <span style="color:#dc2626;">*</span></label>
                    <select name="type" class="form-control" required>
                        <option value="recurring"   <%= (feeHead?.type === 'recurring'   || !feeHead) ? 'selected' : '' %>>Recurring (every month)</option>
                        <option value="one_time"    <%= feeHead?.type === 'one_time'    ? 'selected' : '' %>>One-Time (charged once)</option>
                        <option value="quarterly"   <%= feeHead?.type === 'quarterly'   ? 'selected' : '' %>>Quarterly (every 3 months)</option>
                        <option value="half_yearly" <%= feeHead?.type === 'half_yearly' ? 'selected' : '' %>>Half-Yearly (every 6 months)</option>
                    </select>
                    <small style="color:var(--text-muted);font-size:0.78rem;">Controls how often this fee appears in the fee book.</small>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Default Amount (₹)</label>
                <input type="number" name="defaultAmount" class="form-control" min="0" step="0.01"
                    value="<%= feeHead?.defaultAmount || 0 %>" placeholder="0.00">
                <small style="color:var(--text-muted);font-size:0.78rem;">Pre-filled in fee structures; can be overridden per structure.</small>
            </div>

            <div class="form-group">
                <label class="form-label">Description</label>
                <textarea name="description" class="form-control" rows="2"
                    placeholder="Optional notes about this fee"><%= feeHead?.description || '' %></textarea>
            </div>

            <div style="display:flex;gap:10px;margin-top:8px;">
                <button type="submit" class="btn btn-primary"><%= isEdit ? '💾 Update' : '✅ Create' %> Fee Head</button>
                <a href="/fees/admin/fee-heads" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
