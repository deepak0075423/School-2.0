<div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;">
    <a href="/fees/admin/fee-categories" class="btn btn-secondary btn-sm">← Back</a>
    <h2 style="margin:0;"><%= isEdit ? 'Edit' : 'Create' %> Fee Category</h2>
</div>

<% if (error && error.length) { %><div class="alert alert-error"><%= error %></div><% } %>

<div class="card" style="max-width:480px;">
    <div class="card-body">
        <form method="POST" action="/fees/admin/fee-categories/<%= isEdit ? category._id + '/edit' : 'create' %>">
            <div class="form-group">
                <label class="form-label">Category Name <span style="color:#dc2626;">*</span></label>
                <input type="text" name="name" class="form-control" required
                    value="<%= category?.name || '' %>"
                    placeholder="e.g. Tuition, Transport, Sports, Activity">
                <small style="color:var(--text-muted);font-size:0.78rem;">
                    This name appears in the fee head creation dropdown.
                </small>
            </div>
            <div style="display:flex;gap:10px;margin-top:8px;">
                <button type="submit" class="btn btn-primary">
                    <%= isEdit ? '💾 Update' : '✅ Create' %> Category
                </button>
                <a href="/fees/admin/fee-categories" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
