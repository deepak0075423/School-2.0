<div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;">
    <a href="/fees/admin/student-fees/<%= student._id %>" class="btn btn-secondary btn-sm">← Back</a>
    <h2 style="margin:0;">📒 Ledger — <%= student.name %></h2>
</div>

<div class="stats-grid" style="margin-bottom:20px;">
    <div class="stat-card">
        <div class="stat-icon <%= balance > 0 ? 'orange' : 'green' %>">
            <%= balance > 0 ? '⏳' : '✅' %>
        </div>
        <div class="stat-info">
            <div class="stat-value" style="color:<%= balance > 0 ? '#dc2626' : '#16a34a' %>;">
                ₹<%= Math.abs(balance).toLocaleString('en-IN') %>
            </div>
            <div class="stat-label"><%= balance > 0 ? 'Outstanding' : balance < 0 ? 'Credit Balance' : 'Settled' %></div>
        </div>
    </div>
    <% if (activeYear) { %>
    <div class="stat-card">
        <div class="stat-icon blue">📅</div>
        <div class="stat-info">
            <div class="stat-value" style="font-size:1rem;"><%= activeYear.yearName %></div>
            <div class="stat-label">Academic Year</div>
        </div>
    </div>
    <% } %>
    <div class="stat-card">
        <div class="stat-icon purple" style="background:rgba(147,51,234,0.15);color:#9333ea;">📝</div>
        <div class="stat-info">
            <div class="stat-value"><%= entries.length %></div>
            <div class="stat-label">Total Entries</div>
        </div>
    </div>
</div>

<div class="card">
    <div class="table-wrapper">
        <% if (!entries.length) { %>
        <div class="empty-state" style="padding:30px;"><div style="font-size:2rem;">📒</div><p>No ledger entries for this academic year.</p></div>
        <% } else { %>
        <table>
            <thead>
                <tr><th>Date</th><th>Category</th><th>Description</th><th>Debit (Dr)</th><th>Credit (Cr)</th><th>Running Balance</th></tr>
            </thead>
            <tbody>
                <% entries.forEach(e => { %>
                <tr>
                    <td style="font-size:0.78rem;white-space:nowrap;color:var(--text-muted);">
                        <%= new Date(e.createdAt).toLocaleDateString('en-IN', {day:'2-digit',month:'short',year:'numeric'}) %>
                    </td>
                    <td>
                        <span class="badge badge-<%= e.category === 'payment' ? 'success' : e.category === 'fee_charged' ? 'danger' : e.category === 'fine' ? 'warning' : 'secondary' %>"
                            style="text-transform:capitalize;font-size:0.72rem;"><%= e.category.replace(/_/g,' ') %></span>
                    </td>
                    <td style="font-size:0.82rem;max-width:260px;"><%= e.description %></td>
                    <td style="color:#dc2626;font-weight:600;">
                        <%= e.entryType === 'debit' ? '₹' + e.amount.toLocaleString('en-IN', {minimumFractionDigits:2}) : '' %>
                    </td>
                    <td style="color:#16a34a;font-weight:600;">
                        <%= e.entryType === 'credit' ? '₹' + e.amount.toLocaleString('en-IN', {minimumFractionDigits:2}) : '' %>
                    </td>
                    <td style="font-weight:700;color:<%= e.runningBalance > 0 ? '#dc2626' : '#16a34a' %>;">
                        ₹<%= Math.abs(e.runningBalance).toLocaleString('en-IN', {minimumFractionDigits:2}) %>
                        <span style="font-size:0.72rem;font-weight:400;"><%= e.runningBalance > 0 ? 'Dr' : 'Cr' %></span>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <% } %>
    </div>
</div>
