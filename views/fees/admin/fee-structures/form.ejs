<div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;">
    <a href="/fees/admin/fee-structures" class="btn btn-secondary btn-sm">← Back</a>
    <h2 style="margin:0;"><%= isEdit ? 'Edit' : 'Create' %> Fee Structure</h2>
</div>

<% if (error && error.length) { %><div class="alert alert-error"><%= error %></div><% } %>

<div class="card">
    <div class="card-body">
        <form method="POST" action="/fees/admin/fee-structures/<%= isEdit ? structure._id + '/edit' : 'create' %>" id="structureForm">

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                <div class="form-group">
                    <label class="form-label">Structure Name <span style="color:#dc2626;">*</span></label>
                    <input type="text" name="name" class="form-control" required
                        value="<%= structure?.name || '' %>" placeholder="e.g. Class 10 Fees 2025-26">
                </div>
                <div class="form-group">
                    <label class="form-label">Academic Year</label>
                    <select name="academicYearId" class="form-control">
                        <% academicYears.forEach(ay => { %>
                        <option value="<%= ay._id %>"
                            <%= (structure?.academicYear?.toString() === ay._id.toString() || activeYear?._id?.toString() === ay._id.toString()) ? 'selected' : '' %>>
                            <%= ay.yearName %> <%= ay.status === 'active' ? '(Active)' : '' %>
                        </option>
                        <% }) %>
                    </select>
                </div>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:16px;">
                <div class="form-group">
                    <label class="form-label">Level <span style="color:#dc2626;">*</span></label>
                    <select name="level" class="form-control" id="levelSelect" onchange="toggleScope()">
                        <option value="class"   <%= (structure?.level || 'class') === 'class'   ? 'selected' : '' %>>Class-wide</option>
                        <option value="section" <%= structure?.level === 'section' ? 'selected' : '' %>>Section-specific</option>
                    </select>
                </div>
                <div class="form-group" id="classGroup">
                    <label class="form-label">Class</label>
                    <select name="classId" class="form-control" id="classSelect">
                        <option value="">— Select Class —</option>
                        <% classes.forEach(c => { %>
                        <option value="<%= c._id %>" <%= structure?.class?.toString() === c._id.toString() ? 'selected' : '' %>>
                            Class <%= c.classNumber %> — <%= c.className %>
                        </option>
                        <% }) %>
                    </select>
                </div>
                <div class="form-group" id="sectionGroup" style="display:none;">
                    <label class="form-label">Section</label>
                    <select name="sectionId" class="form-control">
                        <option value="">— Select Section —</option>
                        <% sections.forEach(s => { %>
                        <option value="<%= s._id %>" <%= structure?.section?.toString() === s._id.toString() ? 'selected' : '' %>>
                            <%= s.class?.className %> — Section <%= s.sectionName %>
                        </option>
                        <% }) %>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Due Day of Month</label>
                    <input type="number" name="dueDay" class="form-control" min="1" max="31"
                        value="<%= structure?.dueDay || '' %>" placeholder="e.g. 10">
                    <small style="color:var(--text-muted);font-size:0.75rem;">Day (1–31) fees are due each month. Leave blank if not applicable.</small>
                </div>
            </div>

            <hr style="margin:20px 0;border-color:var(--border);">

            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
                <div>
                    <h3 style="margin:0;font-size:1rem;">Fee Components</h3>
                    <p style="margin:2px 0 0;font-size:0.78rem;color:var(--text-muted);">Fee head and amount are required for each component.</p>
                </div>
                <button type="button" class="btn btn-secondary btn-sm" onclick="addRow()">+ Add Component</button>
            </div>

            <div class="table-wrapper">
                <table id="feeTable">
                    <thead>
                        <tr>
                            <th style="width:45%;">Fee Head <span style="color:#dc2626;">*</span></th>
                            <th>Amount (₹) <span style="color:#dc2626;">*</span></th>
                            <th style="width:5%;"></th>
                        </tr>
                    </thead>
                    <tbody id="feeRows">
                        <% if (structure && structure.items && structure.items.length) { %>
                            <% structure.items.forEach((item, i) => { if (!item.isActive) return; %>
                            <tr id="row-<%= i %>">
                                <td>
                                    <select name="feeHeads" class="form-control" required onchange="prefillAmount(this, <%= i %>)">
                                        <option value="">— Select Fee Head —</option>
                                        <% feeHeads.forEach(h => { %>
                                        <option value="<%= h._id %>"
                                            data-default="<%= h.defaultAmount || 0 %>"
                                            <%= item.feeHead?._id?.toString() === h._id.toString() || item.feeHead?.toString() === h._id.toString() ? 'selected' : '' %>>
                                            <%= h.name %><% if (h.category?.name) { %> · <%= h.category.name %><% } %> (<%= { recurring:'Monthly', one_time:'One-Time', quarterly:'Quarterly', half_yearly:'Half-Yearly' }[h.type] || h.type %>)
                                        </option>
                                        <% }) %>
                                    </select>
                                </td>
                                <td>
                                    <input type="number" name="amounts" id="amt-<%= i %>" class="form-control amount-input"
                                        min="1" step="0.01" required value="<%= item.amount || '' %>" onchange="updateTotal()">
                                </td>
                                <td>
                                    <button type="button" class="btn btn-danger btn-sm" onclick="removeRow('<%= i %>')">✕</button>
                                </td>
                            </tr>
                            <% }) %>
                        <% } else { %>
                            <tr id="row-0">
                                <td>
                                    <select name="feeHeads" class="form-control" required onchange="prefillAmount(this, 0)">
                                        <option value="">— Select Fee Head —</option>
                                        <% feeHeads.forEach(h => { %>
                                        <option value="<%= h._id %>" data-default="<%= h.defaultAmount || 0 %>">
                                            <%= h.name %><% if (h.category?.name) { %> · <%= h.category.name %><% } %> (<%= { recurring:'Monthly', one_time:'One-Time', quarterly:'Quarterly', half_yearly:'Half-Yearly' }[h.type] || h.type %>)
                                        </option>
                                        <% }) %>
                                    </select>
                                </td>
                                <td>
                                    <input type="number" name="amounts" id="amt-0" class="form-control amount-input"
                                        min="1" step="0.01" required placeholder="0.00" onchange="updateTotal()">
                                </td>
                                <td>
                                    <button type="button" class="btn btn-danger btn-sm" onclick="removeRow('0')">✕</button>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <div style="text-align:right;margin-top:12px;font-size:1.05rem;font-weight:700;color:#1d4ed8;">
                Total: ₹<span id="totalDisplay">0</span>
            </div>

            <div style="display:flex;gap:10px;margin-top:20px;">
                <button type="submit" class="btn btn-primary" onclick="return validateForm()">
                    <%= isEdit ? '💾 Update' : '✅ Create' %> Structure
                </button>
                <a href="/fees/admin/fee-structures" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

<script>
let rowCount = <%= (structure?.items?.filter(i => i.isActive)?.length || 1) %>;

const feeHeadsOptions = `<option value="">— Select Fee Head —</option>` +
    [<% feeHeads.forEach((h, i) => { %>`<option value="<%= h._id %>" data-default="<%= h.defaultAmount || 0 %>"><%= h.name %><% if (h.category?.name) { %> · <%= h.category.name %><% } %> (<%= { recurring:'Monthly', one_time:'One-Time', quarterly:'Quarterly', half_yearly:'Half-Yearly' }[h.type] || h.type %>)</option>`<%= i < feeHeads.length-1 ? ',' : '' %><% }) %>].join('');

function toggleScope() {
    const level = document.getElementById('levelSelect').value;
    document.getElementById('classGroup').style.display   = level === 'class'   ? '' : 'none';
    document.getElementById('sectionGroup').style.display = level === 'section' ? '' : 'none';
}

function prefillAmount(sel, rowIdx) {
    const opt = sel.options[sel.selectedIndex];
    const def = parseFloat(opt?.dataset?.default) || 0;
    const amtInput = document.getElementById('amt-' + rowIdx);
    if (amtInput && (!amtInput.value || parseFloat(amtInput.value) === 0) && def > 0) {
        amtInput.value = def;
        updateTotal();
    }
}

function addRow() {
    const tbody = document.getElementById('feeRows');
    const tr = document.createElement('tr');
    tr.id = 'row-' + rowCount;
    tr.innerHTML = `
        <td><select name="feeHeads" class="form-control" required onchange="prefillAmount(this, ${rowCount})">${feeHeadsOptions}</select></td>
        <td><input type="number" name="amounts" id="amt-${rowCount}" class="form-control amount-input" min="1" step="0.01" required placeholder="0.00" onchange="updateTotal()"></td>
        <td><button type="button" class="btn btn-danger btn-sm" onclick="removeRow('${rowCount}')">✕</button></td>
    `;
    tbody.appendChild(tr);
    rowCount++;
}

function removeRow(id) {
    const rows = document.getElementById('feeRows').children;
    if (rows.length <= 1) { alert('At least one fee component is required.'); return; }
    const row = document.getElementById('row-' + id);
    if (row) { row.remove(); updateTotal(); }
}

function updateTotal() {
    const inputs = document.querySelectorAll('.amount-input');
    let total = 0;
    inputs.forEach(i => { total += parseFloat(i.value) || 0; });
    document.getElementById('totalDisplay').textContent = total.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function validateForm() {
    const selects = document.querySelectorAll('select[name="feeHeads"]');
    const amounts = document.querySelectorAll('input[name="amounts"]');
    for (let i = 0; i < selects.length; i++) {
        if (!selects[i].value) { alert('Please select a fee head for all components.'); selects[i].focus(); return false; }
        if (!amounts[i].value || parseFloat(amounts[i].value) <= 0) { alert('Please enter a valid amount (> 0) for all components.'); amounts[i].focus(); return false; }
    }
    // Check for duplicate fee heads
    const selected = [...selects].map(s => s.value).filter(Boolean);
    if (new Set(selected).size !== selected.length) { alert('Each fee head can only appear once in a structure.'); return false; }
    return true;
}

toggleScope();
updateTotal();
</script>
