<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
    <div>
        <h2 style="margin:0;">📒 School Fee Ledger</h2>
        <% if (activeYear) { %><span style="font-size:0.82rem;color:var(--text-muted);">Year: <%= activeYear.yearName %></span><% } %>
    </div>
    <a href="/fees/admin/dashboard" class="btn btn-secondary btn-sm">← Dashboard</a>
</div>

<div class="card" style="margin-bottom:16px;">
    <div class="card-body">
        <form method="GET" style="display:flex;gap:12px;flex-wrap:wrap;align-items:flex-end;">
            <div class="form-group" style="margin:0;">
                <label class="form-label">Category</label>
                <select name="category" class="form-control">
                    <option value="">All</option>
                    <% ['fee_charged','payment','concession','fine','refund','adjustment'].forEach(c => { %>
                    <option value="<%= c %>" <%= category === c ? 'selected' : '' %> style="text-transform:capitalize;">
                        <%= c.replace(/_/g,' ').replace(/\b\w/g,ch=>ch.toUpperCase()) %>
                    </option>
                    <% }) %>
                </select>
            </div>
            <div class="form-group" style="margin:0;">
                <label class="form-label">From</label>
                <input type="date" name="from" class="form-control" value="<%= from || '' %>">
            </div>
            <div class="form-group" style="margin:0;">
                <label class="form-label">To</label>
                <input type="date" name="to" class="form-control" value="<%= to || '' %>">
            </div>
            <button type="submit" class="btn btn-primary" style="height:40px;">Filter</button>
            <a href="/fees/admin/ledger" class="btn btn-secondary" style="height:40px;line-height:24px;">Clear</a>
        </form>
    </div>
</div>

<div class="card">
    <div class="table-wrapper">
        <% if (!entries.length) { %>
        <div class="empty-state" style="padding:30px;"><div style="font-size:2rem;">📒</div><p>No ledger entries found.</p></div>
        <% } else { %>
        <table>
            <thead>
                <tr><th>Date</th><th>Student</th><th>Category</th><th>Description</th><th>Debit</th><th>Credit</th></tr>
            </thead>
            <tbody>
                <% entries.forEach(e => { %>
                <tr>
                    <td style="font-size:0.78rem;white-space:nowrap;color:var(--text-muted);">
                        <%= new Date(e.createdAt).toLocaleDateString('en-IN', {day:'2-digit',month:'short',year:'numeric'}) %>
                    </td>
                    <td style="font-size:0.85rem;"><strong><%= e.student?.name || '—' %></strong></td>
                    <td>
                        <span class="badge badge-<%= e.category === 'payment' ? 'success' : e.category === 'fee_charged' ? 'danger' : e.category === 'fine' ? 'warning' : 'secondary' %>"
                            style="text-transform:capitalize;font-size:0.72rem;"><%= e.category.replace(/_/g,' ') %></span>
                    </td>
                    <td style="font-size:0.82rem;max-width:220px;"><%= e.description %></td>
                    <td style="color:#dc2626;font-weight:600;">
                        <%= e.entryType === 'debit'  ? '₹' + e.amount.toLocaleString('en-IN', {minimumFractionDigits:2}) : '' %>
                    </td>
                    <td style="color:#16a34a;font-weight:600;">
                        <%= e.entryType === 'credit' ? '₹' + e.amount.toLocaleString('en-IN', {minimumFractionDigits:2}) : '' %>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <% } %>
    </div>
</div>
