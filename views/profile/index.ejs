<div class="page-header" style="margin-bottom: 24px;">
    <h2>My Profile</h2>
    <p class="text-muted">Manage your personal and account information.</p>
</div>

<div class="card" style="max-width: 800px; margin: 0 auto; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); border-radius: 8px; border: 1px solid #e2e8f0; background: #fff; padding: 24px;">
    <form action="/profile/update" method="POST" enctype="multipart/form-data">

        <h3 style="color: #1e293b; margin-bottom: 16px; border-bottom: 1px solid #e2e8f0; padding-bottom: 8px;">Profile Picture</h3>
        <div style="display: flex; align-items: center; gap: 24px; margin-bottom: 24px;">
            <div style="width: 100px; height: 100px; border-radius: 50%; overflow: hidden; background-color: #3b82f6; color: white; display: flex; align-items: center; justify-content: center;">
                <% if (userObj.profileImage) { %>
                    <img src="<%= userObj.profileImage %>" alt="Profile" style="width: 100%; height: 100%; object-fit: cover;" />
                <% } else { %>
                    <span style="font-size: 3rem;"><%= userObj.name.charAt(0).toUpperCase() %></span>
                <% } %>
            </div>
            <div>
                <label class="form-label" style="font-weight: 500;">Upload New Picture</label>
                <input type="file" name="profileImage" class="form-control" accept="image/jpeg, image/png, image/webp" />
                <small class="text-muted" style="display:block; margin-top: 4px;">JPEG, PNG or WebP. Max 5MB.</small>
            </div>
        </div>

        <h3 style="color: #1e293b; margin-bottom: 16px; border-bottom: 1px solid #e2e8f0; padding-bottom: 8px;">Personal Details</h3>
        <div class="form-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px;">
            <div class="form-group">
                <label class="form-label" style="font-weight: 500;">Full Name</label>
                <input type="text" name="name" class="form-control" value="<%= userObj.name %>" required />
            </div>
            <div class="form-group">
                <label class="form-label" style="font-weight: 500;">Phone</label>
                <input type="text" name="phone" class="form-control" value="<%= userObj.phone %>" />
            </div>
            <div class="form-group">
                <label class="form-label" style="font-weight: 500;">Email (Read Only)</label>
                <input type="email" class="form-control" value="<%= userObj.email %>" style="background-color: #f1f5f9; cursor: not-allowed;" readonly />
            </div>
            <div class="form-group">
                <label class="form-label" style="font-weight: 500;">Account Role (Read Only)</label>
                <input type="text" class="form-control" value="<%= userObj.role.replace('_', ' ').toUpperCase() %>" style="background-color: #f1f5f9; cursor: not-allowed;" readonly />
            </div>
        </div>

        <% if (userObj.role === 'teacher') { %>
            <h3 style="color: #1e293b; margin-bottom: 16px; border-bottom: 1px solid #e2e8f0; padding-bottom: 8px;">Teacher Details</h3>
            <div class="form-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px;">
                <div class="form-group">
                    <label class="form-label" style="font-weight: 500;">Employee ID (Read Only)</label>
                    <input type="text" class="form-control" value="<%= profileData.employeeId %>" style="background-color: #f1f5f9; cursor: not-allowed;" readonly />
                </div>
                <div class="form-group">
                    <label class="form-label" style="font-weight: 500;">Gender</label>
                    <select name="gender" class="form-control">
                        <option value="Male" <%= profileData.gender === 'Male' ? 'selected' : '' %>>Male</option>
                        <option value="Female" <%= profileData.gender === 'Female' ? 'selected' : '' %>>Female</option>
                        <option value="Other" <%= profileData.gender === 'Other' ? 'selected' : '' %>>Other</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label" style="font-weight: 500;">Date of Birth</label>
                    <input type="date" name="dob" class="form-control" value="<%= profileData.dob ? profileData.dob.toISOString().split('T')[0] : '' %>" />
                </div>
                <div class="form-group">
                    <label class="form-label" style="font-weight: 500;">Qualification</label>
                    <input type="text" name="qualification" class="form-control" value="<%= profileData.qualification %>" />
                </div>
                <div class="form-group">
                    <label class="form-label" style="font-weight: 500;">Experience (Years)</label>
                    <input type="text" name="experience" class="form-control" value="<%= profileData.experience %>" />
                </div>
                <div class="form-group" style="grid-column:span 2;">
                    <label class="form-label" style="font-weight: 500;">Full Address</label>
                    <textarea name="address" class="form-control" rows="2"><%= profileData.address || '' %></textarea>
                </div>
            </div>

        <% } else if (userObj.role === 'student') { %>
            <h3 style="color: #1e293b; margin-bottom: 16px; border-bottom: 1px solid #e2e8f0; padding-bottom: 8px;">Student Details</h3>
            <div class="form-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px;">
                <div class="form-group">
                    <label class="form-label" style="font-weight: 500;">Admission Number (Read Only)</label>
                    <input type="text" class="form-control" value="<%= profileData.admissionNumber %>" style="background-color: #f1f5f9; cursor: not-allowed;" readonly />
                </div>
                <div class="form-group">
                    <label class="form-label" style="font-weight: 500;">Gender</label>
                    <select name="gender" class="form-control">
                        <option value="Male" <%= profileData.gender === 'Male' ? 'selected' : '' %>>Male</option>
                        <option value="Female" <%= profileData.gender === 'Female' ? 'selected' : '' %>>Female</option>
                        <option value="Other" <%= profileData.gender === 'Other' ? 'selected' : '' %>>Other</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label" style="font-weight: 500;">Date of Birth</label>
                    <input type="date" name="dob" class="form-control" value="<%= profileData.dob ? profileData.dob.toISOString().split('T')[0] : '' %>" />
                </div>
                <div class="form-group">
                    <label class="form-label" style="font-weight: 500;">Blood Group</label>
                    <input type="text" name="bloodGroup" class="form-control" value="<%= profileData.bloodGroup %>" />
                </div>
                <div class="form-group">
                    <label class="form-label" style="font-weight: 500;">Religion</label>
                    <input type="text" name="religion" class="form-control" value="<%= profileData.religion %>" />
                </div>
                <div class="form-group" style="grid-column:span 2;">
                    <label class="form-label" style="font-weight: 500;">Full Address</label>
                    <textarea name="address" class="form-control" rows="2"><%= profileData.address %></textarea>
                </div>
            </div>

        <% } else if (userObj.role === 'parent') { %>
            <h3 style="color: #1e293b; margin-bottom: 16px; border-bottom: 1px solid #e2e8f0; padding-bottom: 8px;">Parent/Guardian Details</h3>
            <div class="form-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px;">
                <div class="form-group">
                    <label class="form-label" style="font-weight: 500;">Father Occupation</label>
                    <input type="text" name="fatherOccupation" class="form-control" value="<%= profileData.fatherOccupation %>" />
                </div>
                <div class="form-group">
                    <label class="form-label" style="font-weight: 500;">Mother Occupation</label>
                    <input type="text" name="motherOccupation" class="form-control" value="<%= profileData.motherOccupation %>" />
                </div>
                <div class="form-group">
                    <label class="form-label" style="font-weight: 500;">Guardian Occupation</label>
                    <input type="text" name="guardianOccupation" class="form-control" value="<%= profileData.guardianOccupation %>" />
                </div>
                <div class="form-group">
                    <label class="form-label" style="font-weight: 500;">Emergency Contact No.</label>
                    <input type="text" name="emergencyContact" class="form-control" value="<%= profileData.emergencyContact %>" />
                </div>
                <div class="form-group">
                    <label class="form-label" style="font-weight: 500;">Annual Income</label>
                    <input type="text" name="annualIncome" class="form-control" value="<%= profileData.annualIncome %>" />
                </div>
            </div>
        <% } %>

        <div style="margin-top: 32px; display: flex; justify-content: flex-end;">
            <button type="submit" class="btn btn-primary" style="padding: 10px 24px; font-size: 1rem;">Save Changes</button>
        </div>
    </form>
</div>
