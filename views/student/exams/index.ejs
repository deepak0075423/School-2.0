<div class="page-header">
    <div>
        <h1>📝 My Exams</h1>
        <p>View and attempt your scheduled aptitude exams.</p>
    </div>
</div>

<% if (!exams || exams.length === 0) { %>
<div class="card">
    <div class="empty-state">
        <div class="empty-icon">📝</div>
        <h3>No Exams Scheduled</h3>
        <p>No aptitude exams have been scheduled for your section yet.</p>
    </div>
</div>
<% } else { %>
<div style="display:flex; flex-direction:column; gap:16px;">
    <% exams.forEach(exam => {
        const attempt = attemptMap[exam._id.toString()];
        const submitted = attempt && (attempt.status === 'submitted' || attempt.status === 'auto_submitted');
        const inProgress = attempt && attempt.status === 'in_progress';
        const windowStatus = exam._windowStatus;
        const now = new Date();
        const resultReady = exam.resultApprovalStatus === 'approved' &&
                            exam.resultPublishDate &&
                            now >= new Date(exam.resultPublishDate);
        const resultPending = submitted && !resultReady;
    %>
    <div class="card" style="border-left: 3px solid <%= windowStatus === 'active' ? '#22c55e' : windowStatus === 'upcoming' ? '#3b82f6' : resultReady ? '#a78bfa' : '#94a3b8' %>;">
        <div class="card-body" style="display:flex; align-items:flex-start; justify-content:space-between; gap:16px; flex-wrap:wrap;">
            <div style="flex:1; min-width:0;">
                <div style="display:flex; gap:8px; align-items:center; margin-bottom:6px; flex-wrap:wrap;">
                    <h3 style="margin:0; font-size:16px;"><%= exam.title %></h3>
                    <% if (windowStatus === 'active' && !submitted) { %>
                    <span style="background:rgba(34,197,94,.15); color:#22c55e; border:1px solid rgba(34,197,94,.3); border-radius:99px; font-size:11px; font-weight:700; padding:2px 10px;">🟢 LIVE</span>
                    <% } else if (windowStatus === 'upcoming') { %>
                    <span style="background:rgba(59,130,246,.12); color:#3b82f6; border:1px solid rgba(59,130,246,.3); border-radius:99px; font-size:11px; font-weight:700; padding:2px 10px;">⏳ Upcoming</span>
                    <% } else if (windowStatus === 'ended' || exam.status === 'completed') { %>
                    <span style="background:rgba(148,163,184,.1); color:#94a3b8; border:1px solid rgba(148,163,184,.2); border-radius:99px; font-size:11px; padding:2px 10px;">Ended</span>
                    <% } %>
                    <% if (submitted) { %>
                    <span style="background:rgba(34,197,94,.15); color:#22c55e; border:1px solid rgba(34,197,94,.3); border-radius:99px; font-size:11px; padding:2px 10px;">✓ Submitted</span>
                    <% } %>
                    <% if (resultReady) { %>
                    <span style="background:rgba(167,139,250,.15); color:#a78bfa; border:1px solid rgba(167,139,250,.3); border-radius:99px; font-size:11px; font-weight:700; padding:2px 10px;">📊 Result Available</span>
                    <% } else if (resultPending) { %>
                    <span style="background:rgba(245,158,11,.1); color:#f59e0b; border:1px solid rgba(245,158,11,.25); border-radius:99px; font-size:11px; padding:2px 10px;">⏳ Result Pending</span>
                    <% } %>
                </div>
                <div style="display:flex; gap:20px; flex-wrap:wrap; font-size:13px; color:var(--text-muted);">
                    <span>📅 <%= new Date(exam.examDate).toLocaleDateString('en-IN') %></span>
                    <span>🕐 <%= exam.startTime %></span>
                    <span>⏱ <%= exam.duration %> min</span>
                    <span>❓ <%= exam.totalQuestions %> questions</span>
                    <span>🎯 <%= exam.totalMarks %> marks</span>
                    <% if (exam.subject) { %><span>📚 <%= exam.subject.subjectName %></span><% } %>
                </div>
            </div>

            <div style="display:flex; gap:8px; flex-shrink:0; flex-wrap:wrap; align-items:center;">
                <% if (submitted) { %>
                <a href="/student/exams/<%= exam._id %>/result" class="btn <%= resultReady ? 'btn-primary' : 'btn-secondary' %>" style="padding:8px 16px;">
                    <%= resultReady ? '📊 View Result' : '📋 Check Status' %>
                </a>
                <% } else if (windowStatus === 'active' || inProgress) { %>
                <a href="/student/exams/<%= exam._id %>/attempt" class="btn btn-primary" style="padding:8px 16px;">
                    <%= inProgress ? '▶ Resume Exam' : '▶ Start Exam' %>
                </a>
                <% } else if (windowStatus === 'ended' || exam.status === 'completed') { %>
                <span style="font-size:13px; color:#94a3b8; padding:8px 0;">Not attempted</span>
                <% } else { %>
                <span style="font-size:13px; color:#3b82f6; padding:8px 0;">Starts at <%= exam.startTime %></span>
                <% } %>
            </div>
        </div>
    </div>
    <% }) %>
</div>
<% } %>
