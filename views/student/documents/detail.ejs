<style>
.file-row { display:flex; align-items:center; gap:10px; padding:10px 14px; background:var(--input-bg); border-radius:8px; margin-bottom:8px; }
.cat-badge { display:inline-block; padding:2px 10px; border-radius:10px; font-size:11px; font-weight:700; }
.cat-Assignment { background:#fef3c7; color:#92400e; }
.cat-Notes { background:#dbeafe; color:#1e40af; }
.cat-Circular { background:#d1fae5; color:#065f46; }
.cat-Report { background:#ede9fe; color:#5b21b6; }
.cat-Other { background:#f3f4f6; color:#374151; }
.status-submitted { background:#ecfdf5; color:#065f46; border:1px solid #a7f3d0; }
.status-late      { background:#fef2f2; color:#991b1b; border:1px solid #fecaca; }
.status-pending   { background:#fefce8; color:#a16207; border:1px solid #fde68a; }
.status-badge { display:inline-block; padding:2px 10px; border-radius:10px; font-size:11px; font-weight:700; }
.drop-zone { border:2px dashed var(--border); border-radius:10px; padding:28px; text-align:center; cursor:pointer; transition:border-color .15s; }
.drop-zone:hover, .drop-zone.drag-over { border-color:var(--primary); }
.file-preview-list { list-style:none; padding:0; margin:8px 0 0; }
.file-preview-list li { display:flex; align-items:center; gap:8px; padding:6px 10px; background:var(--input-bg); border-radius:6px; margin-bottom:6px; font-size:13px; }
.file-preview-list .remove-file { cursor:pointer; color:#ef4444; margin-left:auto; }
</style>

<div class="page-header">
    <div>
        <h1 class="page-title"><%= doc.title %></h1>
        <div style="display:flex; gap:8px; margin-top:4px; align-items:center; flex-wrap:wrap;">
            <span class="cat-badge cat-<%= doc.category %>"><%= doc.category %></span>
            <% if (doc.isAssignment) { %><span class="badge badge-orange">Assignment</span><% } %>
        </div>
    </div>
    <a href="/student/documents<%= doc.isAssignment ? '?tab=assignments' : '' %>" class="btn btn-secondary">← Back</a>
</div>

<div style="display:grid; grid-template-columns:1fr 300px; gap:20px;">

<!-- Left: files + submission -->
<div>
    <!-- Document files -->
    <div class="card" style="margin-bottom:16px;">
        <div class="card-header"><h2 class="card-title">Files</h2></div>
        <div class="card-body">
            <% doc.files.forEach(f => { %>
            <div class="file-row">
                <span style="font-size:22px;">📄</span>
                <div style="flex:1; min-width:0;">
                    <div class="fw-semibold" style="font-size:13px;"><%= f.originalName %></div>
                    <div class="text-muted" style="font-size:11px;"><%= fmtSize(f.fileSize) %></div>
                </div>
                <a href="<%= f.filePath %>" target="_blank" class="btn btn-sm btn-secondary">View</a>
                <a href="<%= f.filePath %>" download="<%= f.originalName %>" class="btn btn-sm btn-primary">↓</a>
            </div>
            <% }) %>
        </div>
    </div>

    <% if (doc.description) { %>
    <div class="card" style="margin-bottom:16px;">
        <div class="card-body"><p style="margin:0;"><%= doc.description %></p></div>
    </div>
    <% } %>

    <!-- Submission section -->
    <% if (doc.isAssignment && doc.allowSubmission) { %>
    <div class="card">
        <div class="card-header">
            <h2 class="card-title">Your Submission</h2>
        </div>
        <div class="card-body">

            <% if (mySubmission && mySubmission.status !== 'pending') { %>
            <!-- Already submitted -->
            <div style="margin-bottom:16px;">
                <div style="display:flex; align-items:center; gap:10px; margin-bottom:12px;">
                    <span class="status-badge status-<%= mySubmission.status %>"><%= mySubmission.status %></span>
                    <span class="text-muted" style="font-size:12px;">
                        Submitted <%= new Date(mySubmission.submittedAt).toLocaleString('en-IN',{day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
                    </span>
                </div>
                <% mySubmission.files.forEach(f => { %>
                <div class="file-row">
                    <span>📄</span>
                    <div style="flex:1;"><div style="font-size:13px;"><%= f.originalName %></div></div>
                    <a href="<%= f.filePath %>" download class="btn btn-sm btn-secondary">↓</a>
                </div>
                <% }) %>
                <% if (mySubmission.marks !== null) { %>
                <div style="background:var(--input-bg); border-radius:8px; padding:12px; margin-top:12px;">
                    <div style="font-size:13px; font-weight:600;">
                        Marks: <strong><%= mySubmission.marks %><%= doc.totalMarks ? '/' + doc.totalMarks : '' %></strong>
                    </div>
                    <% if (mySubmission.feedback) { %>
                    <div class="text-muted" style="font-size:13px; margin-top:6px;"><%= mySubmission.feedback %></div>
                    <% } %>
                </div>
                <% } %>
            </div>
            <p class="text-muted" style="font-size:13px; margin-bottom:10px;">You can re-submit to replace your existing submission:</p>
            <% } %>

            <!-- Upload form -->
            <% const dueDate = doc.dueDate ? new Date(doc.dueDate) : null;
               const isOverdue = dueDate && new Date() > dueDate; %>
            <% if (isOverdue && (!mySubmission || mySubmission.status === 'pending')) { %>
            <div style="background:#fef2f2; border:1px solid #fecaca; border-radius:8px; padding:10px 14px; margin-bottom:12px; font-size:13px; color:#991b1b;">
                ⚠️ Due date has passed. Your submission will be marked as late.
            </div>
            <% } %>

            <form method="POST" action="/student/documents/<%= doc._id %>/submit" enctype="multipart/form-data">
                <div class="drop-zone" id="dropZone" onclick="document.getElementById('subFileInput').click()">
                    <div style="font-size:28px; margin-bottom:6px;">📎</div>
                    <p style="margin:0; color:var(--text-secondary); font-size:13px;">Drag & drop or click to attach files</p>
                </div>
                <input type="file" id="subFileInput" name="files" multiple
                       accept=".pdf,.doc,.docx,.xls,.xlsx,.jpg,.jpeg,.png,.gif,.webp" style="display:none;" />
                <ul class="file-preview-list" id="subFileList"></ul>

                <button type="submit" class="btn btn-primary" style="margin-top:12px; width:100%;">
                    <%= mySubmission && mySubmission.status !== 'pending' ? 'Re-submit' : 'Submit Assignment' %>
                </button>
            </form>
        </div>
    </div>
    <% } else if (doc.isAssignment && !doc.allowSubmission) { %>
    <div class="card">
        <div class="card-body">
            <p class="text-muted" style="text-align:center; padding:10px 0;">File submission is disabled for this assignment.</p>
        </div>
    </div>
    <% } %>
</div>

<!-- Right: Info -->
<div>
    <div class="card">
        <div class="card-body">
            <table style="width:100%; font-size:13px; border-collapse:collapse;">
                <tr><td class="text-muted" style="padding:5px 0; width:90px;">From</td><td><%= doc.uploadedBy ? doc.uploadedBy.name : '—' %></td></tr>
                <tr><td class="text-muted" style="padding:5px 0;">Subject</td><td><%= doc.subject || '—' %></td></tr>
                <tr><td class="text-muted" style="padding:5px 0;">Date</td><td><%= new Date(doc.createdAt).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) %></td></tr>
                <% if (doc.tags && doc.tags.length) { %>
                <tr><td class="text-muted" style="padding:5px 0;">Tags</td><td><%= doc.tags.join(', ') %></td></tr>
                <% } %>
            </table>
        </div>
    </div>

    <% if (doc.isAssignment) { %>
    <div class="card" style="margin-top:12px;">
        <div class="card-header"><h2 class="card-title">Assignment Info</h2></div>
        <div class="card-body">
            <table style="width:100%; font-size:13px; border-collapse:collapse;">
                <tr><td class="text-muted" style="padding:4px 0;">Due</td>
                    <td><%= doc.dueDate ? new Date(doc.dueDate).toLocaleString('en-IN',{day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) : 'No due date' %></td></tr>
                <tr><td class="text-muted" style="padding:4px 0;">Marks</td>
                    <td><%= doc.totalMarks ? doc.totalMarks + ' marks' : 'Not graded' %></td></tr>
                <tr><td class="text-muted" style="padding:4px 0;">Submission</td>
                    <td><%= doc.allowSubmission ? 'Allowed' : 'View only' %></td></tr>
            </table>
        </div>
    </div>
    <% } %>
</div>

</div>

<script>
const dropZone  = document.getElementById('dropZone');
const fileInput = document.getElementById('subFileInput');
const fileList  = document.getElementById('subFileList');
let selectedFiles = [];

function renderList() {
    fileList.innerHTML = '';
    selectedFiles.forEach((f, i) => {
        const li = document.createElement('li');
        li.innerHTML = `<span>📄</span><span>${f.name}</span><span class="text-muted">(${(f.size/1024).toFixed(1)} KB)</span><span class="remove-file" data-idx="${i}" style="cursor:pointer;color:#ef4444;margin-left:auto;">✕</span>`;
        fileList.appendChild(li);
    });
}

function merge(newFiles) {
    const names = new Set(selectedFiles.map(f => f.name));
    for (const f of newFiles) if (!names.has(f.name)) selectedFiles.push(f);
    const dt = new DataTransfer(); selectedFiles.forEach(f => dt.items.add(f)); fileInput.files = dt.files;
    renderList();
}

dropZone && dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
dropZone && dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
dropZone && dropZone.addEventListener('drop', e => { e.preventDefault(); dropZone.classList.remove('drag-over'); merge([...e.dataTransfer.files]); });
fileInput && fileInput.addEventListener('change', () => merge([...fileInput.files]));
fileList && fileList.addEventListener('click', e => {
    if (e.target.classList.contains('remove-file')) {
        selectedFiles.splice(Number(e.target.dataset.idx), 1);
        const dt = new DataTransfer(); selectedFiles.forEach(f => dt.items.add(f)); fileInput.files = dt.files;
        renderList();
    }
});
</script>
