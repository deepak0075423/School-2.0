<div class="page-header">
    <div>
        <h1>📝 Class Test Results</h1>
        <p>View your class test performance and continuous assessment scores.</p>
    </div>
    <a href="/student/results" class="btn btn-secondary">Formal Exam Results</a>
</div>

<% if (!myTests || myTests.length === 0) { %>
<div class="card">
    <div class="empty-state">
        <div class="empty-icon">📝</div>
        <h3>No Class Tests Yet</h3>
        <p>Approved class test results will appear here.</p>
    </div>
</div>
<% } else { %>

<%
const bySubject = {};
myTests.forEach(t => {
    const sub = t.test.subject?.subjectName || 'Unknown';
    if (!bySubject[sub]) bySubject[sub] = { total: 0, count: 0 };
    if (!t.isAbsent && t.marks !== null) {
        const pct = (t.marks / t.test.maxMarks) * 100;
        bySubject[sub].total += pct;
        bySubject[sub].count++;
    }
});
const subjectEntries = Object.entries(bySubject);
%>

<% if (subjectEntries.length > 0) { %>
<div class="card" style="margin-bottom:20px;">
    <div class="card-header">
        <div class="card-title">Continuous Assessment (Internal) Score</div>
    </div>
    <div class="card-body">
        <p style="color:var(--text-muted); font-size:13px; margin-bottom:16px;">Average performance across all approved class tests per subject.</p>
        <div class="stats-grid" style="grid-template-columns:repeat(auto-fit,minmax(150px,1fr));">
            <% subjectEntries.forEach(([sub, data]) => { %>
            <div class="stat-card">
                <div class="stat-icon blue">📚</div>
                <div class="stat-info">
                    <div class="stat-value" style="font-size:18px;">
                        <%= data.count > 0 ? (data.total / data.count).toFixed(1) + '%' : '—' %>
                    </div>
                    <div class="stat-label"><%= sub %></div>
                    <div style="font-size:11px; color:var(--text-muted); margin-top:2px;"><%= data.count %> test<%= data.count !== 1 ? 's' : '' %></div>
                </div>
            </div>
            <% }) %>
        </div>
    </div>
</div>
<% } %>

<div class="card">
    <div class="card-header">
        <div class="card-title">All Class Tests</div>
    </div>
    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>Test Title</th>
                    <th>Subject</th>
                    <th>Date</th>
                    <th style="text-align:center;">Marks</th>
                    <th style="text-align:center;">Percentage</th>
                    <th style="text-align:center;">Grade</th>
                </tr>
            </thead>
            <tbody>
                <% myTests.forEach(t => { %>
                <tr>
                    <td class="fw-semibold">
                        <%= t.test.title %>
                        <% if (t.test.topic) { %><br><span style="color:var(--text-muted); font-size:11px;"><%= t.test.topic %></span><% } %>
                    </td>
                    <td><%= t.test.subject?.subjectName %></td>
                    <td style="font-size:13px; color:var(--text-muted);"><%= new Date(t.test.testDate).toLocaleDateString('en-IN') %></td>
                    <td style="text-align:center;">
                        <% if (t.isAbsent) { %><span class="badge badge-orange">Absent</span>
                        <% } else if (t.marks === null) { %><span class="text-muted">—</span>
                        <% } else { %><strong><%= t.marks %></strong>/<%= t.test.maxMarks %>
                        <% } %>
                    </td>
                    <td style="text-align:center;"><%= t.percentage !== null ? t.percentage + '%' : '—' %></td>
                    <td style="text-align:center;">
                        <% const g = t.grade || '—'; %>
                        <span class="badge <%= g==='F'||g==='AB' ? 'badge-red' : g.startsWith('A') ? 'badge-green' : g==='—' ? 'badge-gray' : 'badge-blue' %>"><%= g %></span>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>
<% } %>
