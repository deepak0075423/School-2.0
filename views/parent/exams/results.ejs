<div class="page-header">
    <div>
        <h1>📊 Exam Results</h1>
        <% if (child) { %><p><%= child.name %>'s published exam results.</p><% } %>
    </div>
</div>

<% if (!child) { %>
<div class="card">
    <div class="empty-state">
        <div class="empty-icon">👨‍👩‍👦</div>
        <h3>No Child Profile Found</h3>
        <p>Contact the school admin if you believe this is an error.</p>
    </div>
</div>
<% } else if (!results || results.length === 0) { %>
<div class="card">
    <div class="empty-state">
        <div class="empty-icon">📊</div>
        <h3>No Results Available</h3>
        <p>Results will appear here once they are approved and published by the class teacher.</p>
    </div>
</div>
<% } else { %>
<div style="display:flex; flex-direction:column; gap:16px;">
    <% results.forEach(r => { %>
    <div class="card">
        <div class="card-body">
            <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:16px; flex-wrap:wrap;">
                <div>
                    <h3 style="margin:0 0 4px; font-size:16px;"><%= r.exam?.title %></h3>
                    <div style="display:flex; gap:16px; font-size:13px; color:var(--text-muted); flex-wrap:wrap;">
                        <span>📅 <%= r.exam?.examDate ? new Date(r.exam.examDate).toLocaleDateString('en-IN') : '' %></span>
                        <% if (r.exam?.subject) { %><span>📚 <%= r.exam.subject.subjectName %></span><% } %>
                        <span>🏫 <%= r.exam?.section?.class?.className %> – <%= r.exam?.section?.sectionName %></span>
                    </div>
                </div>
                <div style="text-align:right; flex-shrink:0;">
                    <div style="font-size:28px; font-weight:800; color:<%= r.percentage >= 60 ? '#22c55e' : r.percentage >= 40 ? '#f59e0b' : '#ef4444' %>;">
                        <%= r.obtainedMarks %><span style="font-size:16px; color:var(--text-muted);">/<%= r.totalMarks %></span>
                    </div>
                    <div style="font-size:15px; font-weight:600; color:<%= r.percentage >= 60 ? '#22c55e' : r.percentage >= 40 ? '#f59e0b' : '#ef4444' %>;">
                        <%= r.percentage %>%
                    </div>
                </div>
            </div>

            <!-- Progress bar -->
            <div style="margin-top:14px; height:8px; background:var(--bg); border-radius:99px; overflow:hidden;">
                <div style="height:100%; width:<%= r.percentage %>%; background:<%= r.percentage >= 60 ? '#22c55e' : r.percentage >= 40 ? '#f59e0b' : '#ef4444' %>; border-radius:99px;"></div>
            </div>

            <% if (r.exam?.resultPublishDate) { %>
            <p style="font-size:12px; color:var(--text-muted); margin:8px 0 0;">
                Published: <%= new Date(r.exam.resultPublishDate).toLocaleDateString('en-IN') %>
            </p>
            <% } %>
        </div>
    </div>
    <% }) %>
</div>
<% } %>
