<div class="page-header">
    <div>
        <h1>📝 Child Class Test Results</h1>
        <p>View your child's performance in class tests.</p>
    </div>
    <a href="/parent/results" class="btn btn-secondary">Formal Exam Results</a>
</div>

<% if (!allTests || allTests.length === 0) { %>
<div class="card">
    <div class="empty-state">
        <div class="empty-icon">📝</div>
        <h3>No Class Test Results</h3>
        <p>Approved class test results will appear here.</p>
    </div>
</div>
<% } else { %>
<% allTests.forEach(({ child, tests }) => { %>
<div class="card" style="margin-bottom:20px;">
    <div class="card-header">
        <div class="card-title">👦 <%= child.name %></div>
    </div>
    <% if (!tests || tests.length === 0) { %>
        <div class="card-body" style="color:var(--text-muted);">No approved class tests yet.</div>
    <% } else { %>
    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>Test</th>
                    <th>Subject</th>
                    <th>Date</th>
                    <th style="text-align:center;">Marks</th>
                    <th style="text-align:center;">Grade</th>
                </tr>
            </thead>
            <tbody>
                <% tests.forEach(t => { %>
                <tr>
                    <td class="fw-semibold"><%= t.test.title %></td>
                    <td><%= t.test.subject?.subjectName %></td>
                    <td style="font-size:13px; color:var(--text-muted);"><%= new Date(t.test.testDate).toLocaleDateString('en-IN') %></td>
                    <td style="text-align:center;">
                        <% if (t.isAbsent) { %><span class="badge badge-orange">Absent</span>
                        <% } else if (t.marks === null) { %><span class="text-muted">—</span>
                        <% } else { %><strong><%= t.marks %></strong>/<%= t.test.maxMarks %>
                        <% } %>
                    </td>
                    <td style="text-align:center;">
                        <% const g = t.grade || '—'; %>
                        <span class="badge <%= g==='F'||g==='AB' ? 'badge-red' : g.startsWith('A') ? 'badge-green' : g==='—' ? 'badge-gray' : 'badge-blue' %>"><%= g %></span>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
    <% } %>
</div>
<% }) %>
<% } %>
