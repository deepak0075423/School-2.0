<div class="page-header">
    <div>
        <h1>📊 Child Results</h1>
        <p>View formal exam results for your child.</p>
    </div>
    <a href="/parent/results/class-tests" class="btn btn-secondary">Class Test Results</a>
</div>

<% if (!allResults || allResults.length === 0) { %>
<div class="card">
    <div class="empty-state">
        <div class="empty-icon">📊</div>
        <h3>No Results Available</h3>
        <p>Your child's exam results will appear here once they are published.</p>
    </div>
</div>
<% } else { %>
<% const typeLabel = { MID_TERM: 'Mid Term', FINAL: 'Final', UNIT_TEST: 'Unit Test' }; %>
<% allResults.forEach(({ child, results }) => { %>

<div class="card" style="margin-bottom:20px;">
    <div class="card-header">
        <div class="card-title">👦 <%= child.name %></div>
    </div>

    <% if (!results || results.length === 0) { %>
        <div class="card-body" style="color:var(--text-muted);">No published results yet.</div>
    <% } else { %>
    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>Exam</th>
                    <th>Type</th>
                    <th style="text-align:center;">Total Marks</th>
                    <th style="text-align:center;">Percentage</th>
                    <th style="text-align:center;">Grade</th>
                    <th style="text-align:center;">Rank</th>
                    <th style="text-align:center;">Result</th>
                    <th>Details</th>
                </tr>
            </thead>
            <tbody>
                <% results.forEach(r => { %>
                <tr>
                    <td class="fw-semibold"><%= r.exam?.title %></td>
                    <td><span class="badge badge-blue"><%= typeLabel[r.exam?.examType] || r.exam?.examType %></span></td>
                    <td style="text-align:center;"><%= r.totalMarks %>/<%= r.totalMaxMarks %></td>
                    <td style="text-align:center; font-weight:600;"><%= r.percentage %>%</td>
                    <td style="text-align:center;">
                        <span class="badge <%= r.grade==='F' ? 'badge-red' : r.grade.startsWith('A') ? 'badge-green' : 'badge-blue' %>">
                            <%= r.grade %>
                        </span>
                    </td>
                    <td style="text-align:center;">#<%= r.rank %></td>
                    <td style="text-align:center;">
                        <span class="badge <%= r.isPassed ? 'badge-green' : 'badge-red' %>">
                            <%= r.isPassed ? 'PASS' : 'FAIL' %>
                        </span>
                    </td>
                    <td>
                        <a href="/parent/results/<%= r._id %>" class="btn btn-sm btn-secondary">Details</a>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
    <% } %>
</div>

<% }) %>
<% } %>
