<div class="welcome-banner">
    <div class="welcome-icon">👪</div>
    <div>
        <h2>Welcome, <%= session.userName %>!</h2>
        <p>Parent Dashboard — <%= session.schoolName || '' %></p>
    </div>
</div>

<!-- Children -->
<div class="page-header" style="margin-bottom:16px;">
    <h1 style="font-size:18px;">👦 My Children</h1>
</div>

<% if (childProfiles.length===0) { %>
    <div class="card">
        <div class="empty-state">
            <div class="empty-icon">🎒</div>
            <h3>No children linked</h3>
            <p>Contact your school admin if your child's account is not linked.</p>
        </div>
    </div>
<% } else { %>
    <div id="fees" style="display:grid; grid-template-columns:repeat(auto-fit,minmax(300px,1fr)); gap:16px; margin-bottom:24px;">
        <% childProfiles.forEach(cp=> { %>
            <% const childId = cp.user ? cp.user._id : null; %>
            <div class="card" style="border-top:3px solid #3b82f6;">
                <div class="card-body" style="padding:18px;">
                    <div style="display:flex; align-items:center; gap:12px; margin-bottom:14px;">
                        <div class="user-avatar" style="width:48px; height:48px; font-size:20px; background:#3b82f6; color:#fff;">
                            <%= cp.user ? cp.user.name.charAt(0).toUpperCase() : '?' %>
                        </div>
                        <div>
                            <div style="font-weight:700; font-size:1rem;"><%= cp.user ? cp.user.name : '—' %></div>
                            <div style="font-size:0.75rem; color:var(--text-muted);">
                                <span class="badge badge-cyan" style="font-size:0.7rem;">Class <%= cp.class || '—' %></span>
                                <% if (cp.section) { %><span class="badge badge-purple" style="font-size:0.7rem;">Section <%= cp.section %></span><% } %>
                            </div>
                        </div>
                    </div>
                    <% if (childId) { %>
                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px;">
                        <a href="/fees/parent/child/<%= childId %>/fees" class="btn btn-secondary btn-sm" style="text-align:center; padding:8px;">
                            💰 View Fees
                        </a>
                        <a href="/fees/parent/child/<%= childId %>/pay" class="btn btn-primary btn-sm" style="text-align:center; padding:8px;">
                            💳 Pay Fees
                        </a>
                    </div>
                    <% } %>
                </div>
            </div>
        <% }) %>
    </div>
<% } %>

<!-- Feature Tiles + Calendar -->
<div style="display:grid; grid-template-columns:1fr 260px; gap:20px;">
    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:16px;">
        <div class="card">
            <div class="card-body" style="text-align:center; padding:28px 20px;">
                <div style="font-size:36px; margin-bottom:12px;">📊</div>
                <div class="card-title" style="margin-bottom:4px;">Grades</div>
                <p class="text-muted" style="font-size:12px; margin-bottom:10px;">View child's performance</p>
                <span class="badge badge-gray">Coming Soon</span>
            </div>
        </div>
        <div class="card">
            <div class="card-body" style="text-align:center; padding:28px 20px;">
                <div style="font-size:36px; margin-bottom:12px;">✅</div>
                <div class="card-title" style="margin-bottom:4px;">Attendance</div>
                <p class="text-muted" style="font-size:12px; margin-bottom:10px;">Track daily attendance</p>
                <span class="badge badge-gray">Coming Soon</span>
            </div>
        </div>
        <div class="card">
            <div class="card-body" style="text-align:center; padding:28px 20px;">
                <div style="font-size:36px; margin-bottom:12px;">💬</div>
                <div class="card-title" style="margin-bottom:4px;">Contact Teachers</div>
                <p class="text-muted" style="font-size:12px; margin-bottom:10px;">Communicate with staff</p>
                <span class="badge badge-gray">Coming Soon</span>
            </div>
        </div>
        <div class="card">
            <div class="card-body" style="text-align:center; padding:28px 20px;">
                <div style="font-size:36px; margin-bottom:12px;">📢</div>
                <div class="card-title" style="margin-bottom:4px;">Announcements</div>
                <p class="text-muted" style="font-size:12px; margin-bottom:10px;">School updates & notices</p>
                <span class="badge badge-gray">Coming Soon</span>
            </div>
        </div>
        <div class="card">
            <div class="card-body" style="text-align:center; padding:28px 20px;">
                <div style="font-size:36px; margin-bottom:12px;">📝</div>
                <div class="card-title" style="margin-bottom:4px;">Assignments</div>
                <p class="text-muted" style="font-size:12px; margin-bottom:10px;">View child's tasks</p>
                <span class="badge badge-gray">Coming Soon</span>
            </div>
        </div>
        <div class="card">
            <div class="card-body" style="text-align:center; padding:28px 20px;">
                <div style="font-size:36px; margin-bottom:12px;">💳</div>
                <div class="card-title" style="margin-bottom:4px;">Fee Status</div>
                <p class="text-muted" style="font-size:12px; margin-bottom:10px;">View & pay fees</p>
                <% if (childProfiles.length > 0) { %>
                <a href="/fees/parent/fees" class="btn btn-primary btn-sm">View Now</a>
                <% } else { %>
                <span class="badge badge-gray">No Child Linked</span>
                <% } %>
            </div>
        </div>
    </div>
    <%- include('../partials/dashboard-calendar', { hasHoliday, calendarHolidays, upcomingHolidays, holidayViewUrl }) %>
</div>
