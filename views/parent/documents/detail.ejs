<style>
.file-row { display:flex; align-items:center; gap:10px; padding:10px 14px; background:var(--input-bg); border-radius:8px; margin-bottom:8px; }
.cat-badge { display:inline-block; padding:2px 10px; border-radius:10px; font-size:11px; font-weight:700; }
.cat-Assignment { background:#fef3c7; color:#92400e; }
.cat-Notes { background:#dbeafe; color:#1e40af; }
.cat-Circular { background:#d1fae5; color:#065f46; }
.cat-Report { background:#ede9fe; color:#5b21b6; }
.cat-Other { background:#f3f4f6; color:#374151; }
.status-submitted { background:#ecfdf5; color:#065f46; border:1px solid #a7f3d0; }
.status-late      { background:#fef2f2; color:#991b1b; border:1px solid #fecaca; }
.status-pending   { background:#fefce8; color:#a16207; border:1px solid #fde68a; }
.status-badge { display:inline-block; padding:2px 10px; border-radius:10px; font-size:11px; font-weight:700; }
</style>

<div class="page-header">
    <div>
        <h1 class="page-title"><%= doc.title %></h1>
        <div style="display:flex; gap:8px; margin-top:4px;">
            <span class="cat-badge cat-<%= doc.category %>"><%= doc.category %></span>
            <% if (doc.isAssignment) { %><span class="badge badge-orange">Assignment</span><% } %>
        </div>
    </div>
    <a href="/parent/documents" class="btn btn-secondary">← Back</a>
</div>

<div style="display:grid; grid-template-columns:1fr 300px; gap:20px;">

<!-- Left -->
<div>
    <div class="card" style="margin-bottom:16px;">
        <div class="card-header"><h2 class="card-title">Files</h2></div>
        <div class="card-body">
            <% doc.files.forEach(f => { %>
            <div class="file-row">
                <span style="font-size:22px;">📄</span>
                <div style="flex:1; min-width:0;">
                    <div class="fw-semibold" style="font-size:13px;"><%= f.originalName %></div>
                    <div class="text-muted" style="font-size:11px;"><%= fmtSize(f.fileSize) %></div>
                </div>
                <a href="<%= f.filePath %>" target="_blank" class="btn btn-sm btn-secondary">View</a>
                <a href="<%= f.filePath %>" download="<%= f.originalName %>" class="btn btn-sm btn-primary">↓</a>
            </div>
            <% }) %>
        </div>
    </div>

    <% if (doc.description) { %>
    <div class="card" style="margin-bottom:16px;">
        <div class="card-body"><p style="margin:0;"><%= doc.description %></p></div>
    </div>
    <% } %>

    <!-- Child submissions -->
    <% if (doc.isAssignment && childSubmissions.length) { %>
    <div class="card">
        <div class="card-header"><h2 class="card-title">Child Submissions</h2></div>
        <div class="card-body">
            <% childSubmissions.forEach(sub => { %>
            <div style="border:1px solid var(--border); border-radius:8px; padding:14px; margin-bottom:10px;">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
                    <strong style="font-size:13px;"><%= sub.student ? sub.student.name : '—' %></strong>
                    <span class="status-badge status-<%= sub.status %>"><%= sub.status %></span>
                </div>
                <div class="text-muted" style="font-size:12px; margin-bottom:8px;">
                    Submitted: <%= sub.submittedAt ? new Date(sub.submittedAt).toLocaleString('en-IN',{day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) : '—' %>
                </div>
                <% sub.files.forEach(f => { %>
                <div class="file-row" style="padding:6px 10px;">
                    <span>📄</span>
                    <span style="font-size:12px; flex:1;"><%= f.originalName %></span>
                    <a href="<%= f.filePath %>" target="_blank" class="btn btn-sm btn-secondary">View</a>
                </div>
                <% }) %>
                <% if (sub.marks !== null) { %>
                <div style="background:var(--input-bg); border-radius:6px; padding:8px 12px; margin-top:8px; font-size:13px;">
                    <strong>Marks: <%= sub.marks %><%= doc.totalMarks ? '/' + doc.totalMarks : '' %></strong>
                    <% if (sub.feedback) { %><div class="text-muted" style="margin-top:4px;"><%= sub.feedback %></div><% } %>
                </div>
                <% } %>
            </div>
            <% }) %>
        </div>
    </div>
    <% } else if (doc.isAssignment) { %>
    <div class="card">
        <div class="card-body">
            <p class="text-muted" style="text-align:center;">No submissions from your child yet.</p>
        </div>
    </div>
    <% } %>
</div>

<!-- Right: Info -->
<div>
    <div class="card">
        <div class="card-body">
            <table style="width:100%; font-size:13px; border-collapse:collapse;">
                <tr><td class="text-muted" style="padding:5px 0; width:90px;">From</td><td><%= doc.uploadedBy ? doc.uploadedBy.name : '—' %></td></tr>
                <tr><td class="text-muted" style="padding:5px 0;">Subject</td><td><%= doc.subject || '—' %></td></tr>
                <tr><td class="text-muted" style="padding:5px 0;">Date</td><td><%= new Date(doc.createdAt).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) %></td></tr>
            </table>
        </div>
    </div>

    <% if (doc.isAssignment) { %>
    <div class="card" style="margin-top:12px;">
        <div class="card-header"><h2 class="card-title">Assignment Info</h2></div>
        <div class="card-body">
            <table style="width:100%; font-size:13px; border-collapse:collapse;">
                <tr><td class="text-muted" style="padding:4px 0;">Due</td>
                    <td><%= doc.dueDate ? new Date(doc.dueDate).toLocaleString('en-IN',{day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) : 'No due date' %></td></tr>
                <tr><td class="text-muted" style="padding:4px 0;">Marks</td>
                    <td><%= doc.totalMarks ? doc.totalMarks : 'Not graded' %></td></tr>
            </table>
        </div>
    </div>
    <% } %>
</div>

</div>
