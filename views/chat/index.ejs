    <div class="fg">
      <label>Add Members</label>
      <input type="text" id="grpMemberSearch" placeholder="Search…" oninput="filterGroupContacts(this.value)" autocomplete="off" style="margin-bottom:7px;">
      <div class="cgrid" id="grpContactGrid">
        <div style="padding:20px;text-align:center;color:#484f58;font-size:12px;">Loading…</div>
      </div>
    </div>
    <div id="selectedMembersLabel" style="font-size:12px;color:#388bfd;margin:6px 0;min-height:16px;"></div>
    <button class="btn-pri" onclick="createGroup()">Create Group</button>
  </div>
</div>

<!-- Group Members -->
<div class="mo" id="membersModal" onclick="if(event.target===this)closeModal('membersModal')">
  <div class="mb">
    <button class="mb-close" onclick="closeModal('membersModal')">×</button>
    <div class="mb-title" id="memberModalTitle">👥 Members</div>
    <div id="membersList"></div>

    <!-- Add member section — visible to admins only (rendered server-side for role check) -->
