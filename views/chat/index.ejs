<!-- ═════════════════════════ SCRIPTS ══════════════════════════════════════ -->
<% if (gatewayUrl) { %>
<script src="<%= gatewayUrl %>/socket.io/socket.io.js"></script>
<% } else { %>
<script src="/socket.io/socket.io.js"></script>
<% } %>
<script>
'use strict';
/* ════ Constants ════════════════════════════════════════════════════════════ */
const MY_ID       = '<%= _myId %>';
const MY_ROLE     = '<%= _myRole %>';
const MY_NAME     = '<%= _myName %>';
const GATEWAY_URL = '<%= gatewayUrl %>';

/* ════ State ════════════════════════════════════════════════════════════════ */
let socket              = null;
let allChats            = [];
let activeChat          = null;
let activeChatId        = null;
let replyToMsg          = null;
let typingTimer         = null;
let allContacts         = [];
let groupContacts       = [];
let addMemberContacts   = [];
let selectedGroupMembers = new Set();
let isAmIAdmin          = false;
let loadingMore         = false;
let hasMoreMessages     = false;
let onlineUsers         = new Set();
let searchTimer         = null;
let currentMembers      = [];   // cached for add-member filtering

/* ════ Socket ═══════════════════════════════════════════════════════════════ */
function initSocket() {
    socket = GATEWAY_URL
        ? io(GATEWAY_URL, { transports: ['websocket', 'polling'], withCredentials: true })
        : io({ transports: ['websocket', 'polling'] });

    socket.on('connect',       () => console.log('[Socket] connected:', socket.id));
    socket.on('connect_error', e  => console.warn('[Socket] error:', e.message));

    socket.on('chat:message',         onIncomingMessage);
    socket.on('chat:typing',          onTypingStart);
    socket.on('chat:stop_typing',     onTypingStop);
    socket.on('chat:message_read',    onMessageRead);
    socket.on('chat:message_edited',  onMessageEdited);
    socket.on('chat:message_deleted', onMessageDeleted);
    socket.on('chat:user_online',     d => { onlineUsers.add(d.userId);    updatePresence(d.userId, true); });
    socket.on('chat:user_offline',    d => { onlineUsers.delete(d.userId); updatePresence(d.userId, false); });
    socket.on('chat:group_created',   onGroupCreated);
    socket.on('chat:group_updated',   onGroupUpdated);
    socket.on('chat:member_removed',  onMemberRemoved);
    socket.on('chat:member_added',    () => loadChats());
    socket.on('chat:reaction',        onReactionUpdate);
    socket.on('chat:error',           d => toast('⚠️ ' + d.message, '#f85149'));
}

/* ════ Boot ═════════════════════════════════════════════════════════════════ */
document.addEventListener('DOMContentLoaded', async () => {
    initSocket();
    await loadChats();
    document.getElementById('chatMessages').addEventListener('scroll', onMsgsScroll);
    const hash = location.hash.replace('#', '');
    if (hash) openChat(hash);
});

/* ════ Chat list ════════════════════════════════════════════════════════════ */
async function loadChats() {
    try {
        const r = await api('/chat/api/chats');
        allChats = r.chats || [];
        renderChatList(allChats);
    } catch { }
}

function renderChatList(chats) {
    const el = document.getElementById('chatList');
    if (!chats.length) {
        el.innerHTML = '<div style="padding:28px 16px;text-align:center;color:#484f58;font-size:12px;">No conversations yet.<br>Tap ✏️ to start one!</div>';
        return;
    }
    el.innerHTML = chats.map(c => {
        const name    = esc(c.displayName || c.name || 'Group');
        const preview = chatPreview(c.lastMessage);
        const time    = c.lastActivity ? timeAgo(c.lastActivity) : '';
        const badge   = c.unreadCount  ? `<div class="ci-badge">${c.unreadCount > 99 ? '99+' : c.unreadCount}</div>` : '';
        const avClass = c.type === 'broadcast' ? 'bcast' : c.type === 'group' ? 'grp' : '';
        const typePrefix = c.type === 'broadcast' ? '📢 ' : c.type === 'group' ? '👥 ' : '';
        return `<div class="ci${activeChatId===String(c._id)?' active':''}" id="ci-${c._id}" onclick="openChat('${c._id}')">
            <div class="ca ${avClass}">${c.displayAvatar ? `<img src="${esc(c.displayAvatar)}" alt="">` : name.charAt(0).toUpperCase()}</div>
            <div class="ci-body">
              <div class="ci-top">
                <div class="ci-name">${typePrefix}${name}</div>
                <div class="ci-time">${time}</div>
              </div>
              <div class="ci-preview">${preview}</div>
            </div>
            ${badge}
          </div>`;
    }).join('');
}

function filterChatList(q) {
    if (!q) { renderChatList(allChats); return; }
    const s = q.toLowerCase();
    renderChatList(allChats.filter(c => (c.displayName || c.name || '').toLowerCase().includes(s)));
}

/* ════ Open chat ════════════════════════════════════════════════════════════ */
async function openChat(chatId) {
    activeChatId = String(chatId);
    const chat   = allChats.find(c => String(c._id) === activeChatId);
    activeChat   = chat;

    // Fix: reset unread so re-renders don't show stale badge
    if (chat) chat.unreadCount = 0;

    // Close and reset per-chat search bar when switching chats
    const csb = document.getElementById('chatSearchBar');
    if (csb) { csb.classList.remove('open'); }
    const csi = document.getElementById('inChatSearchInput');
    if (csi) csi.value = '';
    const csr = document.getElementById('chatSearchResults');
    if (csr) csr.innerHTML = '';

    document.querySelectorAll('.ci').forEach(el => el.classList.remove('active'));
    const ci = document.getElementById(`ci-${chatId}`);
    if (ci) { ci.classList.add('active'); const b = ci.querySelector('.ci-badge'); if (b) b.remove(); }

    const name    = chat ? (chat.displayName || chat.name || 'Group') : '…';
    const isGroup = chat && (chat.type === 'group' || chat.type === 'broadcast');
    document.getElementById('winName').textContent = name;
    document.getElementById('winSub').textContent  = isGroup
        ? (chat.type === 'broadcast' ? '📢 Broadcast channel' : '👥 Group')
        : roleLabel(chat && chat.otherUser && chat.otherUser.role);

    const av = document.getElementById('winAvatar');
    av.className = 'ca ' + (isGroup ? (chat.type === 'broadcast' ? 'bcast' : 'grp') : '');
    av.innerHTML = (chat && chat.displayAvatar)
        ? `<img src="${esc(chat.displayAvatar)}" alt="">`
        : `<span>${name.charAt(0).toUpperCase()}</span>`;

    document.getElementById('membersBtn').style.display = isGroup ? '' : 'none';

    const isReadOnly = chat && chat.isReadOnly;
    const canPost    = !isReadOnly || ['school_admin','super_admin','teacher'].includes(MY_ROLE);
    document.getElementById('chatInputRow').style.display    = canPost ? '' : 'none';
    document.getElementById('readonlyNotice').style.display  = canPost  ? 'none' : '';

    isAmIAdmin = chat && chat.memberRole === 'admin';

    document.getElementById('chatEmpty').style.display  = 'none';
    const win = document.getElementById('chatWindow');
    win.style.display       = 'flex';
    win.style.flexDirection = 'column';

    // Mobile: show back button, switch panel
    if (window.innerWidth <= 640) {
        document.getElementById('chatShell').classList.add('chat-open');
        document.getElementById('backBtn').style.display = '';
    }

    document.getElementById('chatMessages').innerHTML = '<div style="padding:40px;text-align:center;color:#484f58;font-size:12px;">Loading…</div>';
    hasMoreMessages = false;
    await loadMessages();

    if (socket) {
        socket.emit('chat:read', { chatId, messageId: null });
    }
    location.hash = chatId;
}

function closeChat() {
    activeChatId = null; activeChat = null;
    document.getElementById('chatWindow').style.display  = 'none';
    document.getElementById('chatEmpty').style.display   = '';
    document.getElementById('chatShell').classList.remove('chat-open');
    document.getElementById('backBtn').style.display     = 'none';
    document.querySelectorAll('.ci').forEach(el => el.classList.remove('active'));
    history.replaceState(null, '', location.pathname);
}

/* ════ Messages ══════════════════════════════════════════════════════════════ */
let _msgs = [];

async function loadMessages(before) {
    try {
        let url = `/chat/api/chats/${activeChatId}/messages?limit=40`;
        if (before) url += `&before=${before}`;
        const r = await api(url);
        if (!before) _msgs = r.messages || [];
        else         _msgs = [...(r.messages || []), ..._msgs];
        hasMoreMessages = r.hasMore;
        renderMessages(_msgs, !!before);
    } catch { }
}

function renderMessages(msgs, prepend = false) {
    const el    = document.getElementById('chatMessages');
    const prevH = el.scrollHeight;

    if (!msgs.length) {
        el.innerHTML = '<div style="padding:48px 16px;text-align:center;color:#484f58;font-size:12px;">No messages yet. Say hello! 👋</div>';
        return;
    }

    el.innerHTML = '';
    let lastDate = '';
    msgs.forEach(m => {
        const d = new Date(m.createdAt).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' });
        if (d !== lastDate) { el.innerHTML += `<div class="msg-date"><span>${d}</span></div>`; lastDate = d; }
        el.innerHTML += buildMsg(m);
    });

    if (prepend) el.scrollTop = el.scrollHeight - prevH;
    else         el.scrollTop = el.scrollHeight;
}

function buildMsg(msg) {
    const isObserver    = !!adminObserverChatId;
    // In observer mode use the viewed user's ID as "me" so their messages appear on the right
    const perspectiveId = isObserver && adminViewUser ? String(adminViewUser._id) : MY_ID;
    const isMine        = String(msg.sender?._id || msg.sender) === perspectiveId;
    const s          = msg.sender || {};
    const time       = new Date(msg.createdAt).toLocaleTimeString('en-IN', { hour:'2-digit', minute:'2-digit' });

    // Permissions: students and parents cannot edit or delete
    const restricted = ['student', 'parent'].includes(MY_ROLE);
    const canEdit    = isMine && !restricted && !isObserver;
    const canDelete  = !isObserver && ((isMine && !restricted) || MY_ROLE === 'school_admin');
    const showMenu   = !isObserver && !msg.isDeleted;

    // Always show sender name for observer mode or group chats
    const showSender = isObserver || (!isMine && activeChat && activeChat.type !== 'direct');

    if (msg.isDeleted) {
        return `<div class="msg-row${isMine?' mine':''}" id="msg-${msg._id}">
            <div class="msg-av">${!isMine ? miniAv(s.name, s.profileImage) : ''}</div>
            <div class="msg-bw">
              <div class="msg-bubble deleted">🚫 This message was deleted</div>
              <div class="msg-meta"><span class="msg-time">${time}</span></div>
            </div></div>`;
    }

    const replyHtml     = (msg.replyTo && !msg.replyTo.isDeleted)
        ? `<div class="msg-reply">↩ <b>${esc((msg.replyTo.sender && msg.replyTo.sender.name) || 'Unknown')}</b>: ${esc(trunc(msg.replyTo.content || '', 60))}</div>`
        : '';
    const fwdHtml       = msg.isForwarded ? `<div class="msg-forwarded">↗ Forwarded</div>` : '';
    const contentHtml   = `<div class="msg-text">${esc(msg.content || '')}</div>`;
    const editBadge     = msg.isEdited ? '<span class="msg-edited"> · edited</span>' : '';
    const statusIcon    = isMine ? (msg._delivered ? '<span class="msg-seen">Seen</span>' : '<span class="msg-sent">Sent</span>') : '';
    const reactionsHtml = _buildReactionsHtml(msg._id, msg.reactions || []);

    const menuHtml = showMenu ? `
        <button class="msg-dd-btn" onclick="toggleMsgMenu(event,'${msg._id}')">▾</button>
        <div class="msg-dropdown" id="dd-${msg._id}">
          <div class="msg-dd-item" onclick="doReply('${msg._id}')">↩ Reply</div>
          <div class="msg-dd-item" onclick="doForward('${msg._id}')">↗ Forward</div>
          <div class="msg-dd-item" onclick="doReact(event,'${msg._id}')">😊 React</div>
          ${canEdit   ? `<div class="msg-dd-item" onclick="doEdit('${msg._id}')">✏️ Edit</div>` : ''}
          ${canDelete ? `<div class="msg-dd-item danger" onclick="doDelete('${msg._id}')">🗑 Delete</div>` : ''}
        </div>
        <div class="react-picker" id="rp-${msg._id}">
          ${['👍','❤️','😂','😮','😢','🙏'].map(e => `<span class="rp-opt" onclick="sendReaction('${msg._id}','${e}')">${e}</span>`).join('')}
        </div>` : '';

    return `<div class="msg-row${isMine?' mine':''}" id="msg-${msg._id}"
        data-sender="${escAttr(s.name||'Unknown')}"
        data-content="${escAttr(trunc(msg.content||'', 80))}">
        <div class="msg-av">${!isMine ? miniAv(s.name, s.profileImage) : ''}</div>
        <div class="msg-bw">
          ${showSender ? `<div class="msg-sname">${esc(s.name||'Unknown')} <span style="font-weight:400;opacity:.6;font-size:10px;">${roleLabel(s.role)}</span></div>` : ''}
          <div class="msg-bubble">
            ${fwdHtml}${replyHtml}${contentHtml}
            <div class="msg-meta"><span class="msg-time">${time}</span>${editBadge}${statusIcon}</div>
            ${menuHtml}
          </div>
          ${reactionsHtml}
        </div></div>`;
}

/* ════ Notification sound (Web Audio API — no file needed) ══════════════════ */
let _audioCtx = null;
function _playNotifSound() {
    try {
        if (!_audioCtx) _audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        const ctx = _audioCtx;
        // Two-tone "ping": 880 Hz then 1100 Hz
        const beep = (freq, startAt, dur) => {
            const osc  = ctx.createOscillator();
            const gain = ctx.createGain();
            osc.connect(gain);
            gain.connect(ctx.destination);
            osc.type      = 'sine';
            osc.frequency.value = freq;
            gain.gain.setValueAtTime(0, ctx.currentTime + startAt);
            gain.gain.linearRampToValueAtTime(0.18, ctx.currentTime + startAt + 0.01);
            gain.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + startAt + dur);
            osc.start(ctx.currentTime + startAt);
            osc.stop(ctx.currentTime  + startAt + dur);
        };
        beep(880,  0,    0.12);
        beep(1100, 0.13, 0.14);
    } catch { /* AudioContext not available — silently skip */ }
}

/* ════ Incoming socket events ════════════════════════════════════════════════ */
function onIncomingMessage(msg) {
    if (msg.tempId) { const el = document.getElementById(`opt-${msg.tempId}`); if (el) el.remove(); }

    const isCurrent = activeChatId && String(msg.chat) === activeChatId;
    // Play notification sound only when the message is from someone else and NOT in the active chat
    if (!isCurrent && String(msg.sender?._id || msg.sender) !== MY_ID) {
        _playNotifSound();
    }

    if (isCurrent) {
        _msgs.push(msg);
        const el     = document.getElementById('chatMessages');
        const atBot  = el.scrollHeight - el.clientHeight - el.scrollTop < 100;
        const d      = new Date(msg.createdAt).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' });
        const lastD  = el.querySelector('.msg-date:last-of-type');
        if (!lastD || lastD.textContent.trim() !== d) {
            el.innerHTML += `<div class="msg-date"><span>${d}</span></div>`;
        }
        el.innerHTML += buildMsg(msg);
        if (atBot) el.scrollTop = el.scrollHeight;
        if (socket) socket.emit('chat:read', { chatId: activeChatId, messageId: msg._id });
    }
    updateListPreview(String(msg.chat), msg);
}

function onTypingStart(data) {
    if (!activeChatId || String(data.chatId) !== activeChatId || data.userId === MY_ID) return;
    document.getElementById('typingBar').textContent = 'Someone is typing…';
}

function onTypingStop(data) {
    if (!activeChatId || String(data.chatId) !== activeChatId || data.userId === MY_ID) return;
    document.getElementById('typingBar').textContent = '';
}

function onMessageRead(data) {
    if (!data || !data.chatId || String(data.chatId) !== activeChatId) return;
    // When the other side reads, mark all my "Sent" messages in this chat as "Seen"
    document.querySelectorAll('#chatMessages .msg-row.mine .msg-sent').forEach(el => {
        el.className = 'msg-seen';
        el.textContent = 'Seen';
    });
}

function onMessageEdited(data) {
    if (!activeChatId || String(data.chatId) !== activeChatId) return;
    const idx = _msgs.findIndex(m => String(m._id) === String(data.messageId));
    if (idx >= 0) { _msgs[idx].content = data.content; _msgs[idx].isEdited = true; }
    const el = document.getElementById(`msg-${data.messageId}`);
    if (!el) return;
    const t = el.querySelector('.msg-text'); if (t) t.textContent = data.content;
    const meta = el.querySelector('.msg-meta');
    if (meta && !meta.querySelector('.msg-edited')) meta.insertAdjacentHTML('beforeend', '<span class="msg-edited"> · edited</span>');
}

function onMessageDeleted(data) {
    if (!activeChatId || String(data.chatId) !== activeChatId) return;
    const idx = _msgs.findIndex(m => String(m._id) === String(data.messageId));
    if (idx >= 0) _msgs[idx].isDeleted = true;
    const el = document.getElementById(`msg-${data.messageId}`);
    if (el) {
        const b = el.querySelector('.msg-bubble');
        if (b) { b.className = 'msg-bubble deleted'; b.innerHTML = '🚫 This message was deleted'; }
        const a = el.querySelector('.msg-actions'); if (a) a.remove();
    }
}

function onGroupCreated(data) { toast(`New group created: ${data.name}`, '#3fb950'); loadChats(); }

function onGroupUpdated(data) {
    if (activeChat && String(activeChat._id) === String(data.chatId)) {
        if (data.name !== undefined) { activeChat.name = data.name; document.getElementById('winName').textContent = data.name; }
        if (data.isReadOnly !== undefined) {
            activeChat.isReadOnly = data.isReadOnly;
            const can = !data.isReadOnly || ['school_admin','super_admin','teacher'].includes(MY_ROLE);
            document.getElementById('chatInputRow').style.display   = can ? '' : 'none';
            document.getElementById('readonlyNotice').style.display = can ? 'none' : '';
        }
    }
    loadChats();
}

function onMemberRemoved(data) {
    if (data.userId === MY_ID) {
        toast('You were removed from this group.', '#f85149');
        closeChat();
    }
    loadChats();
}

function updatePresence(userId, online) {
    if (activeChat && activeChat.type === 'direct' && activeChat.otherUser && String(activeChat.otherUser._id) === userId) {
        document.getElementById('winSub').textContent = online ? '🟢 Online' : '⚫ Offline';
    }
}

/* ════ Send message ══════════════════════════════════════════════════════════ */
async function sendMessage() {
    const ta      = document.getElementById('msgInput');
    if (ta.dataset.editingId) return;   // startEdit's own keydown handler owns Enter in edit mode
    const content = ta.value.trim();
    if (!content || !activeChatId) return;

    const tempId = 'tmp-' + Date.now();
    const optMsg = {
        _id: tempId, chat: activeChatId,
        sender: { _id: MY_ID, name: MY_NAME, role: MY_ROLE },
        content, type: 'text', createdAt: new Date().toISOString(),
        replyTo: replyToMsg ? { _id: replyToMsg._id, content: replyToMsg.content, sender: { name: replyToMsg.senderName } } : null,
    };
    const el = document.getElementById('chatMessages');
    el.innerHTML += `<div id="opt-${tempId}">${buildMsg(optMsg)}</div>`;
    el.scrollTop = el.scrollHeight;

    socket && socket.emit('chat:send', {
        chatId: activeChatId, content, type: 'text',
        replyTo: replyToMsg?._id || null, tempId,
    });
    clearReply(); ta.value = ''; autoResize(ta);
}

/* ════ Input helpers ═════════════════════════════════════════════════════════ */
function handleInputKeydown(e) {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
}

function handleInputChange(el) {
    autoResize(el);
    if (!activeChatId || !socket) return;
    socket.emit('chat:typing', { chatId: activeChatId });
    clearTimeout(typingTimer);
    typingTimer = setTimeout(() => socket.emit('chat:stop_typing', { chatId: activeChatId }), 2000);
}

function autoResize(el) { el.style.height = 'auto'; el.style.height = Math.min(el.scrollHeight, 120) + 'px'; }

/* ════ Emoji picker ═══════════════════════════════════════════════════════════ */
function toggleEmojiPicker(e) {
    e.stopPropagation();
    document.getElementById('emojiPicker').classList.toggle('open');
}
// Use event delegation — avoids encoding issues with multi-codepoint emojis
document.getElementById('emojiPicker').addEventListener('click', function(e) {
    e.stopPropagation();
    const btn = e.target.closest('.ep-emoji');
    if (!btn) return;
    const emoji = btn.dataset.emoji;
    if (!emoji) return;
    const ta  = document.getElementById('msgInput');
    const pos = ta.selectionStart != null ? ta.selectionStart : ta.value.length;
    ta.value  = ta.value.slice(0, pos) + emoji + ta.value.slice(pos);
    ta.focus();
    ta.setSelectionRange(pos + emoji.length, pos + emoji.length);
    autoResize(ta);
    document.getElementById('emojiPicker').classList.remove('open');
});
document.addEventListener('click', () => {
    const p = document.getElementById('emojiPicker');
    if (p) p.classList.remove('open');
});

/* ════ Message dropdown ═══════════════════════════════════════════════════ */
function toggleMsgMenu(e, msgId) {
    e.stopPropagation();
    const btn    = e.currentTarget;
    const dd     = document.getElementById(`dd-${msgId}`);
    if (!dd) return;
    const wasOpen = dd.classList.contains('open');
    closeAllDropdowns();
    if (!wasOpen) {
        const r      = btn.getBoundingClientRect();
        const isMine = !!btn.closest('.msg-row.mine');
        const ddW    = 168;  // matches min-width in CSS
        const ddH    = 200;  // conservative max height

        // Vertical: open below button, flip up if near bottom edge
        let top = r.bottom + 4;
        if (top + ddH > window.innerHeight - 8) top = r.top - ddH - 4;

        // Horizontal: for "mine" right-align, for others left-align
        dd.style.top   = top + 'px';
        dd.style.left  = 'auto';
        dd.style.right = 'auto';
        if (isMine) {
            // Right edge of dropdown = right edge of button; clamp to viewport
            let right = window.innerWidth - r.right;
            if (r.right - ddW < 8) right = window.innerWidth - r.left - ddW;
            dd.style.right = right + 'px';
        } else {
            // Left edge of dropdown = left edge of button; clamp to viewport
            let left = r.left;
            if (left + ddW > window.innerWidth - 8) left = window.innerWidth - ddW - 8;
            dd.style.left = left + 'px';
        }

        dd.classList.add('open');
        btn.classList.add('open');
    }
}

function closeAllDropdowns() {
    document.querySelectorAll('.msg-dropdown.open').forEach(el => el.classList.remove('open'));
    document.querySelectorAll('.msg-dd-btn.open').forEach(el => el.classList.remove('open'));
}

// Read raw content from data attributes (avoids encoding issues)
function doReply(msgId) {
    closeAllDropdowns();
    const el = document.getElementById(`msg-${msgId}`);
    if (!el) return;
    setReply(msgId, el.dataset.sender || 'Unknown', el.dataset.content || '');
}

function doEdit(msgId) {
    closeAllDropdowns();
    const el = document.getElementById(`msg-${msgId}`);
    if (!el) return;
    const textEl = el.querySelector('.msg-text');
    startEdit(msgId, textEl ? textEl.textContent : '');
}

function doDelete(msgId) {
    closeAllDropdowns();
    deleteMsg(msgId);
}

document.addEventListener('click', closeAllDropdowns);

/* ════ Reply ═══════════════════════════════════════════════════════════════ */
function setReply(id, senderName, content) {
    replyToMsg = { _id: id, content, senderName };
    // Use textContent (not innerHTML) with raw strings — no double-encoding
    document.getElementById('replyText').textContent = `↩ ${senderName}: ${content}`;
    const strip = document.getElementById('replyStrip');
    strip.style.display = 'block';
    strip.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    document.getElementById('msgInput').focus();
}
function clearReply() { replyToMsg = null; document.getElementById('replyStrip').style.display = 'none'; }

/* ════ Edit / Delete ════════════════════════════════════════════════════════ */
function startEdit(msgId, currentContent) {
    const ta = document.getElementById('msgInput');
    ta.value = currentContent; ta.dataset.editingId = msgId;
    autoResize(ta); ta.focus();
    ta.placeholder = 'Editing… Enter to save · Esc to cancel';

    function onKey(e) {
        if (e.key === 'Escape') {
            ta.value = ''; ta.dataset.editingId = ''; ta.placeholder = 'Type a message…';
            ta.removeEventListener('keydown', onKey);
        }
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            const c = ta.value.trim(); if (!c) return;
            socket && socket.emit('chat:edit', { messageId: msgId, content: c });
            ta.value = ''; ta.dataset.editingId = ''; ta.placeholder = 'Type a message…';
            ta.removeEventListener('keydown', onKey);
        }
    }
    ta.addEventListener('keydown', onKey);
}

function deleteMsg(id) {
    showGlobalConfirm('Delete this message?', 'Delete Message', function() {
        socket && socket.emit('chat:delete', { messageId: id });
    });
}

/* ════ Infinite scroll ══════════════════════════════════════════════════════ */
async function onMsgsScroll(e) {
    if (loadingMore || !hasMoreMessages || !activeChatId) return;
    if (e.target.scrollTop < 100) {
        loadingMore = true;
        const oldest = _msgs[0];
        if (oldest) await loadMessages(oldest.createdAt);
        loadingMore = false;
    }
}


/* ════ New chat modal ════════════════════════════════════════════════════════ */
async function openNewChatModal() {
    if (!allContacts.length) { const r = await api('/chat/api/contacts'); allContacts = r.contacts || []; }
    renderContactGrid('contactGrid', allContacts, 'direct');
    openModal('newChatModal');
    setTimeout(() => document.getElementById('contactSearch').focus(), 100);
}

function filterContacts(q) {
    const s = q.toLowerCase();
    renderContactGrid('contactGrid', allContacts.filter(c => c.name.toLowerCase().includes(s) || c.role.toLowerCase().includes(s)), 'direct');
}

function renderContactGrid(gridId, contacts, mode) {
    const el = document.getElementById(gridId);
    if (!contacts.length) { el.innerHTML = '<div style="padding:20px;text-align:center;color:#484f58;font-size:12px;">No contacts found</div>'; return; }
    if (mode === 'direct') {
        el.innerHTML = contacts.map(c => `<div class="cg-item" onclick="startDirectChat('${c._id}')">
            ${miniAv(c.name, c.profileImage)}
            <div><div class="cg-name">${esc(c.name)}</div><div class="cg-role">${roleLabel(c.role)}</div></div>
          </div>`).join('');
    } else {
        el.innerHTML = contacts.map(c => {
            const checked = selectedGroupMembers.has(String(c._id));
            return `<div class="cg-item${checked?' sel':''}" onclick="toggleGrpMember('${c._id}', this)">
              <input type="checkbox" ${checked?'checked':''} readonly>
              ${miniAv(c.name, c.profileImage)}
              <div><div class="cg-name">${esc(c.name)}</div><div class="cg-role">${roleLabel(c.role)}</div></div>
            </div>`;
        }).join('');
    }
}

async function startDirectChat(receiverId) {
    closeModal('newChatModal');
    try {
        const r = await api('/chat/direct', 'POST', { receiverId });
        if (r.success) { await loadChats(); openChat(r.chatId); }
        else toast('⚠️ ' + r.message, '#f85149');
    } catch { toast('Failed to start chat', '#f85149'); }
}

/* ════ Group modal ═══════════════════════════════════════════════════════════ */
async function openGroupModal() {
    selectedGroupMembers.clear();
    if (!groupContacts.length) { const r = await api('/chat/api/contacts'); groupContacts = r.contacts || []; }
    renderContactGrid('grpContactGrid', groupContacts, 'group');
    openModal('groupModal');
}

function filterGroupContacts(q) {
    const s = q.toLowerCase();
    renderContactGrid('grpContactGrid', groupContacts.filter(c => c.name.toLowerCase().includes(s) || c.role.toLowerCase().includes(s)), 'group');
}

function toggleGrpMember(userId, el) {
    if (selectedGroupMembers.has(userId)) { selectedGroupMembers.delete(userId); el.classList.remove('sel'); el.querySelector('input').checked = false; }
    else { selectedGroupMembers.add(userId); el.classList.add('sel'); el.querySelector('input').checked = true; }
    document.getElementById('selectedMembersLabel').textContent = selectedGroupMembers.size ? `${selectedGroupMembers.size} selected` : '';
}

async function createGroup() {
    const name = document.getElementById('grpName').value.trim();
    const desc = document.getElementById('grpDesc').value.trim();
    const type = document.getElementById('grpType').value;
    if (!name) { toast('Group name is required', '#f85149'); return; }
    try {
        const r = await api('/chat/group', 'POST', { name, description: desc, type, isReadOnly: type === 'broadcast', memberIds: JSON.stringify([...selectedGroupMembers]) });
        if (r.success) { closeModal('groupModal'); await loadChats(); openChat(r.chatId); }
        else toast('⚠️ ' + r.message, '#f85149');
    } catch { toast('Failed to create group', '#f85149'); }
}

/* ════ Members modal ══════════════════════════════════════════════════════════ */
async function openMembersModal() {
    if (!activeChatId) return;
    try {
        const r    = await api(`/chat/api/chats/${activeChatId}/members`);
        currentMembers = r.members || [];
        const chat = activeChat;
        const tog  = document.getElementById('readonlyToggle');
        if (tog) tog.checked = !!(chat && chat.isReadOnly);

        document.getElementById('memberModalTitle').textContent = `👥 Members (${currentMembers.length})`;
        document.getElementById('membersList').innerHTML = currentMembers.map(m => {
            const u = m.user || {};
            const on = onlineUsers.has(String(u._id));
            return `<div class="ml-item">
                ${miniAv(u.name, u.profileImage)}
                <div style="flex:1;min-width:0;">
                  <div style="font-size:13px;font-weight:600;color:#c9d1d9;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${esc(u.name || '?')}</div>
                  <div style="font-size:11px;color:#6e7681;">${roleLabel(u.role)}${m.role==='admin' ? ' · <span style="color:#e3b341;">Admin</span>' : ''}</div>
                </div>
                <div class="presence-dot ${on?'on':'off'}" title="${on?'Online':'Offline'}"></div>
                ${isAmIAdmin && String(u._id) !== MY_ID
                    ? `<button class="ma-btn danger" onclick="removeMember('${u._id}')" style="margin-left:4px;">Remove</button>`
                    : ''}
              </div>`;
        }).join('');

        // Hide add-member panel when reopening
        const amw = document.getElementById('addMemberWrap');
        if (amw) amw.style.display = 'none';

        openModal('membersModal');
    } catch { toast('Failed to load members', '#f85149'); }
}

function removeMember(userId) {
    showGlobalConfirm('Remove this member from the group?', 'Remove Member', function() {
        api(`/chat/group/${activeChatId}/member/${userId}`, 'DELETE').then(function(r) {
            if (r.success) { closeModal('membersModal'); openMembersModal(); }
            else toast('⚠️ ' + r.message, '#f85149');
        });
    });
}

async function updateReadonly(checked) {
    if (!activeChatId) return;
    await api(`/chat/group/${activeChatId}/settings`, 'PATCH', { isReadOnly: checked });
}

/* ════ Add member ════════════════════════════════════════════════════════════ */
function toggleAddMemberPanel() {
    const wrap = document.getElementById('addMemberWrap');
    if (!wrap) return;
    const isOpen = wrap.style.display !== 'none';
    wrap.style.display = isOpen ? 'none' : '';
    if (!isOpen) {
        addMemberContacts = allContacts.length ? allContacts : [];
        if (!addMemberContacts.length) {
            api('/chat/api/contacts').then(r => {
                allContacts = r.contacts || [];
                addMemberContacts = allContacts;
                renderAddMemberGrid(addMemberContacts);
            });
        } else {
            renderAddMemberGrid(addMemberContacts);
        }
        setTimeout(() => document.getElementById('addMemberSearch').focus(), 100);
    }
}

function filterAddMemberContacts(q) {
    const s = q.toLowerCase();
    const existingIds = new Set(currentMembers.map(m => m.user && String(m.user._id)));
    const filtered = addMemberContacts.filter(c => !existingIds.has(String(c._id)) && (c.name.toLowerCase().includes(s) || c.role.toLowerCase().includes(s)));
    renderAddMemberGrid(filtered);
}

function renderAddMemberGrid(contacts) {
    const existingIds = new Set(currentMembers.map(m => m.user && String(m.user._id)));
    const filtered    = contacts.filter(c => !existingIds.has(String(c._id)));
    const el          = document.getElementById('addMemberGrid');
    if (!filtered.length) { el.innerHTML = '<div style="padding:16px;text-align:center;color:#484f58;font-size:12px;">No contacts to add</div>'; return; }
    el.innerHTML = filtered.map(c => `<div class="cg-item" onclick="doAddMember('${c._id}')">
        ${miniAv(c.name, c.profileImage)}
        <div style="flex:1;"><div class="cg-name">${esc(c.name)}</div><div class="cg-role">${roleLabel(c.role)}</div></div>
        <button class="btn-sec" style="padding:3px 10px;font-size:11px;">Add</button>
      </div>`).join('');
}

async function doAddMember(memberId) {
    const r = await api(`/chat/group/${activeChatId}/member`, 'POST', { memberId });
    if (r.success) { toast('Member added!', '#3fb950'); closeModal('membersModal'); openMembersModal(); }
    else toast('⚠️ ' + r.message, '#f85149');
}

/* ════ Per-chat search ════════════════════════════════════════════════════════ */
let _chatSearchTimer = null;

function toggleChatSearch() {
    if (!activeChatId) return;
    const bar = document.getElementById('chatSearchBar');
    const inp = document.getElementById('inChatSearchInput');
    if (bar.classList.contains('open')) {
        bar.classList.remove('open');
        inp.value = '';
        document.getElementById('chatSearchResults').innerHTML = '';
    } else {
        bar.classList.add('open');
        setTimeout(() => inp.focus(), 50);
    }
}

function onChatSearch(q) {
    clearTimeout(_chatSearchTimer);
    const el = document.getElementById('chatSearchResults');
    if (!q || q.length < 2) { el.innerHTML = ''; return; }
    _chatSearchTimer = setTimeout(async () => {
        el.innerHTML = '<div style="padding:10px;text-align:center;color:#484f58;font-size:12px;">Searching…</div>';
        const r = await api(`/chat/api/search?q=${encodeURIComponent(q)}&chatId=${activeChatId}`);
        if (!r.messages || !r.messages.length) {
            el.innerHTML = '<div style="padding:12px;text-align:center;color:#484f58;font-size:12px;">No results found.</div>';
            return;
        }
        el.innerHTML = r.messages.map(m => {
            const sender = (m.sender && m.sender.name) || 'Unknown';
            return `<div class="csr-item" onclick="jumpToMessage('${m._id}','${m.createdAt}')">
                <div class="csr-sender">${esc(sender)}</div>
                <div class="csr-text">${esc(trunc(m.content || '', 90))}</div>
                <div class="csr-time">${timeAgo(m.createdAt)}</div>
            </div>`;
        }).join('');
    }, 350);
}

async function jumpToMessage(msgId, createdAt) {
    // Collapse search bar
    document.getElementById('chatSearchBar').classList.remove('open');
    document.getElementById('inChatSearchInput').value = '';
    document.getElementById('chatSearchResults').innerHTML = '';

    const doHighlight = () => {
        const el = document.getElementById(`msg-${msgId}`);
        if (!el) return false;
        el.scrollIntoView({ behavior: 'smooth', block: 'center' });
        el.classList.add('msg-jump-highlight');
        setTimeout(() => el.classList.remove('msg-jump-highlight'), 2200);
        return true;
    };

    if (doHighlight()) return;

    // Message not in current window — load the 40-message window that contains it
    try {
        const before = new Date(new Date(createdAt).getTime() + 1000).toISOString();
        const r = await api(`/chat/api/chats/${activeChatId}/messages?limit=40&before=${encodeURIComponent(before)}`);
        _msgs = r.messages || [];
        hasMoreMessages = r.hasMore;
        renderMessages(_msgs, false);
    } catch { }

    setTimeout(doHighlight, 150);
}

/* ════ Admin browse mode ══════════════════════════════════════════════════════ */
let adminMode          = false;
let adminViewUser      = null;
let adminSearchTimer   = null;
let adminObserverChatId = null; // chatId opened in read-only observer mode

function enterAdminMode() {
    adminMode = true; adminViewUser = null;
    document.getElementById('normalHdr').style.display      = 'none';
    document.getElementById('adminBrowseHdr').style.display = '';
    document.getElementById('adminHdrTitle').textContent    = 'Browse Users';
    document.getElementById('chatList').innerHTML =
        '<div style="padding:28px 16px;text-align:center;color:#484f58;font-size:12px;">Search for a user above to browse their chats.</div>';
    setTimeout(() => document.getElementById('adminUserSearch').focus(), 80);
}

function exitAdminMode() {
    adminMode = false; adminViewUser = null; adminObserverChatId = null;
    document.getElementById('adminBrowseHdr').style.display = 'none';
    document.getElementById('normalHdr').style.display      = '';
    // Restore input area if we were in observer mode
    document.getElementById('chatInputRow').style.display   = '';
    document.getElementById('readonlyNotice').style.display = 'none';
    document.getElementById('adminUserSearch').value        = '';
    loadChats();
}

function onAdminUserSearch(q) {
    clearTimeout(adminSearchTimer);
    if (!q || q.length < 1) {
        document.getElementById('chatList').innerHTML =
            '<div style="padding:20px 16px;text-align:center;color:#484f58;font-size:12px;">Type to search users…</div>';
        return;
    }
    adminSearchTimer = setTimeout(async () => {
        const r = await api(`/chat/api/admin/school-users?q=${encodeURIComponent(q)}`);
        renderUserList(r.users || []);
    }, 280);
}

function renderUserList(users) {
    const el = document.getElementById('chatList');
    if (!users.length) {
        el.innerHTML = '<div style="padding:20px 16px;text-align:center;color:#484f58;font-size:12px;">No users found</div>';
        return;
    }
    el.innerHTML = users.map(u =>
        `<div class="ci" onclick="loadAdminUserChats('${u._id}','${esc(u.name)}')">
            ${miniAv(u.name, u.profileImage, 40)}
            <div class="ci-body">
              <div class="ci-top"><div class="ci-name">${esc(u.name)}</div></div>
              <div class="ci-preview">${roleLabel(u.role)}</div>
            </div>
            <span style="font-size:10px;color:#484f58;flex-shrink:0;">›</span>
          </div>`
    ).join('');
}

async function loadAdminUserChats(userId, userName) {
    adminViewUser = { _id: userId, name: userName };
    document.getElementById('adminHdrTitle').textContent =
        (userName.length > 18 ? userName.slice(0,16) + '…' : userName) + "'s Chats";
    document.getElementById('chatList').innerHTML =
        '<div style="padding:20px 16px;text-align:center;color:#484f58;font-size:12px;">Loading…</div>';

    const r     = await api(`/chat/api/admin/user-chats?userId=${userId}`);
    const chats = r.chats || [];

    if (!chats.length) {
        document.getElementById('chatList').innerHTML =
            '<div style="padding:20px 16px;text-align:center;color:#484f58;font-size:12px;">No chats found for this user</div>';
        return;
    }

    document.getElementById('chatList').innerHTML = chats.map(c => {
        const name    = esc(c.displayName || c.name || 'Group');
        const preview = chatPreview(c.lastMessage);
        const time    = c.lastActivity ? timeAgo(c.lastActivity) : '';
        const avClass = c.type === 'broadcast' ? 'bcast' : c.type === 'group' ? 'grp' : '';
        const tpre    = c.type === 'broadcast' ? '📢 ' : c.type === 'group' ? '👥 ' : '';
        return `<div class="ci" onclick="openAdminObserverChat('${c._id}','${esc(c.displayName||c.name||'Chat')}')">
            <div class="ca ${avClass}">${c.displayAvatar ? `<img src="${esc(c.displayAvatar)}" alt="">` : name.charAt(0).toUpperCase()}</div>
            <div class="ci-body">
              <div class="ci-top"><div class="ci-name">${tpre}${name}</div><div class="ci-time">${time}</div></div>
              <div class="ci-preview">${preview}</div>
            </div>
          </div>`;
    }).join('');
}

async function openAdminObserverChat(chatId, chatName) {
    adminObserverChatId = String(chatId);
    activeChatId        = adminObserverChatId;
    activeChat          = { _id: chatId, type: 'group' }; // placeholder

    document.querySelectorAll('.ci').forEach(el => el.classList.remove('active'));
    document.getElementById(`ci-${chatId}`) && document.getElementById(`ci-${chatId}`).classList.add('active');

    document.getElementById('chatEmpty').style.display  = 'none';
    const win = document.getElementById('chatWindow');
    win.style.display       = 'flex';
    win.style.flexDirection = 'column';

    document.getElementById('winName').textContent = chatName;
    document.getElementById('winSub').textContent  = '👁 Admin view — read only';
    document.getElementById('winAvatar').className = 'ca';
    document.getElementById('winAvatar').innerHTML = chatName.charAt(0).toUpperCase();
    document.getElementById('membersBtn').style.display = 'none';

    // Hide input — admin is observer only
    document.getElementById('chatInputRow').style.display   = 'none';
    document.getElementById('readonlyNotice').style.display = '';
    document.getElementById('readonlyNotice').textContent   = '👁 Admin view — read-only observer mode';

    document.getElementById('chatMessages').innerHTML =
        '<div style="padding:40px;text-align:center;color:#484f58;font-size:12px;">Loading…</div>';
    hasMoreMessages = false;
    _msgs = [];
    await loadMessages(); // reuses normal loadMessages — backend now allows admin read
}

/* ════ Chat list utilities ═══════════════════════════════════════════════════ */
function updateListPreview(chatId, msg) {
    const c = allChats.find(x => String(x._id) === chatId);
    if (c) {
        c.lastMessage  = msg;
        c.lastActivity = msg.createdAt;
        // Only increment badge for OTHER chats (not the one currently open)
        if (String(chatId) !== activeChatId) c.unreadCount = (c.unreadCount || 0) + 1;
    } else {
        loadChats(); return;
    }
    renderChatList(allChats);
}

function chatPreview(msg) {
    if (!msg) return '<span style="opacity:.4;font-style:italic;">No messages yet</span>';
    if (msg.isDeleted) return '🚫 Message deleted';
    if (msg.type === 'image') return '📷 Photo';
    if (msg.type === 'file')  return '📎 File';
    const prefix = msg.sender && msg.sender.name ? msg.sender.name.split(' ')[0] + ': ' : '';
    return esc(prefix + trunc(msg.content || '', 38));
}

/* ════ Helpers ═══════════════════════════════════════════════════════════════ */
function miniAv(name, img, size = 30) {
    const s = `width:${size}px;height:${size}px;font-size:${Math.round(size*0.4)}px;`;
    if (img) return `<div class="ca" style="${s}flex-shrink:0;"><img src="${esc(img)}" alt=""></div>`;
    return `<div class="ca" style="${s}flex-shrink:0;">${(name||'?').charAt(0).toUpperCase()}</div>`;
}

function roleLabel(role) {
    return { super_admin:'Super Admin', school_admin:'Admin', teacher:'Teacher', student:'Student', parent:'Parent' }[role] || (role || '');
}

function timeAgo(d) {
    const diff = Date.now() - new Date(d).getTime(), m = Math.floor(diff/60000);
    if (m < 1)  return 'now';
    if (m < 60) return m + 'm';
    const h = Math.floor(m/60);
    if (h < 24) return h + 'h';
    const dy = Math.floor(h/24);
    if (dy < 7) return dy + 'd';
    return new Date(d).toLocaleDateString('en-IN', { day:'numeric', month:'short' });
}

function esc(s)      { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function escAttr(s)  { return String(s||'').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function escJs(s)    { return String(s||'').replace(/\\/g,'\\\\').replace(/'/g,"\\'").replace(/\n/g,'\\n').replace(/\r/g,''); }
function trunc(s,n)  { return s && s.length > n ? s.slice(0,n)+'…' : (s||''); }

async function api(url, method = 'GET', body = null) {
    const opts = { method, headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' } };
    if (body) opts.body = JSON.stringify(body);
    const r = await fetch(url, opts);
    return r.json();
}

function openModal(id)  { document.getElementById(id).style.display = 'flex'; }
function closeModal(id) { document.getElementById(id).style.display = 'none'; }

function toast(msg, color = '#388bfd') {
    const tc = document.getElementById('toastContainer');
    if (!tc) return;
    const t = document.createElement('div');
    t.style.cssText = `pointer-events:auto;background:#161b22;border:1px solid #30363d;border-left:3px solid ${color};border-radius:10px;padding:11px 15px;width:260px;box-shadow:0 8px 24px rgba(0,0,0,.5);animation:slideInToast .25s ease;color:#c9d1d9;font-size:13px;`;
    t.textContent = msg;
    tc.appendChild(t);
    setTimeout(() => { t.style.opacity='0'; t.style.transition='opacity .35s'; setTimeout(() => t.remove(), 350); }, 3800);
}

/* ════ Emoji reactions ══════════════════════════════════════════════════════ */
function _buildReactionsHtml(msgId, reactions) {
    if (!reactions || !reactions.length) return '';
    // Group by emoji
    const groups = {};
    reactions.forEach(r => {
        if (!groups[r.emoji]) groups[r.emoji] = { count: 0, mine: false, names: [] };
        groups[r.emoji].count++;
        groups[r.emoji].names.push(r.userName || 'Someone');
        if (String(r.user) === MY_ID) groups[r.emoji].mine = true;
    });
    const pills = Object.entries(groups).map(([emoji, g]) =>
        `<span class="msg-react-pill${g.mine?' mine':''}" title="${escAttr(g.names.join(', '))}" onclick="sendReaction('${msgId}','${emoji}')">
            ${emoji}<span class="rp-count">${g.count}</span>
        </span>`
    ).join('');
    return `<div class="msg-reactions" id="rxn-${msgId}">${pills}</div>`;
}

function doReact(e, msgId) {
    e.stopPropagation();
    closeAllDropdowns();
    document.querySelectorAll('.react-picker.open').forEach(el => el.classList.remove('open'));

    const rp = document.getElementById(`rp-${msgId}`);
    if (!rp) return;

    // Position the picker using fixed coords relative to the message bubble
    const bubble = rp.closest('.msg-bubble');
    const r      = (bubble || rp).getBoundingClientRect();
    const isMine = !!rp.closest('.msg-row.mine');
    const pickerW = 220;  // 6 emojis × ~36px
    const pickerH = 46;

    // Show above bubble; flip below if near top of viewport
    let top = r.top - pickerH - 8;
    if (top < 8) top = r.bottom + 8;

    rp.style.top   = top + 'px';
    rp.style.left  = 'auto';
    rp.style.right = 'auto';
    if (isMine) {
        let right = window.innerWidth - r.right;
        if (r.right - pickerW < 8) right = window.innerWidth - r.left - pickerW;
        rp.style.right = right + 'px';
    } else {
        let left = r.left;
        if (left + pickerW > window.innerWidth - 8) left = window.innerWidth - pickerW - 8;
        rp.style.left = left + 'px';
    }

    rp.classList.add('open');
}

async function sendReaction(msgId, emoji) {
    // Close picker
    const rp = document.getElementById(`rp-${msgId}`);
    if (rp) rp.classList.remove('open');

    if (socket) {
        socket.emit('chat:react', { messageId: msgId, emoji });
    } else {
        try {
            await api(`/chat/api/messages/${msgId}/react`, 'POST', { emoji });
        } catch { toast('Reaction failed.', '#f85149'); }
    }
}

function onReactionUpdate(data) {
    const { messageId, reactions } = data;
    // Update existing reactions bar or inject one
    const msgEl = document.getElementById(`msg-${messageId}`);
    if (!msgEl) return;
    const bw = msgEl.querySelector('.msg-bw');
    if (!bw) return;
    let rxnEl = document.getElementById(`rxn-${messageId}`);
    const html = _buildReactionsHtml(messageId, reactions);
    if (rxnEl) {
        rxnEl.outerHTML = html || '';
    } else if (html) {
        bw.insertAdjacentHTML('beforeend', html);
    }
}

// Close react pickers on outside click
document.addEventListener('click', () => {
    document.querySelectorAll('.react-picker.open').forEach(el => el.classList.remove('open'));
});

document.addEventListener('keydown', e => {
    if (e.key === 'Escape') document.querySelectorAll('.mo').forEach(el => { el.style.display='none'; });
});

/* ════ Forward message ═══════════════════════════════════════════════════════ */
let _fwdMsgId      = null;
let _fwdChats      = [];
let _fwdContacts   = [];
let _fwdSelected   = new Set();   // ids currently ticked
let _fwdSelMeta    = new Map();   // id → 'chat' | 'contact'

async function doForward(msgId) {
    closeAllDropdowns();
    _fwdMsgId = msgId;
    _fwdSelected.clear();
    _fwdSelMeta.clear();
    _fwdChats = allChats.filter(c => String(c._id) !== activeChatId);

    if (!allContacts.length) {
        const r = await api('/chat/api/contacts');
        allContacts = r.contacts || [];
    }
    _fwdContacts = allContacts;

    document.getElementById('fwdSearch').value = '';
    _renderFwdModal(_fwdChats, _fwdContacts);
    openModal('forwardModal');
}

function _renderFwdModal(chats, contacts) {
    const el  = document.getElementById('fwdList');
    const max = _fwdSelected.size >= 5;
    let html  = '';

    if (chats.length) {
        html += `<div class="fwd-section-label">Chats</div>`;
        html += chats.map(c => {
            const id   = String(c._id);
            const sel  = _fwdSelected.has(id);
            const dis  = max && !sel;
            const name = esc(c.displayName || c.name || 'Group');
            const pfx  = c.type === 'broadcast' ? '📢 ' : c.type === 'group' ? '👥 ' : '';
            return `<div class="cg-item${sel?' sel':''}${dis?' fwd-disabled':''}" onclick="toggleFwdItem('${id}','chat')">
                <input type="checkbox" ${sel?'checked':''} style="width:auto;flex-shrink:0;" onclick="event.stopPropagation();" onchange="toggleFwdItem('${id}','chat')">
                <div class="ca ${c.type==='group'?'grp':c.type==='broadcast'?'bcast':''}" style="width:32px;height:32px;font-size:12px;flex-shrink:0;">${c.displayAvatar?`<img src="${esc(c.displayAvatar)}" alt="">`:name.charAt(0).toUpperCase()}</div>
                <div><div class="cg-name">${pfx}${name}</div></div>
            </div>`;
        }).join('');
    }

    if (contacts.length) {
        html += `<div class="fwd-section-label">People (new chat)</div>`;
        html += contacts.map(c => {
            const id  = String(c._id);
            const sel = _fwdSelected.has(id);
            const dis = max && !sel;
            return `<div class="cg-item${sel?' sel':''}${dis?' fwd-disabled':''}" onclick="toggleFwdItem('${id}','contact')">
                <input type="checkbox" ${sel?'checked':''} style="width:auto;flex-shrink:0;" onclick="event.stopPropagation();" onchange="toggleFwdItem('${id}','contact')">
                ${miniAv(c.name, c.profileImage)}
                <div><div class="cg-name">${esc(c.name)}</div><div class="cg-role">${roleLabel(c.role)}</div></div>
            </div>`;
        }).join('');
    }

    if (!html) html = '<div style="padding:20px;text-align:center;color:#484f58;font-size:12px;">No chats or contacts available.</div>';
    el.innerHTML = html;

    // Update counter and send button
    const count = _fwdSelected.size;
    document.getElementById('fwdCounter').textContent = `${count} / 5 selected`;
    const btn = document.getElementById('fwdSendBtn');
    btn.disabled = count === 0;
    btn.style.opacity  = count ? '1'  : '.4';
    btn.style.cursor   = count ? 'pointer' : 'not-allowed';
}

function filterFwdChats(q) {
    if (!q) { _renderFwdModal(_fwdChats, _fwdContacts); return; }
    const s = q.toLowerCase();
    _renderFwdModal(
        _fwdChats.filter(c    => (c.displayName || c.name || '').toLowerCase().includes(s)),
        _fwdContacts.filter(c => c.name.toLowerCase().includes(s) || (c.role || '').toLowerCase().includes(s))
    );
}

function toggleFwdItem(id, type) {
    if (_fwdSelected.has(id)) {
        _fwdSelected.delete(id);
        _fwdSelMeta.delete(id);
    } else {
        if (_fwdSelected.size >= 5) return;  // hard cap
        _fwdSelected.add(id);
        _fwdSelMeta.set(id, type);
    }
    // Re-render maintaining current search filter
    const q = document.getElementById('fwdSearch').value;
    filterFwdChats(q);
}

async function _doSendForward(targetChatId) {
    if (!_fwdMsgId || !targetChatId) return;
    const srcEl  = document.getElementById(`msg-${_fwdMsgId}`);
    const content = srcEl ? srcEl.dataset.content : '';
    if (!content) return;

    if (socket) {
        socket.emit('chat:send', { chatId: targetChatId, content, replyTo: null, isForwarded: true });
    } else {
        await api('/chat/api/chats/' + targetChatId + '/messages', 'POST', { content, isForwarded: true });
    }
    if (String(targetChatId) === activeChatId) await loadMessages();
}

async function sendAllForwards() {
    if (!_fwdSelected.size) return;
    closeModal('forwardModal');

    let ok = 0, fail = 0;
    for (const id of _fwdSelected) {
        try {
            if (_fwdSelMeta.get(id) === 'contact') {
                const r = await api('/chat/direct', 'POST', { receiverId: id });
                if (r.success) { await _doSendForward(r.chatId); ok++; }
                else fail++;
            } else {
                await _doSendForward(id); ok++;
            }
        } catch { fail++; }
    }

    await loadChats();
    _fwdSelected.clear();
    _fwdSelMeta.clear();
    _fwdMsgId = null;

    if (ok)   toast(`↗ Forwarded to ${ok} chat${ok>1?'s':''}!`, '#3fb950');
    if (fail) toast(`⚠️ Failed for ${fail} recipient${fail>1?'s':''}`, '#f85149');
}
</script>
