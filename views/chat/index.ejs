<%
  /* Passed from controller */
  const _myId       = session && session.userId   ? String(session.userId)   : '';
  const _myRole     = session && session.userRole ? session.userRole         : '';
  const _myName     = session && session.userName ? session.userName         : 'Me';
  const _canGroup   = typeof canCreateGroup !== 'undefined' ? canCreateGroup : false;
%>

<style>
/* ── Layout ─────────────────────────────────────────────────────────── */
.chat-shell{display:flex;height:calc(100vh - 120px);border:1px solid var(--border,#2a2d3e);border-radius:16px;overflow:hidden;background:var(--card-bg,#1a1d2e);}

/* ── Left panel ─────────────────────────────────────────────────────── */
.chat-left{width:320px;min-width:260px;max-width:380px;display:flex;flex-direction:column;border-right:1px solid var(--border,#2a2d3e);flex-shrink:0;}
.chat-left-header{padding:16px;border-bottom:1px solid var(--border,#2a2d3e);display:flex;align-items:center;justify-content:space-between;}
.chat-left-header h3{margin:0;font-size:16px;font-weight:700;color:var(--text,#e2e8f0);}
.chat-header-btns{display:flex;gap:6px;}
.icon-btn{background:rgba(59,130,246,.1);border:1px solid rgba(59,130,246,.25);border-radius:8px;padding:6px 10px;cursor:pointer;color:#3b82f6;font-size:13px;transition:background .2s;}
.icon-btn:hover{background:rgba(59,130,246,.2);}
.chat-search{padding:10px 16px;border-bottom:1px solid var(--border,#2a2d3e);}
.chat-search input{width:100%;padding:8px 12px;border-radius:8px;border:1px solid var(--border,#2a2d3e);background:rgba(255,255,255,.05);color:var(--text,#e2e8f0);font-size:13px;box-sizing:border-box;}
.chat-search input:focus{outline:none;border-color:#3b82f6;}
.chat-list{flex:1;overflow-y:auto;}
.chat-item{display:flex;align-items:center;gap:10px;padding:12px 16px;cursor:pointer;border-bottom:1px solid rgba(255,255,255,.04);transition:background .15s;position:relative;}
.chat-item:hover{background:rgba(255,255,255,.04);}
.chat-item.active{background:rgba(59,130,246,.12);}
.chat-avatar{width:42px;height:42px;border-radius:50%;background:#3b82f6;color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:16px;flex-shrink:0;overflow:hidden;}
.chat-avatar img{width:100%;height:100%;object-fit:cover;border-radius:50%;}
.chat-item-info{flex:1;min-width:0;}
.chat-item-top{display:flex;justify-content:space-between;align-items:baseline;}
.chat-item-name{font-weight:600;font-size:13px;color:var(--text,#e2e8f0);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:160px;}
.chat-item-time{font-size:10px;color:var(--text-muted,#94a3b8);flex-shrink:0;}
.chat-item-preview{font-size:12px;color:var(--text-muted,#94a3b8);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;margin-top:2px;}
.chat-unread-badge{position:absolute;right:14px;bottom:14px;background:#3b82f6;color:#fff;border-radius:10px;min-width:18px;height:18px;font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center;padding:0 4px;}

/* ── Right panel ────────────────────────────────────────────────────── */
.chat-right{flex:1;display:flex;flex-direction:column;min-width:0;}
.chat-empty{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;color:var(--text-muted,#94a3b8);}
.chat-empty-icon{font-size:64px;opacity:.3;}

/* ── Active chat header ──────────────────────────────────────────────── */
.chat-win-header{padding:12px 18px;border-bottom:1px solid var(--border,#2a2d3e);display:flex;align-items:center;gap:12px;flex-shrink:0;}
.chat-win-info{flex:1;min-width:0;}
.chat-win-name{font-weight:700;font-size:15px;color:var(--text,#e2e8f0);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.chat-win-sub{font-size:11px;color:var(--text-muted,#94a3b8);}
.chat-win-actions{display:flex;gap:6px;}

/* ── Messages ─────────────────────────────────────────────────────────── */
.chat-messages{flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:4px;}
.msg-date-divider{text-align:center;margin:10px 0;font-size:11px;color:var(--text-muted,#94a3b8);}
.msg-date-divider span{background:rgba(255,255,255,.06);padding:3px 10px;border-radius:10px;}
.msg-row{display:flex;gap:8px;margin-bottom:2px;}
.msg-row.mine{flex-direction:row-reverse;}
.msg-avatar-wrap{width:32px;flex-shrink:0;}
.msg-bubble-wrap{max-width:68%;display:flex;flex-direction:column;}
.msg-row.mine .msg-bubble-wrap{align-items:flex-end;}
.msg-sender-name{font-size:11px;color:#3b82f6;font-weight:600;margin-bottom:2px;padding-left:4px;}
.msg-bubble{background:rgba(255,255,255,.06);border-radius:12px 12px 12px 3px;padding:9px 13px;position:relative;word-break:break-word;}
.msg-row.mine .msg-bubble{background:rgba(59,130,246,.18);border-radius:12px 12px 3px 12px;}
.msg-bubble.deleted{color:var(--text-muted,#94a3b8);font-style:italic;font-size:12px;}
.msg-text{font-size:13px;color:var(--text,#e2e8f0);line-height:1.5;white-space:pre-wrap;}
.msg-meta{display:flex;align-items:center;gap:5px;margin-top:4px;}
.msg-time{font-size:10px;color:var(--text-muted,#94a3b8);}
.msg-edited{font-size:10px;color:var(--text-muted,#94a3b8);font-style:italic;}
.msg-status{font-size:11px;}
.msg-actions{display:none;gap:4px;margin-top:4px;}
.msg-bubble-wrap:hover .msg-actions{display:flex;}
.msg-action-btn{background:rgba(255,255,255,.08);border:none;border-radius:6px;padding:3px 7px;cursor:pointer;color:var(--text-muted,#94a3b8);font-size:11px;transition:background .15s;}
.msg-action-btn:hover{background:rgba(255,255,255,.15);color:var(--text,#e2e8f0);}
.msg-reply-preview{background:rgba(59,130,246,.1);border-left:3px solid #3b82f6;border-radius:4px;padding:5px 8px;margin-bottom:6px;font-size:11px;color:var(--text-muted,#94a3b8);}
.msg-attach-image{max-width:220px;border-radius:8px;cursor:pointer;margin-top:6px;display:block;}
.msg-attach-file{display:flex;align-items:center;gap:8px;background:rgba(255,255,255,.06);border-radius:8px;padding:8px;margin-top:6px;}
.msg-attach-file a{color:#3b82f6;font-size:12px;text-decoration:none;}
.typing-indicator{font-size:12px;color:var(--text-muted,#94a3b8);padding:4px 8px;font-style:italic;}

/* ── Input area ─────────────────────────────────────────────────────── */
.chat-input-area{border-top:1px solid var(--border,#2a2d3e);padding:12px 16px;flex-shrink:0;}
.reply-strip{display:none;background:rgba(59,130,246,.1);border-left:3px solid #3b82f6;border-radius:6px;padding:6px 10px;margin-bottom:8px;font-size:12px;color:var(--text-muted,#94a3b8);position:relative;}
.reply-strip .close-reply{position:absolute;right:6px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--text-muted,#94a3b8);font-size:16px;}
.file-preview-strip{display:none;align-items:center;gap:8px;background:rgba(255,255,255,.06);border-radius:8px;padding:8px 12px;margin-bottom:8px;}
.file-preview-strip .fp-name{font-size:12px;color:var(--text,#e2e8f0);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.file-preview-strip .fp-clear{background:none;border:none;cursor:pointer;color:var(--text-muted,#94a3b8);font-size:16px;}
.chat-input-row{display:flex;gap:8px;align-items:flex-end;}
.chat-input-row textarea{flex:1;background:rgba(255,255,255,.05);border:1px solid var(--border,#2a2d3e);border-radius:10px;color:var(--text,#e2e8f0);padding:10px 13px;font-size:14px;resize:none;min-height:42px;max-height:120px;font-family:inherit;line-height:1.5;}
.chat-input-row textarea:focus{outline:none;border-color:#3b82f6;}
.send-btn{background:#3b82f6;border:none;border-radius:10px;padding:10px 18px;color:#fff;cursor:pointer;font-size:16px;flex-shrink:0;transition:background .2s;}
.send-btn:hover{background:#2563eb;}
.attach-btn{background:rgba(255,255,255,.06);border:1px solid var(--border,#2a2d3e);border-radius:10px;padding:10px 13px;cursor:pointer;color:var(--text-muted,#94a3b8);font-size:16px;flex-shrink:0;}
.attach-btn:hover{background:rgba(255,255,255,.1);}
.readonly-notice{padding:10px;text-align:center;font-size:12px;color:var(--text-muted,#94a3b8);font-style:italic;}

/* ── Modals ─────────────────────────────────────────────────────────── */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:9999;align-items:center;justify-content:center;}
.modal-box{background:var(--card-bg,#1a1d2e);border:1px solid var(--border,#2a2d3e);border-radius:16px;width:min(500px,92vw);max-height:85vh;overflow-y:auto;padding:28px;position:relative;}
.modal-title{font-size:17px;font-weight:700;color:var(--text,#e2e8f0);margin-bottom:20px;}
.modal-close{position:absolute;top:14px;right:14px;background:none;border:none;cursor:pointer;color:var(--text-muted,#94a3b8);font-size:22px;}
.form-group{margin-bottom:14px;}
.form-group label{font-size:12px;color:var(--text-muted,#94a3b8);font-weight:600;margin-bottom:5px;display:block;}
.form-group input,.form-group textarea,.form-group select{width:100%;padding:9px 12px;border-radius:8px;border:1px solid var(--border,#2a2d3e);background:rgba(255,255,255,.05);color:var(--text,#e2e8f0);font-size:13px;box-sizing:border-box;}
.form-group input:focus,.form-group textarea:focus,.form-group select:focus{outline:none;border-color:#3b82f6;}
.contact-grid{max-height:220px;overflow-y:auto;border:1px solid var(--border,#2a2d3e);border-radius:8px;}
.contact-item{display:flex;align-items:center;gap:10px;padding:9px 12px;cursor:pointer;border-bottom:1px solid rgba(255,255,255,.04);transition:background .15s;}
.contact-item:hover,.contact-item.selected{background:rgba(59,130,246,.1);}
.contact-item input[type=checkbox]{margin:0;accent-color:#3b82f6;}
.contact-name{font-size:13px;color:var(--text,#e2e8f0);font-weight:500;}
.contact-role{font-size:11px;color:var(--text-muted,#94a3b8);}
.btn-primary{background:#3b82f6;border:none;border-radius:8px;padding:10px 20px;color:#fff;cursor:pointer;font-size:14px;font-weight:600;width:100%;margin-top:6px;}
.btn-primary:hover{background:#2563eb;}
.search-result-item{padding:10px 14px;border-bottom:1px solid rgba(255,255,255,.04);cursor:pointer;}
.search-result-item:hover{background:rgba(255,255,255,.05);}
.sr-chat{font-size:10px;color:#3b82f6;margin-bottom:2px;}
.sr-text{font-size:13px;color:var(--text,#e2e8f0);}
.sr-time{font-size:10px;color:var(--text-muted,#94a3b8);}
.members-list-item{display:flex;align-items:center;gap:10px;padding:9px 14px;border-bottom:1px solid rgba(255,255,255,.04);}
.online-dot{width:8px;height:8px;border-radius:50%;background:#22c55e;flex-shrink:0;}
.offline-dot{width:8px;height:8px;border-radius:50%;background:#4b5563;flex-shrink:0;}
@media(max-width:640px){.chat-left{width:100%;max-width:100%;}.chat-right{display:none;}.chat-right.mobile-open{display:flex;position:absolute;inset:0;z-index:10;}.chat-shell{position:relative;}}
</style>

<!-- ════════════════════════════════════════ SHELL ══════════════════════════════════════ -->
<div class="chat-shell">

  <!-- ── LEFT PANEL ────────────────────────────────────────────────────────── -->
  <div class="chat-left">
    <div class="chat-left-header">
      <h3>💬 Chat</h3>
      <div class="chat-header-btns">
        <button class="icon-btn" onclick="openSearchModal()" title="Search messages">🔍</button>
        <% if (_canGroup) { %>
        <button class="icon-btn" onclick="openGroupModal()" title="New group">👥+</button>
        <% } %>
        <button class="icon-btn" onclick="openNewChatModal()" title="New chat">✏️</button>
      </div>
    </div>
    <div class="chat-search">
      <input type="text" id="chatSearchInput" placeholder="Search chats…" oninput="filterChatList(this.value)">
    </div>
    <div class="chat-list" id="chatList">
      <div style="padding:24px;text-align:center;color:var(--text-muted,#94a3b8);font-size:13px;">Loading chats…</div>
    </div>
  </div>

  <!-- ── RIGHT PANEL ───────────────────────────────────────────────────────── -->
  <div class="chat-right" id="chatRight">

    <!-- Empty state -->
    <div class="chat-empty" id="chatEmptyState">
      <div class="chat-empty-icon">💬</div>
      <div style="font-size:16px;font-weight:600;color:var(--text,#e2e8f0);">Select a chat to start messaging</div>
      <div style="font-size:13px;">Or start a new conversation using the ✏️ button</div>
    </div>

    <!-- Active chat window -->
    <div id="chatWindow" style="display:none;flex:1;display:none;flex-direction:column;min-height:0;">

      <!-- Header -->
      <div class="chat-win-header">
        <div class="chat-avatar" id="winAvatar" style="width:38px;height:38px;font-size:14px;"></div>
        <div class="chat-win-info">
          <div class="chat-win-name" id="winName">—</div>
          <div class="chat-win-sub"  id="winSub">—</div>
        </div>
        <div class="chat-win-actions">
          <button class="icon-btn" onclick="openMembersModal()" title="Members" id="membersBtn" style="display:none;">👥</button>
          <button class="icon-btn" onclick="toggleMuteChat()"   title="Mute"    id="muteBtn">🔔</button>
          <button class="icon-btn" onclick="toggleArchiveChat()" title="Archive" id="archiveBtn">📂</button>
        </div>
      </div>

      <!-- Messages -->
      <div class="chat-messages" id="chatMessages"></div>
      <div class="typing-indicator" id="typingIndicator" style="display:none;"></div>

      <!-- Input -->
      <div class="chat-input-area" id="chatInputArea">
        <div class="reply-strip" id="replyStrip">
          <span id="replyText"></span>
          <button class="close-reply" onclick="clearReply()">×</button>
        </div>
        <div class="file-preview-strip" id="filePreviewStrip">
          <span>📎</span>
          <span class="fp-name" id="fpName"></span>
          <button class="fp-clear" onclick="clearFile()">×</button>
        </div>
        <div class="readonly-notice" id="readonlyNotice" style="display:none;">
          📢 This is a broadcast channel — only admins/teachers can post.
        </div>
        <div class="chat-input-row" id="chatInputRow">
          <input type="file" id="fileInput" style="display:none" onchange="handleFileSelect(this)">
          <button class="attach-btn" onclick="document.getElementById('fileInput').click()">📎</button>
          <textarea id="msgInput" rows="1" placeholder="Type a message…"
            onkeydown="handleInputKeydown(event)"
            oninput="handleInputChange(this)"></textarea>
          <button class="send-btn" onclick="sendMessage()">➤</button>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- ════════════════════════════ MODALS ════════════════════════════════════════ -->

<!-- New Direct Chat -->
<div class="modal-overlay" id="newChatModal" onclick="if(event.target===this)closeModal('newChatModal')">
  <div class="modal-box">
    <button class="modal-close" onclick="closeModal('newChatModal')">×</button>
    <div class="modal-title">✏️ New Message</div>
    <div class="form-group">
      <label>Search contacts</label>
      <input type="text" id="contactSearch" placeholder="Name or role…" oninput="filterContacts(this.value)">
    </div>
    <div class="contact-grid" id="contactGrid">
      <div style="padding:20px;text-align:center;color:var(--text-muted,#94a3b8);">Loading…</div>
    </div>
  </div>
</div>

<!-- New Group -->
<div class="modal-overlay" id="groupModal" onclick="if(event.target===this)closeModal('groupModal')">
  <div class="modal-box">
    <button class="modal-close" onclick="closeModal('groupModal')">×</button>
    <div class="modal-title">👥 Create Group</div>
    <div class="form-group">
      <label>Group Name *</label>
      <input type="text" id="grpName" placeholder="e.g. Class 10-A Teachers">
    </div>
    <div class="form-group">
      <label>Description</label>
      <textarea id="grpDesc" rows="2" placeholder="Optional description"></textarea>
    </div>
    <div class="form-group">
      <label>Type</label>
      <select id="grpType">
        <option value="group">Group (interactive)</option>
        <option value="broadcast">Broadcast (read-only for non-admins)</option>
      </select>
    </div>
    <div class="form-group">
      <label>Add Members</label>
      <input type="text" id="grpMemberSearch" placeholder="Search…" oninput="filterGroupContacts(this.value)" style="margin-bottom:6px;">
      <div class="contact-grid" id="grpContactGrid">
        <div style="padding:20px;text-align:center;color:var(--text-muted,#94a3b8);">Loading…</div>
      </div>
    </div>
    <div id="selectedMembersLabel" style="font-size:12px;color:#3b82f6;margin:6px 0;"></div>
    <button class="btn-primary" onclick="createGroup()">Create Group</button>
  </div>
</div>

<!-- Search Messages -->
<div class="modal-overlay" id="searchModal" onclick="if(event.target===this)closeModal('searchModal')">
  <div class="modal-box">
    <button class="modal-close" onclick="closeModal('searchModal')">×</button>
    <div class="modal-title">🔍 Search Messages</div>
    <div class="form-group">
      <input type="text" id="msgSearchInput" placeholder="Search text…" oninput="searchMessages(this.value)">
    </div>
    <div id="searchResults" style="margin-top:8px;"></div>
  </div>
</div>

<!-- Group Members -->
<div class="modal-overlay" id="membersModal" onclick="if(event.target===this)closeModal('membersModal')">
  <div class="modal-box">
    <button class="modal-close" onclick="closeModal('membersModal')">×</button>
    <div class="modal-title">👥 Members</div>
    <div id="membersList"></div>
    <% if (_myRole === 'school_admin' || _myRole === 'super_admin' || _myRole === 'teacher') { %>
    <div style="margin-top:16px;padding-top:16px;border-top:1px solid var(--border,#2a2d3e);">
      <div style="font-size:13px;font-weight:600;color:var(--text,#e2e8f0);margin-bottom:10px;">Group Settings</div>
      <label style="display:flex;align-items:center;gap:8px;font-size:13px;color:var(--text,#e2e8f0);cursor:pointer;">
        <input type="checkbox" id="readonlyToggle" onchange="updateReadonly(this.checked)" style="accent-color:#3b82f6;">
        Read-only (only admins/teachers can post)
      </label>
    </div>
    <% } %>
  </div>
</div>

<!-- ════════════════════════════ SCRIPTS ═══════════════════════════════════════ -->
<% if (gatewayUrl) { %>
<script src="<%= gatewayUrl %>/socket.io/socket.io.js"></script>
<% } else { %>
<script src="/socket.io/socket.io.js"></script>
<% } %>
<script>
'use strict';
/* ════ State ═══════════════════════════════════════════════════════════════ */
const MY_ID       = '<%= _myId %>';
const MY_ROLE     = '<%= _myRole %>';
const MY_NAME     = '<%= _myName %>';
const GATEWAY_URL = '<%= gatewayUrl %>';

let socket         = null;
let allChats       = [];
let activeChat     = null;   // current chat object
let activeChatId   = null;
let replyToMsg     = null;   // { _id, content, senderName }
let pendingFile    = null;   // { attachment, type }
let typingTimer    = null;
let allContacts    = [];
let groupContacts  = [];
let selectedGroupMembers = new Set();
let isAmIAdmin     = false;
let loadingMore    = false;
let hasMoreMessages = false;
let onlineUsers    = new Set();
let searchTimer    = null;

/* ════ Socket.io ════════════════════════════════════════════════════════════ */
function initSocket() {
    socket = GATEWAY_URL
        ? io(GATEWAY_URL, { transports: ['websocket', 'polling'], withCredentials: true })
        : io({ transports: ['websocket', 'polling'] });

    socket.on('connect', () => console.log('[Socket] connected:', socket.id));
    socket.on('connect_error', e => console.warn('[Socket] error:', e.message));

    socket.on('chat:message',        onIncomingMessage);
    socket.on('chat:typing',         onTyping);
    socket.on('chat:message_read',   onMessageRead);
    socket.on('chat:message_edited', onMessageEdited);
    socket.on('chat:message_deleted',onMessageDeleted);
    socket.on('chat:user_online',    d => { onlineUsers.add(d.userId); updatePresence(d.userId, true); });
    socket.on('chat:user_offline',   d => { onlineUsers.delete(d.userId); updatePresence(d.userId, false); });
    socket.on('chat:group_created',  onGroupCreated);
    socket.on('chat:group_updated',  onGroupUpdated);
    socket.on('chat:member_removed', onMemberRemoved);
    socket.on('chat:error',          d => showToastChat('⚠️ ' + d.message, '#ef4444'));
}

/* ════ Init ═════════════════════════════════════════════════════════════════ */
document.addEventListener('DOMContentLoaded', async () => {
    initSocket();
    await loadChats();

    // Infinite scroll for messages
    document.getElementById('chatMessages').addEventListener('scroll', onMessagesScroll);

    // Open chat if URL has #chatId
    const hash = location.hash.replace('#', '');
    if (hash) openChat(hash);
});

/* ════ Chat list ════════════════════════════════════════════════════════════ */
async function loadChats() {
    try {
        const r = await apiFetch('/chat/api/chats');
        allChats = r.chats || [];
        renderChatList(allChats);
    } catch { }
}

function renderChatList(chats) {
    const el = document.getElementById('chatList');
    if (!chats.length) {
        el.innerHTML = '<div style="padding:24px;text-align:center;color:var(--text-muted,#94a3b8);font-size:13px;">No conversations yet.<br>Start one with the ✏️ button!</div>';
        return;
    }
    el.innerHTML = chats.map(c => {
        const name     = esc(c.displayName || c.name || 'Group');
        const preview  = chatPreview(c.lastMessage);
        const time     = c.lastActivity ? timeAgo(c.lastActivity) : '';
        const badge    = c.unreadCount  ? `<div class="chat-unread-badge">${c.unreadCount > 99 ? '99+' : c.unreadCount}</div>` : '';
        const avatar   = avatarHtml(name, c.displayAvatar, 42);
        const typeIcon = c.type === 'broadcast' ? '📢 ' : c.type === 'group' ? '👥 ' : '';
        return `<div class="chat-item${activeChatId===String(c._id)?' active':''}" id="ci-${c._id}" onclick="openChat('${c._id}')">
            ${avatar}
            <div class="chat-item-info">
              <div class="chat-item-top">
                <div class="chat-item-name">${typeIcon}${name}</div>
                <div class="chat-item-time">${time}</div>
              </div>
              <div class="chat-item-preview">${preview}</div>
            </div>
            ${badge}
          </div>`;
    }).join('');
}

function filterChatList(q) {
    if (!q) { renderChatList(allChats); return; }
    const s = q.toLowerCase();
    renderChatList(allChats.filter(c =>
        (c.displayName || c.name || '').toLowerCase().includes(s)
    ));
}

/* ════ Open chat ════════════════════════════════════════════════════════════ */
async function openChat(chatId) {
    activeChatId = String(chatId);
    const chat   = allChats.find(c => String(c._id) === activeChatId);
    activeChat   = chat;

    // Highlight in list
    document.querySelectorAll('.chat-item').forEach(el => el.classList.remove('active'));
    const ci = document.getElementById(`ci-${chatId}`);
    if (ci) { ci.classList.add('active'); const badge = ci.querySelector('.chat-unread-badge'); if (badge) badge.remove(); }

    // Update header
    const name   = chat ? (chat.displayName || chat.name || 'Group') : '…';
    const isGroup = chat && (chat.type === 'group' || chat.type === 'broadcast');
    document.getElementById('winName').textContent = name;
    document.getElementById('winSub').textContent  = isGroup ? (chat.type === 'broadcast' ? '📢 Broadcast channel' : '👥 Group') : roleLabel(chat && chat.otherUser && chat.otherUser.role);
    const av = document.getElementById('winAvatar');
    av.innerHTML = (chat && chat.displayAvatar)
        ? `<img src="${esc(chat.displayAvatar)}" alt="">`
        : `<span>${name.charAt(0).toUpperCase()}</span>`;

    document.getElementById('membersBtn').style.display = isGroup ? '' : 'none';

    // Read-only input control
    const isReadOnly = chat && chat.isReadOnly;
    const canPost    = !isReadOnly || ['school_admin','super_admin','teacher'].includes(MY_ROLE);
    document.getElementById('chatInputRow').style.display    = canPost ? '' : 'none';
    document.getElementById('readonlyNotice').style.display  = (!canPost) ? '' : 'none';

    isAmIAdmin = chat && chat.memberRole === 'admin';

    // Show window
    document.getElementById('chatEmptyState').style.display = 'none';
    const win = document.getElementById('chatWindow');
    win.style.display = 'flex';
    win.style.flexDirection = 'column';

    // Load messages
    document.getElementById('chatMessages').innerHTML = '<div style="padding:24px;text-align:center;color:var(--text-muted,#94a3b8);">Loading…</div>';
    hasMoreMessages = false;
    await loadMessages();

    // Tell socket to join this room (in case it wasn't already)
    if (socket) socket.emit('chat:join_room', { chatId });

    // Mark as read
    if (socket) socket.emit('chat:read', { chatId, messageId: null });

    location.hash = chatId;
}

/* ════ Messages ══════════════════════════════════════════════════════════════ */
let _messages = [];

async function loadMessages(before) {
    try {
        let url = `/chat/api/chats/${activeChatId}/messages?limit=40`;
        if (before) url += `&before=${before}`;
        const r = await apiFetch(url);
        if (!before) _messages = r.messages || [];
        else         _messages = [...(r.messages || []), ..._messages];
        hasMoreMessages = r.hasMore;
        renderMessages(_messages, !!before);
    } catch { }
}

function renderMessages(msgs, prepend = false) {
    const el    = document.getElementById('chatMessages');
    const prevH = el.scrollHeight;

    if (!msgs.length) {
        el.innerHTML = '<div style="padding:40px;text-align:center;color:var(--text-muted,#94a3b8);">No messages yet. Say hello! 👋</div>';
        return;
    }

    el.innerHTML = '';
    let lastDate = '';
    msgs.forEach(msg => {
        const d = new Date(msg.createdAt).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' });
        if (d !== lastDate) {
            el.innerHTML += `<div class="msg-date-divider"><span>${d}</span></div>`;
            lastDate = d;
        }
        el.innerHTML += buildMsgHtml(msg);
    });

    if (prepend) {
        el.scrollTop = el.scrollHeight - prevH;
    } else {
        el.scrollTop = el.scrollHeight;
    }
}

function buildMsgHtml(msg) {
    const isMine = String(msg.sender && msg.sender._id || msg.sender) === MY_ID;
    const sender = msg.sender || {};
    const sName  = sender.name || 'Unknown';
    const sRole  = sender.role || '';
    const time   = new Date(msg.createdAt).toLocaleTimeString('en-IN', { hour:'2-digit', minute:'2-digit' });

    if (msg.isDeleted) {
        return `<div class="msg-row${isMine?' mine':''}">
            <div class="msg-avatar-wrap">${!isMine ? avatarHtml(sName, sender.profileImage, 32, 32) : ''}</div>
            <div class="msg-bubble-wrap">
              <div class="msg-bubble deleted">🚫 This message was deleted</div>
              <div class="msg-meta"><span class="msg-time">${time}</span></div>
            </div>
          </div>`;
    }

    let replyHtml = '';
    if (msg.replyTo && !msg.replyTo.isDeleted) {
        const rSender = (msg.replyTo.sender && msg.replyTo.sender.name) || 'Unknown';
        replyHtml = `<div class="msg-reply-preview">↩ <b>${esc(rSender)}</b>: ${esc(truncate(msg.replyTo.content, 60))}</div>`;
    }

    let contentHtml = '';
    if (msg.type === 'image' && msg.attachments && msg.attachments[0]) {
        const att = msg.attachments[0];
        contentHtml = `<img class="msg-attach-image" src="${esc(att.fileUrl)}" alt="${esc(att.originalName)}" onclick="window.open(this.src,'_blank')">`;
        if (msg.content) contentHtml += `<div class="msg-text">${esc(msg.content)}</div>`;
    } else if (msg.type === 'file' && msg.attachments && msg.attachments[0]) {
        const att = msg.attachments[0];
        contentHtml = `<div class="msg-attach-file">📎 <a href="${esc(att.fileUrl)}" target="_blank">${esc(att.originalName)}</a> <span style="font-size:10px;color:var(--text-muted,#94a3b8);">(${fmtSize(att.fileSize)})</span></div>`;
        if (msg.content) contentHtml += `<div class="msg-text">${esc(msg.content)}</div>`;
    } else {
        contentHtml = `<div class="msg-text">${esc(msg.content)}</div>`;
    }

    const editedBadge = msg.isEdited ? '<span class="msg-edited">(edited)</span>' : '';
    const statusIcon  = isMine ? (msg._delivered ? '✓✓' : '✓') : '';

    const actionsHtml = `<div class="msg-actions">
        <button class="msg-action-btn" onclick="setReply('${msg._id}','${esc(sName)}','${esc(truncate(msg.content,40))}')">↩ Reply</button>
        ${isMine ? `<button class="msg-action-btn" onclick="startEdit('${msg._id}','${esc(msg.content)}')">✏️ Edit</button>` : ''}
        ${(isMine || MY_ROLE === 'school_admin' || MY_ROLE === 'super_admin') ? `<button class="msg-action-btn" onclick="deleteMsg('${msg._id}')" style="color:#ef4444;">🗑 Delete</button>` : ''}
      </div>`;

    return `<div class="msg-row${isMine?' mine':''}" id="msg-${msg._id}">
        <div class="msg-avatar-wrap">${!isMine ? avatarHtml(sName, sender.profileImage, 32, 32) : ''}</div>
        <div class="msg-bubble-wrap">
          ${!isMine && activeChat && activeChat.type !== 'direct' ? `<div class="msg-sender-name">${esc(sName)} <span style="font-size:10px;opacity:.6;">(${roleLabel(sRole)})</span></div>` : ''}
          <div class="msg-bubble">
            ${replyHtml}
            ${contentHtml}
            <div class="msg-meta">
              <span class="msg-time">${time}</span>
              ${editedBadge}
              ${statusIcon ? `<span class="msg-status">${statusIcon}</span>` : ''}
            </div>
          </div>
          ${actionsHtml}
        </div>
      </div>`;
}

/* ════ Incoming Socket events ═══════════════════════════════════════════════ */
function onIncomingMessage(msg) {
    // Remove optimistic if tempId matches
    if (msg.tempId) {
        const el = document.getElementById(`opt-${msg.tempId}`);
        if (el) el.remove();
    }

    const isCurrent = activeChatId && String(msg.chat) === activeChatId;
    if (isCurrent) {
        _messages.push(msg);
        const el = document.getElementById('chatMessages');
        const atBottom = el.scrollHeight - el.clientHeight - el.scrollTop < 80;
        const d = new Date(msg.createdAt).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' });
        // Add date divider if needed
        const lastDiv = el.querySelector('.msg-date-divider:last-of-type');
        if (!lastDiv || lastDiv.textContent.trim() !== d) {
            el.innerHTML += `<div class="msg-date-divider"><span>${d}</span></div>`;
        }
        el.innerHTML += buildMsgHtml(msg);
        if (atBottom) el.scrollTop = el.scrollHeight;
        if (socket) socket.emit('chat:read', { chatId: activeChatId, messageId: msg._id });
    }

    // Update chat list preview
    updateChatPreviewInList(String(msg.chat), msg);
}

function onTyping(data) {
    if (!activeChatId || String(data.chatId) !== activeChatId) return;
    const el = document.getElementById('typingIndicator');
    if (data.isTyping && data.userId !== MY_ID) {
        el.textContent = 'Someone is typing…';
        el.style.display = '';
    } else {
        el.style.display = 'none';
    }
}

function onMessageRead(data) {
    // Could update tick icons — simplified: no-op
}

function onMessageEdited(data) {
    if (!activeChatId || String(data.chatId) !== activeChatId) return;
    const idx = _messages.findIndex(m => String(m._id) === String(data.messageId));
    if (idx >= 0) {
        _messages[idx].content  = data.content;
        _messages[idx].isEdited = true;
    }
    const msgEl = document.getElementById(`msg-${data.messageId}`);
    if (msgEl) {
        const textEl = msgEl.querySelector('.msg-text');
        if (textEl) textEl.textContent = data.content;
        const meta = msgEl.querySelector('.msg-meta');
        if (meta && !meta.querySelector('.msg-edited')) {
            meta.insertAdjacentHTML('beforeend', '<span class="msg-edited">(edited)</span>');
        }
    }
}

function onMessageDeleted(data) {
    if (!activeChatId || String(data.chatId) !== activeChatId) return;
    const idx = _messages.findIndex(m => String(m._id) === String(data.messageId));
    if (idx >= 0) _messages[idx].isDeleted = true;
    const msgEl = document.getElementById(`msg-${data.messageId}`);
    if (msgEl) {
        const bubble = msgEl.querySelector('.msg-bubble');
        if (bubble) { bubble.className = 'msg-bubble deleted'; bubble.innerHTML = '🚫 This message was deleted'; }
        const actions = msgEl.querySelector('.msg-actions');
        if (actions) actions.remove();
    }
}

function onGroupCreated(data) {
    showToastChat(`New group created: ${data.name}`, '#22c55e');
    loadChats();
}

function onGroupUpdated(data) {
    if (activeChat && String(activeChat._id) === String(data.chatId)) {
        if (data.name !== undefined) {
            activeChat.name = data.name;
            document.getElementById('winName').textContent = data.name;
        }
        if (data.isReadOnly !== undefined) {
            activeChat.isReadOnly = data.isReadOnly;
            const canPost = !data.isReadOnly || ['school_admin','super_admin','teacher'].includes(MY_ROLE);
            document.getElementById('chatInputRow').style.display   = canPost ? '' : 'none';
            document.getElementById('readonlyNotice').style.display = !canPost  ? '' : 'none';
        }
    }
    loadChats();
}

function onMemberRemoved(data) {
    if (data.userId === MY_ID) {
        showToastChat('You were removed from this group.', '#ef4444');
        activeChatId = null; activeChat = null;
        document.getElementById('chatWindow').style.display = 'none';
        document.getElementById('chatEmptyState').style.display = '';
    }
    loadChats();
}

function updatePresence(userId, online) {
    if (activeChat && activeChat.type === 'direct' &&
        activeChat.otherUser && String(activeChat.otherUser._id) === userId) {
        document.getElementById('winSub').textContent = online ? '🟢 Online' : 'Offline';
    }
}

/* ════ Send message ══════════════════════════════════════════════════════════ */
async function sendMessage() {
    const textarea = document.getElementById('msgInput');
    const content  = textarea.value.trim();
    if (!content && !pendingFile) return;
    if (!activeChatId) return;

    const tempId = 'tmp-' + Date.now();

    if (pendingFile) {
        // Send with attachment via REST first, then emit
        const { attachment, type } = pendingFile;
        const payload = { chatId: activeChatId, content, type, attachments: [attachment], replyTo: replyToMsg?._id, tempId };
        clearReply(); clearFile(); textarea.value = ''; autoResize(textarea);
        if (socket) socket.emit('chat:send', payload);
    } else {
        // Optimistic render
        const optMsg = {
            _id: tempId, chat: activeChatId,
            sender: { _id: MY_ID, name: MY_NAME, role: MY_ROLE },
            content, type: 'text', createdAt: new Date().toISOString(),
            replyTo: replyToMsg ? { _id: replyToMsg._id, content: replyToMsg.content, sender: { name: replyToMsg.senderName } } : null,
        };
        const el = document.getElementById('chatMessages');
        el.innerHTML += `<div id="opt-${tempId}">${buildMsgHtml(optMsg)}</div>`;
        el.scrollTop = el.scrollHeight;

        if (socket) socket.emit('chat:send', {
            chatId: activeChatId,
            content,
            type: 'text',
            replyTo: replyToMsg?._id || null,
            tempId,
        });
        clearReply(); textarea.value = ''; autoResize(textarea);
    }
}

/* ════ Input helpers ═════════════════════════════════════════════════════════ */
function handleInputKeydown(e) {
    if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        sendMessage();
    }
}

function handleInputChange(el) {
    autoResize(el);
    if (!activeChatId || !socket) return;
    socket.emit('chat:typing_start', { chatId: activeChatId });
    clearTimeout(typingTimer);
    typingTimer = setTimeout(() => {
        socket.emit('chat:typing_stop', { chatId: activeChatId });
    }, 2000);
}

function autoResize(el) {
    el.style.height = 'auto';
    el.style.height = Math.min(el.scrollHeight, 120) + 'px';
}

/* ════ Reply ═══════════════════════════════════════════════════════════════ */
function setReply(msgId, senderName, content) {
    replyToMsg = { _id: msgId, content, senderName };
    const strip = document.getElementById('replyStrip');
    document.getElementById('replyText').textContent = `↩ ${senderName}: ${content}`;
    strip.style.display = '';
    document.getElementById('msgInput').focus();
}
function clearReply() {
    replyToMsg = null;
    document.getElementById('replyStrip').style.display = 'none';
}

/* ════ Edit / Delete ════════════════════════════════════════════════════════ */
function startEdit(msgId, currentContent) {
    const input = document.getElementById('msgInput');
    input.value = currentContent;
    input.dataset.editingId = msgId;
    autoResize(input);
    input.focus();
    input.placeholder = 'Editing message… (Enter to save, Esc to cancel)';

    input.addEventListener('keydown', function onKey(e) {
        if (e.key === 'Escape') {
            input.value = ''; input.dataset.editingId = '';
            input.placeholder = 'Type a message…';
            input.removeEventListener('keydown', onKey);
        }
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            const newContent = input.value.trim();
            if (!newContent) return;
            if (socket) socket.emit('chat:edit', { messageId: msgId, content: newContent });
            input.value = ''; input.dataset.editingId = '';
            input.placeholder = 'Type a message…';
            input.removeEventListener('keydown', onKey);
        }
    }, { once: false });
}

async function deleteMsg(msgId) {
    if (!confirm('Delete this message?')) return;
    if (socket) socket.emit('chat:delete', { messageId: msgId });
}

/* ════ File upload ══════════════════════════════════════════════════════════ */
function handleFileSelect(input) {
    const file = input.files[0];
    if (!file) return;
    const fd = new FormData();
    fd.append('file', file);

    fetch('/chat/upload', { method: 'POST', body: fd })
        .then(r => r.json())
        .then(data => {
            if (!data.success) { showToastChat('Upload failed: ' + data.message, '#ef4444'); return; }
            pendingFile = { attachment: data.attachment, type: data.type };
            document.getElementById('fpName').textContent = data.attachment.originalName;
            document.getElementById('filePreviewStrip').style.display = 'flex';
        })
        .catch(() => showToastChat('Upload failed', '#ef4444'));

    input.value = '';
}
function clearFile() {
    pendingFile = null;
    document.getElementById('filePreviewStrip').style.display = 'none';
}

/* ════ Infinite scroll ══════════════════════════════════════════════════════ */
async function onMessagesScroll(e) {
    if (loadingMore || !hasMoreMessages || !activeChatId) return;
    if (e.target.scrollTop < 100) {
        loadingMore = true;
        const oldest = _messages[0];
        if (oldest) await loadMessages(oldest.createdAt);
        loadingMore = false;
    }
}

/* ════ Mute / Archive ════════════════════════════════════════════════════════ */
async function toggleMuteChat() {
    if (!activeChatId) return;
    const r = await apiFetch(`/chat/${activeChatId}/mute`, 'POST', {});
    if (r.success) {
        showToastChat(r.isMuted ? '🔕 Chat muted' : '🔔 Chat unmuted', '#3b82f6');
        document.getElementById('muteBtn').textContent = r.isMuted ? '🔕' : '🔔';
        const c = allChats.find(x => String(x._id) === activeChatId);
        if (c) c.isMuted = r.isMuted;
    }
}

async function toggleArchiveChat() {
    if (!activeChatId) return;
    const r = await apiFetch(`/chat/${activeChatId}/archive`, 'POST', {});
    if (r.success) {
        showToastChat(r.isArchived ? '📂 Archived' : '📂 Unarchived', '#3b82f6');
        await loadChats();
    }
}

/* ════ New chat modal ════════════════════════════════════════════════════════ */
async function openNewChatModal() {
    if (!allContacts.length) {
        const r = await apiFetch('/chat/api/contacts');
        allContacts = r.contacts || [];
    }
    renderContactGrid('contactGrid', allContacts, 'direct');
    openModal('newChatModal');
}

function filterContacts(q) {
    const s = q.toLowerCase();
    const filtered = allContacts.filter(c =>
        c.name.toLowerCase().includes(s) || c.role.toLowerCase().includes(s)
    );
    renderContactGrid('contactGrid', filtered, 'direct');
}

function renderContactGrid(gridId, contacts, mode) {
    const el = document.getElementById(gridId);
    if (!contacts.length) {
        el.innerHTML = '<div style="padding:20px;text-align:center;color:var(--text-muted,#94a3b8);">No contacts found</div>';
        return;
    }
    if (mode === 'direct') {
        el.innerHTML = contacts.map(c => `
            <div class="contact-item" onclick="startDirectChat('${c._id}')">
              ${avatarHtml(c.name, c.profileImage, 32, 32)}
              <div><div class="contact-name">${esc(c.name)}</div><div class="contact-role">${roleLabel(c.role)}</div></div>
            </div>`).join('');
    } else {
        el.innerHTML = contacts.map(c => {
            const checked = selectedGroupMembers.has(String(c._id));
            return `<div class="contact-item${checked?' selected':''}" onclick="toggleGroupMember('${c._id}', this)">
              <input type="checkbox" ${checked?'checked':''} readonly>
              ${avatarHtml(c.name, c.profileImage, 28, 28)}
              <div><div class="contact-name">${esc(c.name)}</div><div class="contact-role">${roleLabel(c.role)}</div></div>
            </div>`;
        }).join('');
    }
}

async function startDirectChat(receiverId) {
    closeModal('newChatModal');
    try {
        const r = await apiFetch('/chat/direct', 'POST', { receiverId });
        if (r.success) {
            await loadChats();
            openChat(r.chatId);
        } else {
            showToastChat('⚠️ ' + r.message, '#ef4444');
        }
    } catch { showToastChat('Failed to start chat', '#ef4444'); }
}

/* ════ Group modal ═══════════════════════════════════════════════════════════ */
async function openGroupModal() {
    selectedGroupMembers.clear();
    if (!groupContacts.length) {
        const r = await apiFetch('/chat/api/contacts');
        groupContacts = r.contacts || [];
    }
    renderContactGrid('grpContactGrid', groupContacts, 'group');
    openModal('groupModal');
}

function filterGroupContacts(q) {
    const s = q.toLowerCase();
    const filtered = groupContacts.filter(c =>
        c.name.toLowerCase().includes(s) || c.role.toLowerCase().includes(s)
    );
    renderContactGrid('grpContactGrid', filtered, 'group');
}

function toggleGroupMember(userId, el) {
    if (selectedGroupMembers.has(userId)) {
        selectedGroupMembers.delete(userId);
        el.classList.remove('selected');
        el.querySelector('input').checked = false;
    } else {
        selectedGroupMembers.add(userId);
        el.classList.add('selected');
        el.querySelector('input').checked = true;
    }
    document.getElementById('selectedMembersLabel').textContent =
        selectedGroupMembers.size ? `${selectedGroupMembers.size} member(s) selected` : '';
}

async function createGroup() {
    const name     = document.getElementById('grpName').value.trim();
    const desc     = document.getElementById('grpDesc').value.trim();
    const type     = document.getElementById('grpType').value;
    const isRO     = type === 'broadcast';
    if (!name) { showToastChat('Group name is required', '#ef4444'); return; }
    try {
        const r = await apiFetch('/chat/group', 'POST', {
            name, description: desc, type,
            isReadOnly: isRO,
            memberIds: JSON.stringify([...selectedGroupMembers]),
        });
        if (r.success) {
            closeModal('groupModal');
            await loadChats();
            openChat(r.chatId);
        } else {
            showToastChat('⚠️ ' + r.message, '#ef4444');
        }
    } catch { showToastChat('Failed to create group', '#ef4444'); }
}

/* ════ Members modal ═════════════════════════════════════════════════════════ */
async function openMembersModal() {
    if (!activeChatId) return;
    try {
        const r = await apiFetch(`/chat/api/chats/${activeChatId}/members`);
        const el = document.getElementById('membersList');
        const chat = activeChat;
        const isROChat = chat && chat.isReadOnly;
        document.getElementById('readonlyToggle') && (document.getElementById('readonlyToggle').checked = isROChat);

        el.innerHTML = (r.members || []).map(m => {
            const u = m.user || {};
            const online = onlineUsers.has(String(u._id));
            return `<div class="members-list-item">
                ${avatarHtml(u.name, u.profileImage, 36, 36)}
                <div class="chat-win-info">
                  <div class="chat-win-name" style="font-size:13px;">${esc(u.name || '?')}</div>
                  <div class="chat-win-sub">${roleLabel(u.role)}${m.role==='admin'?' · Admin':''}</div>
                </div>
                <div class="${online?'online-dot':'offline-dot'}" title="${online?'Online':'Offline'}"></div>
                ${isAmIAdmin && String(u._id) !== MY_ID
                    ? `<button class="msg-action-btn" onclick="removeMember('${u._id}')" style="color:#ef4444;">Remove</button>`
                    : ''}
              </div>`;
        }).join('');
        openModal('membersModal');
    } catch { showToastChat('Failed to load members', '#ef4444'); }
}

async function removeMember(userId) {
    if (!confirm('Remove this member?')) return;
    const r = await apiFetch(`/chat/group/${activeChatId}/member/${userId}`, 'DELETE');
    if (r.success) { closeModal('membersModal'); openMembersModal(); }
    else showToastChat('⚠️ ' + r.message, '#ef4444');
}

async function updateReadonly(checked) {
    if (!activeChatId) return;
    await apiFetch(`/chat/group/${activeChatId}/settings`, 'PATCH', { isReadOnly: checked });
}

/* ════ Search messages ═══════════════════════════════════════════════════════ */
function openSearchModal() { openModal('searchModal'); document.getElementById('msgSearchInput').focus(); }

function searchMessages(q) {
    clearTimeout(searchTimer);
    if (!q || q.length < 2) { document.getElementById('searchResults').innerHTML = ''; return; }
    searchTimer = setTimeout(async () => {
        const r = await apiFetch(`/chat/api/search?q=${encodeURIComponent(q)}`);
        const el = document.getElementById('searchResults');
        if (!r.messages || !r.messages.length) {
            el.innerHTML = '<div style="padding:16px;text-align:center;color:var(--text-muted,#94a3b8);">No results</div>';
            return;
        }
        el.innerHTML = r.messages.map(m => {
            const chat = m.chat || {};
            const chatName = chat.name || 'Direct';
            return `<div class="search-result-item" onclick="closeModal('searchModal');openChat('${chat._id}')">
                <div class="sr-chat">💬 ${esc(chatName)}</div>
                <div class="sr-text">${esc(truncate(m.content, 80))}</div>
                <div class="sr-time">${timeAgo(m.createdAt)}</div>
              </div>`;
        }).join('');
    }, 350);
}

/* ════ Utilities ═════════════════════════════════════════════════════════════ */
function updateChatPreviewInList(chatId, msg) {
    const c = allChats.find(x => String(x._id) === chatId);
    if (c) {
        c.lastMessage  = msg;
        c.lastActivity = msg.createdAt;
        if (String(chatId) !== activeChatId) c.unreadCount = (c.unreadCount || 0) + 1;
    } else {
        loadChats();
    }
    renderChatList(allChats);
}

function chatPreview(msg) {
    if (!msg) return '<span style="font-style:italic;opacity:.6;">No messages yet</span>';
    if (msg.isDeleted) return '🚫 Message deleted';
    if (msg.type === 'image') return '📷 Photo';
    if (msg.type === 'file')  return '📎 File';
    const senderPrefix = msg.sender && msg.sender.name ? msg.sender.name.split(' ')[0] + ': ' : '';
    return esc(senderPrefix + truncate(msg.content || '', 40));
}

function avatarHtml(name, imgUrl, size = 42, fSize = 16) {
    const s = `width:${size}px;height:${size}px;font-size:${fSize}px;`;
    if (imgUrl) return `<div class="chat-avatar" style="${s}"><img src="${esc(imgUrl)}" alt=""></div>`;
    return `<div class="chat-avatar" style="${s}">${(name||'?').charAt(0).toUpperCase()}</div>`;
}

function roleLabel(role) {
    return { super_admin:'Super Admin', school_admin:'Admin', teacher:'Teacher', student:'Student', parent:'Parent' }[role] || (role||'');
}

function timeAgo(d) {
    const diff = Date.now() - new Date(d).getTime();
    const m = Math.floor(diff / 60000);
    if (m < 1) return 'now';
    if (m < 60) return m + 'm';
    const h = Math.floor(m / 60);
    if (h < 24) return h + 'h';
    const dy = Math.floor(h / 24);
    if (dy < 7) return dy + 'd';
    return new Date(d).toLocaleDateString('en-IN', { day:'numeric', month:'short' });
}

function esc(s) {
    return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function truncate(s, n) {
    return s && s.length > n ? s.slice(0, n) + '…' : (s || '');
}

function fmtSize(bytes) {
    if (!bytes) return '0B';
    if (bytes < 1024) return bytes + 'B';
    if (bytes < 1048576) return Math.round(bytes/1024) + 'KB';
    return (bytes/1048576).toFixed(1) + 'MB';
}

async function apiFetch(url, method = 'GET', body = null) {
    const opts = { method, headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' } };
    if (body) opts.body = JSON.stringify(body);
    const r = await fetch(url, opts);
    return r.json();
}

function openModal(id)  { document.getElementById(id).style.display = 'flex'; }
function closeModal(id) { document.getElementById(id).style.display = 'none'; }

function showToastChat(msg, color = '#3b82f6') {
    const tc = document.getElementById('toastContainer');
    if (!tc) return;
    const t = document.createElement('div');
    t.style.cssText = `pointer-events:auto;background:var(--card-bg,#1a1d2e);border:1px solid var(--border,#2a2d3e);border-left:4px solid ${color};border-radius:12px;padding:12px 16px;width:280px;box-shadow:0 8px 32px rgba(0,0,0,.5);animation:slideInToast .3s ease;position:relative;color:var(--text,#e2e8f0);font-size:13px;`;
    t.textContent = msg;
    tc.appendChild(t);
    setTimeout(() => { t.style.opacity = '0'; t.style.transition = 'opacity .4s'; setTimeout(() => t.remove(), 400); }, 4000);
}

document.addEventListener('keydown', e => {
    if (e.key === 'Escape') {
        document.querySelectorAll('.modal-overlay').forEach(el => { el.style.display = 'none'; });
    }
});
</script>
