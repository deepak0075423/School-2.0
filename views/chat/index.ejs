      </div>
      <div class="fg" style="margin-bottom:8px;">
        <input type="text" id="addMemberSearch" placeholder="Search contacts…" oninput="filterAddMemberContacts(this.value)" autocomplete="off">
      </div>
      <div class="cgrid" id="addMemberGrid" style="max-height:160px;">
        <div style="padding:16px;text-align:center;color:#484f58;font-size:12px;">Loading…</div>
      </div>
    </div>
    <% } %>

    <!-- Group settings -->
    <% if (_myRole === 'school_admin' || _myRole === 'teacher') { %>
    <hr class="section-divider">
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;">
      <label style="display:flex;align-items:center;gap:8px;font-size:13px;color:#c9d1d9;cursor:pointer;">
        <input type="checkbox" id="readonlyToggle" onchange="updateReadonly(this.checked)" style="accent-color:#388bfd;">
        Broadcast mode (read-only for non-admins)
      </label>
      <% if (_myRole === 'school_admin' || _myRole === 'teacher') { %>
      <button class="btn-sec" style="font-size:11px;padding:5px 12px;" id="addMemberBtn" onclick="toggleAddMemberPanel()">+ Add Members</button>
