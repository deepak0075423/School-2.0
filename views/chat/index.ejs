<%
  const _myId     = session && session.userId   ? String(session.userId)   : '';
  const _myRole   = session && session.userRole ? session.userRole         : '';
  const _myName   = session && session.userName ? session.userName         : 'Me';
  const _canGroup = typeof canCreateGroup !== 'undefined' ? canCreateGroup : false;
%>

<style>
/* ═══════════════════════ CHAT SHELL ═══════════════════════════════════════ */
.cs{display:flex;height:calc(100vh - 110px);border-radius:18px;overflow:hidden;background:#0d1117;border:1px solid #21262d;box-shadow:0 24px 80px rgba(0,0,0,.5);}

/* ═══════════════════════ LEFT PANEL ════════════════════════════════════════ */
.cl{width:310px;min-width:260px;max-width:340px;display:flex;flex-direction:column;border-right:1px solid #21262d;background:#161b22;flex-shrink:0;}
.cl-hdr{padding:14px 16px 10px;background:linear-gradient(135deg,#1c2230,#161b22);border-bottom:1px solid #21262d;}
.cl-hdr-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
.cl-hdr-top h3{margin:0;font-size:15px;font-weight:700;color:#e6edf3;letter-spacing:.3px;}
.cl-btns{display:flex;gap:5px;}
.cl-btn{background:rgba(56,139,253,.12);border:1px solid rgba(56,139,253,.2);border-radius:8px;padding:5px 9px;cursor:pointer;color:#58a6ff;font-size:13px;transition:all .2s;line-height:1;}
.cl-btn:hover{background:rgba(56,139,253,.22);border-color:rgba(56,139,253,.4);}
.cl-search{position:relative;}
.cl-search input{width:100%;padding:7px 12px 7px 34px;border-radius:8px;border:1px solid #30363d;background:rgba(255,255,255,.04);color:#c9d1d9;font-size:12px;box-sizing:border-box;transition:border .2s;}
.cl-search input:focus{outline:none;border-color:#388bfd;background:rgba(255,255,255,.06);}
.cl-search::before{content:'🔍';position:absolute;left:10px;top:50%;transform:translateY(-50%);font-size:12px;opacity:.5;pointer-events:none;}

/* Chat list */
.cl-list{flex:1;overflow-y:auto;}
.cl-list::-webkit-scrollbar{width:4px;}
.cl-list::-webkit-scrollbar-thumb{background:#30363d;border-radius:4px;}
.ci{display:flex;align-items:center;gap:10px;padding:11px 14px;cursor:pointer;border-bottom:1px solid rgba(255,255,255,.03);transition:background .15s;position:relative;}
.ci:hover{background:rgba(255,255,255,.04);}
.ci.active{background:rgba(56,139,253,.1);border-left:2px solid #388bfd;}
.ci.active .ci-name{color:#58a6ff;}
.ca{width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,#388bfd,#1f6feb);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:15px;flex-shrink:0;overflow:hidden;}
.ca img{width:100%;height:100%;object-fit:cover;border-radius:50%;}
.ca.grp{background:linear-gradient(135deg,#3fb950,#238636);}
.ca.bcast{background:linear-gradient(135deg,#e3b341,#9e6a03);}
.ci-body{flex:1;min-width:0;}
.ci-top{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:2px;}
.ci-name{font-weight:600;font-size:13px;color:#c9d1d9;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:150px;}
.ci-time{font-size:10px;color:#6e7681;flex-shrink:0;}
.ci-preview{font-size:12px;color:#6e7681;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.ci-badge{position:absolute;right:12px;top:50%;transform:translateY(-50%);background:#388bfd;color:#fff;border-radius:10px;min-width:18px;height:18px;font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center;padding:0 5px;}

/* ═══════════════════════ RIGHT PANEL ═══════════════════════════════════════ */
.cr{flex:1;display:flex;flex-direction:column;min-width:0;background:#0d1117;}

/* Empty state */
.cr-empty{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;color:#484f58;}
.cr-empty-icon{font-size:56px;opacity:.25;}
.cr-empty-title{font-size:15px;font-weight:600;color:#8b949e;}
.cr-empty-sub{font-size:12px;color:#484f58;}

/* Chat window header */
.cw-hdr{padding:11px 16px;border-bottom:1px solid #21262d;display:flex;align-items:center;gap:11px;flex-shrink:0;background:#161b22;}
.cw-info{flex:1;min-width:0;}
.cw-name{font-weight:700;font-size:14px;color:#e6edf3;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.cw-sub{font-size:11px;color:#6e7681;margin-top:1px;}
.cw-actions{display:flex;gap:5px;}

/* Messages */
.cw-msgs{flex:1;overflow-y:auto;padding:14px 16px;display:flex;flex-direction:column;gap:3px;}
.cw-msgs::-webkit-scrollbar{width:4px;}
.cw-msgs::-webkit-scrollbar-thumb{background:#21262d;border-radius:4px;}
.msg-date{text-align:center;margin:10px 0 6px;font-size:11px;color:#484f58;}
.msg-date span{background:#161b22;border:1px solid #21262d;padding:3px 10px;border-radius:10px;}
.msg-row{display:flex;gap:8px;margin-bottom:1px;align-items:flex-end;}
.msg-row.mine{flex-direction:row-reverse;}
.msg-av{width:28px;flex-shrink:0;}
.msg-bw{max-width:70%;display:flex;flex-direction:column;}
.msg-row.mine .msg-bw{align-items:flex-end;}
.msg-sname{font-size:11px;color:#388bfd;font-weight:600;margin-bottom:2px;padding-left:2px;}
.msg-bubble{background:#1c2230;border-radius:14px 14px 14px 3px;padding:9px 12px;position:relative;word-break:break-word;border:1px solid #21262d;}
.msg-row.mine .msg-bubble{background:rgba(56,139,253,.16);border-radius:14px 14px 3px 14px;border-color:rgba(56,139,253,.2);}
.msg-bubble.deleted{color:#484f58;font-style:italic;background:#161b22;border-color:#21262d;}
.msg-text{font-size:13px;color:#c9d1d9;line-height:1.55;white-space:pre-wrap;}
.msg-meta{display:flex;align-items:center;gap:5px;margin-top:5px;}
.msg-time{font-size:10px;color:#484f58;}
.msg-edited{font-size:10px;color:#484f58;font-style:italic;}
.msg-status{font-size:10px;color:#388bfd;}
.msg-reply{background:rgba(56,139,253,.08);border-left:2px solid #388bfd;border-radius:4px;padding:5px 8px;margin-bottom:7px;font-size:11px;color:#8b949e;}
/* WhatsApp-style message dropdown */
.msg-dd-btn{display:none;position:absolute;top:5px;right:5px;background:rgba(0,0,0,.28);border:none;border-radius:50%;width:20px;height:20px;cursor:pointer;font-size:10px;color:rgba(255,255,255,.8);align-items:center;justify-content:center;z-index:5;padding:0;line-height:1;transition:background .15s;}
.msg-bw:hover .msg-dd-btn, .msg-dd-btn.open{display:flex;}
.msg-dd-btn:hover{background:rgba(0,0,0,.45);}
/* Dropdown and react-picker use position:fixed so overflow:auto on .cw-msgs never clips them */
.msg-dropdown{display:none;position:fixed;min-width:160px;background:#1c2230;border:1px solid #30363d;border-radius:10px;box-shadow:0 10px 28px rgba(0,0,0,.6);z-index:9000;overflow:hidden;}
.msg-dropdown.open{display:block;}
.msg-dd-item{padding:10px 15px;font-size:13px;color:#c9d1d9;cursor:pointer;display:flex;align-items:center;gap:9px;white-space:nowrap;transition:background .12s;}
.msg-dd-item:hover{background:rgba(56,139,253,.12);}
.msg-dd-item.danger{color:#f85149;}
/* Forwarded / flags */
.msg-forwarded{font-size:10px;color:#6e7681;margin-bottom:5px;display:flex;align-items:center;gap:3px;opacity:.85;}
/* Seen / Sent status */
.msg-seen{font-size:10px;color:#3fb950;font-weight:600;}
.msg-sent{font-size:10px;color:#484f58;}
/* Emoji reactions */
.msg-reactions{display:flex;flex-wrap:wrap;gap:4px;margin-top:6px;padding:0 2px;}
.msg-react-pill{display:inline-flex;align-items:center;gap:3px;background:rgba(255,255,255,.06);border:1px solid #30363d;border-radius:20px;padding:3px 9px 3px 7px;font-size:14px;cursor:pointer;transition:all .15s;user-select:none;line-height:1.3;}
.msg-react-pill:hover{background:rgba(56,139,253,.15);border-color:rgba(56,139,253,.4);}
.msg-react-pill.mine{background:rgba(56,139,253,.18);border-color:rgba(56,139,253,.5);}
.msg-react-pill .rp-count{font-size:11px;color:#8b949e;font-weight:600;}
/* React picker — also position:fixed to escape the scroll container */
.react-picker{display:none;position:fixed;background:#1c2230;border:1px solid #30363d;border-radius:12px;padding:7px 10px;box-shadow:0 8px 24px rgba(0,0,0,.7);z-index:9000;white-space:nowrap;}
.react-picker.open{display:flex;gap:5px;}
.react-picker .rp-opt{font-size:22px;cursor:pointer;padding:3px 5px;border-radius:6px;transition:background .12s;line-height:1;}
.react-picker .rp-opt:hover{background:rgba(255,255,255,.12);}
/* Forward multi-select */
.fwd-section-label{font-size:10px;font-weight:700;color:#6e7681;text-transform:uppercase;letter-spacing:.5px;padding:8px 4px 4px;}
.fwd-disabled{opacity:.38;cursor:not-allowed!important;pointer-events:none;}
/* Per-chat search bar */
.chat-search-bar{display:none;background:#161b22;border-bottom:1px solid #21262d;padding:10px 14px 6px;}
.chat-search-bar.open{display:block;}
.chat-search-bar input{width:100%;padding:7px 12px;border-radius:8px;border:1px solid #30363d;background:#0d1117;color:#c9d1d9;font-size:13px;box-sizing:border-box;outline:none;transition:border .2s;}
.chat-search-bar input:focus{border-color:#388bfd;}
.chat-search-results{max-height:220px;overflow-y:auto;margin-top:6px;}
.chat-search-results::-webkit-scrollbar{width:3px;}
.chat-search-results::-webkit-scrollbar-thumb{background:#30363d;border-radius:3px;}
.csr-item{padding:9px 10px;cursor:pointer;border-radius:8px;border-bottom:1px solid rgba(255,255,255,.03);transition:background .12s;}
.csr-item:hover{background:rgba(56,139,253,.1);}
.csr-sender{font-size:11px;color:#388bfd;font-weight:600;margin-bottom:2px;}
.csr-text{font-size:12px;color:#c9d1d9;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.csr-time{font-size:10px;color:#6e7681;margin-top:2px;}
/* Jump-to-message highlight */
@keyframes msgJumpFade{0%,20%{box-shadow:0 0 0 3px rgba(56,139,253,.6);}100%{box-shadow:none;}}
.msg-jump-highlight .msg-bubble{animation:msgJumpFade 2s ease forwards;}
.msg-dd-item.danger:hover{background:rgba(248,81,73,.1);}
.typing-bar{font-size:12px;color:#6e7681;padding:4px 16px 0;font-style:italic;min-height:20px;}

/* Input area */
.cw-input{border-top:1px solid #21262d;padding:12px 14px;flex-shrink:0;background:#161b22;}
.reply-strip{display:none;background:rgba(56,139,253,.08);border-left:2px solid #388bfd;border-radius:6px;padding:6px 10px;margin-bottom:8px;font-size:12px;color:#8b949e;position:relative;}
.reply-strip .rs-close{position:absolute;right:8px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:#6e7681;font-size:18px;line-height:1;}
.ro-notice{padding:10px;text-align:center;font-size:12px;color:#6e7681;font-style:italic;}
.cw-input-row{display:flex;gap:8px;align-items:flex-end;}
.cw-input-row textarea{flex:1;background:#0d1117;border:1px solid #30363d;border-radius:10px;color:#c9d1d9;padding:9px 12px;font-size:13px;resize:none;min-height:40px;max-height:120px;font-family:inherit;line-height:1.5;transition:border .2s;}
.cw-input-row textarea:focus{outline:none;border-color:#388bfd;}
.emoji-btn{background:#1c2230;border:1px solid #30363d;border-radius:10px;padding:9px 11px;cursor:pointer;font-size:16px;flex-shrink:0;transition:background .2s;line-height:1;}
.emoji-btn:hover{background:#21262d;}
.send-btn{background:#1f6feb;border:none;border-radius:10px;padding:9px 16px;color:#fff;cursor:pointer;font-size:15px;flex-shrink:0;transition:background .2s;line-height:1;}
.send-btn:hover{background:#388bfd;}

/* Emoji picker */
.emoji-picker{display:none;position:absolute;bottom:68px;left:14px;background:#161b22;border:1px solid #30363d;border-radius:12px;padding:10px;z-index:200;box-shadow:0 8px 32px rgba(0,0,0,.5);max-width:280px;}
.emoji-picker.open{display:flex;flex-wrap:wrap;gap:4px;}
.ep-emoji{font-size:20px;cursor:pointer;padding:4px;border-radius:6px;transition:background .15s;line-height:1;}
.ep-emoji:hover{background:rgba(255,255,255,.1);}

/* ═══════════════════════ MODALS ════════════════════════════════════════════ */
.mo{display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:9999;align-items:center;justify-content:center;backdrop-filter:blur(4px);}
.mb{background:#161b22;border:1px solid #30363d;border-radius:16px;width:min(460px,92vw);max-height:85vh;overflow-y:auto;padding:24px;position:relative;}
.mb::-webkit-scrollbar{width:4px;}
.mb::-webkit-scrollbar-thumb{background:#30363d;border-radius:4px;}
.mb-title{font-size:15px;font-weight:700;color:#e6edf3;margin-bottom:18px;padding-right:28px;}
.mb-close{position:absolute;top:14px;right:14px;background:none;border:none;cursor:pointer;color:#6e7681;font-size:20px;line-height:1;transition:color .2s;}
.mb-close:hover{color:#c9d1d9;}
.fg{margin-bottom:13px;}
.fg label{font-size:11px;color:#8b949e;font-weight:600;margin-bottom:5px;display:block;text-transform:uppercase;letter-spacing:.4px;}
.fg input,.fg textarea,.fg select{width:100%;padding:8px 11px;border-radius:8px;border:1px solid #30363d;background:#0d1117;color:#c9d1d9;font-size:13px;box-sizing:border-box;transition:border .2s;}
.fg input:focus,.fg textarea:focus,.fg select:focus{outline:none;border-color:#388bfd;}
.fg select option{background:#161b22;}
.cgrid{max-height:200px;overflow-y:auto;border:1px solid #21262d;border-radius:8px;}
.cgrid::-webkit-scrollbar{width:3px;}
.cgrid::-webkit-scrollbar-thumb{background:#30363d;border-radius:3px;}
.cg-item{display:flex;align-items:center;gap:9px;padding:8px 11px;cursor:pointer;border-bottom:1px solid rgba(255,255,255,.03);transition:background .15s;}
.cg-item:last-child{border-bottom:none;}
.cg-item:hover,.cg-item.sel{background:rgba(56,139,253,.1);}
.cg-item input[type=checkbox]{margin:0;accent-color:#388bfd;width:auto;flex-shrink:0;}
.cg-name{font-size:13px;color:#c9d1d9;font-weight:500;}
.cg-role{font-size:11px;color:#6e7681;}
.btn-pri{background:#1f6feb;border:none;border-radius:8px;padding:9px 18px;color:#fff;cursor:pointer;font-size:13px;font-weight:600;width:100%;margin-top:8px;transition:background .2s;}
.btn-pri:hover{background:#388bfd;}
.btn-sec{background:#21262d;border:1px solid #30363d;border-radius:8px;padding:8px 16px;color:#c9d1d9;cursor:pointer;font-size:13px;font-weight:500;transition:background .2s;}
.btn-sec:hover{background:#2d333b;}
.sr-item{padding:10px 12px;border-bottom:1px solid rgba(255,255,255,.03);cursor:pointer;border-radius:6px;transition:background .15s;}
.sr-item:hover{background:rgba(255,255,255,.04);}
.sr-chat{font-size:10px;color:#388bfd;margin-bottom:2px;font-weight:600;}
.sr-text{font-size:12px;color:#c9d1d9;}
.sr-time{font-size:10px;color:#6e7681;margin-top:2px;}
.ml-item{display:flex;align-items:center;gap:10px;padding:9px 12px;border-bottom:1px solid rgba(255,255,255,.03);}
.ml-item:last-child{border-bottom:none;}
.presence-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.presence-dot.on{background:#3fb950;}
.presence-dot.off{background:#30363d;}
.section-divider{border:none;border-top:1px solid #21262d;margin:14px 0;}
.add-member-wrap{margin-top:14px;}
.add-member-wrap .am-label{font-size:12px;font-weight:600;color:#c9d1d9;margin-bottom:10px;display:flex;align-items:center;justify-content:space-between;}

@media(max-width:640px){
  .cl{position:absolute;inset:0;z-index:5;width:100%!important;max-width:100%!important;border-right:none;}
  .cr{display:none;}
  .cs.chat-open .cl{display:none;}
  .cs.chat-open .cr{display:flex!important;position:absolute;inset:0;z-index:5;}
  .cs{position:relative;}
}
</style>

<!-- ═════════════════════════ CHAT SHELL ════════════════════════════════════ -->
<div class="cs" id="chatShell">

  <!-- ── LEFT PANEL ─────────────────────────────────────────────────────── -->
  <div class="cl" id="chatLeft">
    <!-- Normal header -->
    <div class="cl-hdr" id="normalHdr">
      <div class="cl-hdr-top">
        <h3>Messages</h3>
        <div class="cl-btns">
          <% if (_myRole === 'school_admin') { %>
          <button class="cl-btn" id="adminModeBtn" onclick="enterAdminMode()" title="Browse all users">👤</button>
          <% } %>
          <% if (_canGroup) { %>
          <button class="cl-btn" onclick="openGroupModal()" title="New group">👥</button>
          <% } %>
          <button class="cl-btn" onclick="openNewChatModal()" title="New chat">✏️</button>
        </div>
      </div>
      <div class="cl-search">
        <input type="text" id="chatSearchInput" placeholder="Search conversations…" oninput="filterChatList(this.value)">
      </div>
    </div>

    <% if (_myRole === 'school_admin') { %>
    <!-- Admin browse header (hidden by default) -->
    <div class="cl-hdr" id="adminBrowseHdr" style="display:none;">
      <div class="cl-hdr-top">
        <h3 id="adminHdrTitle" style="font-size:14px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:180px;">Browse Users</h3>
        <button class="cl-btn" onclick="exitAdminMode()" title="Back">← Back</button>
      </div>
      <div class="cl-search">
        <input type="text" id="adminUserSearch" placeholder="Search by name or role…" oninput="onAdminUserSearch(this.value)" autocomplete="off">
      </div>
    </div>
    <% } %>

    <div class="cl-list" id="chatList">
      <div style="padding:28px 16px;text-align:center;color:#484f58;font-size:12px;">Loading…</div>
    </div>
  </div>

  <!-- ── RIGHT PANEL ────────────────────────────────────────────────────── -->
  <div class="cr" id="chatRight">

    <!-- Empty state -->
    <div class="cr-empty" id="chatEmpty">
      <div class="cr-empty-icon">💬</div>
      <div class="cr-empty-title">Your messages</div>
      <div class="cr-empty-sub">Start a conversation with the ✏️ button</div>
    </div>

    <!-- Active chat window -->
    <div id="chatWindow" style="display:none;flex:1;flex-direction:column;min-height:0;">

      <!-- Header -->
      <div class="cw-hdr">
        <button id="backBtn" style="display:none;background:none;border:none;cursor:pointer;color:#8b949e;font-size:18px;padding:0 6px 0 0;" onclick="closeChat()">←</button>
        <div class="ca" id="winAvatar" style="width:36px;height:36px;font-size:14px;flex-shrink:0;"></div>
        <div class="cw-info">
          <div class="cw-name" id="winName">—</div>
          <div class="cw-sub"  id="winSub">—</div>
        </div>
        <div class="cw-actions">
          <button class="cl-btn" onclick="toggleChatSearch()" title="Search in chat" id="chatSearchBtn">🔍</button>
          <button class="cl-btn" onclick="openMembersModal()" title="Members" id="membersBtn" style="display:none;">👥</button>
        </div>
      </div>

      <!-- Per-chat search bar -->
      <div class="chat-search-bar" id="chatSearchBar">
        <input type="text" id="inChatSearchInput" placeholder="Search in this chat…" oninput="onChatSearch(this.value)" autocomplete="off">
        <div class="chat-search-results" id="chatSearchResults"></div>
      </div>

      <!-- Messages -->
      <div class="cw-msgs" id="chatMessages"></div>
      <div class="typing-bar" id="typingBar"></div>

      <!-- Input -->
      <div class="cw-input" id="chatInputArea" style="position:relative;">
        <!-- Emoji picker -->
        <div class="emoji-picker" id="emojiPicker">
          <%- ['😀','😂','😍','🥰','😊','😎','🤔','😅','😭','😡','👍','👎','❤️','🔥','✅','💯','🎉','🙏','😴','🤣','💪','🤦','🙌','👏','🤝','😤','😱','💀','🫡','😇','🥳','🫂','❓','‼️','💬','📝','✨','🌟','⭐','🚀'].map(e => `<span class="ep-emoji" data-emoji="${e}">${e}</span>`).join('') %>
        </div>
        <div class="reply-strip" id="replyStrip">
          <span id="replyText"></span>
          <button class="rs-close" onclick="clearReply()">×</button>
        </div>
        <div class="ro-notice" id="readonlyNotice" style="display:none;">
          📢 This is a broadcast channel — only admins &amp; teachers can post.
        </div>
        <div class="cw-input-row" id="chatInputRow">
          <button class="emoji-btn" onclick="toggleEmojiPicker(event)" title="Emoji">😊</button>
          <textarea id="msgInput" rows="1" placeholder="Type a message…"
            onkeydown="handleInputKeydown(event)"
            oninput="handleInputChange(this)"></textarea>
          <button class="send-btn" onclick="sendMessage()">➤</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════ MODALS ════════════════════════════════════ -->

<!-- New Direct Chat -->
<div class="mo" id="newChatModal" onclick="if(event.target===this)closeModal('newChatModal')">
  <div class="mb">
    <button class="mb-close" onclick="closeModal('newChatModal')">×</button>
    <div class="mb-title">✏️ New Message</div>
    <div class="fg">
      <label>Search contacts</label>
      <input type="text" id="contactSearch" placeholder="Name or role…" oninput="filterContacts(this.value)" autocomplete="off">
    </div>
    <div class="cgrid" id="contactGrid">
      <div style="padding:20px;text-align:center;color:#484f58;font-size:12px;">Loading…</div>
    </div>
  </div>
</div>

<!-- New Group -->
<div class="mo" id="groupModal" onclick="if(event.target===this)closeModal('groupModal')">
  <div class="mb">
    <button class="mb-close" onclick="closeModal('groupModal')">×</button>
    <div class="mb-title">👥 Create Group</div>
    <div class="fg">
      <label>Group Name *</label>
      <input type="text" id="grpName" placeholder="e.g. Class 10-A Teachers">
