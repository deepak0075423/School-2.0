<hr style="margin: 30px 0; border: 1px solid #e5e7eb;">

<form action="/super-admin/users/create" method="POST">
    <div class="form-section">
        <div class="form-section-header">
            <span>👤</span>
            <h3>User Details</h3>
        </div>
        <div class="form-section-body">
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label">Full Name *</label>
                    <input type="text" name="name" class="form-control" placeholder="Full name" required />
                </div>
                <div class="form-group">
                    <label class="form-label">Email *</label>
                    <input type="email" name="email" class="form-control" placeholder="user@example.com" required />
                </div>
                <div class="form-group">
                    <label class="form-label">Phone</label>
                    <input type="text" name="phone" class="form-control" placeholder="+91 XXXXX XXXXX" />
                </div>
                <div class="form-group">
                    <label class="form-label">Role *</label>
                    <select name="role" class="form-control" required>
                        <option value="">— Select Role —</option>
                        <option value="super_admin">⭐ Super Admin</option>
                        <option value="school_admin">School Admin</option>
                        <option value="teacher">Teacher</option>
                        <option value="student">Student</option>
                        <option value="parent">Parent</option>
                    </select>
                </div>
                <div class="form-group col-span-2">
                    <label class="form-label">Assign to School</label>
                    <select name="school" class="form-control">
                        <option value="">— No School (System-level) —</option>
                        <% schools.forEach(s=> { %>
                            <option value="<%= s._id %>">
                                <%= s.name %>
                            </option>
                            <% }) %>
                    </select>
                </div>
            </div>
        </div>
    </div>
    <div class="alert alert-warning">
        📧 A welcome email with login credentials will be sent automatically.
    </div>
    <button type="submit" class="btn btn-primary btn-lg">👤 Create User & Send Email</button>
</form>