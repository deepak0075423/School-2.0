<style>
.action-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 10px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 600;
    white-space: nowrap;
}
.action-CREATE_HOLIDAY  { background:#ecfdf5; color:#065f46; border:1px solid #a7f3d0; }
.action-UPDATE_HOLIDAY  { background:#eff6ff; color:#1d4ed8; border:1px solid #bfdbfe; }
.action-DELETE_HOLIDAY  { background:#fef2f2; color:#991b1b; border:1px solid #fecaca; }
.action-IMPORT_HOLIDAYS { background:#f5f3ff; color:#6d28d9; border:1px solid #ddd6fe; }

.diff-block { font-size: 12px; display: flex; flex-direction: column; gap: 3px; max-width: 300px; }
.diff-row { display: flex; gap: 5px; flex-wrap: wrap; }
.diff-label { font-weight: 600; color: var(--text-muted); min-width: 72px; flex-shrink: 0; }
.diff-old { color: #ef4444; text-decoration: line-through; }
.diff-new { color: #10b981; font-weight: 500; }
</style>

<div class="page-header">
    <div>
        <h1>📋 Holiday Audit Log — All Schools</h1>
        <p>View every holiday action across all schools. Use filters to drill down.</p>
    </div>
</div>

<!-- Summary Stats -->
<div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(150px,1fr)); gap:16px; margin-bottom:24px;">
    <div class="stat-card">
        <div class="stat-value"><%= total %></div>
        <div class="stat-label">Total Records</div>
    </div>
    <div class="stat-card">
        <div class="stat-value" style="color:#065f46;"><%= logs.filter(l=>l.actionType==='CREATE_HOLIDAY').length %></div>
        <div class="stat-label">Creates (this page)</div>
    </div>
    <div class="stat-card">
        <div class="stat-value" style="color:#1d4ed8;"><%= logs.filter(l=>l.actionType==='UPDATE_HOLIDAY').length %></div>
        <div class="stat-label">Updates (this page)</div>
    </div>
    <div class="stat-card">
        <div class="stat-value" style="color:#991b1b;"><%= logs.filter(l=>l.actionType==='DELETE_HOLIDAY').length %></div>
        <div class="stat-label">Deletes (this page)</div>
    </div>
</div>

<!-- Filters -->
<form method="GET" action="/super-admin/holidays/audit" style="display:flex; gap:12px; flex-wrap:wrap; align-items:center; margin-bottom:20px;">
    <select name="school" class="form-control" style="max-width:220px;" onchange="this.form.submit()">
        <option value="">All Schools</option>
        <% schools.forEach(s => { %>
        <option value="<%= s._id %>" <%= schoolFilter === s._id.toString() ? 'selected' : '' %>><%= s.name %></option>
        <% }) %>
    </select>
    <select name="action" class="form-control" style="max-width:180px;" onchange="this.form.submit()">
        <option value="">All Actions</option>
        <option value="CREATE_HOLIDAY"  <%= actionFilter === 'CREATE_HOLIDAY'  ? 'selected' : '' %>>Created</option>
        <option value="UPDATE_HOLIDAY"  <%= actionFilter === 'UPDATE_HOLIDAY'  ? 'selected' : '' %>>Updated</option>
        <option value="DELETE_HOLIDAY"  <%= actionFilter === 'DELETE_HOLIDAY'  ? 'selected' : '' %>>Deleted</option>
        <option value="IMPORT_HOLIDAYS" <%= actionFilter === 'IMPORT_HOLIDAYS' ? 'selected' : '' %>>Imported</option>
    </select>
    <% if (schoolFilter || actionFilter) { %>
    <a href="/super-admin/holidays/audit" class="btn btn-secondary btn-sm">✕ Clear Filters</a>
    <% } %>
    <span style="font-size:13px; color:var(--text-muted); margin-left:auto;"><%= total %> record<%= total !== 1 ? 's' : '' %></span>
</form>

<% if (logs.length === 0) { %>
<div class="empty-state">
    <div class="empty-icon">📋</div>
    <h3>No audit records found</h3>
    <p>No holiday actions match the selected filters.</p>
</div>
<% } else { %>
<div class="table-wrapper">
    <table class="data-table">
        <thead>
            <tr>
                <th>Action</th>
                <th>School</th>
                <th>Holiday</th>
                <th>Performed By</th>
                <th>When</th>
                <th>Changes</th>
            </tr>
        </thead>
        <tbody>
        <% const actionIcons  = { CREATE_HOLIDAY:'✅', UPDATE_HOLIDAY:'✏️', DELETE_HOLIDAY:'🗑️', IMPORT_HOLIDAYS:'📥' };
           const actionLabels = { CREATE_HOLIDAY:'Created', UPDATE_HOLIDAY:'Updated', DELETE_HOLIDAY:'Deleted', IMPORT_HOLIDAYS:'Imported' }; %>
        <% logs.forEach(log => {
            const isCreate = log.actionType === 'CREATE_HOLIDAY';
            const isUpdate = log.actionType === 'UPDATE_HOLIDAY';
            const isDelete = log.actionType === 'DELETE_HOLIDAY';
            const isImport = log.actionType === 'IMPORT_HOLIDAYS';
            const snapshot = log.newValue || log.oldValue || {};
        %>
        <tr>
            <td>
                <span class="action-badge action-<%= log.actionType %>">
                    <%= actionIcons[log.actionType] || '•' %> <%= actionLabels[log.actionType] || log.actionType %>
                </span>
            </td>
            <td>
                <span style="font-weight:600; font-size:14px; color:var(--text);">
                    <%= log.school?.name || '—' %>
                </span>
            </td>
            <td>
                <% if (isImport) { %>
                    <span style="font-size:13px; color:var(--text);">Bulk Import</span>
                    <% if (log.newValue) { %>
                    <div style="font-size:12px; color:var(--text-muted);">
                        <%= log.newValue.imported %> created, <%= log.newValue.skipped %> skipped
                    </div>
                    <% } %>
                <% } else { %>
                    <span style="font-weight:600; font-size:14px; color:var(--text);"><%= snapshot.name || '—' %></span>
                    <% if (snapshot.type) { %>
                    <div style="font-size:12px; color:var(--text-muted); text-transform:capitalize; margin-top:2px;">
                        <%= snapshot.type.replace(/_/g,' ') %>
                    </div>
                    <% } %>
                <% } %>
            </td>
            <td>
                <% if (log.user) { %>
                <div style="font-weight:600; font-size:14px; color:var(--text);"><%= log.user.name %></div>
                <div style="font-size:12px; color:var(--text-muted);"><%= log.user.role?.replace(/_/g,' ') %></div>
                <% } else { %><span style="color:var(--text-muted);">—</span><% } %>
            </td>
            <td style="white-space:nowrap; font-size:13px; color:var(--text);">
                <%= new Date(log.createdAt).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) %>
                <div style="font-size:12px; color:var(--text-muted);">
                    <%= new Date(log.createdAt).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'}) %>
                </div>
            </td>
            <td>
                <% if (isCreate && log.newValue) { %>
                <div class="diff-block">
                    <div class="diff-row">
                        <span class="diff-label">Dates</span>
                        <span class="diff-new">
                            <%= new Date(log.newValue.startDate).toLocaleDateString('en-IN',{day:'2-digit',month:'short'}) %>
                            – <%= new Date(log.newValue.endDate).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) %>
                        </span>
                    </div>
                </div>
                <% } else if (isUpdate && log.oldValue && log.newValue) { %>
                <div class="diff-block">
                    <% const fields = [['name','Name'],['type','Type'],['startDate','Start'],['endDate','End'],['scope','For']];
                       let changed = 0;
                       fields.forEach(([key,label]) => {
                           const o=String(log.oldValue[key]||''), n=String(log.newValue[key]||'');
                           if(o!==n){changed++; %>
                    <div class="diff-row">
                        <span class="diff-label"><%= label %></span>
                        <span class="diff-old"><%= o.replace(/_/g,' ') %></span>
                        <span style="color:var(--text-muted);">→</span>
                        <span class="diff-new"><%= n.replace(/_/g,' ') %></span>
                    </div>
                    <% }}) %>
                    <% if(changed===0){%><span style="font-size:12px;color:var(--text-muted);">Minor update</span><%}%>
                </div>
                <% } else if (isDelete && log.oldValue) { %>
                <div class="diff-block">
                    <div class="diff-row">
                        <span class="diff-label">Dates</span>
                        <span class="diff-old">
                            <%= new Date(log.oldValue.startDate).toLocaleDateString('en-IN',{day:'2-digit',month:'short'}) %>
                            – <%= new Date(log.oldValue.endDate).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) %>
                        </span>
                    </div>
                </div>
                <% } else { %><span style="font-size:12px; color:var(--text-muted);">—</span><% } %>
            </td>
        </tr>
        <% }) %>
        </tbody>
    </table>
</div>

<!-- Pagination -->
<% if (totalPages > 1) { %>
<div style="display:flex; justify-content:center; align-items:center; gap:8px; margin-top:24px; flex-wrap:wrap;">
    <% if (page > 1) { %>
    <a href="?page=<%= page-1 %>&school=<%= schoolFilter %>&action=<%= actionFilter %>" class="btn btn-secondary btn-sm">← Prev</a>
    <% } %>
    <span style="font-size:13px; color:var(--text-muted);">Page <%= page %> of <%= totalPages %></span>
    <% if (page < totalPages) { %>
    <a href="?page=<%= page+1 %>&school=<%= schoolFilter %>&action=<%= actionFilter %>" class="btn btn-secondary btn-sm">Next →</a>
    <% } %>
</div>
<% } %>
<% } %>
