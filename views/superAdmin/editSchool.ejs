<%
  var _phoneCode = '+91', _phoneLocal = '';
  if (typeof old !== 'undefined' && old && old.countryCode) {
      _phoneCode  = old.countryCode;
      _phoneLocal = old.phoneLocal || '';
  } else if (school.phone) {
      var _m = school.phone.match(/^(\+\d+)\s*(.*)/);
      if (_m) { _phoneCode = _m[1]; _phoneLocal = _m[2]; }
      else     { _phoneLocal = school.phone; }
  }
  var _countries = [
    ['+91','🇮🇳','India'],      ['+1','🇺🇸','US/Canada'],
    ['+44','🇬🇧','UK'],          ['+61','🇦🇺','Australia'],
    ['+971','🇦🇪','UAE'],        ['+966','🇸🇦','Saudi Arabia'],
    ['+65','🇸🇬','Singapore'],   ['+60','🇲🇾','Malaysia'],
    ['+92','🇵🇰','Pakistan'],    ['+880','🇧🇩','Bangladesh'],
    ['+977','🇳🇵','Nepal'],      ['+94','🇱🇰','Sri Lanka'],
    ['+86','🇨🇳','China'],       ['+81','🇯🇵','Japan'],
    ['+82','🇰🇷','South Korea'], ['+7','🇷🇺','Russia'],
    ['+49','🇩🇪','Germany'],     ['+33','🇫🇷','France'],
    ['+39','🇮🇹','Italy'],       ['+34','🇪🇸','Spain'],
    ['+31','🇳🇱','Netherlands'], ['+27','🇿🇦','South Africa'],
    ['+55','🇧🇷','Brazil'],      ['+52','🇲🇽','Mexico'],
    ['+234','🇳🇬','Nigeria'],    ['+254','🇰🇪','Kenya'],
    ['+20','🇪🇬','Egypt'],       ['+46','🇸🇪','Sweden'],
    ['+41','🇨🇭','Switzerland'], ['+64','🇳🇿','New Zealand'],
  ];
%>
<div class="page-header">
    <div>
        <h1>✏️ Edit School</h1>
        <p>Update details for <%= school.name %></p>
    </div>
    <a href="/super-admin/schools" class="btn btn-secondary">← Back</a>
</div>

<form action="/super-admin/schools/<%= school._id %>/edit" method="POST" id="editSchoolForm" novalidate>
    <div class="form-section">
        <div class="form-section-header">
            <span>🏫</span>
            <h3>School Information</h3>
        </div>
        <div class="form-section-body">
            <div class="form-grid">

                <div class="form-group col-span-2">
                    <label class="form-label">School Name <span style="color:var(--danger)">*</span></label>
                    <input type="text" name="name" id="field-name"
                        class="form-control <%= (errors && errors.name) ? 'is-invalid' : '' %>"
                        placeholder="e.g. Green Valley School"
                        value="<%= (old && old.name != null) ? old.name : school.name %>" />
                    <span id="err-name" class="field-error" <%= (errors && errors.name) ? '' : 'hidden' %>><%= (errors && errors.name) || '' %></span>
                </div>

                <div class="form-group col-span-2">
                    <label class="form-label">Email <span style="color:var(--danger)">*</span></label>
                    <input type="email" name="email" id="field-email"
                        class="form-control <%= (errors && errors.email) ? 'is-invalid' : '' %>"
                        placeholder="school@example.com"
                        value="<%= (old && old.email != null) ? old.email : school.email %>" />
                    <span id="err-email" class="field-error" <%= (errors && errors.email) ? '' : 'hidden' %>><%= (errors && errors.email) || '' %></span>
                </div>

                <div class="form-group col-span-2">
                    <label class="form-label">Phone <span style="color:var(--danger)">*</span></label>
                    <div style="display:flex;gap:8px;">
                        <select id="field-country-code" class="form-control" style="width:120px;flex-shrink:0;">
                            <% _countries.forEach(function(c){ %>
                                <option value="<%= c[0] %>" <%= _phoneCode === c[0] ? 'selected' : '' %>><%= c[1] %> <%= c[0] %></option>
                            <% }); %>
                        </select>
                        <input type="text" id="field-phone"
                            class="form-control <%= (errors && errors.phone) ? 'is-invalid' : '' %>"
                            placeholder="Phone number"
                            inputmode="numeric"
                            value="<%= _phoneLocal %>"
                            style="flex:1;" />
                    </div>
                    <input type="hidden" name="phone" id="combined-phone" value="<%= _phoneCode %> <%= _phoneLocal %>" />
                    <span id="err-phone" class="field-error" <%= (errors && errors.phone) ? '' : 'hidden' %>><%= (errors && errors.phone) || '' %></span>
                </div>

                <div class="form-group col-span-2">
                    <label class="form-label">Address <span style="color:var(--danger)">*</span></label>
                    <input type="text" name="address" id="field-address"
                        class="form-control <%= (errors && errors.address) ? 'is-invalid' : '' %>"
                        placeholder="Full school address"
                        value="<%= (old && old.address != null) ? old.address : school.address %>" />
                    <span id="err-address" class="field-error" <%= (errors && errors.address) ? '' : 'hidden' %>><%= (errors && errors.address) || '' %></span>
                </div>

                <div class="form-group col-span-2">
                    <label class="form-label">Website</label>
                    <input type="text" name="website" id="field-website"
                        class="form-control <%= (errors && errors.website) ? 'is-invalid' : '' %>"
                        placeholder="https://yourschool.edu"
                        value="<%= (old && old.website != null) ? old.website : school.website %>" />
                    <span id="err-website" class="field-error" <%= (errors && errors.website) ? '' : 'hidden' %>><%= (errors && errors.website) || '' %></span>
                </div>

            </div>
        </div>
    </div>
    <button type="submit" class="btn btn-primary btn-lg">💾 Save Changes</button>
</form>

<script>
(function () {
    var PHONE_RULES = {
        '+91':  {min:10,max:10}, '+1':   {min:10,max:10},
        '+44':  {min:10,max:10}, '+61':  {min:9, max:9 },
        '+971': {min:9, max:9 }, '+966': {min:9, max:9 },
        '+65':  {min:8, max:8 }, '+60':  {min:9, max:10},
        '+92':  {min:10,max:10}, '+880': {min:10,max:10},
        '+977': {min:10,max:10}, '+94':  {min:9, max:9 },
        '+86':  {min:11,max:11}, '+81':  {min:10,max:11},
        '+82':  {min:9, max:10}, '+7':   {min:10,max:10},
        '+49':  {min:10,max:11}, '+33':  {min:9, max:9 },
        '+39':  {min:9, max:10}, '+34':  {min:9, max:9 },
        '+31':  {min:9, max:9 }, '+27':  {min:9, max:9 },
        '+55':  {min:10,max:11}, '+52':  {min:10,max:10},
        '+234': {min:10,max:10}, '+254': {min:9, max:9 },
        '+20':  {min:10,max:10}, '+46':  {min:9, max:10},
        '+41':  {min:9, max:9 }, '+64':  {min:8, max:10},
    };

    function phonePlaceholder(code) {
        var r = PHONE_RULES[code];
        if (!r) return 'Phone number';
        return r.min === r.max ? r.min + '-digit number' : r.min + '–' + r.max + '-digit number';
    }

    function setError(fieldId, errId, msg) {
        var f = document.getElementById(fieldId);
        var e = document.getElementById(errId);
        if (f) f.classList.add('is-invalid');
        if (e) { e.textContent = msg; e.removeAttribute('hidden'); }
    }
    function clearError(fieldId, errId) {
        var f = document.getElementById(fieldId);
        var e = document.getElementById(errId);
        if (f) f.classList.remove('is-invalid');
        if (e) { e.textContent = ''; e.setAttribute('hidden', ''); }
    }

    function isValidEmail(v) { return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v); }
    function isValidUrl(v)   { try { new URL(v); return true; } catch(e) { return false; } }

    var codeSel    = document.getElementById('field-country-code');
    var phoneInput = document.getElementById('field-phone');

    if (codeSel && phoneInput) {
        codeSel.addEventListener('change', function () {
            phoneInput.placeholder = phonePlaceholder(codeSel.value);
            clearError('field-phone', 'err-phone');
        });
        phoneInput.placeholder = phonePlaceholder(codeSel.value);
    }

    ['field-name','field-email','field-phone','field-address','field-website'].forEach(function(id) {
        var el = document.getElementById(id);
        if (el) el.addEventListener('input', function() { clearError(id, 'err-' + id.replace('field-','')); });
    });

    var form = document.getElementById('editSchoolForm');
    if (form) form.addEventListener('submit', function (e) {
        var valid = true;

        var nameEl    = document.getElementById('field-name');
        var emailEl   = document.getElementById('field-email');
        var codeEl    = document.getElementById('field-country-code');
        var phoneEl   = document.getElementById('field-phone');
        var addressEl = document.getElementById('field-address');
        var websiteEl = document.getElementById('field-website');

        var name = nameEl ? nameEl.value.trim() : '';
        if (!name || name.length < 2) {
            setError('field-name','err-name','School name is required and must be at least 2 characters.');
            valid = false;
        } else { clearError('field-name','err-name'); }

        var email = emailEl ? emailEl.value.trim() : '';
        if (!email) {
            setError('field-email','err-email','Email is required.');
            valid = false;
        } else if (!isValidEmail(email)) {
            setError('field-email','err-email','Please enter a valid email address.');
            valid = false;
        } else { clearError('field-email','err-email'); }

        var code  = codeEl  ? codeEl.value  : '+91';
        var local = phoneEl ? phoneEl.value.replace(/\D/g,'') : '';
        var rule  = PHONE_RULES[code];
        if (!local) {
            setError('field-phone','err-phone','Phone number is required.');
            valid = false;
        } else if (rule && (local.length < rule.min || local.length > rule.max)) {
            var range = rule.min === rule.max ? rule.min+'-digit' : rule.min+'–'+rule.max+'-digit';
            setError('field-phone','err-phone','Enter a valid '+range+' number for the selected country.');
            valid = false;
        } else {
            clearError('field-phone','err-phone');
            var combined = document.getElementById('combined-phone');
            if (combined) combined.value = code + ' ' + local;
        }

        var address = addressEl ? addressEl.value.trim() : '';
        if (!address) {
            setError('field-address','err-address','Address is required.');
            valid = false;
        } else { clearError('field-address','err-address'); }

        var website = websiteEl ? websiteEl.value.trim() : '';
        if (website && !isValidUrl(website)) {
            setError('field-website','err-website','Please enter a valid URL (e.g. https://yourschool.edu).');
            valid = false;
        } else { clearError('field-website','err-website'); }

        if (!valid) {
            e.preventDefault();
            var first = document.querySelector('#editSchoolForm .is-invalid');
            if (first) first.focus();
        }
    });
})();
</script>
