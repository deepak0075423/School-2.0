<div class="page-header">
    <div>
        <h1>🏗️ Create School</h1>
        <p>Add a new school to the system</p>
    </div>
    <a href="/super-admin/schools" class="btn btn-secondary">← Back</a>
</div>

<form action="/super-admin/schools/create" method="POST">
    <div class="form-section">
        <div class="form-section-header">
            <span>🏫</span>
            <h3>School Information</h3>
        </div>
        <div class="form-section-body">
            <div class="form-grid">
                <div class="form-group col-span-2">
                    <label class="form-label">School Name *</label>
                    <input type="text" name="name" class="form-control" placeholder="e.g. Green Valley School"
                        required />
                </div>
                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input type="email" name="email" class="form-control" placeholder="school@example.com" />
                </div>
                <div class="form-group">
                    <label class="form-label">Phone</label>
                    <input type="text" name="phone" class="form-control" placeholder="+91 XXXXX XXXXX" />
                </div>
                <div class="form-group col-span-2">
                    <label class="form-label">Address</label>
                    <input type="text" name="address" class="form-control" placeholder="Full school address" />
                </div>
                <div class="form-group col-span-2">
                    <label class="form-label">Website</label>
                    <input type="url" name="website" class="form-control" placeholder="https://yourschool.edu" />
                </div>
            </div>
        </div>
    </div>
    <button type="submit" class="btn btn-primary btn-lg">🏫 Create School</button>
</form>