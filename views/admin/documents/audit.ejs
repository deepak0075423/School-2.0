<div class="page-header">
    <div>
        <h1 class="page-title">Document Audit Log</h1>
        <p class="text-muted">Track all document actions across your school</p>
    </div>
    <a href="/admin/documents" class="btn btn-secondary">← Back</a>
</div>

<% if (!logs.length) { %>
<div class="card">
    <div class="card-body">
        <div class="empty-state">
            <div class="empty-icon">📋</div>
            <p>No document audit events yet.</p>
        </div>
    </div>
</div>
<% } else { %>
<div class="card">
    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>Action</th>
                    <th>User</th>
                    <th>Role</th>
                    <th>Entity</th>
                    <th>Date & Time</th>
                </tr>
            </thead>
            <tbody>
                <% logs.forEach(log => { %>
                <tr>
                    <td>
                        <span class="badge <%= log.actionType.includes('DELETE') ? 'badge-red' : log.actionType.includes('UPLOAD') ? 'badge-green' : 'badge-gray' %>"
                              style="font-size:11px;">
                            <%= log.actionType.replace(/_/g,' ') %>
                        </span>
                    </td>
                    <td><%= log.user ? log.user.name : '—' %></td>
                    <td style="font-size:12px; color:var(--text-secondary);"><%= log.user ? log.user.role : '—' %></td>
                    <td style="font-size:12px;">
                        <% if (log.newValue && log.newValue.title) { %>
                        <%= log.newValue.title %>
                        <% } else if (log.oldValue && log.oldValue.title) { %>
                        <%= log.oldValue.title %>
                        <% } else { %>
                        —
                        <% } %>
                    </td>
                    <td style="font-size:12px;">
                        <%= new Date(log.createdAt).toLocaleString('en-IN',{day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>
<% } %>
