<div class="page-header">
    <div class="breadcrumb">
        <a href="/admin/subjects">Subjects</a> / Edit Subject
    </div>
    <div>
        <h1>✏️ Edit Subject</h1>
        <p>Update details and assign teachers to <%= subject.subjectName %></p>
    </div>
</div>

<div class="card" style="max-width: 600px;">
    <div class="card-body">
        <form action="/admin/subjects/<%= subject._id %>/edit" method="POST">
            <div class="form-group">
                <label class="form-label">Subject Name *</label>
                <input type="text" name="subjectName" class="form-control" value="<%= subject.subjectName %>" required>
            </div>
            
            <div class="form-group">
                <label class="form-label">Subject Code *</label>
                <input type="text" name="subjectCode" class="form-control" value="<%= subject.subjectCode %>" required maxlength="20">
            </div>
            
            <div class="form-group">
                <label class="form-label">Description</label>
                <textarea name="description" class="form-control" rows="3"><%= subject.description %></textarea>
            </div>
            
            <div class="form-group">
                <label class="form-label">Assign Teachers</label>
                <div style="border: 1px solid #cbd5e1; border-radius: 6px; overflow: hidden; background: #fff;">
                    <input type="text" placeholder="🔍 Search teacher by name or email..." style="width: 100%; border: none; border-bottom: 1px solid #cbd5e1; padding: 10px 14px; background: #f8fafc; outline: none; font-size: 0.95em;" onkeyup="filterCheckboxes(this, 'editTeacherList')">
                    <div id="editTeacherList" style="height: 200px; overflow-y: auto; padding: 8px 0;">
                        <% const assignedIds = subject.teachers ? subject.teachers.map(t => t._id.toString()) : []; %>
                        <% teachers.forEach(teacher => { %>
                            <label class="teacher-option" style="display: flex; align-items: center; padding: 6px 14px; cursor: pointer; font-weight: normal; margin: 0; transition: background 0.2s;" onmouseover="this.style.background='rgba(59,130,246,0.1)'" onmouseout="this.style.background='transparent'">
                                <input type="checkbox" name="teachers" value="<%= teacher._id %>" style="margin-right: 10px; cursor: pointer;" <%= assignedIds.includes(teacher._id.toString()) ? 'checked' : '' %>>
                                <span class="teacher-name" style="color: #334155;"><%= teacher.name %> <span style="color:#94a3b8; font-size:0.9em;">(<%= teacher.email %>)</span></span>
                            </label>
                        <% }) %>
                    </div>
                </div>
            </div>
            
            <div style="margin-top: 20px;">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a href="/admin/subjects" class="btn btn-secondary">Cancel</a>
            </div>
</form>
    </div>
</div>

<script>
function filterCheckboxes(input, listId) {
    const filter = input.value.toLowerCase();
    const list = document.getElementById(listId);
    const labels = list.getElementsByTagName('label');
    for (let i = 0; i < labels.length; i++) {
        const span = labels[i].querySelector('.teacher-name');
        if (span) {
            const txtValue = span.textContent || span.innerText;
            if (txtValue.toLowerCase().indexOf(filter) > -1) {
                labels[i].style.display = "flex";
            } else {
                labels[i].style.display = "none";
            }
        }
    }
}
</script>
