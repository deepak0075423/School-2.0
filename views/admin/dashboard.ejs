<div class="welcome-banner">
    <div class="welcome-icon">🏫</div>
    <div>
        <h2>Welcome, <%= session.userName %>!</h2>
        <p>School Admin Dashboard — <%= schoolName || 'Your School' %></p>
    </div>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon green">👨‍🏫</div>
        <div class="stat-info">
            <div class="stat-value"><%= stats.teachers %></div>
            <div class="stat-label">Teachers</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon cyan">🎒</div>
        <div class="stat-info">
            <div class="stat-value"><%= stats.students %></div>
            <div class="stat-label">Students</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon orange">👪</div>
        <div class="stat-info">
            <div class="stat-value"><%= stats.parents %></div>
            <div class="stat-label">Parents</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon purple" style="background:rgba(147,51,234,0.15); color:#9333ea;">🏫</div>
        <div class="stat-info">
            <div class="stat-value"><%= stats.classes || 0 %></div>
            <div class="stat-label">Active Classes</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon blue" style="background:rgba(59,130,246,0.15); color:#3b82f6;">📂</div>
        <div class="stat-info">
            <div class="stat-value"><%= stats.sections || 0 %></div>
            <div class="stat-label">Active Sections</div>
        </div>
    </div>
</div>

<div style="display:grid; grid-template-columns:1fr 1fr 260px; gap:20px;">
    <div class="card">
        <div class="card-header">
            <div class="card-title">⚡ Quick Actions</div>
        </div>
        <div class="card-body" style="display:flex; flex-direction:column; gap:10px;">
            <div style="font-size:0.75rem; font-weight:700; text-transform:uppercase; color:var(--text-muted); margin-bottom:4px;">
                👥 Users</div>
            <a href="/admin/teachers/create" class="btn btn-primary">👨‍🏫 Add Teacher</a>
            <a href="/admin/students/create" class="btn btn-primary">🎒 Add Student &amp; Parent</a>
            <a href="/admin/admins/create" class="btn btn-primary">🛡️ Add Co-Admin</a>
            <div style="font-size:0.75rem; font-weight:700; text-transform:uppercase; color:var(--text-muted); margin:8px 0 4px;">
                🏫 Class Management</div>
            <a href="/admin/academic-years" class="btn btn-secondary">📅 Academic Years</a>
            <a href="/admin/classes" class="btn btn-secondary">🏫 Classes</a>
            <a href="/admin/subjects" class="btn btn-secondary">📚 Subjects</a>
            <a href="/admin/reports" class="btn btn-secondary">📊 Reports</a>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <div class="card-title">🕒 Recent Activity</div>
        </div>
        <div class="table-wrapper">
            <% if (recentUsers.length===0) { %>
                <div class="empty-state" style="padding:30px;">
                    <p>No recent users.</p>
                </div>
            <% } else { %>
                <table>
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Role</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% recentUsers.forEach(u=> { %>
                            <tr>
                                <td class="text-primary fw-semibold"><%= u.name %></td>
                                <td>
                                    <span class="badge <%= u.role==='teacher'?'badge-green':u.role==='student'?'badge-cyan':'badge-orange' %>">
                                        <%= u.role %>
                                    </span>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } %>
        </div>
    </div>

    <%- include('../partials/dashboard-calendar', { hasHoliday, calendarHolidays, upcomingHolidays, holidayViewUrl }) %>
</div>
