<style>
.stat-row { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-bottom:20px; }
.report-bar-container { background:var(--border); border-radius:4px; height:10px; overflow:hidden; margin-top:4px; }
.report-bar { height:10px; border-radius:4px; background:var(--primary); transition:width .4s; }
</style>

<div class="page-header">
    <div>
        <h1 class="page-title">Leave Reports</h1>
        <p class="text-muted">Analytics and usage statistics for leave management</p>
    </div>
    <a href="/admin/leave/reports/export" class="btn btn-secondary">⬇ Export Excel</a>
</div>

<!-- Summary stats -->
<div class="stat-row">
    <div class="stat-card">
        <div class="stat-icon purple">📋</div>
        <div class="stat-info">
            <div class="stat-value"><%= applications.length %></div>
            <div class="stat-label">Total Applications</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green">✅</div>
        <div class="stat-info">
            <div class="stat-value"><%= applications.filter(a => a.status === 'approved').length %></div>
            <div class="stat-label">Approved</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon cyan">⏳</div>
        <div class="stat-info">
            <div class="stat-value"><%= applications.filter(a => a.status === 'pending').length %></div>
            <div class="stat-label">Pending</div>
        </div>
    </div>
</div>

<div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:20px;">

    <!-- Usage by leave type -->
    <div class="card">
        <div class="card-header"><div class="card-title">Usage by Leave Type</div></div>
        <div class="card-body">
            <% const maxDays = Math.max(...usageByType.map(u => u.days), 1); %>
            <% if (!usageByType.length) { %>
            <p class="text-muted">No data yet.</p>
            <% } else { %>
            <% usageByType.forEach(u => { %>
            <div style="margin-bottom:14px;">
                <div style="display:flex; justify-content:space-between; font-size:13px;">
                    <span class="fw-semibold"><%= u.name %> <span class="badge badge-blue" style="font-size:10px;"><%= u.code %></span></span>
                    <span class="text-muted"><%= u.days %> days / <%= u.count %> applications</span>
                </div>
                <div class="report-bar-container">
                    <div class="report-bar" style="width:<%= Math.round((u.days / maxDays) * 100) %>%"></div>
                </div>
            </div>
            <% }) %>
            <% } %>
        </div>
    </div>

    <!-- Month-wise usage -->
    <div class="card">
        <div class="card-header"><div class="card-title">Monthly Usage (Current Year)</div></div>
        <div class="card-body">
            <% const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
               const maxMonthDays = Math.max(...monthlyUsage, 1); %>
            <% monthlyUsage.forEach((days, i) => { %>
            <div style="display:flex; align-items:center; gap:10px; margin-bottom:7px;">
                <span style="width:30px; font-size:12px; color:var(--text-muted); flex-shrink:0;"><%= months[i] %></span>
                <div style="flex:1; background:var(--border); border-radius:4px; height:8px; overflow:hidden;">
                    <div style="height:8px; border-radius:4px; background:#b45309; width:<%= Math.round((days / maxMonthDays) * 100) %>%; transition:width .4s;"></div>
                </div>
                <span style="width:30px; font-size:12px; text-align:right; color:var(--text-muted);"><%= days %></span>
            </div>
            <% }) %>
        </div>
    </div>
</div>

<!-- Frequent absentees -->
<div class="card" style="margin-bottom:20px;">
    <div class="card-header">
        <div class="card-title">Teacher Leave Summary (Approved)</div>
    </div>
    <div class="table-wrapper">
        <% if (!teacherStats.length) { %>
        <div class="empty-state" style="padding:30px;"><p class="text-muted">No approved leaves yet.</p></div>
        <% } else { %>
        <table>
            <thead>
                <tr><th>#</th><th>Teacher</th><th>Total Days Taken</th><th>No. of Applications</th></tr>
            </thead>
            <tbody>
                <% teacherStats.forEach((t, i) => { %>
                <tr>
                    <td class="text-muted"><%= i + 1 %></td>
                    <td class="fw-semibold"><%= t.name %></td>
                    <td><strong><%= t.totalDays %></strong> days</td>
                    <td><%= t.count %></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <% } %>
    </div>
</div>

<!-- All Applications audit trail -->
<div class="card">
    <div class="card-header">
        <div class="card-title">All Applications</div>
        <a href="/admin/leave/reports/export" class="btn btn-sm btn-secondary">Export</a>
    </div>
    <div class="table-wrapper">
        <% if (!applications.length) { %>
        <div class="empty-state" style="padding:30px;"><p class="text-muted">No applications found.</p></div>
        <% } else { %>
        <table>
            <thead>
                <tr><th>Teacher</th><th>Type</th><th>Dates</th><th>Days</th><th>Status</th><th>Applied</th></tr>
            </thead>
            <tbody>
                <% applications.forEach(app => { %>
                <tr>
                    <td class="fw-semibold"><%= app.teacher ? app.teacher.name : '—' %></td>
                    <td><%= app.leaveType ? app.leaveType.name : '—' %></td>
                    <td style="font-size:12px;"><%= fmtDate(app.fromDate) %> → <%= fmtDate(app.toDate) %></td>
                    <td><%= app.totalDays %></td>
                    <td>
                        <span style="font-size:11px; padding:2px 8px; border-radius:10px; font-weight:700;
                            background:<%= app.status==='approved'?'#ecfdf5':app.status==='rejected'?'#fef2f2':'#fefce8' %>;
                            color:<%= app.status==='approved'?'#065f46':app.status==='rejected'?'#991b1b':'#a16207' %>">
                            <%= app.status %>
                        </span>
                    </td>
                    <td style="font-size:12px;"><%= fmtDate(app.appliedAt) %></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <% } %>
    </div>
</div>
