<div class="page-header">
    <div>
        <h1>🔍 Marks Review: <%= exam.title %></h1>
        <p>Review all submitted marks before final approval.</p>
    </div>
    <div style="display:flex; gap:8px; align-items:center;">
        <a href="/admin/results/exams/<%= exam._id %>" class="btn btn-secondary">← Back</a>
        <% if (exam.status === 'CLASS_APPROVED') { %>
        <form method="POST" action="/admin/results/exams/<%= exam._id %>/approve" style="display:inline;">
            <button type="submit" class="btn btn-primary" data-confirm="Approve exam and generate results?" data-confirm-title="Approve Exam" data-confirm-type="info">
                Approve & Generate Results
            </button>
        </form>
        <% } %>
    </div>
</div>

<% exam.subjects.forEach((sc, sIdx) => {
    const sheet = sheets.find(s => String(s.subject?._id || s.subject) === String(sc.subject?._id));
%>
<div class="card" style="margin-bottom:20px;">
    <div class="card-header">
        <div class="card-title"><%= sc.subject?.subjectName %> — Max: <%= sc.maxMarks %> | Passing: <%= sc.passingMarks %></div>
        <% if (sheet) { %>
            <span class="badge <%= sheet.status === 'SUBMITTED' ? 'badge-green' : 'badge-orange' %>"><%= sheet.status %></span>
        <% } else { %>
            <span class="badge badge-red">NOT SUBMITTED</span>
        <% } %>
    </div>

    <% if (sheet && sheet.entries && sheet.entries.length > 0) { %>
    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>Student</th>
                    <th style="text-align:center;">Marks Obtained</th>
                    <th style="text-align:center;">Absent</th>
                    <th style="text-align:center;">Grade</th>
                    <th>Remarks</th>
                </tr>
            </thead>
            <tbody>
                <% sheet.entries.forEach(entry => {
                    const stud = students.find(s => String(s._id) === String(entry.student?._id || entry.student));
                    const pct = entry.isAbsent ? 0 : (entry.marksObtained / sc.maxMarks * 100);
                    let grade = 'AB';
                    if (!entry.isAbsent) {
                        if (pct >= 90) grade='A+'; else if (pct >= 80) grade='A';
                        else if (pct >= 70) grade='B+'; else if (pct >= 60) grade='B';
                        else if (pct >= 50) grade='C'; else if (pct >= 40) grade='D'; else grade='F';
                    }
                %>
                <tr>
                    <td class="fw-semibold"><%= stud?.name || entry.student?.name || '—' %></td>
                    <td style="text-align:center;">
                        <% if (entry.isAbsent) { %>
                            <span class="text-muted">AB</span>
                        <% } else { %>
                            <strong><%= entry.marksObtained ?? '—' %></strong>/<%= sc.maxMarks %>
                        <% } %>
                    </td>
                    <td style="text-align:center;">
                        <% if (entry.isAbsent) { %><span class="badge badge-orange">Absent</span><% } else { %>—<% } %>
                    </td>
                    <td style="text-align:center;">
                        <span class="badge <%= grade === 'F' || grade === 'AB' ? 'badge-red' : grade.startsWith('A') ? 'badge-green' : 'badge-blue' %>">
                            <%= grade %>
                        </span>
                    </td>
                    <td style="color:var(--text-muted); font-size:13px;"><%= entry.remarks || '—' %></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
    <% } else { %>
        <div class="card-body" style="color:var(--text-muted);">No marks entries found for this subject.</div>
    <% } %>
</div>
<% }) %>
