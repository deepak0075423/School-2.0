<%
const sBadge = {
    DRAFT:'badge-gray', MARKS_PENDING:'badge-orange', SUBMITTED:'badge-blue',
    CLASS_APPROVED:'badge-purple', FINAL_APPROVED:'badge-green',
    REJECTED:'badge-red', REOPENED:'badge-orange'
};
const typeLabel = { MID_TERM:'Mid Term', FINAL:'Final Exam', UNIT_TEST:'Unit Test' };
%>

<div class="page-header">
    <div>
        <h1>📋 <%= exam.title %></h1>
        <p>
            <span class="badge badge-blue"><%= typeLabel[exam.examType] %></span>
            &nbsp; <%= exam.section?.class?.className %> – Section <%= exam.section?.sectionName %>
            &nbsp;·&nbsp; <%= exam.academicYear?.yearName %>
        </p>
    </div>
    <div style="display:flex; gap:8px; align-items:center;">
        <a href="/admin/results/exams" class="btn btn-secondary">← Back</a>
        <% if (new Date(exam.startDate) > new Date()) { %>
            <a href="/admin/results/exams/<%= exam._id %>/edit" class="btn btn-warning">✏️ Edit Exam</a>
        <% } %>
        <% if (exam.status === 'CLASS_APPROVED') { %>
            <a href="/admin/results/exams/<%= exam._id %>/marks-review" class="btn btn-primary">Review & Approve</a>
        <% } %>
        <% if (exam.resultsGenerated) { %>
            <a href="/admin/results/exams/<%= exam._id %>/result" class="btn btn-secondary">View Results</a>
        <% } %>
    </div>
</div>

<!-- Status Overview -->
<div class="stats-grid" style="grid-template-columns:repeat(auto-fit,minmax(155px,1fr)); margin-bottom:20px;">
    <div class="stat-card">
        <div class="stat-icon blue">📊</div>
        <div class="stat-info">
            <div class="stat-value" style="font-size:14px; font-weight:700; letter-spacing:0;">
                <span class="badge <%= sBadge[exam.status] || 'badge-gray' %>">
                    <%= exam.status.replace(/_/g,' ') %>
                </span>
            </div>
            <div class="stat-label">Current Status</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon purple">📚</div>
        <div class="stat-info">
            <div class="stat-value"><%= exam.subjects.length %></div>
            <div class="stat-label">Subjects</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green">📅</div>
        <div class="stat-info">
            <div class="stat-value" style="font-size:13px; letter-spacing:0;">
                <%= new Date(exam.startDate).toLocaleDateString('en-IN') %>
            </div>
            <div class="stat-label">Exam Start</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon orange">📅</div>
        <div class="stat-info">
            <div class="stat-value" style="font-size:13px; letter-spacing:0;">
                <%= exam.publishDate ? new Date(exam.publishDate).toLocaleDateString('en-IN') : '—' %>
            </div>
            <div class="stat-label">Publish Date</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon cyan">👤</div>
        <div class="stat-info">
            <div class="stat-value" style="font-size:14px; letter-spacing:0;"><%= exam.createdBy?.name %></div>
            <div class="stat-label">Created By</div>
        </div>
    </div>
</div>

<% if (exam.status === 'REJECTED' && exam.rejectionReason) { %>
<div class="alert alert-error" style="margin-bottom:20px;">
    <strong>Rejected:</strong> <%= exam.rejectionReason %>
</div>
<% } %>

<!-- Subject Marks Status -->
<div class="card" style="margin-bottom:20px;">
    <div class="card-header">
        <div class="card-title">Subject Marks Status</div>
    </div>
    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>Subject</th>
                    <th>Assigned Teacher</th>
                    <th style="text-align:center;">Max Marks</th>
                    <th style="text-align:center;">Passing</th>
                    <th>Marks Status</th>
                    <th>Submitted By</th>
                </tr>
            </thead>
            <tbody>
                <% exam.subjects.forEach(sc => {
                    const sheet = sheets.find(s => String(s.subject?._id || s.subject) === String(sc.subject?._id || sc.subject));
                %>
                <tr>
                    <td class="fw-semibold"><%= sc.subject?.subjectName || '—' %></td>
                    <td><%= sc.assignedTeacher?.name || '—' %></td>
                    <td style="text-align:center;"><%= sc.maxMarks %></td>
                    <td style="text-align:center;"><%= sc.passingMarks %></td>
                    <td>
                        <% if (sheet && sheet.status === 'SUBMITTED') { %>
                            <span class="badge badge-green">SUBMITTED</span>
                        <% } else { %>
                            <span class="badge badge-orange">PENDING</span>
                        <% } %>
                    </td>
                    <td style="color:var(--text-muted); font-size:13px;"><%= sheet?.submittedBy?.name || '—' %></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<!-- Admin Actions -->
<% if (exam.status === 'CLASS_APPROVED') { %>
<div class="card" style="margin-bottom:20px;">
    <div class="card-header">
        <div class="card-title">Admin Approval</div>
    </div>
    <div class="card-body">
        <p style="color:var(--text-muted); font-size:13px; margin-bottom:16px;">
            All marks have been validated by the class teacher. Review and give final approval to generate results.
        </p>
        <div style="display:flex; gap:10px; margin-bottom:16px;">
            <a href="/admin/results/exams/<%= exam._id %>/marks-review" class="btn btn-primary">Review All Marks</a>
            <form method="POST" action="/admin/results/exams/<%= exam._id %>/approve" style="display:inline;">
                <button type="submit" class="btn btn-success" onclick="return confirm('Approve this exam and generate results for all students?')">
                    ✓ Final Approve & Generate Results
                </button>
            </form>
            <button class="btn btn-danger" onclick="document.getElementById('rejectPanel').style.display='block'">Reject</button>
        </div>
        <div id="rejectPanel" style="display:none; background:#fff5f5; border:1px solid #fca5a5; border-radius:10px; padding:16px;">
            <form method="POST" action="/admin/results/exams/<%= exam._id %>/reject">
                <div class="form-group">
                    <label class="form-label">Rejection Reason *</label>
                    <textarea name="reason" class="form-control" rows="3" required placeholder="Explain what needs to be corrected…"></textarea>
                </div>
                <div style="display:flex; gap:8px;">
                    <button type="submit" class="btn btn-danger">Confirm Reject</button>
                    <button type="button" class="btn btn-secondary" onclick="document.getElementById('rejectPanel').style.display='none'">Cancel</button>
                </div>
            </form>
        </div>
    </div>
</div>
<% } %>

<!-- Reopen -->
<% if (exam.status === 'FINAL_APPROVED') { %>
<div class="card" style="margin-bottom:20px;">
    <div class="card-header">
        <div class="card-title">⚠️ Reopen for Correction</div>
    </div>
    <div class="card-body">
        <p style="color:var(--text-muted); font-size:13px; margin-bottom:16px;">
            Reopening will unlock all marks sheets and restart the approval workflow. All generated results will be cleared.
        </p>
        <button class="btn btn-warning" onclick="document.getElementById('reopenPanel').style.display='block'">Reopen Exam</button>
        <div id="reopenPanel" style="display:none; margin-top:16px; background:#fffbeb; border:1px solid #fde68a; border-radius:10px; padding:16px;">
            <form method="POST" action="/admin/results/exams/<%= exam._id %>/reopen">
                <div class="form-group">
                    <label class="form-label">Reason for Reopening</label>
                    <textarea name="reason" class="form-control" rows="2" placeholder="Enter reason (optional)…"></textarea>
                </div>
                <div style="display:flex; gap:8px;">
                    <button type="submit" class="btn btn-warning" onclick="return confirm('This will reset all approvals and clear generated results. Continue?')">Confirm Reopen</button>
                    <button type="button" class="btn btn-secondary" onclick="document.getElementById('reopenPanel').style.display='none'">Cancel</button>
                </div>
            </form>
        </div>
    </div>
</div>
<% } %>

<!-- Results Preview -->
<% if (results && results.length > 0) { %>
<div class="card" style="margin-bottom:20px;">
    <div class="card-header">
        <div class="card-title">Results Overview (Top 10)</div>
        <a href="/admin/results/exams/<%= exam._id %>/result" class="btn btn-secondary btn-sm">Full Results →</a>
    </div>
    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th style="text-align:center;">Rank</th>
                    <th>Student</th>
                    <th style="text-align:center;">Total</th>
                    <th style="text-align:center;">%</th>
                    <th style="text-align:center;">Grade</th>
                    <th style="text-align:center;">Result</th>
                </tr>
            </thead>
            <tbody>
                <% results.slice(0,10).forEach(r => { %>
                <tr>
                    <td style="text-align:center; font-weight:700; color:var(--primary);">#<%= r.rank %></td>
                    <td class="fw-semibold"><%= r.student?.name %></td>
                    <td style="text-align:center;"><%= r.totalMarks %>/<%= r.totalMaxMarks %></td>
                    <td style="text-align:center; font-weight:600;"><%= r.percentage %>%</td>
                    <td style="text-align:center;">
                        <span class="badge <%= r.grade === 'F' ? 'badge-red' : r.grade.startsWith('A') ? 'badge-green' : 'badge-blue' %>">
                            <%= r.grade %>
                        </span>
                    </td>
                    <td style="text-align:center;">
                        <span class="badge <%= r.isPassed ? 'badge-green' : 'badge-red' %>">
                            <%= r.isPassed ? 'PASS' : 'FAIL' %>
                        </span>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>
<% } %>

<!-- Audit Log -->
<div class="card">
    <div class="card-header">
        <div class="card-title">🕒 Audit Log</div>
    </div>
    <% if (!exam.auditLog || exam.auditLog.length === 0) { %>
        <div class="card-body" style="color:var(--text-muted);">No audit entries yet.</div>
    <% } else { %>
    <div class="table-wrapper">
        <table>
            <thead><tr><th>Action</th><th>By</th><th>Date & Time</th><th>Notes</th></tr></thead>
            <tbody>
                <% exam.auditLog.slice().reverse().forEach(log => { %>
                <tr>
                    <td><span class="badge badge-blue"><%= log.action %></span></td>
                    <td><%= log.by?.name || '—' %></td>
                    <td style="font-size:12px; color:var(--text-muted);">
                        <%= new Date(log.at).toLocaleString('en-IN') %>
                    </td>
                    <td style="color:var(--text-muted); font-size:13px;"><%= log.notes || '—' %></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
    <% } %>
</div>
