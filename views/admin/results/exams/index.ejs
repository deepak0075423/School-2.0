
<div class="page-header">
    <div>
        <h1>📋 Formal Exams</h1>
        <p>Manage Mid Term, Final, and Unit Test exams across all sections.</p>
    </div>
    <a href="/admin/results/exams/create" class="btn btn-primary">+ Create Exam</a>
</div>

<!-- Filters -->
<div class="card mb-4">
    <form method="GET" action="/admin/results/exams" class="filter-form">
        <div class="form-row">
            <div class="form-group">
                <label>Academic Year</label>
                <select name="academicYearId" class="form-control">
                    <option value="">All Years</option>
                    <% academicYears.forEach(y => { %>
                        <option value="<%= y._id %>" <%= selectedAcademicYear === String(y._id) ? 'selected' : '' %>><%= y.yearName %></option>
                    <% }) %>
                </select>
            </div>
            <div class="form-group">
                <label>Section</label>
                <select name="sectionId" class="form-control">
                    <option value="">All Sections</option>
                    <% sections.forEach(s => { %>
                        <option value="<%= s._id %>" <%= selectedSection === String(s._id) ? 'selected' : '' %>><%= s.class?.className %> – <%= s.sectionName %></option>
                    <% }) %>
                </select>
            </div>
            <div class="form-group form-group-action">
                <button type="submit" class="btn btn-secondary">Filter</button>
                <a href="/admin/results/exams" class="btn btn-ghost">Clear</a>
            </div>
        </div>
    </form>
</div>

<% if (!exams || exams.length === 0) { %>
<div class="card">
    <div class="empty-state">
        <div class="empty-icon">📋</div>
        <h3>No Exams Found</h3>
        <p>Create your first formal exam to get started.</p>
        <a href="/admin/results/exams/create" class="btn btn-primary">Create Exam</a>
    </div>
</div>
<% } else { %>
<div class="card">
    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Type</th>
                    <th>Section</th>
                    <th>Academic Year</th>
                    <th>Date Range</th>
                    <th>Publish Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <%
                const statusBadge = {
                    DRAFT: 'badge-yellow', MARKS_PENDING: 'badge-yellow',
                    SUBMITTED: 'badge-blue', CLASS_APPROVED: 'badge-purple',
                    FINAL_APPROVED: 'badge-green', REJECTED: 'badge-red', REOPENED: 'badge-orange'
                };
                const typeLabel = { MID_TERM: 'Mid Term', FINAL: 'Final', UNIT_TEST: 'Unit Test' };
                exams.forEach(exam => { %>
                <tr>
                    <td class="fw-semibold"><%= exam.title %></td>
                    <td><span class="badge badge-blue"><%= typeLabel[exam.examType] || exam.examType %></span></td>
                    <td><%= exam.section?.class?.className %> – <%= exam.section?.sectionName %></td>
                    <td><%= exam.academicYear?.yearName %></td>
                    <td class="text-sm">
                        <%= new Date(exam.startDate).toLocaleDateString('en-IN') %> –
                        <%= new Date(exam.endDate).toLocaleDateString('en-IN') %>
                    </td>
                    <td class="text-sm"><%= new Date(exam.publishDate).toLocaleDateString('en-IN') %></td>
                    <td><span class="badge <%= statusBadge[exam.status] || 'badge-yellow' %>"><%= exam.status.replace(/_/g,' ') %></span></td>
                    <td>
                        <div class="action-btns">
                            <a href="/admin/results/exams/<%= exam._id %>" class="btn btn-sm btn-secondary">View</a>
                            <% if (exam.status === 'CLASS_APPROVED') { %>
                                <a href="/admin/results/exams/<%= exam._id %>/marks-review" class="btn btn-sm btn-primary">Review & Approve</a>
                            <% } %>
                            <% if (exam.resultsGenerated) { %>
                                <a href="/admin/results/exams/<%= exam._id %>/result" class="btn btn-sm btn-ghost">Results</a>
                            <% } %>
                        </div>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>
<% } %>
