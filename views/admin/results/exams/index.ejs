<div class="page-header">
    <div>
        <h1>📋 Formal Exams</h1>
        <p>Manage Mid Term, Final, and Unit Test exams. Approval: Teacher → Class Teacher → Admin.</p>
    </div>
    <a href="/admin/results/exams/create" class="btn btn-primary">+ Create Exam</a>
</div>

<!-- Filters -->
<div class="card" style="margin-bottom:20px;">
    <div class="card-body">
        <form method="GET" action="/admin/results/exams">
            <div style="display:grid; grid-template-columns:1fr 1fr auto; gap:14px; align-items:flex-end;">
                <div class="form-group" style="margin-bottom:0;">
                    <label class="form-label">Academic Year</label>
                    <select name="academicYearId" class="form-control">
                        <option value="">All Years</option>
                        <% academicYears.forEach(y => { %>
                            <option value="<%= y._id %>" <%= selectedAcademicYear === String(y._id) ? 'selected' : '' %>>
                                <%= y.yearName %>
                            </option>
                        <% }) %>
                    </select>
                </div>
                <div class="form-group" style="margin-bottom:0;">
                    <label class="form-label">Section</label>
                    <select name="sectionId" class="form-control">
                        <option value="">All Sections</option>
                        <% sections.forEach(s => { %>
                            <option value="<%= s._id %>" <%= selectedSection === String(s._id) ? 'selected' : '' %>>
                                Class <%= s.class?.classNumber %> - <%= s.sectionName %>
                            </option>
                        <% }) %>
                    </select>
                </div>
                <div style="display:flex; gap:8px;">
                    <button type="submit" class="btn btn-primary">Filter</button>
                    <a href="/admin/results/exams" class="btn btn-secondary">Clear</a>
                </div>
            </div>
        </form>
    </div>
</div>

<% if (!exams || exams.length === 0) { %>
<div class="card">
    <div class="empty-state">
        <div class="empty-icon">📋</div>
        <h3>No Exams Found</h3>
        <p>Create your first formal exam to get started.</p>
        <a href="/admin/results/exams/create" class="btn btn-primary">+ Create Exam</a>
    </div>
</div>
<% } else { %>
<%
const sBadge = {
    DRAFT:'badge-gray', MARKS_PENDING:'badge-orange',
    SUBMITTED:'badge-blue', CLASS_APPROVED:'badge-purple',
    FINAL_APPROVED:'badge-green', REJECTED:'badge-red', REOPENED:'badge-orange'
};
const typeLabel = { MID_TERM:'Mid Term', FINAL:'Final Exam', UNIT_TEST:'Unit Test' };
%>
<div class="card">
    <div class="card-header">
        <div class="card-title">All Exams (<%= exams.length %>)</div>
    </div>
    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>Exam Title</th>
                    <th>Type</th>
                    <th>Section</th>
                    <th>Academic Year</th>
                    <th>Exam Dates</th>
                    <th>Publish Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% exams.forEach(exam => { %>
                <tr>
                    <td class="fw-semibold"><%= exam.title %></td>
                    <td><span class="badge badge-blue"><%= typeLabel[exam.examType] || exam.examType %></span></td>
                    <td>Class <%= exam.section?.class?.classNumber %> - <%= exam.section?.sectionName %></td>
                    <td><%= exam.academicYear?.yearName %></td>
                    <td style="font-size:12px; color:var(--text-muted);">
                        <%= new Date(exam.startDate).toLocaleDateString('en-IN') %> –
                        <%= new Date(exam.endDate).toLocaleDateString('en-IN') %>
                    </td>
                    <td style="font-size:12px;"><%= exam.publishDate ? new Date(exam.publishDate).toLocaleDateString('en-IN') : '—' %></td>
                    <td>
                        <span class="badge <%= sBadge[exam.status] || 'badge-gray' %>">
                            <%= exam.status.replace(/_/g,' ') %>
                        </span>
                    </td>
                    <td>
                        <div style="display:flex; gap:6px; flex-wrap:wrap;">
                            <a href="/admin/results/exams/<%= exam._id %>" class="btn btn-secondary btn-sm">View</a>
                            <% if (new Date(exam.startDate) > new Date()) { %>
                                <a href="/admin/results/exams/<%= exam._id %>/edit" class="btn btn-warning btn-sm">Edit</a>
                            <% } %>
                            <% if (exam.status === 'CLASS_APPROVED') { %>
                                <a href="/admin/results/exams/<%= exam._id %>/marks-review" class="btn btn-primary btn-sm">Review & Approve</a>
                            <% } %>
                            <% if (exam.resultsGenerated) { %>
                                <a href="/admin/results/exams/<%= exam._id %>/result" class="btn btn-secondary btn-sm">Results</a>
                            <% } %>
                            <form method="POST" action="/admin/results/exams/<%= exam._id %>/delete" style="display:inline;">
                                <button type="submit" class="btn btn-danger btn-sm"
                                    data-confirm="Delete '<%= exam.title %>'? All marks and results will be permanently removed." data-confirm-title="Delete Exam" data-confirm-type="danger">
                                    Delete
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>
<% } %>
