<div class="page-header">
    <div>
        <h1>🛡️ Add Co-Admin</h1>
        <p>Create a new School Admin for <%= session.schoolName %></p>
    </div>
    <a href="/admin/admins" class="btn btn-secondary">← Back to Co-Admins</a>
</div>

<form action="/admin/admins/create" method="POST">
    <div class="form-section">
        <div class="form-section-header">
            <span>👤</span>
            <h3>Admin Information</h3>
            <span class="section-badge">School Admin</span>
        </div>
        <div class="form-section-body">
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label">Full Name *</label>
                    <input type="text" name="name" class="form-control" placeholder="Admin's full name" required />
                </div>
                <div class="form-group">
                    <label class="form-label">Email Address *</label>
                    <input type="email" name="email" class="form-control" placeholder="admin@example.com" required />
                </div>
                <div class="form-group">
                    <label class="form-label">Phone</label>
                    <input type="text" name="phone" class="form-control" placeholder="+91 XXXXX XXXXX" />
                </div>
                <div class="form-group" style="display:flex; align-items:flex-end;">
                    <div style="background:#eef2ff; border:1px solid #c7d2fe; border-radius:8px; padding:12px 16px; width:100%;">
                        <div style="font-size:12px; font-weight:600; color:#4f46e5; margin-bottom:4px;">🏫 School Assignment</div>
                        <div style="font-size:14px; color:#374151; font-weight:600;"><%= session.schoolName %></div>
                        <div style="font-size:11px; color:#6b7280; margin-top:2px;">Auto-assigned to your school</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="alert alert-warning">
        📧 The new co-admin will receive login credentials via email. They will be prompted to set a new password on first login.
    </div>

    <button type="submit" class="btn btn-primary btn-lg">🛡️ Create Co-Admin Account</button>
</form>
