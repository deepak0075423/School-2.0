<div class="page-header">
    <div>
        <h1>🏫 Create New Class</h1>
        <p>Add a class for an academic year</p>
    </div>
    <a href="/admin/classes" class="btn btn-secondary">← Back</a>
</div>

<div class="card" style="max-width:560px;">
    <div class="card-header">
        <div class="card-title">Class Details</div>
    </div>
    <div class="card-body">
        <form action="/admin/classes/create" method="POST">
            <div class="form-group">
                <label class="form-label">Academic Year *</label>
                <select name="academicYear" class="form-control" required>
                    <option value="">— Select academic year —</option>
                    <% years.forEach(y=> { %>
                        <option value="<%= y._id %>">
                            <%= y.yearName %>
                        </option>
                        <% }) %>
                </select>
                <% if (years.length===0) { %>
                    <p class="form-hint" style="color:var(--error);">⚠️ No active academic years. <a
                            href="/admin/academic-years">Create one first</a>.</p>
                    <% } %>
            </div>
            <div class="form-group">
                <label class="form-label">Class Number *</label>
                <input type="number" name="classNumber" class="form-control" placeholder="e.g. 5" min="1" max="12"
                    required>
                <span class="form-hint">Must be unique within the academic year</span>
            </div>
            <div class="form-group">
                <label class="form-label">Class Name *</label>
                <input type="text" name="className" class="form-control" placeholder="e.g. Class 5" required>
            </div>
            <div class="form-group">
                <label class="form-label">Status</label>
                <select name="status" class="form-control">
                    <option value="active">Active</option>
                    <option value="inactive">Inactive</option>
                </select>
            </div>
            <div style="display:flex; gap:12px; margin-top:8px;">
                <button type="submit" class="btn btn-primary" <%=years.length===0 ? 'disabled' : '' %>>Create
                    Class</button>
                <a href="/admin/classes" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>