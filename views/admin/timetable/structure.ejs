<div class="page-header">
    <div>
        <h1>📅 Timetable Config — <%= section.sectionName %></h1>
        <p><%= section.class?.className %> ( <%= section.academicYear?.yearName %> )</p>
    </div>
    <div style="display:flex; gap:8px; flex-wrap:wrap;">
        <% if (timetable && timetable.periodsStructure && timetable.periodsStructure.length > 0) { %>
            <a href="/admin/sections/<%= section._id %>/timetable/entries" class="btn btn-secondary">Assign Subjects & Teachers →</a>
            <a href="/admin/sections/<%= section._id %>/timetable/download" class="btn btn-secondary">⬇ This Section PDF</a>
        <% } %>
        <a href="/admin/timetable/download-all" class="btn btn-primary">⬇ All Classes PDF</a>
        <a href="/admin/sections/<%= section._id %>" class="btn btn-secondary">← Back to Section</a>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <div class="card-title">School Timing & Periods Configuration</div>
    </div>
    <div class="card-body">
        <form action="/admin/sections/<%= section._id %>/timetable/structure" method="POST">
            <div style="display:flex; gap:20px; margin-bottom: 20px;">
                <div class="form-group" style="flex:1;">
                    <label class="form-label">School Start Time</label>
                    <input type="time" name="startTime" class="form-control" value="<%= section.startTime || '08:00' %>" required>
                </div>
                <div class="form-group" style="flex:1;">
                    <label class="form-label">School End Time</label>
                    <input type="time" name="endTime" class="form-control" value="<%= section.endTime || '14:00' %>" required>
                </div>
            </div>

            <div style="display:flex; gap:20px; margin-bottom: 20px;">
                <div class="form-group" style="flex:1;">
                    <label class="form-label">Total No. of Periods</label>
                    <input type="number" name="totalPeriods" class="form-control" value="<%= section.totalPeriods || 8 %>" min="1" required>
                </div>
                <div class="form-group" style="flex:1;">
                    <label class="form-label">Lunch Time Duration (in minutes)</label>
                    <input type="number" name="lunchTimeTotalInMinutes" class="form-control" value="<%= section.lunchTimeTotalInMinutes || 30 %>" min="0" required>
                </div>
            </div>

            <div style="display:flex; gap:20px; margin-bottom: 20px;">
                <div class="form-group" style="flex:1;">
                    <label class="form-label">Lunch Break After Which Period?</label>
                    <input type="number" name="lunchAfterPeriod" class="form-control" value="<%= section.lunchAfterPeriod || 4 %>" min="1" required>
                </div>
                <div class="form-group" style="flex:1; display:flex; flex-direction:column; justify-content:center;">
                    <label class="form-label" style="display:flex; align-items:center; gap:8px; cursor:pointer; margin-top:28px;">
                        <input type="checkbox" name="openOnSaturday" <%= section.openOnSaturday ? 'checked' : '' %> style="transform: scale(1.2);">
                        <span style="font-weight: 500;">Open on Saturday</span>
                    </label>
                </div>
            </div>

            <div class="alert alert-info" style="margin-bottom:20px; background:rgba(59,130,246,0.1); border:1px solid var(--primary); border-radius:8px; padding:12px; color:var(--primary);">
                ℹ️ <strong>Auto-calculation:</strong> The system will automatically calculate the duration of each period based on the start and end times, minus the lunch duration. If the duration is not a perfect integer, the remaining minutes will be added to the final period.
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%;">Generate Timetable Structure</button>
        </form>
    </div>
</div>
