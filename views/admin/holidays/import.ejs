<div class="page-header">
    <div>
        <h1>📥 Import Holidays</h1>
        <p>Bulk upload holidays from a CSV or Excel file.</p>
    </div>
    <a href="/admin/holidays" class="btn btn-secondary">← Back</a>
</div>

<!-- Instructions Card -->
<div class="form-section" style="margin-bottom:24px;">
    <div class="form-section-header">
        <h3>Instructions</h3>
    </div>
    <div class="form-section-body">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:20px;">
            <div>
                <div style="font-weight:700; font-size:14px; margin-bottom:10px; color:var(--text);">Required Columns</div>
                <div style="display:flex; flex-direction:column; gap:6px;">
                    <div style="display:flex; gap:10px; font-size:13px;">
                        <span style="background:#f0f4ff; color:var(--primary); padding:2px 8px; border-radius:4px; font-family:monospace; font-size:12px; white-space:nowrap;">Name</span>
                        <span style="color:var(--text);">Holiday name (required)</span>
                    </div>
                    <div style="display:flex; gap:10px; font-size:13px;">
                        <span style="background:#f0f4ff; color:var(--primary); padding:2px 8px; border-radius:4px; font-family:monospace; font-size:12px; white-space:nowrap;">Start Date</span>
                        <span style="color:var(--text);">Format: YYYY-MM-DD</span>
                    </div>
                    <div style="display:flex; gap:10px; font-size:13px;">
                        <span style="background:#f0f4ff; color:var(--primary); padding:2px 8px; border-radius:4px; font-family:monospace; font-size:12px; white-space:nowrap;">End Date</span>
                        <span style="color:var(--text);">Format: YYYY-MM-DD</span>
                    </div>
                </div>
            </div>
            <div>
                <div style="font-weight:700; font-size:14px; margin-bottom:10px; color:var(--text);">Optional Columns</div>
                <div style="display:flex; flex-direction:column; gap:6px;">
                    <div style="display:flex; gap:10px; font-size:13px;">
                        <span style="background:#f0f4ff; color:var(--primary); padding:2px 8px; border-radius:4px; font-family:monospace; font-size:12px; white-space:nowrap;">Type</span>
                        <span style="color:var(--text-muted);">public / school_specific / optional / exam_break</span>
                    </div>
                    <div style="display:flex; gap:10px; font-size:13px;">
                        <span style="background:#f0f4ff; color:var(--primary); padding:2px 8px; border-radius:4px; font-family:monospace; font-size:12px; white-space:nowrap;">Description</span>
                        <span style="color:var(--text-muted);">Brief note</span>
                    </div>
                    <div style="display:flex; gap:10px; font-size:13px;">
                        <span style="background:#f0f4ff; color:var(--primary); padding:2px 8px; border-radius:4px; font-family:monospace; font-size:12px; white-space:nowrap;">Is Recurring</span>
                        <span style="color:var(--text-muted);">yes / no</span>
                    </div>
                    <div style="display:flex; gap:10px; font-size:13px;">
                        <span style="background:#f0f4ff; color:var(--primary); padding:2px 8px; border-radius:4px; font-family:monospace; font-size:12px; white-space:nowrap;">Applicability</span>
                        <span style="color:var(--text-muted);">all / specific_classes / specific_departments</span>
                    </div>
                </div>
            </div>
        </div>

        <div style="display:flex; align-items:center; gap:10px; background:#f0fdf4; border:1px solid #bbf7d0; border-radius:10px; padding:12px 16px;">
            <span style="font-size:20px;">📄</span>
            <div style="flex:1;">
                <div style="font-weight:600; font-size:14px; color:#166534;">Download Template</div>
                <div style="font-size:13px; color:#374151;">Get a pre-formatted Excel file with sample data and column notes.</div>
            </div>
            <a href="/admin/holidays/template" class="btn btn-secondary btn-sm">⬇ Download Template</a>
        </div>
    </div>
</div>

<!-- Upload Form -->
<div class="form-section">
    <div class="form-section-header">
        <h3>Upload File</h3>
    </div>
    <div class="form-section-body">
        <form method="POST" action="/admin/holidays/import" enctype="multipart/form-data" id="importForm">

            <div class="form-group">
                <label class="form-label">Select CSV / Excel File *</label>
                <div id="dropZone" style="border:2px dashed var(--border); border-radius:12px; padding:36px; text-align:center; cursor:pointer; transition:border-color .2s, background .2s;"
                     onclick="document.getElementById('fileInput').click()"
                     ondragover="handleDragOver(event)" ondragleave="handleDragLeave(event)" ondrop="handleDrop(event)">
                    <div style="font-size:32px; margin-bottom:8px;">📂</div>
                    <div style="font-weight:600; font-size:14px; color:var(--text);" id="dropLabel">
                        Click to browse or drag & drop here
                    </div>
                    <div style="font-size:12px; color:var(--text-muted); margin-top:4px;">
                        Supports .csv, .xlsx, .xls — max 5 MB
                    </div>
                </div>
                <input type="file" id="fileInput" name="csvFile" accept=".csv,.xlsx,.xls"
                       style="display:none;" onchange="handleFileSelect(this)" required />
            </div>

            <div id="filePreview" style="display:none; background:var(--sidebar-bg); border-radius:10px; padding:12px 16px; margin-bottom:16px; display:flex; align-items:center; gap:12px;">
                <span style="font-size:24px;">📊</span>
                <div style="flex:1;">
                    <div style="font-weight:600; font-size:14px;" id="fileName"></div>
                    <div style="font-size:12px; color:var(--text-muted);" id="fileSize"></div>
                </div>
                <button type="button" onclick="clearFile()" style="background:none;border:none;color:#ef4444;font-size:18px;cursor:pointer;">✕</button>
            </div>

            <div style="display:flex; align-items:center; gap:12px; padding:12px 16px; background:#fffbeb; border:1px solid #fde68a; border-radius:10px; margin-bottom:20px;">
                <span style="font-size:18px;">⚠️</span>
                <div style="font-size:13px; color:#92400e;">
                    Importing will <strong>add</strong> new holidays. It will not overwrite or delete existing ones.
                    Applicability for imported holidays defaults to <strong>All Users</strong>.
                </div>
            </div>

            <div style="display:flex; gap:12px;">
                <button type="submit" class="btn btn-primary" id="importBtn" disabled>📥 Import Holidays</button>
                <a href="/admin/holidays" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

<script>
function handleDragOver(e) {
    e.preventDefault();
    document.getElementById('dropZone').style.borderColor = 'var(--primary)';
    document.getElementById('dropZone').style.background = '#f0f4ff';
}
function handleDragLeave(e) {
    document.getElementById('dropZone').style.borderColor = '';
    document.getElementById('dropZone').style.background = '';
}
function handleDrop(e) {
    e.preventDefault();
    handleDragLeave(e);
    const file = e.dataTransfer.files[0];
    if (file) applyFile(file);
}
function handleFileSelect(input) {
    if (input.files[0]) applyFile(input.files[0]);
}
function applyFile(file) {
    const allowed = /\.(csv|xlsx|xls)$/i;
    if (!allowed.test(file.name)) {
        alert('Only .csv, .xlsx, and .xls files are supported.');
        return;
    }
    document.getElementById('fileName').textContent = file.name;
    document.getElementById('fileSize').textContent = (file.size / 1024).toFixed(1) + ' KB';
    document.getElementById('filePreview').style.display = 'flex';
    document.getElementById('dropLabel').textContent = 'File selected — click to change';
    document.getElementById('importBtn').disabled = false;

    // Transfer to actual file input via DataTransfer
    const dt = new DataTransfer();
    dt.items.add(file);
    document.getElementById('fileInput').files = dt.files;
}
function clearFile() {
    document.getElementById('fileInput').value = '';
    document.getElementById('filePreview').style.display = 'none';
    document.getElementById('dropLabel').textContent = 'Click to browse or drag & drop here';
    document.getElementById('importBtn').disabled = true;
}
</script>
