<style>
/* ── Holiday type badges ───────────────────────────────────── */
.badge-public          { background:#eff6ff; color:#1d4ed8; border:1px solid #bfdbfe; }
.badge-school_specific { background:#f5f3ff; color:#6d28d9; border:1px solid #ddd6fe; }
.badge-optional        { background:#fffbeb; color:#b45309; border:1px solid #fde68a; }
.badge-exam_break      { background:#ecfdf5; color:#065f46; border:1px solid #a7f3d0; }
.type-badge {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 600;
    text-transform: capitalize;
    white-space: nowrap;
}

/* ── View tabs ─────────────────────────────────────────────── */
.view-tabs {
    display: flex;
    gap: 4px;
    border-bottom: 2px solid var(--border);
    margin-bottom: 24px;
}
.view-tab {
    padding: 9px 20px;
    border: none;
    background: none;
    cursor: pointer;
    font-size: 14px;
    font-weight: 500;
    color: var(--text-muted);
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    transition: all .15s;
    border-radius: 6px 6px 0 0;
}
.view-tab.active { color: var(--primary); border-bottom-color: var(--primary); background: #f0f4ff; }

/* ── Calendar ──────────────────────────────────────────────── */
.cal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
}
.cal-nav-btn {
    background: var(--sidebar-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 6px 14px;
    cursor: pointer;
    font-size: 16px;
    color: var(--text);
    transition: background .15s;
}
.cal-nav-btn:hover { background: var(--border); }
.cal-month-label { font-size: 20px; font-weight: 700; color: var(--text); }

.cal-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
}
.cal-day-header {
    text-align: center;
    font-size: 12px;
    font-weight: 600;
    color: var(--text-muted);
    padding: 8px 0;
    text-transform: uppercase;
    letter-spacing: .5px;
}
.cal-cell {
    min-height: 80px;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 6px;
    background: var(--card-bg, #fff);
    position: relative;
    transition: border-color .15s;
}
.cal-cell.empty { background: var(--sidebar-bg); border-color: transparent; }
.cal-cell.today  { border-color: var(--primary); }
.cal-cell.today .cal-date { background: var(--primary); color: #fff; border-radius: 50%; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; }
.cal-date { font-size: 13px; font-weight: 600; color: var(--text); margin-bottom: 4px; }
.cal-holiday-pill {
    display: block;
    font-size: 11px;
    padding: 2px 6px;
    border-radius: 4px;
    margin-top: 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    cursor: pointer;
    font-weight: 500;
    transition: opacity .15s;
}
.cal-holiday-pill:hover { opacity: .8; }
.pill-public          { background:#3b82f6; color:#fff; }
.pill-school_specific { background:#8b5cf6; color:#fff; }
.pill-optional        { background:#f59e0b; color:#fff; }
.pill-exam_break      { background:#10b981; color:#fff; }

/* ── Legend ────────────────────────────────────────────────── */
.cal-legend {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 20px;
}
.legend-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--text);
}
.legend-dot {
    width: 12px; height: 12px;
    border-radius: 3px;
    flex-shrink: 0;
}

/* ── Holiday detail modal ──────────────────────────────────── */
.holiday-modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.45);
    z-index: 1100;
    align-items: center;
    justify-content: center;
}
.holiday-modal-overlay.open { display: flex; }
.holiday-modal {
    background: var(--card-bg, #fff);
    border-radius: 14px;
    padding: 28px 32px;
    max-width: 480px;
    width: 90%;
    box-shadow: 0 20px 60px rgba(0,0,0,.2);
    position: relative;
}
.holiday-modal-close {
    position: absolute;
    top: 14px; right: 18px;
    background: none; border: none;
    font-size: 22px; cursor: pointer;
    color: var(--text-muted);
    line-height: 1;
}
.holiday-modal-title { font-size: 20px; font-weight: 700; margin-bottom: 16px; color: var(--text); }
.holiday-detail-row {
    display: flex;
    gap: 8px;
    align-items: flex-start;
    margin-bottom: 10px;
    font-size: 14px;
    color: var(--text);
}
.detail-label { font-weight: 600; min-width: 90px; color: var(--text-muted); }
</style>

<div class="page-header">
    <div>
        <h1>🎉 Holiday Management</h1>
        <p>Manage school holidays and view them on the calendar.</p>
    </div>
    <div style="display:flex; gap:8px; flex-wrap:wrap;">
        <a href="/admin/holidays/create"  class="btn btn-primary">+ Add Holiday</a>
        <a href="/admin/holidays/import"  class="btn btn-secondary">📥 Import</a>
        <a href="/admin/holidays/export"  class="btn btn-secondary">📤 Export</a>
        <a href="/admin/holidays/audit"   class="btn btn-secondary">📋 Audit Log</a>
    </div>
</div>

<!-- View Tabs -->
<div class="view-tabs">
    <button class="view-tab active" onclick="showTab('list', this)">📋 List View</button>
    <button class="view-tab"        onclick="showTab('calendar', this)">📅 Calendar View</button>
</div>

<!-- ── LIST VIEW ─────────────────────────────────────────── -->
<div id="tab-list">

    <!-- Filters -->
    <div style="display:flex; gap:12px; flex-wrap:wrap; margin-bottom:20px; align-items:center;">
        <input type="text" id="filterSearch" placeholder="Search holiday name…"
               class="form-control" style="max-width:240px;"
               oninput="applyFilters()" />
        <select id="filterType" class="form-control" style="max-width:180px;" onchange="applyFilters()">
            <option value="">All Types</option>
            <option value="public">Public</option>
            <option value="school_specific">School Specific</option>
            <option value="optional">Optional</option>
            <option value="exam_break">Exam Break</option>
        </select>
        <select id="filterScope" class="form-control" style="max-width:200px;" onchange="applyFilters()">
            <option value="">All Applicability</option>
            <option value="all">All Users</option>
            <option value="specific_classes">Specific Classes</option>
            <option value="specific_departments">Specific Departments</option>
        </select>
        <span id="filterCount" style="font-size:13px; color:var(--text-muted);"></span>
    </div>

    <% if (holidays.length === 0) { %>
    <div class="empty-state">
        <div class="empty-icon">🎉</div>
        <h3>No holidays yet</h3>
        <p>Start by adding the first holiday for your school.</p>
        <a href="/admin/holidays/create" class="btn btn-primary">Add First Holiday</a>
    </div>
    <% } else { %>
    <div class="table-wrapper">
        <table class="data-table" id="holidaysTable">
            <thead>
                <tr>
                    <th>Holiday Name</th>
                    <th>Type</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Duration</th>
                    <th>Applicability</th>
                    <th>Recurring</th>
                    <th>Created By</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% holidays.forEach(h => {
                    const start    = new Date(h.startDate);
                    const end      = new Date(h.endDate);
                    const duration = Math.round((end - start) / 86400000) + 1;
                    const typeLabel = {
                        public: 'Public', school_specific: 'School Specific',
                        optional: 'Optional', exam_break: 'Exam Break'
                    }[h.type] || h.type;
                %>
                <tr class="holiday-row"
                    data-name="<%= h.name.toLowerCase() %>"
                    data-type="<%= h.type %>"
                    data-scope="<%= h.applicability.scope %>">
                    <td>
                        <div style="font-weight:600; color:var(--text);"><%= h.name %></div>
                        <% if (h.description) { %>
                        <div style="font-size:12px; color:var(--text-muted); margin-top:2px;">
                            <%= h.description.length > 60 ? h.description.substring(0, 60) + '…' : h.description %>
                        </div>
                        <% } %>
                    </td>
                    <td>
                        <span class="type-badge badge-<%= h.type %>"><%= typeLabel %></span>
                    </td>
                    <td><%= start.toLocaleDateString('en-IN', {day:'2-digit', month:'short', year:'numeric'}) %></td>
                    <td><%= end.toLocaleDateString('en-IN', {day:'2-digit', month:'short', year:'numeric'}) %></td>
                    <td>
                        <span style="font-size:13px; color:var(--text-muted);">
                            <%= duration === 1 ? '1 day' : duration + ' days' %>
                        </span>
                    </td>
                    <td>
                        <% if (h.applicability.scope === 'all') { %>
                            <span style="font-size:13px; color:var(--text-muted);">All Users</span>
                        <% } else if (h.applicability.scope === 'specific_classes') { %>
                            <% if (h.applicability.classes && h.applicability.classes.length) { %>
                                <span style="font-size:12px; color:var(--text-muted);">
                                    Classes: <%= h.applicability.classes.map(c => c.classNumber).join(', ') %>
                                </span>
                            <% } else { %>
                                <span style="font-size:12px; color:var(--text-muted);">Specific Classes</span>
                            <% } %>
                        <% } else { %>
                            <span style="font-size:12px; color:var(--text-muted);">
                                Depts: <%= (h.applicability.departments || []).join(', ').replace(/_/g,' ') || '—' %>
                            </span>
                        <% } %>
                    </td>
                    <td>
                        <% if (h.isRecurring) { %>
                            <span style="color:#10b981; font-size:13px; font-weight:600;">✓ Yearly</span>
                        <% } else { %>
                            <span style="color:var(--text-muted); font-size:13px;">—</span>
                        <% } %>
                    </td>
                    <td>
                        <% if (h.createdBy) { %>
                        <div style="font-size:13px; color:var(--text);"><%= h.createdBy.name %></div>
                        <div style="font-size:11px; color:var(--text-muted);">
                            <%= new Date(h.createdAt).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) %>
                        </div>
                        <% if (h.updatedBy && h.updatedBy._id && h.updatedBy._id.toString() !== h.createdBy._id.toString()) { %>
                        <div style="font-size:11px; color:var(--primary); margin-top:2px;">
                            Edited by <%= h.updatedBy.name %>
                        </div>
                        <% } %>
                        <% } else { %><span style="color:var(--text-muted); font-size:13px;">—</span><% } %>
                    </td>
                    <td>
                        <div style="display:flex; gap:8px;">
                            <a href="/admin/holidays/<%= h._id %>/edit" class="btn btn-secondary btn-sm">Edit</a>
                            <form method="POST" action="/admin/holidays/<%= h._id %>/delete"
                                  data-confirm-submit="Delete holiday '<%= h.name %>'?" data-confirm-title="Delete Holiday">
                                <button class="btn btn-sm" style="background:#fef2f2; color:#ef4444; border:1px solid #fecaca;">Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
    <% } %>
</div>

<!-- ── CALENDAR VIEW ──────────────────────────────────────── -->
<div id="tab-calendar" style="display:none;">

    <div class="cal-legend">
        <div class="legend-item"><div class="legend-dot" style="background:#3b82f6;"></div> Public</div>
        <div class="legend-item"><div class="legend-dot" style="background:#8b5cf6;"></div> School Specific</div>
        <div class="legend-item"><div class="legend-dot" style="background:#f59e0b;"></div> Optional</div>
        <div class="legend-item"><div class="legend-dot" style="background:#10b981;"></div> Exam Break</div>
    </div>

    <div class="card" style="padding:24px;">
        <div class="cal-header">
            <button class="cal-nav-btn" onclick="prevMonth()">&#8592;</button>
            <div class="cal-month-label" id="calMonthLabel"></div>
            <button class="cal-nav-btn" onclick="nextMonth()">&#8594;</button>
        </div>
        <div class="cal-grid" id="calGrid"></div>
    </div>
</div>

<!-- ── Holiday Detail Modal ───────────────────────────────── -->
<div class="holiday-modal-overlay" id="holidayModal" onclick="closeModal(event)">
    <div class="holiday-modal">
        <button class="holiday-modal-close" onclick="closeModal(null, true)">&times;</button>
        <div class="holiday-modal-title" id="modalName"></div>
        <div id="modalBody"></div>
    </div>
</div>

<script>
const HOLIDAYS = <%- holidaysJson %>;

const TYPE_LABELS = {
    public: 'Public',
    school_specific: 'School Specific',
    optional: 'Optional',
    exam_break: 'Exam Break',
};

const SCOPE_LABELS = {
    all: 'All Users',
    specific_classes: 'Specific Classes',
    specific_departments: 'Specific Departments',
};

// ── Tab switching ──────────────────────────────────────────
function showTab(tab, btn) {
    document.getElementById('tab-list').style.display     = tab === 'list'     ? '' : 'none';
    document.getElementById('tab-calendar').style.display = tab === 'calendar' ? '' : 'none';
    document.querySelectorAll('.view-tab').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    if (tab === 'calendar') renderCalendar();
}

// ── List filtering ─────────────────────────────────────────
function applyFilters() {
    const search = document.getElementById('filterSearch').value.toLowerCase();
    const type   = document.getElementById('filterType').value;
    const scope  = document.getElementById('filterScope').value;
    const rows   = document.querySelectorAll('.holiday-row');
    let visible  = 0;
    rows.forEach(row => {
        const matchName  = !search || row.dataset.name.includes(search);
        const matchType  = !type   || row.dataset.type  === type;
        const matchScope = !scope  || row.dataset.scope === scope;
        const show = matchName && matchType && matchScope;
        row.style.display = show ? '' : 'none';
        if (show) visible++;
    });
    const total = rows.length;
    document.getElementById('filterCount').textContent =
        visible === total ? `${total} holiday${total !== 1 ? 's' : ''}` : `${visible} of ${total} holidays`;
}
applyFilters();

// ── Calendar ───────────────────────────────────────────────
const DAY_NAMES = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
const MONTH_NAMES = ['January','February','March','April','May','June','July','August','September','October','November','December'];

let calYear  = new Date().getFullYear();
let calMonth = new Date().getMonth(); // 0-indexed

function prevMonth() {
    calMonth--;
    if (calMonth < 0) { calMonth = 11; calYear--; }
    renderCalendar();
}
function nextMonth() {
    calMonth++;
    if (calMonth > 11) { calMonth = 0; calYear++; }
    renderCalendar();
}

function buildHolidayMap(year, month) {
    const map = {};
    const monthStart = new Date(year, month, 1);
    const monthEnd   = new Date(year, month + 1, 0);

    HOLIDAYS.forEach(h => {
        const start = new Date(h.startDate + 'T00:00:00');
        const end   = new Date(h.endDate   + 'T00:00:00');
        if (start > monthEnd || end < monthStart) return;

        const cur = new Date(Math.max(start, monthStart));
        const lim = new Date(Math.min(end,   monthEnd));
        while (cur <= lim) {
            const day = cur.getDate();
            if (!map[day]) map[day] = [];
            map[day].push(h);
            cur.setDate(cur.getDate() + 1);
        }
    });
    return map;
}

function renderCalendar() {
    document.getElementById('calMonthLabel').textContent =
        `${MONTH_NAMES[calMonth]} ${calYear}`;

    const grid    = document.getElementById('calGrid');
    const today   = new Date();
    const isToday = (d) => d === today.getDate() && calMonth === today.getMonth() && calYear === today.getFullYear();

    const firstDow     = new Date(calYear, calMonth, 1).getDay();
    const daysInMonth  = new Date(calYear, calMonth + 1, 0).getDate();
    const holidayMap   = buildHolidayMap(calYear, calMonth);

    let html = DAY_NAMES.map(d => `<div class="cal-day-header">${d}</div>`).join('');

    // Empty cells before month start
    for (let i = 0; i < firstDow; i++) html += '<div class="cal-cell empty"></div>';

    for (let d = 1; d <= daysInMonth; d++) {
        const dayHolidays = holidayMap[d] || [];
        const todayClass  = isToday(d) ? ' today' : '';
        html += `<div class="cal-cell${todayClass}">
            <div class="cal-date">${d}</div>
            ${dayHolidays.map(h =>
                `<span class="cal-holiday-pill pill-${h.type}" onclick="openModal('${h._id}')" title="${h.name}">${h.name}</span>`
            ).join('')}
        </div>`;
    }

    grid.innerHTML = html;
}

// ── Modal ──────────────────────────────────────────────────
function openModal(id) {
    const h = HOLIDAYS.find(x => x._id === id);
    if (!h) return;

    document.getElementById('modalName').textContent = h.name;

    const fmt = (d) => new Date(d + 'T00:00:00').toLocaleDateString('en-IN', { day:'2-digit', month:'long', year:'numeric' });
    const start = new Date(h.startDate + 'T00:00:00');
    const end   = new Date(h.endDate   + 'T00:00:00');
    const days  = Math.round((end - start) / 86400000) + 1;

    const typeColors = {
        public: '#3b82f6', school_specific: '#8b5cf6',
        optional: '#f59e0b', exam_break: '#10b981',
    };

    document.getElementById('modalBody').innerHTML = `
        <div style="display:inline-block; padding:4px 12px; border-radius:12px; background:${typeColors[h.type]}22;
             color:${typeColors[h.type]}; font-weight:600; font-size:13px; margin-bottom:16px; border:1px solid ${typeColors[h.type]}44;">
            ${TYPE_LABELS[h.type] || h.type}
        </div>
        <div class="holiday-detail-row"><span class="detail-label">Start Date</span><span>${fmt(h.startDate)}</span></div>
        <div class="holiday-detail-row"><span class="detail-label">End Date</span><span>${fmt(h.endDate)}</span></div>
        <div class="holiday-detail-row"><span class="detail-label">Duration</span><span>${days} day${days !== 1 ? 's' : ''}</span></div>
        <div class="holiday-detail-row"><span class="detail-label">For</span><span>${SCOPE_LABELS[h.scope] || h.scope}</span></div>
        ${h.isRecurring ? '<div class="holiday-detail-row"><span class="detail-label">Recurring</span><span style="color:#10b981; font-weight:600;">✓ Repeats yearly</span></div>' : ''}
        ${h.description ? `<div class="holiday-detail-row"><span class="detail-label">Note</span><span style="color:var(--text-muted);">${h.description}</span></div>` : ''}
    `;

    document.getElementById('holidayModal').classList.add('open');
}

function closeModal(e, force) {
    if (force || (e && e.target === document.getElementById('holidayModal'))) {
        document.getElementById('holidayModal').classList.remove('open');
    }
}

document.addEventListener('keydown', e => {
    if (e.key === 'Escape') document.getElementById('holidayModal').classList.remove('open');
});
</script>
