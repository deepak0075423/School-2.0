<div style="min-height:60vh; display:flex; align-items:center; justify-content:center; text-align:center;">
    <div>
        <div style="font-size:64px; margin-bottom:20px;">❌</div>
        <h1 style="font-size:28px; font-weight:800; color:var(--text-primary); margin-bottom:8px;">
            <%= title %>
        </h1>
        <p style="color:var(--text-secondary); margin-bottom:28px;">
            <%= message %>
        </p>
        <a href="javascript:history.back()" class="btn btn-secondary">← Go Back</a>
        <a href="/" class="btn btn-primary" style="margin-left:12px;">🏠 Home</a>
    </div>
</div>